)\n# TLE epoch on line1: columns 19-32? format YYDDD.DDDDDDDD\nrecs=[]\nfor i in range(0,len(lines),3):\n    if i+2>=len(lines): break\n    l1=lines[i].strip(); l2=lines[i+1].strip()\n    if not l1.startswith('1 ') or not l2.startswith('2 '):\n        continue\n    m=re.match(r'^1\\s+\\d+\\S+\\s+(\\d{2})(\\d{3})\\.(\\d+)', l1)\n    if not m:\n        continue\n    yy=int(m.group(1)); doy=int(m.group(2)); frac=m.group(3)\n    year=2000+yy if yy<57 else 1900+yy\n    day=int(doy)\n    frac_day=float('0.'+frac) if not frac.startswith('0') else float(frac)\n    # frac_day represents fraction of day after decimal. but parse: m.group(3) digits after decimal without leading.\n    # actual epoch string like 24122.17811289 => DOY=122 frac=17811289/1e8\n    frac_val=int(m.group(3))\n    frac=frac_val/(10**len(m.group(3)))\n    dt=datetime(year,1,1)+timedelta(days=day-1+frac)\n    # mean motion n revs per day on line2 columns 52-63? let's parse float from end\n    parts=l2.split()\n    n=float(parts[-1])\n    # semi-major axis\n    a=(mu/( (2*np.pi*n/86400.0)**2 ))**(1/3)  # km\n    recs.append((dt,a))\n\nrecs_df=pd.DataFrame(recs,columns=['epoch','a_km']).sort_values('epoch')\n# round to nearest hour\nrecs_df['epoch_hr']=recs_df['epoch'].dt.round('h')\n# if multiple same hour take mean\nrecs_hour=recs_df.groupby('epoch_hr',as_index=False)['a_km'].mean().sort_values('epoch_hr')\n# compute delta a between consecutive hours (aligned hourly) by differencing\nrecs_hour=recs_hour.set_index('epoch_hr').asfreq('h')\n# After asfreq, interpolated gaps? we should only compute where consecutive available.\n# We'll forward-fill none; keep NaN.\nrecs_hour['da_km']=recs_hour['a_km'].diff() # km change per hour\n\n# Take May 1-30 hours\nda=recs_hour.loc[start:end,'da_km'].copy()\n# align with omni index\ncommon=da.index.intersection(omni.index)\n\nda=da.loc[common]\nap=omni.loc[common,'ap_index_nT']\n\n# compute r^2 for lags 0-48: match da(t) with ap(t-lag)\n# i.e. ap_shifted = ap shifted by 