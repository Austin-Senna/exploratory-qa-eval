\n        return np.nan\n    # values may include non-numeric like '<' in separate tag columns; actual count is in adjacent column\n    try:\n        return float(s)\n    except:\n        # extract number\n        m = re.search(r'[-+]?\\d*\\.?\\d+', s)\n        return float(m.group()) if m else np.nan\n\nresults=[]\nfor beach, relpath in files.items():\n    path = os.path.join(sandbox_dir,'kramabench-environment-hard-12',relpath)\n    df = pd.read_csv(path, dtype=str)\n    # strip whitespace from column names\n    df.columns = [c.strip() for c in df.columns]\n    # identify 3-Day Rain column\n    rain3_col = None\n    for c in df.columns:\n        if '3-Day Rain' in c:\n            rain3_col = c\n            break\n    if rain3_col is None:\n        # sometimes header includes quotes in first line? We'll fallback exact\n        rain3_col='3-Day Rain'\n    # Enterococcus count columns: look for columns whose header contains 'Enterococcus' and not just Tag\n    enter_cols = [c for c in df.columns if 'Enterococcus' in c]\n    # In these files, there are Tag and Enterococcus pairs; Tag columns likely empty name 'Tag'. We'll take numeric columns right after Tag? safer: take columns that are not 'Tag' and contain 'Enterococcus'\n    enter_cols = [c for c in enter_cols if c.lower().find('enterococcus')!=-1 and c.lower()!='tag']\n    # But df has extra header rows; we already read; might include duplicate 'Enterococcus' columns with same name -> pandas disambiguates\n    # We'll instead detect numeric columns by sampling dtype numeric\n    # create list of columns where values look numeric\n    numeric_cols=[]\n    for c in df.columns:\n        if 'Enterococcus' in c:\n            # check first non-null\n            ser=df[c].dropna().head(20)\n            if ser.empty: continue\n            ok=0; total=0\n            for v in ser:\n                total+=1\n                try:\n                    float(str(v).strip().replace(',',''))\n                    ok+=1\n                except:\n                    pass\n            if ok>=max(1,total*0.6):\n                numeric_cols.append(c)\n    if not numeric_cols:\n        # fallback: all columns with 'Enterococcus' and not 'Tag'\n        numeric_cols=[c for c in df.columns if ('Enterococcus' in c and 'Tag' not in c)]\n\n    # compute no-rain mask: 3-Day Rain == 0\n    rain3 = df[rain3_col].apply(parse_enterococcus_value)\n    mask = rain3.fillna(-1)==0\n    # fail if any enterococcus count >=104? Actually each row has possibly multiple sub-samples (North/Middle/South). But question asks samples. We'll count each enterococcus measurement column as a sample.\n    fails=0; total_samples=0\n    for c in numeric_cols:\n        vals = df.loc[mask,c].apply(parse_enterococcus_value)\n        vals_non = vals.dropna()\n        total_samples += len(vals_non)\n        fails += (vals_non >= 104).sum()\n    results.append((beach,fails,total_samples,len(numeric_cols)))\n\nresults_sorted=sorted(results, key=lambda x:x[1], reverse=True)\nprint(results_sorted[:10])\nbest=results_sorted[0]\nprint('BEST',best)\n"}) [toolUseId=call_l2ltdOJvzqMPN6XqX0Evxwa5]
