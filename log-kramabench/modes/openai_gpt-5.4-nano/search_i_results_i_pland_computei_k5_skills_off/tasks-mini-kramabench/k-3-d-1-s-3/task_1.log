 string contain on protein column candidates if present\nif protein_col is not None:\n    matched = df[df[protein_col].astype(str).isin(proteins)].copy()\n    print('protein_col', protein_col, 'matched_rows', matched.shape[0])\n    # Determine mapping to FDA-approved drugs: check for any 'drug'/'target' fields with approved\n    if approved_col is not None:\n        matched2 = matched[matched[approved_col].notna()]\n        print('approved_col', approved_col, 'after_notna', matched2.shape[0])\n        targets = sorted(matched2[protein_col].dropna().astype(str).unique())\n    else:\n        targets = sorted(matched[protein_col].dropna().astype(str).unique())\nelse:\n    # brute search across object columns for any protein occurrences\n    obj_cols=[c for c in cols if df[c].dtype=='object']\n    print('using obj_cols', obj_cols[:20], 'count', len(obj_cols))\n    mask = pd.Series(False, index=df.index)\n    for c in obj_cols:\n        ser=df[c].astype(str)\n        m=ser.isin(proteins)\n        if m.any():\n            mask = mask | m\n    matched=df[mask]\n    print('matched_rows', matched.shape[0])\n    targets=sorted(set(matched[obj_cols[0]].astype(str)))\n\nprint('hyperactivated_proteins_count', len(proteins))\nprint('intersection_targets', targets)\nprint('intersection_count', len(targets))\nprint('\\n'.join(targets))\n", "dataset_id": "kramabench-biomedical-hard-8", "file_path": "files/hyperactivated.csv", "s3_uri": "s3://sana-kramabench/datagov/kramabench-biomedical-hard-8/files/hyperactivated.csv"}) [toolUseId=call_2kR0rwSYwdxuZkiC6HDjryXy]
