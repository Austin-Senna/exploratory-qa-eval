ved_mask = pd.Series(True, index=df.index)\n        if fda_cols:\n            approved_mask = pd.Series(False, index=df.index)\n            for c in fda_cols:\n                ser = df[c].astype(str).str.strip().str.lower()\n                approved_mask |= ser.str.contains('approved|fda', na=False)\n                approved_mask |= ser.isin(['yes', 'y', 'true', '1'])\n\n        for c in protein_cols:\n            ser = df[c].dropna().astype(str).str.strip()\n            normalized = ser.str.upper()\n            direct = normalized[normalized.isin(norm_to_original.keys())]\n            if not direct.empty:\n                valid_idx = direct.index.intersection(df[approved_mask].index) if fda_cols else direct.index\n                for val in normalized.loc[valid_idx].unique():\n                    if val in norm_to_original:\n                        matches.add(norm_to_original[val])\n\n            # Also handle delimiter-separated target lists in a cell\n            for idx, cell in ser.items():\n                if fda_cols and not approved_mask.loc[idx]:\n                    continue\n                tokens = [t.strip().upper() for t in re.split(r'[;,/|]+', cell) if t.strip()]\n                for tok in tokens:\n                    if tok in norm_to_original:\n                        matches.add(norm_to_original[tok])\n\n    # Fallback: search rows mentioning both a hyperactivated protein and FDA-approved text\n    elif fda_cols:\n        row_text = df.astype(str).agg(' | '.join, axis=1).str.upper()\n        approved_mask = pd.Series(False, index=df.index)\n        for c in fda_cols:\n            ser = df[c].astype(str).str.strip().str.lower()\n            approved_mask |= ser.str.contains('approved|fda', na=False)\n            approved_mask |= ser.isin(['yes', 'y', 'true', '1'])\n        for idx, text in row_text.items():\n            if not approved_mask.loc[idx]:\n                continue\n            for norm_name, orig in norm_to_original.items():\n         