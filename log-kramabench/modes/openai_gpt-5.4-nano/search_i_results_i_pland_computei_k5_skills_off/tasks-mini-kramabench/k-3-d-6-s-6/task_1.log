LS = ['xrsb_flux_observed', 'xrsa_flux_observed']\nFEAT_COLS = OMNI_COLS + GOES_COLS\nTARGET_COL = 'Orbit Mean Density (kg/m^3)'\nCONTEXT_HOURS = 16\nHORIZON_HOURS = 4\n\n\ndef load_feature_frame(omni_path, goes_path):\n    omni = pd.read_csv(omni_path, parse_dates=['Timestamp'])[['Timestamp'] + OMNI_COLS].copy()\n    goes = pd.read_csv(goes_path, parse_dates=['Timestamp'])[['Timestamp'] + GOES_COLS].copy()\n\n    # OMNI is hourly; GOES is minute-level. Aggregate GOES to hourly and align.\n    omni = omni.set_index('Timestamp').sort_index()\n    omni['Kp_index'] = omni['Kp_index'] / 10.0\n\n    goes = goes.set_index('Timestamp').sort_index().resample('1H').mean()\n    feat = omni.join(goes, how='inner').sort_index()\n    feat = feat[FEAT_COLS].astype(float)\n    return feat\n\n\ndef load_density_frame(path):\n    dens = pd.read_csv(path, parse_dates=['Timestamp'])[['Timestamp', TARGET_COL]].copy()\n    dens = dens.set_index('Timestamp').sort_index().resample('1H').mean()\n    dens = dens.rename(columns={TARGET_COL: 'rho'})\n    return dens\n\n\ndef fit_var1_projection(context_df):\n    # Fit x_t = c + A x_{t-1} on the provided context window.\n    X_prev = context_df.iloc[:-1].values\n    X_next = context_df.iloc[1:].values\n    reg = LinearRegression()\n    reg.fit(X_prev, X_next)\n    return reg\n\n\ndef forecast_var1(reg, last_vec, steps):\n    preds = []\n    cur = np.asarray(last_vec, dtype=float).reshape(1, -1)\n    for _ in range(steps):\n        cur = reg.predict(cur)\n        preds.append(cur.ravel().copy())\n    return np.vstack(preds)\n\n\ndef build_window_sample(feature_df, density_df, anchor_time):\n    # Use 16 hourly feature values ending at anchor_time to fit a local VAR(1),\n    # then forecast the next 4 hourly feature vectors.\n    context = feature_df.loc[:anchor_time].tail(CONTEXT_HOURS)\n    if len(context) < CONTEXT_HOURS:\n        return None\n    if context.isna().any().any():\n        return None\n\n    reg_var = fit_var1_projection(context)\n    feat_fore = forecast_var1(reg_var, context.iloc[-1].values, HORIZON_HOURS)\n\n    future_times = pd.date_range(anchor_time + pd.Timedelta(hours=1), periods=HORIZON_HOURS, freq='1H')\n    if not set(future_times).issubset(set(density_df.index)):\n        return None\n    y = density_df.loc[future_times, 'rho'].values\n    if np.isnan(y).any():\n        return None\n\n    X_rows = []\n    for step in range(HORIZON_HOURS):\n        row = {'horizon': step + 1}\n        for j, col in enumerate(FEAT_COLS):\n            row[col] = feat_fore[step, j]\n        X_rows.append(row)\n    X = pd.DataFrame(X_rows)\n    return X, y, future_times\n\n\ndef build_training_set(feature_df, density_df):\n    X_parts, y_parts = [], []\n    possible_anchors = feature_df.index\n    for anchor in possible_anchors:\n        sample = build_window_sample(feature_df, density_df, anchor)\n        if sample is None:\n            continue\n        X_i, y_i, _ = sample\n        X_parts.append(X_i)\n        y_parts.append(y_i)\n    if not X_parts:\n        raise ValueError('No valid training samples could be built.')\n    X_train = pd.concat(X_parts, ignore_index=True)\n    y_train = np.concatenate(y_parts)\n    return X_train, y_train\n\n\ntrain_feat = load_feature_frame(omni_train_path, goes_train_path)\ntest_feat = load_feature_frame(omni_test_path, goes_test_path)\ntrain_dens = load_density_frame(dens_train_path)\ntest_dens = load_density_frame(dens_test_path)\n\n# Train on all valid wu334 anchors; each anchor contributes next-4h examples.\nX_train, y_train = build_training_set(train_feat, train_dens)\nreg = LinearRegression()\nreg.fit(X_train, y_train)\n\n# Evaluate on wu335 forecast window: use last available 16h context from wu335 features\n# to predict the next 4h density values at the start of the density window.\nforecast_anchor = test_feat.index.max()\nX_test, y_test, future_times = build_window_sample(test_feat, test_dens, forecast_anchor)\ny_pred = reg.predict(X_test)\nrmse = np.s