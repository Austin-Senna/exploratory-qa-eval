ni_test[['Timestamp','f10.7_index','Kp_index','Dst_index_nT']]\n          .merge(goes_test[['Timestamp','xrsb_flux_observed','xrsa_flux_observed']], on='Timestamp', how='inner'))\n\n# Density columns\nDcol = 'Orbit Mean Density (kg/m^3)'\n\n# Windows per prompt: 16h context -> 4h forecast (hourly steps). We need density at next 4 hourly timestamps.\n# Identify density start/end per wu.\ntrain_density_start = pd.Timestamp('2016-10-23 00:00:00')\ntrain_density_end = pd.Timestamp('2016-10-24 00:00:00')  # exclusive\n\ntest_density_start = pd.Timestamp('2016-10-29 00:00:00')\n# but wu335 file spans 2016-10-26..29; forecast window 2016-10-29 ? prompt says density 2016-10-29 (single day). We'll use 2016-10-29 00:00 to 2016-10-30 00:00.\n# Determine exact density timestamps in sat_test\nmin_ts, max_ts = sat_test['Timestamp'].min(), sat_test['Timestamp'].max()\n\n# We'll forecast for density timestamps equal to sat_test within [2016-10-29 00:00, 2016-10-29 04:00] stepping hourly.\nforecast_times = pd.date_range('2016-10-29 00:00:00', periods=4, freq='1H')\n\n# For VAR projection, use 16h context of features ending at time t (the last input timestamp). Density begins immediately after overlap, meaning density at time t corresponds to features at time t.\n# So for forecasting density at t+1..t+4 hours, we project features forward from context ending at time t.\n# We'll set t such that density times align: use density at times forecast_times as y_{t+1..t+4} with t = forecast_times[0]-1h.\n\ndef build_var_features(X, context_end, horizon=4, lags=1):\n    # X indexed hourly, contains required features\n    X = X.sort_values('Timestamp').set_index('Timestamp')\n    # select context window of 16 hours ending at context_end (inclusive)\n    ctx_start = context_end - pd.Timedelta(hours=15)\n    ctx = X.loc[ctx_start:context_end]\n    # fit VAR(1) per dimension using multivariate regression with lag-1\n    # Prepare lagged pairs within context\n    Z0 = ctx.iloc[:-1].values\n    Z1 = ctx.iloc[1:].values\n    # regression Z1 = A*Z0 + c\n    Z0_aug = np.hstack([Z0, np.ones((Z0.shape[0],1))])\n    coef, *_ = np.linalg.lstsq(Z0_aug, Z1, rcond=None)\n    A = coef[:-1,:].T  # shape (d,d)\n    c = coef[-1,:]    # shape (d,)\n    d = Z1.shape[1]\n    # project forward starting from last context state at context_end\n    last = ctx.iloc[-1].values\n    proj = []\n    cur = last\n    for _ in range(horizon):\n        cur = A @ cur + c\n        proj.append(cur.copy())\n    proj = np.array(proj)  # horizon x d\n    return proj\n\n# Training: build samples for each hour t such that y is next 4 density hours.\n# We only have density from 2016-10-23 00:00 to 2016-10-24 00:00. With horizon 4, t ranges from 2016-10-22 21:00 to 2016-10-23 20:00? but features only up to 2016-10-23 00:00 due to overlap.\n# Given prompt: training uses OMNI/GOES 2016-10-22 to 2016-10-23; density starts 2016-10-23 and overlapped at single timestamp where OMNI/GOES ends and density begins.\n# Hence context_end for forecasting first y at 2016-10-23 00:00 corresponds to context_end = 2016-10-22 23:00. We'll use only that single training sample.\n\ncontext_end_train = pd.Timestamp('2016-10-22 23:00:00')\n\nproj_train = build_var_features(X_train, context_end_train, horizon=4)  # 4x5\nY_train = sat_train.set_index('Timestamp').loc[forecast_times.replace(year=2016,month=10,day=23)[:4] if False else pd.date_range('2016-10-23 00:00:00', periods=4, freq='1H'),'Orbit Mean Density (kg/m^3)'].values\n\n# However easier: define y times for training\ntrain_forecast_times = pd.date_range('2016-10-23 00:00:00', periods=4, freq='1H')\nY_train = sat_train.set_index('Timestamp').loc[train_forecast_times, Dcol].values\n\n# Each of the 4 horizons is target; features are projected state at that horizon.\n# Create training rows by stacking horizons with corresponding projected features.\nX_reg_train = proj_train\n\n# Fit linear regression\nreg = LinearRegression().fit(X_reg_train, Y_train)\n\n# Evaluation: build projection from context_end_test where first forecast time is 2016-10-29 00:00 -> context_end = 2016-10-28 23:00\ncontext_end_test = pd.Timestamp('2016-10-28 23:00:00')\nproj_test = build_var_features(X_test, context_end_test, horizon=4)\nY_test = sat_test.set_index('Timestamp').loc[forecast_times, Dcol].values\n\npred = reg.predict(proj_test)\nrmse = np.sqrt(mean_squared_error(Y_test, pred))\nprint(rmse)\n"}) [toolUseId=call_nXd5KHwm0Uh4dpGEcQjEO1W3]
