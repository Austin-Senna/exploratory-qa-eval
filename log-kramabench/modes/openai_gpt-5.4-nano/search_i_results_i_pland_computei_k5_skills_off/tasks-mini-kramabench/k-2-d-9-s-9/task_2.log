header_line = raw[header_idx]\n    headers = [h.strip().strip('\"') for h in header_line.split(',')]\n    data_lines = raw[header_idx+1:]\n    # Sometimes trailing empty cols; use csv parsing via pandas\n    tmp_path = '/tmp/tmp_beach.csv'\n    Path(tmp_path).write_text(header_line+'\\n'+'\\n'.join(data_lines),encoding='utf-8')\n    df2 = pd.read_csv(tmp_path)\n    # date column name 'Date'\n    datecol='Date'\n    year = pd.to_datetime(df2[datecol]).dt.year\n    mask=(year>=2020)&(year<=2024)\n    df2=df2[mask].copy()\n    # Enterococcus columns: columns whose name contains 'Enterococcus'\n    enter_cols=[c for c in df2.columns if 'Enterococcus' in str(c)]\n    # determine beach name from first line\n    beach_name = raw[0].split(',')[0].strip().strip('\"')\n    for c in enter_cols:\n        df2[c]=df2[c].apply(parse_enterococcus)\n    # reshape: long with one record per date*sensor\n    for c in enter_cols:\n        sub=df2[[datecol,c]].copy()\n        sub['beach']=beach_name\n        sub['enterococcus']=sub[c]\n        sub=sub.drop(columns=[c])\n        sub=sub.dropna(subset=['enterococcus'])\n        rows.append(sub)\n\nall_df=pd.concat(rows,ignore_index=True)\nall_df['meet']=all_df['enterococcus']<104\n# beach meets standard 100%: all samples for that beach meet\n# definition: between 2020-2024 inclusive.\nsummary=all_df.groupby('beach').agg(n=('meet','count'),meet_all=('meet','all'))\nans=summary[summary['meet_all']].sort_index()\nprint(list(ans.index))\nprint(ans)\n", "intent": "Identify Boston Harbor beaches with Enterococcus <104 per 100 mL for 100% of samples between 2020-2024 inclusive."}) [toolUseId=call_mDPq2nKz1ZkLPbpZqGCR5fRg]
