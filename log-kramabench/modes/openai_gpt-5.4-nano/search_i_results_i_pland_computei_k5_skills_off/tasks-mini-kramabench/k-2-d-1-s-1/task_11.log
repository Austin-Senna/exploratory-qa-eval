t few rows as data and pick columns by position based on standard format: col0 branch name, col4 median.\n# Empirically: columns: Military Branch, # of Reports, # of Fraud Reports, % Reporting Fraud Loss, Total Fraud Loss, Median Fraud Loss\n# These correspond to indices 0,1,2,3,4,5\n# Find first data row where col0 starts with 'U.S.'\nstart=None\nfor i in range(row_idx+1, len(text)):\n    v=str(text.iloc[i,0]).strip()\n    if v.startswith('U.S.'):\n        start=i\n        break\n# Find end at first row where col0 is empty\nend=None\nfor i in range(start, len(text)):\n    v=str(text.iloc[i,0]).strip()\n    if v=='':\n        end=i\n        break\nif start is None:\n    raise SystemExit('No branch data found')\nif end is None:\n    end=len(text)\nsub=text.iloc[start:end, :6].copy()\nsub.columns=['Branch','Reports','#Fraud','%Fraud','Total','Median']\n# Clean median values like '$1,300 '\n\ndef parse_money(x):\n    s=str(x)\n    s=s.replace('$','').replace(',','').strip()\n    if s=='':\n        return np.nan\n    # some medians may have trailing spaces\n    return float(s)\nsub['Median_num']=sub['Median'].apply(parse_money)\nmax_row=sub.loc[sub['Median_num'].idxmax()]\nprint(max_row['Branch'])\nprint(max_row['Median_num'])\n"})
