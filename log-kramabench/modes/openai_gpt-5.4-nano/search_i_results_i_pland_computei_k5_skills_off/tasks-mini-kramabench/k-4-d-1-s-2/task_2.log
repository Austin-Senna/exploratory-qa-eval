le Age_ky columns; pick first numeric\n# coerce to numeric\nage_col=None\nfor c in xdf.columns:\n    if 'Age_ky' in str(c):\n        # test numeric\n        vals=pd.to_numeric(xdf[c], errors='coerce')\n        if vals.notna().sum()>1000:\n            age_col=c\n            break\nprint('age_col',age_col)\n\n# Now filter to Maltese area. Since dataset only has ODP 967 sites, likely Maltese area corresponds to Hole? Let's inspect unique Hole/Core/Section for Maltese? Search for 'Maltese' string overall.\nmask_all = xdf.apply(lambda r: r.astype(str).str.contains('Malt',case=False,na=False).any(), axis=1)\nprint('rows with Malt in any cell',mask_all.sum())\n\n# If none, maybe 'Maltese area' corresponds to Site == 'Maltese' not present; but question says recorded people in Maltese area; maybe in this dataset, 'Site' values map to Maltese area via 'Site' column like 'ODP 967' etc. We'll look for any region labels: maybe 'Hole' has D or B only.\nprint('unique Hole',xdf['Hole'].unique()[:10])\nprint('unique Core',xdf['Core'].unique()[:10])\nprint('unique Section',xdf['Section'].unique()[:10])\n\n# So perhaps Maltese area refers to 'ODP 967' as Malta? We'll treat all rows as Maltese area.\nsub=xdf.dropna(subset=[age_col,Kcol]).copy()\nsub['age']=pd.to_numeric(sub[age_col],errors='coerce')\nsub['K']=pd.to_numeric(sub[Kcol],errors='coerce')\nsub=sub.dropna(subset=['age','K'])\nprint('sub rows',len(sub),'age range',sub['age'].min(),sub['age'].max())\n# first and last times people recorded: likely minimum and maximum Age_ky\nt1=sub['age'].min(); t2=sub['age'].max()\nprint('t1,t2',t1,t2)\n# need interpolate potassium between bracketing samples around t1 and t2.\n# since t1 and t2 are at sample points, interpolation equals K at those times. But if need between, we still compute using nearest bracketing.\n\ndef interp_at(t):\n    # get two nearest points around t\n    below=sub[sub['age']<=t].sort_values('age')\n    above=sub[sub['age']>=t].sort_values('age')\n    if len(below)==0 or len(above)==0:\n        return np.nan\n    a=below.iloc[-1]\n    b=above.iloc[0]\n    if a['age']==b['age']:\n        return float(a['K'])\n    return float(a['K'] + (b['K']-a['K'])*(t-a['age'])/(b['age']-a['age']))\n\nk1=interp_at(t1)\nk2=interp_at(t2)\navg=(k1+k2)/2\nprint('k1,k2,avg',k1,k2,avg)\nprint('avg_round',round(avg,4))\n"}) [toolUseId=call_avbnBfOeTFlFOqNUhOxuqGbR]
