mns:\n    clc = c.lower()\n    if clc in ['al','aluminum'] or clc=='aluminum (al)':\n        al_col = c\n        break\nif al_col is None:\n    # try exact 'Al'\n    for c in cl.columns:\n        if c.strip()=='Al':\n            al_col=c\n            break\nif al_col is None:\n    raise ValueError('No aluminum column')\n\ncl[year_col] = pd.to_numeric(cl[year_col], errors='coerce')\ncl[al_col] = pd.to_numeric(cl[al_col], errors='coerce')\ncl = cl.dropna(subset=[year_col, al_col])\n\ncl['dist'] = (cl[year_col] - best_year).abs()\nmin_dist = cl['dist'].min()\nmax_al = float(cl.loc[cl['dist']==min_dist, al_col].max())\n\nprint('best_year', best_year)\nprint('max_al', max_al)\n"}) [toolUseId=call_own3RbpqYFMJAhIE2G2NoHeO]
