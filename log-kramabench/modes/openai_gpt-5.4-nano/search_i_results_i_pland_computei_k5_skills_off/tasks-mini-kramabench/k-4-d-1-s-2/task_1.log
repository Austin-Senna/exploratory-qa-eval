 c.startswith('Cal. BC 2 sigma')]\n\n# choose midpoint of 1 sigma if available\nif len(one_sigma)>=2:\n    # pick first two\n    c1, c2 = one_sigma[0], one_sigma[1]\n    ne[c1] = pd.to_numeric(ne[c1], errors='coerce')\n    ne[c2] = pd.to_numeric(ne[c2], errors='coerce')\n    ne = ne.dropna(subset=[c1,c2])\n    ne['year_1sigma_mid'] = (ne[c1] + ne[c2]) / 2.0\n    year_col = 'year_1sigma_mid'\nelif len(one_sigma)==1:\n    year_col = one_sigma[0]\n    ne[year_col] = pd.to_numeric(ne[year_col], errors='coerce')\n    ne = ne.dropna(subset=[year_col])\nelse:\n    raise ValueError('No Cal. BC 1 sigma columns found')\n\n# max latitude north\nmax_lat = ne[lat_col].max()\nmax_lat_rows = ne[ne[lat_col]==max_lat].copy()\n\n# break ties by later year (less BC magnitude -> later). Since years are BC, later means higher numeric (e.g., 5000 BC later than 6000 BC? Actually later = closer to present -> smaller magnitude). If dataset uses BC with larger numbers older; later should be smaller number. We'll infer: if values positive like 5000 BC; later = smaller.\n# We'll compute later_by_min = year_col minimum.\nmax_lat_rows['__year_num']=max_lat_rows[year_col]\n\n# if year_1sigma_mid still BC, later is smaller numeric; choose smallest.\nmin_year = max_lat_rows['__year_num'].min()\nbest_year_rows = max_lat_rows[max_lat_rows['__year_num']==min_year].copy()\n\nbest_year = float(best_year_rows['__year_num'].iloc[0])\n\n# climate dataset: find closest year(s) to best_year\ncl = pd.read_excel(cl_path)\ncl.columns=[c.strip() for c in cl.columns]\n\n# find year column and aluminum column\nyear_candidates=[c for c in cl.columns if 'Year' in c]\nal_candidates=[c for c in cl.columns if c.lower() in ['al','aluminum'] or 'al'==c.lower() or 'Al'==c]\n\n# choose year col\nyear_col_cl = year_candidates[0] if year_candidates else None\n# pick aluminum\nal_col = None\nfor c in cl.columns:\n    if c.lower()=='al' or c.lower()=='aluminum':\n        al_col=c\n        break\nif al_col is None:\n    # maybe 'Al' exactly\n    for c in cl.columns:\n        if c.strip()=='Al':\n            al_col=c\n            break\nif year_col_cl is None or al_col is None:\n    raise ValueError('Could not identify climate year/al columns')\n\ncl[year_col_cl]=pd.to_numeric(cl[year_col_cl], errors='coerce')\ncl[al_col]=pd.to_numeric(cl[al_col], errors='coerce')\ncl=cl.dropna(subset=[year_col_cl, al_col])\n\n# closest years\ncl['dist']=(cl[year_col_cl]-best_year).abs()\nmin_dist=cl['dist'].min()\nclosest_years = cl.loc[cl['dist']==min_dist, year_col_cl].unique()\nmax_al = cl.loc[cl['dist']==min_dist, al_col].max()\n\nprint('BEST_LAT',max_lat)\nprint('BEST_YEAR',best_year)\nprint('TIED_ROWS',len(best_year_rows))\nprint('CLOSEST_YEARS',sorted(list(map(float,closest_years))))\nprint('MAX_AL',float(max_al))\n"}) [toolUseId=call_6XYWQPiXuY0NhApokIQl6KL1]
