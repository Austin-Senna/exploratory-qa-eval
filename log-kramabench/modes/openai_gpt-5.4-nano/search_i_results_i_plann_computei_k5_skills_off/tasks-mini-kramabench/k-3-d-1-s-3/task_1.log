.rels'))\n            relmap = {rel.attrib['Id']: rel.attrib['Target'] for rel in rels.findall(f'{{{pkg}}}Relationship')}\n\n            chosen = None\n            for sheet in workbook.find('a:sheets', ns):\n                if sheet_name is None or sheet.attrib.get('name') == sheet_name:\n                    chosen = sheet\n                    break\n            if chosen is None:\n                return []\n\n            rid = chosen.attrib[f'{{{ns[\"r\"]}}}id']\n            target = relmap[rid]\n            sheet_path = 'xl/' + target.lstrip('/') if not target.startswith('xl/') else target\n            tree = ET.fromstring(z.read(sheet_path))\n\n            rows = []\n            for row in tree.findall('.//a:sheetData/a:row', ns):\n                cells = {}\n                for cell in row.findall('a:c', ns):\n                    value = cell.find('a:v', ns)\n                    text = '' if value is None else (value.text or '')\n                    if cell.attrib.get('t') == 's' and text:\n                        text = shared[int(text)]\n                    cells[col_index(cell.attrib.get('r', 'A1'))] = text\n                if cells:\n                    rows.append([cells.get(i, '') for i in range(max(cells) + 1)])\n            if not rows:\n                return []\n            header = rows[0]\n            return [dict(zip(header, row + [''] * (len(header) - len(row)))) for row in rows[1:]]\n\n    hyper_set = set(hyperactivated)\n    out_seen = set()\n    for row in read_xlsx_sheet(mmc6_path, sheet_name='G-FDA approved drugs'):\n        gene = (row.get('gene_name') or '').strip()\n        if gene in hyper_set and gene not in out_seen:\n            out_seen.add(gene)\n            result.append(gene)\n\nprint(result)", "reason": "Rewrote the code to fulfill the intent: it loads hyperactivated proteins from the available CSV, checks whether the FDA-approved drug target mapping workbook is present in the sandbox, and if so reads the relevant sheet and prints the intersection with mapped drug targets. If the mapping file is absent, it still prints an empty result as required."}) [toolUseId=call_mNsTbbxK4mqwnrZbDPOvS0FE]
