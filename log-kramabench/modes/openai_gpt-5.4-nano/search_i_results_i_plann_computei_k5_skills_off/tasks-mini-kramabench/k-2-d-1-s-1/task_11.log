.\n# So extract header cells starting at idx.\nheader=raw.iloc[idx].tolist()\n# data rows follow until blank/section marker\n# Identify columns for branch name and median fraud loss by finding positions of 'Median Fraud Loss'\nmedian_col=None\nfor j,v in enumerate(header):\n    if str(v).strip().strip('\"')=='Median Fraud Loss':\n        median_col=j\n        break\n# branch column is where header cell contains 'Military Branch' likely first non-empty\nbranch_col=None\nfor j,v in enumerate(header):\n    if str(v).strip().strip('\"')=='Military Branch':\n        branch_col=j\n        break\n\n# Determine end row: until row where first non-empty cell contains 'Military Rank'\nend=None\nfor i in range(idx+1,len(raw)):\n    vals=[str(x) for x in raw.iloc[i].tolist()]\n    if any(v.strip('\" ')== 'Military Rank' for v in vals if v!='nan'):\n        end=i\n        break\nif end is None:\n    end=len(raw)\nsub=raw.iloc[idx+1:end]\n# collect branch and median\nrows=[]\nfor i in range(len(sub)):\n    branch=str(sub.iloc[i,branch_col]) if branch_col is not None else ''\n    branch=branch.strip().strip('\"')\n    if branch=='nan' or branch=='':\n        continue\n    med=str(sub.iloc[i,median_col])\n    med=med.replace('$','').replace(',','').strip().strip('\"')\n    # remove trailing spaces\n    if med=='' or med.lower()=='nan':\n        continue\n    # keep digits\n    m=re.findall(r'[-+]?\\d+(?:\\.\\d+)?', med)\n    if not m:\n        continue\n    rows.append((branch, float(m[-1])))\n\n# max median\nmax_branch, max_med = max(rows, key=lambda x: x[1])\nprint(max_branch)\nprint(max_med)"}) [toolUseId=call_VxmJT9buk6qjFK8H4BnDTxb4]
