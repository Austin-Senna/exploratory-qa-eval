n abund.columns:\n    if c.strip()=='PLK1' or c.strip().upper()=='PLK1':\n        plk_col=c\n    if c.strip()=='CHEK2-S163' or c.strip().upper()=='CHEK2-S163'.upper() or c.strip()=='CHEK2-S163 abundance':\n        chek_col=c\n# sometimes columns are named 'PLK1 (abundance)' etc\nif plk_col is None:\n    for c in abund.columns:\n        if 'PLK1' in c:\n            plk_col=c;break\nif chek_col is None:\n    for c in abund.columns:\n        if 'CHEK2-S163' in c:\n            chek_col=c;break\n\n# filter\nsub=abund.copy()\nif tumor_col is not None:\n    sub=sub[sub[tumor_col].astype(str).str.contains('Endometrioid|Serous', case=False, regex=True, na=False)]\nif incl_col is not None:\n    # keep rows where included true\n    s=sub[incl_col]\n    if s.dtype==bool:\n        sub=sub[s]\n    else:\n        sub=sub[s.astype(str).str.lower().isin(['true','1','included','yes'])]\n\n# drop missing for both proteins\nsub=sub[[plk_col,chek_col]].apply(pd.to_numeric, errors='coerce').dropna()\n\nrho, p = spearmanr(sub[plk_col].astype(float), sub[chek_col].astype(float))\nprint(rho)\n"}) [toolUseId=call_Ga3q58HBp8tyDjmXv9YkuB9p]
