   break\n\n# Fallback: README likely insufficient. If no metadata sheet exists, use all samples.\nif meta_sheet is None:\n    included = vals.index.tolist()\nelse:\n    meta = pd.read_excel(xls, sheet_name=meta_sheet)\n    # find column containing sample ids\n    sample_col = None\n    for c in meta.columns:\n        if str(c).lower() in ['sample','samples','sample_id','idx','id']:\n            sample_col=c\n            break\n    if sample_col is None:\n        # find column with pattern S001\n        for c in meta.columns:\n            if meta[c].astype(str).str.match(r'^S\\d+$').any():\n                sample_col=c\n                break\n    # find histology column\n    hist_col=None\n    for c in meta.columns:\n        if meta[c].astype(str).str.contains('Serous|Endometrioid', case=False, regex=True, na=False).any():\n            hist_col=c\n            break\n    if hist_col is None:\n        # try any column with 'histology'\n        for c in meta.columns:\n            if 'hist' in str(c).lower() or 'type' in str(c).lower():\n                hist_col=c\n                break\n    meta['__sample']=meta[sample_col].astype(str)\n    included_meta = meta.loc[meta[hist_col].astype(str).str.contains('Serous|Endometrioid', case=False, regex=True, na=False), '__sample']\n    included = [s for s in included_meta.unique().tolist() if s in vals.index]\n\nsub = vals.loc[included, ['PLK1','CHEK2-S163']].replace('NA', np.nan)\nsub = sub.apply(pd.to_numeric, errors='coerce')\nsub = sub.dropna()\n\ncorr = sub['PLK1'].corr(sub['CHEK2-S163'], method='spearman')\nprint(corr)\nprint(len(sub))"}) [toolUseId=call_P0WfaKqrMaahPcjmziXmqfm5]
