== 'b':\n        return raw == '1'\n    try:\n        number = float(raw)\n        return int(number) if number.is_integer() else number\n    except ValueError:\n        return raw\n\n\ndef read_sheet(path, sheet_name):\n    with ZipFile(path) as zf:\n        strings = shared_strings(zf)\n        worksheet = ET.fromstring(zf.read(sheet_path(zf, sheet_name)))\n        rows = []\n        for row in worksheet.findall('.//m:sheetData/m:row', NS):\n            values = {}\n            max_col = -1\n            for cell in row.findall('m:c', NS):\n                idx = col_idx(cell.attrib['r'])\n                values[idx] = cell_value(cell, strings)\n                max_col = max(max_col, idx)\n            if max_col >= 0:\n                rows.append([values.get(i) for i in range(max_col + 1)])\n        return rows\n\n\ndef median(values):\n    ordered = sorted(values)\n    n = len(ordered)\n    mid = n // 2\n    if n % 2 == 1:\n        return ordered[mid]\n    return (ordered[mid - 1] + ordered[mid]) / 2\n\n\nclinical_rows = read_sheet(clinical_path, 'UCEC_CPTAC3_meta_table_V2.1')\nclinical_headers = clinical_rows[0]\nidx_i = clinical_headers.index('idx')\nexcluded_i = clinical_headers.index('Case_excluded')\nhistology_i = clinical_headers.index('Histologic_type')\n\nserous_ids = {\n    str(row[idx_i])\n    for row in clinical_rows[1:]\n    if row[excluded_i] == 'No' and row[histology_i] == 'Serous'\n}\n\nmutation_rows = read_sheet(mutation_path, 'B-APM subtypes')\nmutation_headers = mutation_rows[0]\nmut_idx_i = mutation_headers.index('idx')\nlog_i = mutation_headers.index('Log2_variant_per_Mbp')\n\nlinear_values = [\n    2 ** float(row[log_i])\n    for row in mutation_rows[1:]\n    if str(row[mut_idx_i]) in serous_ids and row[log_i] is not None\n]\n\nresult = f\"{median(linear_values):.4f}\"\nprint(result)", "reason": "Rewrote the code to follow the dataset-specific workflow from the plan: read the clinical sheet to identify non-excluded Serous cases, read the 'B-APM