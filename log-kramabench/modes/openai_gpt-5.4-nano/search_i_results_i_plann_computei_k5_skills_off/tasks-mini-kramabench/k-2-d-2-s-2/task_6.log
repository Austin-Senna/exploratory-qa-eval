fire_col, noaa_acres_col)\nprint('NIFC cols:', nifc_year_col, nifc_fire_col, nifc_acres_col)\n\n# Ensure numeric\nfor col in [noaa_fire_col, noaa_acres_col]:\n    noaa[col] = pd.to_numeric(noaa[col], errors='coerce')\nfor col in [nifc_fire_col, nifc_acres_col]:\n    nifc[col] = pd.to_numeric(nifc[col], errors='coerce')\n\n# Annual aggregation (NOAA is monthly stats)\nnoaa_annual = noaa.groupby(noaa_year_col, as_index=False).agg({noaa_fire_col:'sum', noaa_acres_col:'sum'})\nnoaa_annual.columns = ['year','noaa_fires','noaa_acres']\n\nnifc_annual = nifc.groupby(nifc_year_col, as_index=False).agg({nifc_fire_col:'sum', nifc_acres_col:'sum'})\nnifc_annual.columns = ['year','nifc_fires','nifc_acres']\n\nmerged = pd.merge(noaa_annual, nifc_annual, on='year', how='inner')\nmerged['diff_fires'] = merged['noaa_fires'] - merged['nifc_fires']\nmerged['diff_acres'] = merged['noaa_acres'] - merged['nifc_acres']\n\n# Drop missing\nmerged = merged.dropna(subset=['diff_fires','diff_acres'])\n\ncorr = merged['diff_fires'].corr(merged['diff_acres'])\nprint('n_years', len(merged))\nprint('corr', corr)\n\nprint(corr)"}) [toolUseId=call_BJ6c6DS903lrQN4VSmBdfLmi]
