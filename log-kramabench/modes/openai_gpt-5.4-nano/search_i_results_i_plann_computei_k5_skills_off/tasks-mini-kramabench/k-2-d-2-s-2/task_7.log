   # numeric column that isn't year\n    num_cols = [c for c in df.columns if pd.api.types.is_numeric_dtype(df[c])]\n    if year_col in num_cols:\n        num_cols.remove(year_col)\n    acres_col = num_cols[-1]\n\n# Ensure numeric\ndf[year_col] = pd.to_numeric(df[year_col], errors='coerce')\ndf[acres_col] = pd.to_numeric(df[acres_col], errors='coerce')\ndf = df.dropna(subset=[geo_col, year_col, acres_col])\n\n# Total acres burned by geo-year (sum across causes)\nagg = df.groupby([geo_col, year_col], as_index=False)[acres_col].sum()\nagg = agg.rename(columns={acres_col:'total_acres'})\n\n# For each geo, compute mean and std across years\nstats = agg.groupby(geo_col)['total_acres'].agg(['mean','std']).reset_index()\nstats['z'] = None\n# merge\nagg2 = agg.merge(stats, on=geo_col, how='left')\nagg2['z'] = (agg2['total_acres'] - agg2['mean'])/agg2['std']\n\n# Find max absolute z (anomalous)\nagg2['abs_z'] = agg2['z'].abs()\nrow = agg2.loc[agg2['abs_z'].idxmax()]\ngeo = row[geo_col]\nyear = int(row[year_col])\nprint(geo, year, row['z'])\nprint('ALL_COLS', df.columns)\nprint('USING', geo_col, year_col, acres_col)\n"}) [toolUseId=call_07PDeJVsBDBEn8yT8B9vu1LH]
