ef load_wide(tsv_text):\n    df = pd.read_csv(StringIO(tsv_text), sep='\\t', na_values=['N/A'])\n    df.columns = df.columns.str.replace('*', '', regex=False)\n    df = df[df['Year'].astype(str).str.fullmatch(r'\\d{4}')].copy()\n    area_cols = [c for c in df.columns if c not in ['Year', 'Total']]\n    for c in area_cols:\n        df[c] = pd.to_numeric(df[c].astype(str).str.replace(',', '', regex=False), errors='coerce')\n    df['Year'] = pd.to_numeric(df['Year'], errors='coerce').astype(int)\n    return df[['Year'] + area_cols]\n\nhuman = load_wide(human_tsv)\nlightning = load_wide(lightning_tsv)\n\n# Sum causes to get total acres by geographic area and year.\ntotal = human.merge(lightning, on='Year', suffixes=('_human', '_lightning'))\nareas = human.columns[1:]\nrecords = []\nfor area in areas:\n    lcol = area if area in lightning.columns else area\n    series = total[f'{area}_human'] + total[lcol + '_lightning']\n    area_df = pd.DataFrame({\n        'Year': total['Year'],\n        'Geographic Area': area,\n        'Total Acres': series\n    })\n    records.append(area_df)\nlong_df = pd.concat(records, ignore_index=True)\n\n# Compute z-scores within each geographic area across years.\nlong_df['z'] = long_df.groupby('Geographic Area')['Total Acres'].transform(\n    lambda s: (s - s.mean()) / s.std()\n)\nlong_df['abs_z'] = long_df['z'].abs()\nresult = long_df.loc[long_df['abs_z'].idxmax(), ['Geographic Area', 'Year']]\nprint(f\"{result['Geographic Area']}, {int(result['Year'])}\")\n", "reason": "Rewrote the code to avoid disabled network access by embedding the provided wildfire tables locally, correctly reading them as tab-separated wide-format data, cleaning commas/N/A and the starred column name, summing human and lightning acres by geographic area and year, computing within-area z-scores, selecting the maximum absolute z-score, and printing the result."}) [toolUseId=call_ty5rEq5HyVJItsku7AJMl6Zj]
