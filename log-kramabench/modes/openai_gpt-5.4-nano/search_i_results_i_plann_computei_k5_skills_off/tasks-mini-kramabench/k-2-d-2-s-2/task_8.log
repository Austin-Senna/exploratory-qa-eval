uracy\nstate_unsafe = air.groupby('State', as_index=False).agg(\n    total_aqi_days=('Days with AQI','sum'),\n    unsafe_days=(unsafe_cols, 'sum')\n)\n# Pandas with list in agg may not work as expected; handle robustly\n# fallback compute unsafe_days as sum of each unsafe col\nstate_unsafe = air.groupby('State', as_index=False).agg(total_aqi_days=('Days with AQI','sum'))\nstate_unsafe['unsafe_days'] = air.groupby('State')[unsafe_cols].sum().sum(axis=1).values\n\nstate_unsafe['unsafe_prop'] = state_unsafe['unsafe_days'] / state_unsafe['total_aqi_days']\n\nfire['Total Acres Burned'] = pd.to_numeric(fire['Total Acres Burned'], errors='coerce')\n\nmerged = state_unsafe.merge(fire[['State','Total Acres Burned']], on='State', how='inner')\nmerged = merged.dropna(subset=['unsafe_prop','Total Acres Burned'])\n\ncorr = merged['unsafe_prop'].corr(merged['Total Acres Burned'], method='pearson')\n\nprint(round(corr,2))\nprint('n', len(merged))\nprint(merged[['State','unsafe_prop','Total Acres Burned']].head())\n"}) [toolUseId=call_kWEsdmx4NstOlLxAzaeLfKv5]
