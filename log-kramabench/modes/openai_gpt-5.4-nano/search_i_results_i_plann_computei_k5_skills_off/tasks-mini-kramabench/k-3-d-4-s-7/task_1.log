ll use Community as location key given question (Boston/Chatham/etc)\nwater['BeachType']=water['Beach Type Description'].str.strip().str.title()\n# determine which communities belong to which type by given mapping, irrespective of beach type column.\n\n# rainfall locations\nlocs_fresh=['Boston','Chatham','Amherst','Ashburnham']\nlocs_marine=['Boston','Chatham']\n\n# compute exceedance rate per year per community within specified sets, regardless of beach type column.\n\nexceed_comm = water.groupby(['Year','Community']).agg(exceed_rate=('exceed','mean'), n=('exceed','size')).reset_index()\n\n# keep only specified communities\nexceed_comm_f=exceed_comm[exceed_comm['Community'].isin(locs_fresh)].copy()\nexceed_comm_m=exceed_comm[exceed_comm['Community'].isin(locs_marine)].copy()\n\n# average exceedance rates across communities for each year (weighted by n to be safer)\nexceed_rate_f = exceed_comm_f.groupby('Year').apply(lambda g: np.average(g['exceed_rate'], weights=g['n'])).reset_index(name='exceed_rate')\nexceed_rate_m = exceed_comm_m.groupby('Year').apply(lambda g: np.average(g['exceed_rate'], weights=g['n'])).reset_index(name='exceed_rate')\n\n# load rainfall\nrpaths={\n'Boston':'/home/ec2-user/eval_eqa/exploratory-qa-eval/.sandbox_isolated/task_1676013_1778999464843/kramabench-environment-hard-14/files/monthly_precipitations_boston.csv',\n'Chatham':'/home/ec2-user/eval_eqa/exploratory-qa-eqa/exploratory-qa-eval/.sandbox_isolated/task_1676013_1778999464843/kramabench-environment-hard-14/files/monthly_precipitations_chatham.csv',\n'Amherst':'/home/ec2-user/eval_eqa/exploratory-qa-eval/.sandbox_isolated/task_1676013_1778999464843/kramabench-environment-hard-14/files/monthly_precipitations_amherst.csv',\n'Ashburnham':'/home/ec2-user/eval_eqa/exploratory-qa-eval/.sandbox_isolated/task_1676013_1778999464843/kramabench-environment-hard-14/files/monthly_precipitations_ashburnham.csv',\n}\n\nrpaths = {\n'Boston': '/home/ec2-user/eval_eqa/exploratory-qa-eval/.sandbox_isolated/task_1676013_1778999464843/kramabench-environment-hard-14/files/monthly_precipitations_boston.csv',\n'Chatham': '/home/ec2-user/eval_eqa/exploratory-qa-eval/.sandbox_isolated/task_1676013_1778999464843/kramabench-environment-hard-14/files/monthly_precipitations_chatham.csv',\n'Amherst': '/home/ec2-user/eval_eqa/exploratory-qa-eval/.sandbox_isolated/task_1676013_1778999464843/kramabench-environment-hard-14/files/monthly_precipitations_amherst.csv',\n'Ashburnham': '/home/ec2-user/eval_eqa/exploratory-qa-eval/.sandbox_isolated/task_1676013_1778999464843/kramabench-environment-hard-14/files/monthly_precipitations_ashburnham.csv'\n}\n\nmonths=['Jun','Jul','Aug']\n\ndef load_rain(path):\n    df=pd.read_csv(path)\n    df['Year']=df['Year'].astype(int)\n    for m in ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec','Annual']:\n        if m in df.columns:\n            df[m]=pd.to_numeric(df[m].replace('M',np.nan), errors='coerce')\n    return df\n\nrain_by_loc={loc:load_rain(rpaths[loc]) for loc in rpaths}\n\n# impute missing monthly with median across non-missing years for that location+month\nfor loc,df in rain_by_loc.items():\n    for m in months:\n        med=df[m].median(skipna=True)\n        df[m]=df[m].fillna(med)\n    rain_by_loc[loc]=df\n\n# compute summer total rainfall per year per location as sum Jun+Jul+Aug\nfor loc in rain_by_loc:\n    df=rain_by_loc[loc]\n    df['summer_rain']=df[months].sum(axis=1)\n    rain_by_loc[loc]=df[['Year','summer_rain']]\n\nyears=[2007,2008,2009]\n\ndef avg_summer(locs):\n    vals=[]\n    for loc in locs:\n        d=rain_by_loc[loc]\n        vals.append(d[d['Year'].isin(years)].set_index('Year')['summer_rain'])\n    mat=pd.concat(vals,axis=1)\n    # average across locations\n    return mat.mean(axis=1).reset_index(name='summer_rain')\n\nrain_f=avg_summer(locs_fresh)\nrain_m=avg_summer(locs_marine)\n\n# merge with exceedance\ncorrs={}\nfor typ,exceed,rain in [('Freshwater',exceed_rate_f,rain_f),('Marine',exceed_rate_m,rain_m)]:\n    merged=exceed.merge(rain,on='Year')\n    x=merged['summer_rain'].values\n    y=merged['exceed_rate'].values\n    cor=np.corrcoef(x,y)[0,1]\n    corrs[typ]=cor\n\nprint(corrs)\nprint('Freshwater>Marine', corrs['Freshwater']>corrs['Marine'])\n"}) [toolUseId=call_ugreOcJSrgaNyaSqx8ZN2dM4]
