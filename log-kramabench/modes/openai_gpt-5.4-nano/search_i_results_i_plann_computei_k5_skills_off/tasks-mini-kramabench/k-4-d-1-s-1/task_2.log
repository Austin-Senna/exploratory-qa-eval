eetData/m:row', ns):\n                values = {}\n                for cell in row.findall('m:c', ns):\n                    ref = cell.attrib.get('r', '')\n                    idx = column_index(ref) if ref else len(values)\n                    cell_type = cell.attrib.get('t')\n                    value = ''\n                    if cell_type == 'inlineStr':\n                        is_node = cell.find('m:is', ns)\n                        if is_node is not None:\n                            value = ''.join((t.text or '') for t in is_node.iter('{http://schemas.openxmlformats.org/spreadsheetml/2006/main}t'))\n                    else:\n                        value_node = cell.find('m:v', ns)\n                        if value_node is not None and value_node.text is not None:\n                            value = value_node.text\n                            if cell_type == 's':\n                                value = shared[int(value)]\n                    values[idx] = value\n                max_idx = max(values.keys()) if values else -1\n                rows.append([values.get(i, '') for i in range(max_idx + 1)])\n            sheets.append((name, rows))\n        return sheets\n\n\nsheets = parse_workbook(path)\noutput_lines = []\nfor name, rows in sheets:\n    headers = rows[0] if rows else []\n    normalized = [str(h).strip() for h in headers]\n    has_age = 'Age' in normalized or 'patient age' in {h.lower() for h in normalized}\n    has_figo = 'FIGO_stage' in normalized or 'figo_stage' in {h.lower() for h in normalized} or 'figo stage' in {h.lower() for h in normalized}\n    marker = '  <-- likely eligibility tumor samples table' if has_age and has_figo else ''\n    output_lines.append(f\"Sheet: {name} | columns: {', '.join(normalized[:40])}{marker}\")\n\nprint('\\n'.join(output_lines))", "reason": "Replaced pandas/openpyxl usage with direct XLSX XML parsing via zipfile and ElementTree so the workbook can be inspected in the sandbox without openpyxl. The script now 