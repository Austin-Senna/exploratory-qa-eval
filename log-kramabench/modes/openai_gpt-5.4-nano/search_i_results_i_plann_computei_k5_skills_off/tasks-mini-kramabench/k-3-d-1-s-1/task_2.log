b.get('t')\n    v = cell.find(f'{NS_MAIN}v')\n    if t == 'inlineStr':\n        is_elem = cell.find(f'{NS_MAIN}is')\n        if is_elem is None:\n            return ''\n        parts = []\n        t_elem = is_elem.find(f'{NS_MAIN}t')\n        if t_elem is not None:\n            parts.append(t_elem.text or '')\n        else:\n            for r in is_elem.findall(f'{NS_MAIN}r'):\n                tt = r.find(f'{NS_MAIN}t')\n                parts.append(tt.text or '' if tt is not None else '')\n        return ''.join(parts)\n    if v is None or v.text is None:\n        return None\n    txt = v.text\n    if t == 's':\n        return shared_strings[int(txt)]\n    return txt\n\n\ndef parse_sheet_rows(zf, sheet_path, shared_strings):\n    root = ET.fromstring(zf.read(sheet_path))\n    sheet_data = root.find(f'{NS_MAIN}sheetData')\n    rows = []\n    for row in sheet_data.findall(f'{NS_MAIN}row'):\n        vals = {}\n        for c in row.findall(f'{NS_MAIN}c'):\n            ref = c.attrib.get('r', '')\n            letters = ''.join(ch for ch in ref if ch.isalpha())\n            if not letters:\n                continue\n            idx = col_letters_to_index(letters)\n            vals[idx] = cell_value(c, shared_strings)\n        rows.append(vals)\n    return rows\n\n\ndef to_float(x):\n    if x is None:\n        return None\n    if isinstance(x, (int, float)):\n        return float(x)\n    s = str(x).strip()\n    if s == '':\n        return None\n    try:\n        return float(s)\n    except ValueError:\n        return None\n\n\nwith zipfile.ZipFile(path) as zf:\n    shared_strings = parse_shared_strings(zf)\n    sheet_path = get_first_sheet_path(zf)\n    rows = parse_sheet_rows(zf, sheet_path, shared_strings)\n\n# Data starts after 5 metadata rows; row 6 is header\nheader_row = rows[5]\nmax_col = max(header_row) if header_row else -1\nheaders = [header_row.get(i) for i in range(max_col + 1)]\n\n# Drop completely empty columns to mirror prior successful plan\nnonempty_cols 