est is None:\n    # fallback: search any col containing 'Wet' and 'Dry'\n    for sheet in xl.sheet_names:\n        df = xl.parse(sheet)\n        cols = [str(c).strip() for c in df.columns]\n        year_col=None\n        for c in cols:\n            if 'year' in c.lower():\n                year_col=c;break\n        if year_col is None: continue\n        wet_col=None\n        for c in cols:\n            if 'wet' in c.lower() and 'dry' in c.lower():\n                wet_col=c;break\n        if wet_col:\n            ser_num=pd.to_numeric(df[wet_col], errors='coerce')\n            if ser_num.notna().sum()>10:\n                best=(sheet,year_col,wet_col,df);break\n\nsheet, year_col, wet_col, df = best\n\nd = df[[year_col, wet_col]].copy()\nd[year_col]=pd.to_numeric(d[year_col], errors='coerce')\nd[wet_col]=pd.to_numeric(d[wet_col], errors='coerce')\nd = d.dropna(subset=[year_col, wet_col])\n# sort by year\n# if multiple entries per year, take mean\nif d.duplicated(subset=[year_col]).any():\n    d = d.groupby(year_col, as_index=False)[wet_col].mean()\n\nd = d.sort_values(year_col)\n# year-over-year increases: compare consecutive years\ndiff = d[wet_col].diff()\n# comparable transitions are from year i-1 to year i\nincreases = (diff>0).sum()  # strictly increasing\ntransitions = diff.notna().sum()\npercent = increases/transitions*100 if transitions else np.nan\npercent_rounded = round(percent+1e-12,2)\nprint(sheet, year_col, wet_col, increases, transitions, percent_rounded)\npercent_rounded"}) [toolUseId=call_PDPQ8Qi36nrz1E8t9Xm5r1bJ]
