ndf.columns=cols\n# clean columns names by stripping quotes and whitespace\nclean_cols=[]\nfor c in df.columns:\n    s=str(c)\n    s=s.replace('\"','').strip()\n    clean_cols.append(s)\ndf.columns=clean_cols\n# keep relevant columns\n# date column contains 'Date'\n# find column names containing '1-Day Rain','3-Day Rain','Enterococcus'\ncol_date=[c for c in df.columns if c=='Date' or c.endswith('Date')][0]\ncol_r3=[c for c in df.columns if '3-Day Rain' in c][0]\n# enterococcus columns: there are 3 tags maybe with < and > in same cell; likely format: Tag,Enterococcus,Tag,Enterococcus,...\n# For 3-day rainfall correspond to 3-Day Rain and the next Enterococcus column after it.\n# Let's locate index of 3-Day Rain and take column after last tag? We'll inspect columns order\nprint('Columns:', df.columns.tolist())\nidx=list(df.columns).index(col_r3)\n# expected next columns: Tag, Enterococcus (for 1-day), Tag, Enterococcus (for 2-day), Tag, Enterococcus (for 3-day)\n# So for 3-day, after 3-day rain column should be 'Tag' then 'Enterococcus'.\nnext_cols=df.columns[idx+1:idx+3]\nprint('next after 3-day rain', next_cols)\ncol_tag=next_cols[0]; col_ent=next_cols[1]\n\nsub=df[[col_date,col_r3,col_tag,col_ent]].copy()\n# drop rows where date is nan\nsub=sub.dropna(subset=[col_date])\n# parse date\nsub[col_date]=pd.to_datetime(sub[col_date].astype(str).str.replace('\"','').str.strip(), errors='coerce')\nsub=sub.dropna(subset=[col_date])\n# rainfall numeric\nsub[col_r3]=pd.to_numeric(sub[col_r3], errors='coerce')\n\n# enterococcus label processing: tag column likely contains '<' or '>' or blank; ent column numeric\nsub[col_ent]=pd.to_numeric(sub[col_ent], errors='coerce')\n# if ent is nan skip\nsub=sub.dropna(subset=[col_r3,col_ent,col_tag])\n\ndef est(row):\n    tag=str(row[col_tag]).strip()\n    x=row[col_ent]\n    if tag in ['<','<=']:\n        return x/2\n    if tag in ['>','>=']:\n        return x\n    return x\n\nsub['enterococcus_est']=sub.apply(est,axis=1)\n\n# Quincy mun