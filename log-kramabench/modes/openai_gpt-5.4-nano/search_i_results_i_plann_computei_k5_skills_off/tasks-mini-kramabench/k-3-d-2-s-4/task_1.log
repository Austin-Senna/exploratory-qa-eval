t['Enterococcus'] = nums\nsubset.loc[s.str.match(r'^\\s*<', na=False), 'Enterococcus'] = nums[s.str.match(r'^\\s*<', na=False)] / 2.0\nsubset.loc[s.str.match(r'^\\s*>', na=False), 'Enterococcus'] = nums[s.str.match(r'^\\s*>', na=False)]\n\n# Use rainfall feature from dataset if available; otherwise join to a beach datasheet if present.\nrain_col = None\nfor c in subset.columns:\n    lc = str(c).strip().lower()\n    if lc in {'3-day rain', '3 day rain', '3-day rainfall', '3 day rainfall'}:\n        rain_col = c\n        break\n\nanalysis = subset\n\nif rain_col is None:\n    # Try joining with any local beach datasheet that contains rain information.\n    datasheet_candidates = sorted(base.glob('*datasheet*.csv'))\n    joined = None\n    for ds_path in datasheet_candidates:\n        try:\n            ds = pd.read_csv(ds_path, skiprows=1, header=[0, 1])\n            cols = ds.columns.to_frame(index=False)\n            cols[0] = cols[0].replace(r'^Unnamed.*', np.nan, regex=True).ffill()\n            flat_cols = []\n            for a, b in cols.itertuples(index=False, name=None):\n                parts = [str(x).strip() for x in (a, b) if pd.notna(x) and str(x).strip() and not str(x).startswith('Unnamed')]\n                flat_cols.append('_'.join(parts))\n            ds.columns = flat_cols\n\n            value_cols = [c for c in ds.columns if ('Tag' in c) or ('Enterococcus' in c)]\n            id_cols = [c for c in ds.columns if c not in value_cols]\n            if not any('3-Day Rain' in c for c in id_cols + value_cols):\n                continue\n\n            long_df = ds.melt(id_vars=id_cols, value_vars=value_cols, var_name='Variable', value_name='Value')\n            long_df['Location'] = long_df['Variable'].astype(str).str.split('_').str[0]\n            long_df['Measure'] = long_df['Variable'].astype(str).str.split('_').str[1]\n            tidy = long_df.pivot(index=id_cols + ['Location'], columns='Measure', values='Value').reset_index()\n            tidy.column