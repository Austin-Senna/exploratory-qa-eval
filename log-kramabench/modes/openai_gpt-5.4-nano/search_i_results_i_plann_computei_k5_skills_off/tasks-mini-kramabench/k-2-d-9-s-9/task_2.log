alues='Value', aggfunc='first').reset_index()\n    tidy.columns.name = None\n    if 'Enterococcus' in tidy.columns:\n        tidy['Enterococcus'] = pd.to_numeric(tidy['Enterococcus'], errors='coerce')\n    return tidy\n\ndef matches_location(beach_name, location):\n    location = str(location).lower()\n    if beach_name == 'Pleasure Bay Beach':\n        return 'pleasure bay' in location\n    if beach_name == 'Castle Island Beach':\n        return 'castle island' in location\n    if beach_name == 'City Point Beach':\n        return 'city point' in location\n    if beach_name == 'M Street Beach':\n        return 'm. street' in location or 'm street' in location\n    if beach_name == 'Carson Beach':\n        return location in ['i street', 'mccormack bathhouse'] or 'carson' in location\n    if beach_name == 'Constitution Beach':\n        return location in ['north', 'middle', 'south'] or 'constitution' in location\n    if beach_name == 'Tenean Beach':\n        return location == 'middle' or 'tenean' in location\n    if beach_name == 'Wollaston Beach':\n        return location in ['channing street', 'milton road', 'rice road', 'sachem street'] or 'wollaston' in location\n    if beach_name == 'Malibu Beach':\n        return 'malibu' in location\n    return beach_name.replace(' Beach', '').lower() in location\n\n# Candidate datasheet files in this dataset.\ndatasheet_files = sorted(glob.glob(os.path.join(input_dir, '*datasheet.csv')))\n\nfound = []\ncompliant_beaches = []\nfor path in datasheet_files:\n    try:\n        tidy = prepare_beach_datasheet(path)\n    except Exception:\n        continue\n    if 'Date' not in tidy.columns or 'Enterococcus' not in tidy.columns:\n        continue\n    years = pd.to_datetime(tidy['Date'], errors='coerce').dt.year\n    recent = tidy[(years >= 2020) & (years <= 2024)].copy()\n    if recent.empty:\n        continue\n\n    matched_beaches = []\n    for beach in beaches:\n        mask = recent['Location'].apply(lambda v: matches_location