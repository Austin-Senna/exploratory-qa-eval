occus']>104\npct = ( (failed & (samples['rain']>0)).sum() / failed.sum())*100\nprint('failed_total', int(failed.sum()))\nprint('failed_with_rain24', int((failed & (samples['rain']>0)).sum()))\nprint(f'{pct:.2f}')\n"}) [toolUseId=call_JBuRz9QkkNI7bdS106KeoIpi]
