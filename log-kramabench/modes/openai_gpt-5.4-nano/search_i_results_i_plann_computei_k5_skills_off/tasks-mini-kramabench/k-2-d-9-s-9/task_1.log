ies.apply(conv)\n\nall_rows=[]\nfor p in paths:\n    df=pd.read_csv(p)\n    # Identify rain column for 1-Day Rain and enterococcus columns\n    # Constitution beach has multiple Tag/Enterococcus columns for North/Middle/South. We'll melt those.\n    # We'll treat any columns named like '1-Day Rain' for overall sampling point and corresponding Enterococcus columns.\n    # Common patterns: first line headers include Date,1-Day Rain,2-Day Rain,3-Day Rain,Tag,Enterococcus,Tag,Enterococcus,...\n    cols=list(df.columns)\n    # rename first col Date if needed\n    # determine 1-day rain column: contains '1-Day Rain'\n    rain1_cols=[c for c in cols if '1-Day Rain' in str(c)]\n    if not rain1_cols:\n        # sometimes header row shifts; try first numeric col after Date\n        continue\n    rain1_col=rain1_cols[0]\n    rain1=df[rain1_col]\n\n    # enterococcus columns: those with 'Enterococcus' substring\n    enter_cols=[c for c in cols if 'Enterococcus' in str(c)]\n    if not enter_cols:\n        # sometimes only one Enterococcus column without substring due to multi-row header\n        # fallback: last column\n        enter_cols=[cols[-1]]\n\n    for ec in enter_cols:\n        tmp=pd.DataFrame({'rain1':rain1,'enter':parse_enterococcus_col(df[ec])})\n        all_rows.append(tmp)\n\ndata=pd.concat(all_rows, ignore_index=True)\n# drop nan enterococcus\ndata=data.dropna(subset=['enter'])\nmeet = data['enter']<=104\nfail = ~meet\n# rain within 24 hours: 1-Day Rain >0 (treat 0.0 as no rain)\nwith_rain_24 = data['rain1']>0\nfailed_count = fail.sum()\nfailed_with_rain = (fail & with_rain_24).sum()\nperc = (failed_with_rain/failed_count*100) if failed_count else np.nan\nprint('failed_count', failed_count)\nprint('failed_with_rain', failed_with_rain)\nprint('perc', perc)\nprint('perc_2dp', round(perc,2))"}) [toolUseId=call_7UDCS3M32alGagmTDyW7denb]
