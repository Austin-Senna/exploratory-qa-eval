# parse entities: split by '(' taking left part before parentheses; then split by '-' between actors\n# if conflict string has ' (', keep all before '(' plus inside parentheses ignored.\n\ndef get_entities(conf):\n    left=conf.split('(')[0].strip()\n    # split by '-' but keep hyphenated names like 'Mongols-Tibet'? still actors.\n    parts=[p.strip() for p in left.split('-') if p.strip()]\n    return parts\n\n# compute per-conf attribution counts based on entities mapping\nattrib_counts={}\nfor conf in res['Conflict'].unique():\n    ents=get_entities(conf)\n    mods=set()\n    for e in ents:\n        m=modern_from_entity(e)\n        if m!='—':\n            mods.add(m)\n    # if no ents, skip\n    for m in mods:\n        attrib_counts[m]=attrib_counts.get(m,0)+1\n\n# top 10\nitems=sorted(attrib_counts.items(), key=lambda x: -x[1])[:10]\nprint('unique conflicts',res['Conflict'].nunique())\nprint('top attrib',items)\n"}) [toolUseId=call_9HJLz0SKEz4zFqMLvh513EXk]
