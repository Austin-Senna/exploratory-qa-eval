d['lat'].sub(lat).abs()<th) & (world['lng'].sub(lon).abs()<th)]\n    if len(subset)==0:\n        continue\n    # If multiple, keep last sample in data for that modern city match: define by modern city's index/id\n    # We'll collect all combinations then later take last by roman row order\n    for j,wrow in subset.iterrows():\n        matches.append((i,j,row['rank_num'],wrow['population']))\n\nif not matches:\n    print('no matches')\nelse:\n    m=pd.DataFrame(matches, columns=['anc_row','mod_row','rank','pop'])\n    # take last sample in data if multiple ancient cities for same modern city: last by anc_row appearance in roman order\n    m = m.sort_values('anc_row')\n    m_last = m.groupby('mod_row', as_index=False).tail(1)  # last ancient per modern\n\n    # Pearson correlation between rank and population\n    corr = m_last[['rank','pop']].corr(method='pearson').iloc[0,1]\n    print('n_pairs', len(m_last))\n    print('corr', corr)\n    print('corr_6dec', f\"{corr:.6f}\")\n"})
