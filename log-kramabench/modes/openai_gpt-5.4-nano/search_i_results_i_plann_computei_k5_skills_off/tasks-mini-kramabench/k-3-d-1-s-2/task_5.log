olumns 0-48 excluding first three time columns\nmins=arr.min(axis=0); maxs=arr.max(axis=0)\ncands=[]\nfor j in range(3,49):\n    # AP expected 0-400; ignore columns mostly missing 99999.99\n    col=arr[:,j]\n    frac_valid=np.mean(col<99990)\n    if frac_valid<0.9: \n        continue\n    if maxs[j]>200 and mins[j]>=0 and maxs[j]<4000:\n        cands.append(j)\nprint('cands',cands)\n\n# Further narrow: AP typically integer-ish and has many distinct values; choose highest count of values between 0 and 200\nbest=None\nfor j in cands:\n    col=arr[:,j]\n    valid=col[col<99990]\n    count_in=np.sum((valid>=0)&(valid<=200))\n    distinct=len(np.unique(np.round(valid[(valid>=0)&(valid<=200)],2)))\n    score=count_in*distinct\n    if best is None or score>best[0]:\n        best=(score,j,count_in,distinct)\nprint('best_col',best)\nap_col=best[1]\n\nap=pd.Series(arr[:,ap_col],index=pd.DatetimeIndex(dts)).sort_index()\nmay_ap=ap[(ap.index>=pd.Timestamp('2024-05-01'))&(ap.index<pd.Timestamp('2024-06-01'))]\ncommon=tle_series.index.intersection(may_ap.index)\nX=tle_series.loc[common]\n\nbest_lag=None; best_r2=-1\nfor lag in range(0,49):\n    y=may_ap.loc[common].shift(lag)\n    dfc=pd.concat([X,y.rename('ap')],axis=1).dropna()\n    if len(dfc)<10: continue\n    r=np.corrcoef(dfc['delta_a'].values, dfc['ap'].values)[0,1]\n    r2=r*r\n    if r2>best_r2:\n        best_r2=r2; best_lag=lag\nprint(best_lag,best_r2)\n"}) [toolUseId=call_Ez8qqRwbbz2Koq5pqzk9QKXh]
