ind('main:dimension', NS)\n        for row in root.findall('.//main:sheetData/main:row', NS):\n            row_map = {}\n            for c in row.findall('main:c', NS):\n                ref = c.attrib.get('r', '')\n                typ = c.attrib.get('t', '')\n                v = c.find('main:v', NS)\n                is_node = c.find('main:is', NS)\n                value = ''\n                if typ == 's' and v is not None and v.text is not None:\n                    idx = int(v.text)\n                    value = shared_strings[idx] if 0 <= idx < len(shared_strings) else ''\n                elif typ == 'inlineStr' and is_node is not None:\n                    value = ''.join(t.text or '' for t in is_node.iter('{%s}t' % NS['main']))\n                elif v is not None and v.text is not None:\n                    value = v.text\n                row_map[col_letters(ref)] = normalize(value)\n            rows.append(row_map)\n        sheets.append((name, rows, dim_ref.attrib.get('ref', '') if dim_ref is not None else ''))\n    return sheets\n\n\ndef scan_sheet(name, rows):\n    hist_pat = re.compile(r'endometrioid|endometr|serous', re.I)\n    age_pat = re.compile(r'\\bage\\b', re.I)\n    excl_pat = re.compile(r'exclud|includ|eligible|enroll|screen|drop|omit', re.I)\n    idx_pat = re.compile(r'^idx$|patient|subject|case|sample|participant', re.I)\n\n    findings = {\n        'sheet': name,\n        'histology_hits': [],\n        'age_hits': [],\n        'exclusion_hits': [],\n        'idx_like_headers': set(),\n        'header_hits': []\n    }\n\n    header_candidates = []\n    if rows:\n        first = rows[0]\n        for k in sorted(first.keys()):\n            if first.get(k):\n                header_candidates.append(first[k])\n\n    for h in header_candidates:\n        hs = normalize(h)\n        if hist_pat.search(hs) or age_pat.search(hs) or excl_pat.search(hs) or idx_pat.search(hs):\n            findings['header_hits'].append(hs)\n        if idx_pat.search(hs):\n            findings['idx_like_headers'].add(hs)\n\n    for rnum, row in enumerate(rows, start=1):\n        for col, val in row.items():\n            sval = normalize(val)\n            if not sval:\n                continue\n            if hist_pat.search(sval) and len(findings['histology_hits']) < 8:\n                findings['histology_hits'].append(f'R{rnum}{col}: {sval}')\n            if age_pat.search(sval) and len(findings['age_hits']) < 8:\n                findings['age_hits'].append(f'R{rnum}{col}: {sval}')\n            if excl_pat.search(sval) and len(findings['exclusion_hits']) < 8:\n                findings['exclusion_hits'].append(f'R{rnum}{col}: {sval}')\n            if idx_pat.search(sval) and len(findings['header_hits']) < 20:\n                findings['header_hits'].append(sval)\n\n    return findings\n\n\nsheets = load_xlsx_cells(path)\nall_findings = [scan_sheet(name, rows) for name, rows, _ in sheets]\n\nprint('Workbook scan summary')\nprint('Sheets:', ', '.join(name for name, _, _ in sheets))\nprint()\n\nany_hist = False\nany_age = False\nany_excl = False\nidx_sheets = []\n\nfor f in all_findings:\n    has = bool(f['histology_hits'] or f['age_hits'] or f['exclusion_hits'] or f['header_hits'])\n    if not has:\n        continue\n    print('Sheet:', f['sheet'])\n    if f['header_hits']:\n        print('  Header/label hits:', '; '.join(dict.fromkeys(f['header_hits'])))\n    if f['histology_hits']:\n        any_hist = True\n        print('  Histology hits:', ' | '.join(f['histology_hits']))\n    if f['age_hits']:\n        any_age = True\n        print('  Age hits:', ' | '.join(f['age_hits']))\n    if f['exclusion_hits']:\n        any_excl = True\n        print('  Exclusion/inclusion hits:', ' | '.join(f['exclusion_hits']))\n    if f['idx_like_headers']:\n        idx_sheets.append(f['sheet'])\n        print('  idx/patient-like headers:', ', '.join(sorted(f['idx_like_headers'])))\n    print()\n\nprint('Inference:')\nif idx_sheets:\n    print(\"'idx' appe