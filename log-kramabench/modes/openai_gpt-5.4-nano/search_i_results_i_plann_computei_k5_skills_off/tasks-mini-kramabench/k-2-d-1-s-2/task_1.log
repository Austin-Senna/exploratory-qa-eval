t = ET.fromstring(zf.read(sheet_target))\n    sheet_data = root.find(f'{{{NS_MAIN}}}sheetData')\n    headers = []\n    if sheet_data is None:\n        return headers\n\n    for row in sheet_data.findall(f'{{{NS_MAIN}}}row')[:max_rows]:\n        values = {}\n        max_idx = -1\n        for c in row.findall(f'{{{NS_MAIN}}}c'):\n            ref = c.attrib.get('r', '')\n            m = re.match(r'([A-Z]+)', ref)\n            if not m:\n                continue\n            idx = col_letters_to_index(m.group(1))\n            max_idx = max(max_idx, idx)\n            cell_type = c.attrib.get('t')\n            value = ''\n            if cell_type == 's':\n                v = c.find(f'{{{NS_MAIN}}}v')\n                if v is not None and v.text is not None:\n                    try:\n                        value = shared_strings[int(v.text)]\n                    except Exception:\n                        value = v.text\n            elif cell_type == 'inlineStr':\n                t = c.find(f'.//{{{NS_MAIN}}}t')\n                value = t.text if t is not None and t.text is not None else ''\n            else:\n                v = c.find(f'{{{NS_MAIN}}}v')\n                value = v.text if v is not None and v.text is not None else ''\n            values[idx] = str(value).strip()\n        if max_idx >= 0:\n            headers.append([values.get(i, '') for i in range(max_idx + 1)])\n    return headers\n\n\nwith zipfile.ZipFile(path, 'r') as zf:\n    shared_strings = parse_shared_strings(zf)\n    sheets = get_sheet_targets(zf)\n\n    selected_sheet = None\n    selected_headers = None\n    for name, target in sheets:\n        headers = extract_header_rows(zf, target, shared_strings)\n        flat = [cell for row in headers for cell in row if cell]\n        if any(re.search(r'APP\\s*-?\\s*Z', cell, re.I) for cell in flat):\n            selected_sheet = name\n            selected_headers = headers\n            break\n\n    if selected_sheet is None and sheets:\n        selected_sheet, target = sheets[0]\n        selected_headers = extract_header_rows(zf, target, shared_strings)\n\nprint('sheet', selected_sheet)\ncols = []\nif selected_headers:\n    for i, row in enumerate(selected_headers, 1):\n        print(f'header row {i}:')\n        print(row)\n        cols.extend([c for c in row if c])\n\nage_like = [c for c in cols if re.search(r'\\bage\\b', c, re.I)]\nprint('age-like columns:', age_like)", "reason": "Rewrote the inspection code to avoid pandas/openpyxl entirely by reading the .xlsx file as a zip archive and parsing workbook/sheet XML directly. It finds the sheet containing an APP-Z header, prints that sheet name, prints header rows/column labels, and highlights age-like column names."}) [toolUseId=call_fg6dAp1KMc084TrZ79vPW0Ui]
