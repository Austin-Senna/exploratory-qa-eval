ol)\nprint(con.execute(q).df())\n# compute exact fraction using minimal count reaching >=0.9\nq2=f\"\"\"\nWITH t AS (\n  SELECT {col}::DOUBLE as residential_dam\n  FROM read_csv_auto('{path}')\n  WHERE start_year=2008\n),\nordered AS (\n  SELECT residential_dam,\n         SUM(residential_dam) OVER (ORDER BY residential_dam DESC ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) as cum_dam,\n         SUM(residential_dam) OVER () as total_dam\n  FROM t\n)\nSELECT COUNT(*) * 1.0 / (SELECT COUNT(*) FROM t) as fraction,\n       COUNT(*) as fires_needed,\n       SUM(residential_dam) as total_res_dam,\n       MAX(cum_dam) as cum_dam_at_end\nFROM ordered\nWHERE cum_dam >= 0.9*total_dam\nGROUP BY total_dam;\n\"\"\"\nprint(con.execute(q2).df().head())\n"}) [toolUseId=call_z7xQspaPWNpRkH1oDaAK8DGm]
