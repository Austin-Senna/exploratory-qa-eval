rbody','location','site','beach','marine'])]\n\n# exceedance flag\nexceed_candidates = [c for c in water.columns if any(k in c.lower() for k in ['exceed','exceedance','violation','unsafe','not met','failed'])]\n\n# water key to join EJ\nwater_key_candidates = [c for c in water.columns if any(k in c.lower() for k in ['community','geoid','fips','tract','county','city','block'])]\n\n# If there are too many, pick the most plausible\n# Choose EJ pct as first candidate with ej word\nej_pct_col = None\nfor c in ej_pct_candidates:\n    if 'ej' in c.lower() or 'environmental' in c.lower() or 'justice' in c.lower():\n        ej_pct_col = c\n        break\nif ej_pct_col is None:\n    ej_pct_col = ej_pct_candidates[0]\n\n# Join key: pick common-looking column\njoin_key = None\n# Use intersection of key candidates between water and ej by name similarity\nfor c in water_key_candidates:\n    for d in key_candidates:\n        if c.lower() == d.lower():\n            join_key = c\n            break\n    if join_key is not None:\n        break\nif join_key is None:\n    # fallback: pick first water key candidate and first ej key candidate\n    join_key = water_key_candidates[0]\n    ej_join_key = key_candidates[0]\nelse:\n    ej_join_key = join_key\n\n# Determine exceedance boolean column\nexceed_col = None\nfor c in exceed_candidates:\n    if 'flag' in c.lower() or 'binary' in c.lower() or 'bool' in c.lower() or 'yes' in c.lower():\n        exceed_col = c\n        break\nif exceed_col is None:\n    # pick first\n    exceed_col = exceed_candidates[0]\n\n# Determine marine beach filter column/value\n# Find a text column indicating water body category\nmarine_col = None\nfor c in water.columns:\n    if water[c].dtype == object and any(k in c.lower() for k in ['water','body','location','type','site','beach']):\n        # check if 'marine' or 'ocean' present in sample\n        marine_col = c\n        break\nif marine_col is None:\n    # fallback: first object column\n    obj_cols = [c for c in water.columns if water[c].dtype == object]\n    marine_col = obj_cols[0]\n\n# Now filter to marine beach samples in 2023: year already 2023 file.\n# Filter rows where marine_col contains 'marine' and 'beach' or 'beach' and maybe 'ocean'\nmask = water[marine_col].astype(str).str.lower().str.contains('marine') | water[marine_col].astype(str).str.lower().str.contains('ocean')\nmask2 = water[marine_col].astype(str).str.lower().str.contains('beach')\n# If both exist separately, require both when possible; otherwise use mask\nif mask2.any():\n    marine_mask = mask & mask2\nelse:\n    marine_mask = mask\n\nmarine = water.loc[marine_mask].copy()\n\n# Ensure exceedance column is numeric/bool\n# Convert common encodings\nex = marine[exceed_col]\nif ex.dtype == object:\n    ex_l = ex.astype(str).str.lower()\n    exceed_bool = ex_l.isin(['true','t','yes','y','1','exceed','exceeded','violation','unsafe','fail','failed'])\n    exceed_num = exceed_bool.astype(int)\nelse:\n    # assume 1/0 or threshold count\n    exceed_num = pd.to_numeric(ex, errors='coerce').fillna(0).astype(int)\n\nmarine['__exceed'] = exceed_num\n\n# Join with EJ\nej_sub = ej[[ej_join_key, ej_pct_col]].copy()\n# Convert ej pct to numeric\nej_sub[ej_pct_col] = pd.to_numeric(ej_sub[ej_pct_col], errors='coerce')\n\nmarine = marine.merge(ej_sub, left_on=join_key, right_on=ej_join_key, how='left', suffixes=('','_ej'))\n\n# drop missing\nmarine = marine.dropna(subset=[ej_pct_col])\n\n# Compute exceedance rate by groups\nmarine['__group'] = pd.cut(marine[ej_pct_col], bins=[-float('inf'),24.999999,49.999999, float('inf')], labels=['<25','25-50','>50'])\n\nrate_gt50 = marine.loc[machine_mask := (marine[ej_pct_col] > 50), '__exceed'].mean() if (marine[ej_pct_col] > 50).any() else float('nan')\nrate_lt25 = marine.loc[marine[ej_pct_col] < 25, '__exceed'].mean() if (marine[ej_pct_col] < 25).any() else float('nan')\n\ndiff = rate_gt50 - rate_lt25\nprint('rate_gt50', rate_gt50)\nprint('rate_lt25', rate_lt25)\nprint('di