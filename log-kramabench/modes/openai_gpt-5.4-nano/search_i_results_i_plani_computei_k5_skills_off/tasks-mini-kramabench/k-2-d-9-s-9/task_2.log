alue'\n    )\n    long_df['Location'] = long_df['Variable'].str.split('_').str[0]\n    long_df['Measure'] = long_df['Variable'].str.split('_').str[1]\n\n    tidy = long_df.pivot(index=id_cols + ['Location'], columns='Measure', values='Value').reset_index()\n    tidy.columns.name = None\n\n    for col in tidy.columns:\n        if col not in id_cols + ['Location', 'Tag']:\n            tidy[col] = pd.to_numeric(tidy[col], errors='coerce')\n    return tidy\n\n\ndef matches_location(beach_name, location):\n    location = str(location).lower()\n    if beach_name == 'Pleasure Bay Beach':\n        return 'pleasure bay' in location\n    if beach_name == 'Castle Island Beach':\n        return 'castle island' in location\n    if beach_name == 'City Point Beach':\n        return 'city point' in location\n    if beach_name == 'M Street Beach':\n        return 'm. street' in location or 'm street' in location\n    if beach_name == 'Carson Beach':\n        return location in ['i street', 'mccormack bathhouse'] or 'carson' in location\n    if beach_name == 'Constitution Beach':\n        return location in ['north', 'middle', 'south'] or 'constitution' in location\n    if beach_name == 'Tenean Beach':\n        return location == 'middle' or 'tenean' in location\n    if beach_name == 'Wollaston Beach':\n        return location in ['channing street', 'milton road', 'rice road', 'sachem street'] or 'wollaston' in location\n    return beach_name.replace(' Beach', '').lower() in location\n\n\nresult = []\nfor filename, beach_names in files_and_beaches:\n    path = os.path.join(base, filename)\n    df = prepare_beach_datasheet(path)\n    years = df['Date'].astype(str).str.extract(r'(\\d{4})$')[0]\n    recent = df[years.astype(float).between(2020, 2024, inclusive='both')].copy()\n\n    clean = []\n    for beach_name in beach_names:\n        mask = recent['Location'].apply(lambda value: matches_location(beach_name, value))\n        beach_rows = recent[mask]\n        if len(beach_rows) and i