   frames = []\n    for col in enter_cols:\n        location = col[: -len('_Enterococcus')].strip()\n        temp = df[[date_col, 'Date_parsed', col]].copy()\n        temp['Location'] = location\n        temp['Enterococcus'] = temp[col].apply(parse_enterococcus)\n        frames.append(temp[[date_col, 'Date_parsed', 'Location', 'Enterococcus']])\n\n    long_df = pd.concat(frames, ignore_index=True) if frames else pd.DataFrame(columns=[date_col, 'Date_parsed', 'Location', 'Enterococcus'])\n    long_df = long_df.dropna(subset=['Enterococcus']).copy()\n    long_df['Location_norm'] = long_df['Location'].astype(str).str.strip().str.lower()\n\n    result = {}\n    if key == 'pleasure':\n        result['pleasure'] = long_df[long_df['Location_norm'].apply(BEACH_MATCHERS['pleasure'])].copy()\n        result['castle_island'] = long_df[long_df['Location_norm'].str.contains('castle island', na=False)].copy()\n    else:\n        result[key] = long_df[long_df['Location_norm'].apply(BEACH_MATCHERS[key])].copy()\n    return result\n\n\nall_samples = {}\nfor key, path, _ in files:\n    loaded = load_beach_samples(path, key)\n    all_samples.update(loaded)\n\nbeach_names = {\n    'constitution': 'Constitution Beach',\n    'pleasure': 'Pleasure Bay Beach',\n    'castle_island': 'Castle Island Beach',\n    'city_point': 'City Point Beach',\n    'm_street': 'M Street Beach',\n    'carson': 'Carson Beach',\n    'malibu': 'Malibu Beach',\n    'tenean': 'Tenean Beach',\n    'wollaston': 'Wollaston Beach',\n}\n\nclean_beaches = []\nfor key, name in beach_names.items():\n    samples = all_samples.get(key, pd.DataFrame())\n    if not samples.empty and (samples['Enterococcus'] < 104).all():\n        clean_beaches.append(name)\n\nprint(clean_beaches)", "reason": "Rewrote the script to avoid the s3fs dependency by mapping S3 URIs to local sandbox paths, parse the two-row beach datasheet headers, extract and normalize Enterococcus values including '<' qualified values, handle the multi-beach Pleasure Bay/Castle Island sheet, filter samples to 2020-2024, and print the beaches whose Enterococcus samples are all below the 104 standard."})
