urn None\n    s=str(s).strip().strip('\"')\n    # remove leading/trailing\n    m=re.search(r'(\\w+\\s+\\d{1,2},\\s+\\d{4})',s)\n    if m:\n        s2=m.group(1)\n    else:\n        s2=s\n    return pd.to_datetime(s2)\n\ndef parse_enterococcus(val):\n    if pd.isna(val): return None\n    s=str(val).strip().strip('\"')\n    if s=='': return None\n    # formats: '<,10' or '<,10' sometimes '<, 10'? We'll remove commas\n    s=s.replace(' ', '')\n    # if contains '<,' treat as below number\n    m=re.match(r'<,?(\\d+)', s)\n    if m:\n        return int(m.group(1))-1  # ensure <104 if threshold less\n    m=re.match(r',?(\\d+)$', s)\n    if m:\n        return int(m.group(1))\n    # maybe like '<,10,'? take first number\n    m=re.search(r'(\\d+)', s)\n    return int(m.group(1)) if m else None\n\n\ndef evaluate_file(path):\n    df=load_messy(path)\n    samples=extract_beach_samples(df)\n    # identify Enterococcus columns: header contains 'Enterococcus'\n    ent_cols=[c for c in samples.columns if str(c).endswith('Enterococcus') or 'Enterococcus' in str(c)]\n    date_col=samples.columns[0]\n    samples['_date']=samples[date_col].map(parse_date)\n    samples=samples[(samples['_date']>=pd.Timestamp('2020-01-01')) & (samples['_date']<=pd.Timestamp('2024-12-31'))]\n    # create long form with each ent col as a site key based on previous non-empty column in header row? We'll infer site labels from original header rows\n    # In these files, ent columns correspond to specific sites under top header rows.\n    # We can approximate site by pairing ent col position with nearest preceding column in samples.columns for which header has a site name (non-Enterococcus, non-rain/tag).\n    # We'll build mapping from column order.\n    col_list=list(samples.columns)\n    # find top site names by looking at original df header rows (the row before date row contains site names)\n    # site header row is r-2 maybe; just take last non-empty in first rows.\n    r=int(df.index[df.apply(lambda r: r