ar'].values\nys = agg['K'].values\n\n# Linear interpolation for average over continuous time: average of linearly interpolated function over [a,b]\n# If function is piecewise linear through points, average = integral/length.\n\na, b = malta_start, malta_end\nif a>b: a,b = b,a\nlength = b-a\n\n# Compute integral piecewise between consecutive x points\nintegral = 0.0\nfor i in range(len(xs)-1):\n    x0,x1 = xs[i], xs[i+1]\n    if x1<=a or x0>=b:\n        continue\n    left = max(a,x0)\n    right = min(b,x1)\n    if right<=left:\n        continue\n    y0,y1 = ys[i], ys[i+1]\n    # linear y(x)= y0 + (y1-y0)*(x-x0)/(x1-x0)\n    slope = (y1-y0)/(x1-x0)\n    # integral of y over [l,r]\n    # y(x)= y0 + slope*(x-x0)\n    integral += ( (y0 - slope*x0)*(right-left) + 0.5*slope*(right**2-left**2) )\n\navg = integral/length\nprint('malta_start',a,'malta_end',b,'avgK',avg)\nprint('rounded',round(avg,4))\nprint(avg)\n", "dataset_id": "kramabench-archeology-hard-1", "file_path": "files/climateMeasurements.xlsx"}) [toolUseId=call_cINIfJeHMfcnHpKjNKct2lhT]
