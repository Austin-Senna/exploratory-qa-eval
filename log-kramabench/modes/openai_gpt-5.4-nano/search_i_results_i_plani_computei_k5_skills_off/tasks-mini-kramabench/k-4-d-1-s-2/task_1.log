] = rad_hs_neol.loc[mask,cal2].apply(later_from_range)\n\n# Northernmost: max latitude; tie break by later calendar year (larger? For BC, later=smaller BC)\n# We'll pick later by sorting CalLaterBC ascending (smaller BC -> later)\nrad_hs_neol = rad_hs_neol.dropna(subset=['Latitude','CalLaterBC'])\n\n# For robustness, if multiple samples share max latitude, choose with smallest CalLaterBC\nmax_lat = rad_hs_neol['Latitude'].max()\ncand = rad_hs_neol[rad_hs_neol['Latitude']==max_lat]\n# later year => smallest BC\nsel = cand.sort_values('CalLaterBC', ascending=True).iloc[0]\nselected_year_bc = sel['CalLaterBC']\n\n# Convert BC year to CE-like? Climate likely uses Age_ky forward in thousands years ago.\n# We'll match by climate 'Age_ky' converted to years BP? Need closest year to that year.\n\ncli = pd.read_excel(cli_path, sheet_name=0)\n\n# Climate dataset has columns Age_ky and Al, possibly more. We need closest year to selected_year_bc.\n# Interpret selected_year_bc as calendar year BC. Convert to years before present (BP) as: yearBP = selected_year_bc + 1950\n# Since climate Age_ky likely in thousands of years ago relative to present.\n# We'll compute target age_ky = (selected_year_bc + 1950)/1000.\n\ntarget_age_ky = (selected_year_bc + 1950)/1000.0\n\ncli['Age_ky'] = pd.to_numeric(cli['Age_ky'], errors='coerce')\ncli['Al'] = pd.to_numeric(cli['Al'], errors='coerce')\ncli = cli.dropna(subset=['Age_ky','Al'])\n\n# Find closest climate Age_ky value(s)\nmin_diff = (cli['Age_ky']-target_age_ky).abs().min()\nclosest = cli[(cli['Age_ky']-target_age_ky).abs()==min_diff]\nmax_al = closest['Al'].max()\n\nans = round(float(max_al),4)\nprint(\"selected_year_bc\", selected_year_bc)\nprint(\"target_age_ky\", target_age_ky)\nprint(\"min_diff\", min_diff)\nprint(\"max_al\", ans)\nprint(ans)\n"})
