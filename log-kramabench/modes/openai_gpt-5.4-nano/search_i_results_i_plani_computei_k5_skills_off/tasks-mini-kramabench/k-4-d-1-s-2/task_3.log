stology'\n    candidates=[c for c in clin.columns if any(k in str(c).lower() for k in ['histology','tumor','cancer','diagnosis'])]\n    if candidates:\n        c=candidates[0]\n        serous_row_mask=clin[c].astype(str).str.contains('serous',case=False,na=False)\n    else:\n        raise ValueError('no serous mask')\n\n# exclusion column\nex_col=None\nfor c in clin.columns:\n    if 'exclude' in str(c).lower() or 'exclusion' in str(c).lower() or 'reason' in str(c).lower():\n        ex_col=c\n        break\nif ex_col is None:\n    # look for columns with 'Excluded' or 'non-excluded'\n    for c in clin.columns:\n        if 'excluded' in str(c).lower():\n            ex_col=c;break\nprint('exclusion col',ex_col)\n\nif ex_col is None:\n    # maybe column named 'Included' boolean\n    for c in clin.columns:\n        if 'include' in str(c).lower():\n            ex_col=c;break\n\n# define non-excluded mask\nif ex_col is not None:\n    v=clin[ex_col]\n    # treat True/1/Yes as excluded? We'll infer by checking unique values\n    uniq=pd.Series(v.dropna().unique()).astype(str).str.lower().head(20).tolist()\n    print('exclusion unique sample',uniq)\n    # if column contains 'no' / 'false' for non-excluded\n    non_ex_mask=~clin[ex_col].astype(str).str.lower().isin(['true','1','yes','excluded'])\n    # if values like 'Not excluded' vs 'Excluded'\n    if clin[ex_col].astype(str).str.contains('excluded',case=False,na=False).any():\n        non_ex_mask=~clin[ex_col].astype(str).str.contains('excluded',case=False,na=False)\n    else:\n        non_ex_mask=clin[ex_col].astype(str).str.lower().isin(['false','0','no']) | ~clin[ex_col].astype(str).str.lower().isin(['true','1','yes'])\nelse:\n    non_ex_mask=pd.Series(True,index=clin.index)\n\nfiltered=clin[serous_row_mask & non_ex_mask].copy()\nprint('filtered rows',len(filtered))\n\n# identify patient/sample id column\nid_col=None\nfor c in clin.columns:\n    if any(k in str(c).lower() for k in ['sample','patient','tumor','specimen','id']):\n        # choose one with most non-null\n        nn=filtered[c].notna().sum()\n        if nn>0 and (id_col is None or nn>filtered[id_col].notna().sum()):\n            id_col=c\nprint('id_col',id_col)\n\n# load mutation burden workbook\nxl2=pd.ExcelFile(mb)\nprint('mutation sheets',xl2.sheet_names)\n# find sheet containing 'mutation' or 'burden'\nmb_sh=None\nfor sh in xl2.sheet_names:\n    df=xl2.parse(sh,nrows=50)\n    text=' '.join(map(str,df.columns))+' '+ ' '.join(df.astype(str).head(20).values.ravel())\n    if re.search('mutat|burden',text, re.I):\n        mb_sh=sh;break\nif mb_sh is None:\n    mb_sh=xl2.sheet_names[0]\nprint('chosen mb sheet',mb_sh)\nmbdf=xl2.parse(mb_sh)\nprint('mb cols',mbdf.columns.tolist()[:60])\n\n# find log-scale mutation burden column and sample id column\nlog_col=None\nfor c in mbdf.columns:\n    if 'log' in str(c).lower() and 'mut' in str(c).lower():\n        log_col=c;break\nif log_col is None:\n    for c in mbdf.columns:\n        if 'mut' in str(c).lower() and 'log' in str(c).lower():\n            log_col=c;break\nif log_col is None:\n    # maybe 'mutation burden (log10)'\n    for c in mbdf.columns:\n        if 'log' in str(c).lower() and ('burden' in str(c).lower() or 'variants' in str(c).lower()):\n            log_col=c;break\nprint('log_col',log_col)\n\nif log_col is None:\n    raise ValueError('no log_col')\n\nmb_id_col=None\nfor c in mbdf.columns:\n    if any(k in str(c).lower() for k in ['sample','patient','id','tumor']):\n        if mbdf[c].notna().sum()>0:\n            mb_id_col=c;break\nprint('mb_id_col',mb_id_col)\n\n# align\nfiltered_ids=filtered[id_col].astype(str)\nmbdf[mb_id_col]=mbdf[mb_id_col].astype(str)\nsub=mbdf[mbdf[mb_id_col].isin(filtered_ids)].copy()\nprint('matched',len(sub))\n\n# convert log-scale to linear variants per Mbp. likely log10.\nvals=sub[log_col].astype(float).values\n# check if typical log10 negative\nprint('log min max',vals.min(),vals.max())\n# assume log10(variants/Mb)\nlinear=10**vals\nmedian=np.median(linear)\nprint('median linear',median)\nprint('rounded',round(float(median),4))\n", "intent": "Compute the median number of variants per Mbp for non-excluded serous tumor samples; convert from log-scale mutation burden to linear variants per Mbp and return median rounded to 4 decimals.", "dataset_id": "kramabench-biomedical-hard-5"}) [toolUseId=call_DG5VrcVIW4kxA8z0vlL09u7h]
