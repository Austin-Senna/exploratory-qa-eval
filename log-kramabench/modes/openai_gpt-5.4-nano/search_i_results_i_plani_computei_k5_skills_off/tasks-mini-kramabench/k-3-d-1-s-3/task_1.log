ol is None:\n    raise ValueError(f'Could not find protein site column in hyperactivated file. Columns: {list(hyper.columns)}')\n\nhyper_sel = hyper[hyper[sample_col].astype(str).isin(cnv_high_ids)].copy()\n\n# 3) Load FDA-approved target genes and collect gene symbols from all plausible target/gene columns.\nxl = pd.ExcelFile(fda_file)\nall_gene_values = set()\nfor sheet in xl.sheet_names:\n    df = pd.read_excel(fda_file, sheet_name=sheet)\n    for c in df.columns:\n        lc = str(c).lower()\n        if any(k in lc for k in ['gene', 'symbol', 'target']):\n            vals = (\n                df[c]\n                .dropna()\n                .astype(str)\n                .str.replace(r'[;,|/]', ' ', regex=True)\n                .str.split()\n                .explode()\n                .str.strip()\n            )\n            vals = vals[vals.str.match(r'^[A-Za-z0-9\\-]+$', na=False)]\n            all_gene_values.update(v.upper() for v in vals if v)\n\nif not all_gene_values:\n    raise ValueError('No FDA target gene names found in workbook.')\n\n# 4) Intersect hyperactivated protein sites with FDA targets by extracting gene symbol from site strings.\ndef extract_gene(site_text: str):\n    s = str(site_text).strip()\n    if not s or s.lower() == 'nan':\n        return None\n\n    patterns = [\n        r'^([A-Z0-9\\-]+)[_:\\s\\-]*[STY]\\d+',   # e.g. AKT1 S473 / AKT1_S473\n        r'^([A-Z0-9\\-]+)[_:\\s\\-]*p\\.[A-Z]\\d+', # e.g. EGFR p.Y1068\n        r'^([A-Z0-9\\-]+)',                      # leading gene token\n    ]\n    for pat in patterns:\n        m = re.match(pat, s, flags=re.IGNORECASE)\n        if m:\n            token = m.group(1).upper()\n            if token in all_gene_values:\n                return token\n\n    upper_s = s.upper()\n    for g in sorted(all_gene_values, key=len, reverse=True):\n        if re.search(rf'(?<![A-Z0-9]){re.escape(g)}(?![A-Z0-9])', upper_s):\n            return g\n    return None\n\nhyper_sel['__gene__'] = hyper_sel[site_col].map(extract_gene)\nmatched_sites = sorted(hyper_sel.loc[hyper_sel['__gene__'].isin(all_gene_values), site_col].dropna().astype(str).unique())\n\nprint(matched_sites)", "reason": "Repaired the code to align with the authored clinical-filter record by explicitly using idx, CNV_class, Histologic_type, and Case_excluded to obtain endometrioid CNV_HIGH non-excluded sample IDs, then intersected hyperactivated protein sites from those samples with FDA-approved target gene symbols and printed the matched protein sites."}) [toolUseId=call_TBKZXReDeqQInIRcET92zvH8]
