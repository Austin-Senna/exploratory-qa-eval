d')\n    & clinical['Case_excluded'].astype(str).str.lower().eq('no')\n].copy()\n\nsample_ids = set(filt['idx'].astype(str).str.strip())\n\n# Hyperactivated protein sites\nhyper = pd.read_csv(hyper_file)\ncols_lower = {c.lower(): c for c in hyper.columns}\n\nsample_col = None\nfor cand in ['sample', 'sample_id', 'idx', 'patient', 'case']:\n    if cand in cols_lower:\n        sample_col = cols_lower[cand]\n        break\nif sample_col is None:\n    for c in hyper.columns:\n        lc = c.lower()\n        if 'sample' in lc or lc == 'idx':\n            sample_col = c\n            break\n\nsite_col = None\nfor cand in hyper.columns:\n    lc = cand.lower()\n    if 'site' in lc:\n        site_col = cand\n        break\nif site_col is None:\n    raise ValueError('Could not identify protein site column in hyperactivated.csv')\nif sample_col is None:\n    raise ValueError('Could not identify sample id column in hyperactivated.csv')\n\nhyper_sel = hyper[hyper[sample_col].astype(str).str.strip().isin(sample_ids)].copy()\nsite_series = hyper_sel[site_col].dropna().astype(str).str.strip()\n\n# FDA-approved drug target gene names\nfda = read_xlsx_sheet(fda_file)\n\ngene_col = None\nfor c in fda.columns:\n    lc = c.lower()\n    if 'gene' in lc and ('target' in lc or 'name' in lc or lc == 'gene'):\n        gene_col = c\n        break\nif gene_col is None:\n    for c in fda.columns:\n        if c.lower() in {'gene', 'symbol', 'target gene', 'gene name'}:\n            gene_col = c\n            break\nif gene_col is None:\n    raise ValueError('Could not identify FDA target gene column')\n\nraw_genes = set()\nfor val in fda[gene_col].dropna().astype(str):\n    parts = re.split(r'[;,/|]', val)\n    for part in parts:\n        g = part.strip().upper()\n        if g and g != 'NAN':\n            raw_genes.add(g)\n\n# Match protein sites whose gene symbol corresponds to an FDA-approved target\nmatched_sites = set()\nfor site in site_series:\n    tokens = re.findall(r'[A-Z0-9]{2,15}', site.upper())\n    gene = tokens[0] if tokens else None\n    if gene in raw_genes:\n        matched_sites.add(site)\n    else:\n        for g in raw_genes:\n            if re.search(rf'(^|[^A-Z0-9]){re.escape(g)}([^A-Z0-9]|$)', site.upper()):\n                matched_sites.add(site)\n                break\n\nfor s in sorted(matched_sites):\n    print(s)\n", "reason": "Rewrote the script to avoid openpyxl by parsing XLSX files directly with zip/xml, used the known clinical filter from the plan (Endometrioid + CNV_HIGH + Case_excluded=No), then intersected hyperactivated protein sites from those samples with FDA target gene names and printed the matched sites."})
