 proteins\nhyper=pd.read_csv(hyper_file)\nprint('hyper columns', list(hyper.columns)[:50])\nprint('hyper head', hyper.head(3).to_dict('records'))\n\n# Determine columns for sample id and protein site\n# common: sample_id, Protein, Site, hyperactivated_protein_site\nhid_cols={}\nfor c in hyper.columns:\n    lc=str(c).lower()\n    if 'sample' in lc and ('id' in lc or 'patient' in lc): hid_cols['sample_id']=c\n    if 'protein' in lc and 'site' in lc: hid_cols['site']=c\n    elif lc=='site' or 'site' in lc: hid_cols.setdefault('site',c)\n    if 'protein' in lc and 'hyper' not in lc and 'site' not in lc: hid_cols.setdefault('protein',c)\n\nprint('hyper candidates', hid_cols)\n\nsample_col=hid_cols.get('sample_id')\nsite_col=hid_cols.get('site')\nprotein_col=hid_cols.get('protein')\n\nhyper_sel=hyper[hyper[sample_col].astype(str).isin(sample_ids)]\nprint('hyper_sel rows', len(hyper_sel))\n\n# Create site identifier column\nif site_col:\n    sites=set(hyper_sel[site_col].astype(str))\nelif protein_col:\n    sites=set(hyper_sel[protein_col].astype(str))\nelse:\n    sites=set()\nprint('unique sites from hyper_sel', len(sites))\nprint(list(sites)[:10])\n\n# Load FDA-approved drug targets\nfda=pd.read_excel(fda_file, sheet_name=0)\nprint('fda columns', list(fda.columns)[:50])\nprint('fda head', fda.head(3).to_dict('records'))\n\n# Find gene name column\ngene_col=None\nfor c in fda.columns:\n    lc=str(c).lower()\n    if 'gene' in lc or 'target' in lc:\n        gene_col=c\n        # if 'approved' etc still ok\n        break\nif gene_col is None:\n    for c in fda.columns:\n        if str(c).lower() in ['target gene','gene','gene name','approved gene','symbol']:\n            gene_col=c\n            break\nprint('gene_col', gene_col)\n\ngenes=set(fda[gene_col].astype(str))\nprint('num genes', len(genes))\nprint(list(genes)[:10])\n\n# Intersect: need mapping from protein sites to gene names.\n# Assume site strings contain gene symbol like 'EGFR' or 'ERBB2:...' or 'EGFR p.Y1068'\n# We'll extract gene symbol as leading uppercase letters optionally with digits.\nimport re\n\ndef extract_gene(site):\n    # look for common gene symbol patterns at start\n    m=re.match(r'([A-Z0-9]{2,10})', site)\n    if m:\n        return m.group(1)\n    # otherwise look for any gene in genes within string\n    for g in genes:\n        if g in site:\n            return g\n    return None\n\nmatched=set()\nfor s in sites:\n    g=extract_gene(s)\n    if g and g in genes:\n        matched.add(s)\n\nprint('matched sites', len(matched))\nprint(sorted(matched)[:50])\n", "intent": "Intersect hyperactivated protein sites in CNV_HIGH endometrioid samples with FDA-approved drug target gene names; output matched protein sites.", "dataset_id": "kramabench-biomedical-hard-8", "file_path": "files/1-s2.0-S0092867420301070-mmc1.xlsx"}) [toolUseId=call_Qb1PBHaLRFsOVXa0LGbcO7D3]
