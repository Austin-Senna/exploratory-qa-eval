ion\nstate_df = df.groupby(state_col).agg(unsafe_days=(unsafe_col,'sum'), total_days=(total_col,'sum')).reset_index()\nstate_df['proportion_generally_unsafe'] = state_df['unsafe_days'] / state_df['total_days']\n\n# Clean state names (strip)\nstate_df[state_col] = state_df[state_col].astype(str).str.strip()\n\n# Return mapping\nout = state_df[[state_col,'proportion_generally_unsafe']].rename(columns={state_col:'state'})\nprint(out.head())\nprint(out.shape)\n\n# Save for next step\nout.to_csv('/mnt/data/state_proportion_unsafe_2024.csv', index=False)\nprint('saved')"}) [toolUseId=call_BmoWEsol8bOhGDrEDQWFo4eh]
