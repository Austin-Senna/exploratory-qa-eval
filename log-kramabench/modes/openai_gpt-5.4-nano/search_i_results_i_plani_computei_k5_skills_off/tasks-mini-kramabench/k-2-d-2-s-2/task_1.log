alues('epoch')\n    return out\n\ndef avg_rate(df, start, end):\n    d=parse_tle(df)\n    start=pd.Timestamp(start, tz='UTC')\n    end=pd.Timestamp(end, tz='UTC')\n    m=(d['epoch']>=start)&(d['epoch']<=end)\n    sub=d.loc[m].copy().reset_index(drop=True)\n    if len(sub)<2:\n        return np.nan\n    # consecutive differences\n    sub['dt_days']=sub['epoch'].diff().dt.total_seconds()/86400.0\n    sub['da']=sub['a_km'].diff()\n    sub=sub.dropna(subset=['dt_days','da'])\n    sub=sub[sub['dt_days']>0]\n    sub['rate']=sub['da']/sub['dt_days']\n    return sub['rate'].mean()\n\nquiet_path='/home/ec2-user/eval_eqa/exploratory-qa-eval/.sandbox_isolated/task_1647778_1778994276934/kramabench-astronomy-easy-6/files/space-track/58214_quiet.csv'\nstorm_path='/home/ec2-user/eval_eqa/exploratory-qa-eval/.sandbox_isolated/task_1647778_1778994276934/kramabench-astronomy-easy-6/files/space-track/58214_storm.csv'\n\nquiet_df=pd.read_csv(quiet_path)\nstorm_df=pd.read_csv(storm_path)\n\nquiet_rate=avg_rate(quiet_df,'2024-05-01','2024-05-04')\nstorm_rate=avg_rate(storm_df,'2024-05-10','2024-05-13')\n\nprint(quiet_rate)\nprint(storm_rate)\nprint(f'pair: ({quiet_rate:.6f}, {storm_rate:.6f})')"}) [toolUseId=call_uw94aiOzumqOUfneFJ5eM80r]
