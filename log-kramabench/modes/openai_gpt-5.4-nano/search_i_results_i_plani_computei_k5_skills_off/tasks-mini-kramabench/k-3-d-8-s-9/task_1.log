 in data2.columns if '3-Day Rain' in c][0]\nrain2=to_numeric(data2[col_3_2]).fillna(0)\nno_rain2=rain2==0\nenc_cols2=[c for c in data2.columns if 'Enterococcus' in c]\n# map three site columns by order they appear after parsing header\n# header has: Date,1-Day Rain,2-Day Rain,3-Day Rain, Tag, Enterococcus, Tag.1, Enterococcus.1, Tag.2, Enterococcus.2\n# title row 3rd line contains names: Pleasure Bay @ Broadway, Pleasure Bay @ Flagpole, Castle Island Playground\nsite_names=['Pleasure Bay Beach','Pleasure Bay Beach','Castle Island Beach']\nsite_fail={}\nfor site_name,c in zip(site_names,enc_cols2):\n    num=to_numeric(data2[c])\n    cnt=int(((num>=104) & no_rain2).sum())\n    site_fail[site_name]=site_fail.get(site_name,0)+cnt\n\ncounts={'Constitution Beach':fail_total}\ncounts.update(site_fail)\nprint(counts)\nmax_beach=max(counts, key=lambda k: counts[k])\nprint(max_beach, counts[max_beach])\n"}) [toolUseId=call_j1kUeTqd0RnKaooQ0MxiK4iv]
