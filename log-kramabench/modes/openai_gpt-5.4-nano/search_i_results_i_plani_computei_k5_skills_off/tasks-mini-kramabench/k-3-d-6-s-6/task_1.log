e windows where context ends at time t0 (last context point), target times are t0+10min..t0+4h.\n# Context window 16h preceding t0 inclusive of t0? prompt: 16-hour context window to project input time series forward.\n# We'll use context from t0-16h to t0 inclusive, fit VAR(1) on that feature sequence, project 4h ahead (24 steps at 10min).\n\n# To match prompt: training uses OMNI/GOES window ending at density start; density begins immediately after. so t0 corresponds to first density timestamp (2016-10-23 00:00)\n# and targets are first 4h of density (2016-10-23 00:10..04:00). Similarly evaluation density begins at 2016-10-29 00:00? We'll use that day first timestamp.\n\nstep='10min'\nsteps_forecast=int((forecast_hours*60)/10)\n\nfeature_cols=cols_omni+cols_goes\n\nfrom sklearn.linear_model import LinearRegression\n\n\ndef rmse_for_window(df, start_time, context_end, forecast_steps):\n    # df indexed by Timestamp with feature_cols and 'Orbit Mean Density (kg/m^3)'\n    target_col=df.columns[0]\n\n    # select context_end and build sequence up to context_end for VAR fitting\n    context_start=context_end-pd.Timedelta(hours=16)\n    context=df.loc[context_start:context_end, feature_cols]\n    y_past=df.loc[context_start:context_end, feature_cols]  # features only\n    # fit VAR(1): X_t = A X_{t-1} + e, multivariate least squares\n    Z=context.values[:-1]\n    W=context.values[1:]\n    # add intercept\n    Z_aug=np.hstack([np.ones((Z.shape[0],1)), Z])\n    # solve B minimizing ||Z_aug*B - W||\n    B,_,_,_=np.linalg.lstsq(Z_aug,W,rcond=None)\n    # B shape (p+1,k)\n    # project forward forecast_steps using VAR recursively\n    last=context.values[-1]\n    preds=[]\n    x=last\n    for i in range(forecast_steps):\n        x_aug=np.hstack([1,x])\n        x=B.T.dot(x_aug)\n        preds.append(x)\n    preds=np.array(preds) # shape (forecast_steps,k)\n    # Linear regression mapping projected features to density for training or prediction.\n    # For training we need observed density corresponding to these target times to fit regression.\n    # Here we'll just return projected features for given horizon start.\n    return preds\n\n# Training setup: single window as per prompt (VAR at end of input window)\ntrain_context_end=pd.Timestamp('2016-10-23 00:00:00')\n# create training samples for 4h: densities at times train_context_end+10min..+4h\ntrain_target_times=pd.date_range(train_context_end+pd.Timedelta(minutes=10), train_context_end+pd.Timedelta(hours=4), freq='10min')\ntrain_y=train_df.loc[train_target_times,'Orbit Mean Density (kg/m^3)'].values\n# projected features\n# Build context from 2016-10-22 08:00 to 2016-10-23 00:00 within train_df\ncontext_start=train_context_end-pd.Timedelta(hours=16)\ncontext=train_df.loc[context_start:train_context_end, feature_cols].dropna()\n# fit VAR\nZ=context.values[:-1]; W=context.values[1:]\nZ_aug=np.hstack([np.ones((Z.shape[0],1)),Z])\nB,_,_,_=np.linalg.lstsq(Z_aug,W,rcond=None)\nlast=context.values[-1]\nproj=[]; x=last\nforecast_steps=len(train_target_times)\nfor i in range(forecast_steps):\n    x_aug=np.hstack([1,x])\n    x=B.T.dot(x_aug)\n    proj.append(x)\nproj=np.array(proj)\n\nlinreg=LinearRegression().fit(proj, train_y)\n\n# Evaluation: density starts at 2016-10-29 00:00 from density dataset?\neval_context_end=pd.Timestamp('2016-10-29 00:00:00')\n# ensure in eval_df\nprint('eval_df range',eval_df.index.min(),eval_df.index.max())\n\neval_target_times=pd.date_range(eval_context_end+pd.Timedelta(minutes=10), eval_context_end+pd.Timedelta(hours=4), freq='10min')\n\neval_y=eval_df.loc[eval_target_times,'Orbit Mean Density (kg/m^3)'].values\n\ncontext2=eval_df.loc[eval_context_end-pd.Timedelta(hours=16):eval_context_end, feature_cols].dropna()\nZ=context2.values[:-1]; W=context2.values[1:]\nZ_aug=np.hstack([np.ones((Z.shape[0],1)),Z])\nB2,_,_,_=np.linalg.lstsq(Z_aug,W,rcond=None)\nlast=context2.values[-1]\nproj2=[]; x=last\nforecast_steps=len(eval_target_times)\nfor i in range(forecast_steps):\n    x_aug=np.hstack([1,x])\n    x=B2.T.dot(x_aug)\n    proj2.append(x)\nproj2=np.array(proj2)\n\npred=linreg.predict(proj2)\nrmse=float(np.sqrt(np.mean((pred-eval_y)**2)))\nprint(rmse)\n"})
