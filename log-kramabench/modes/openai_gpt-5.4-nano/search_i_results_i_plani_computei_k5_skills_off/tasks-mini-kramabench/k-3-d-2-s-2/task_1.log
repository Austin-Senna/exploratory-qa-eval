() if len(lo)>0 else float('nan')\n\n# Difference: higher EJ share rate minus lower EJ share rate\ndiff = hi_rate - lo_rate\n\n# Round to 2 decimals\nprint(round(hi_rate, 6), round(lo_rate, 6), round(diff, 2))\nprint('HI_n',len(hi),'LO_n',len(lo))\n", "dataset_id": "kramabench-environment-hard-7", "file_path": "files/water-body-testing-2023.csv"}) [toolUseId=call_hA6NJlGNXn7d995hZDBORoDd]
