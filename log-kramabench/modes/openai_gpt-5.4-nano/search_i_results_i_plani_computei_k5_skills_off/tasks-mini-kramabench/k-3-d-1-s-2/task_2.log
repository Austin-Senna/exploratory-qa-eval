pe=bool)\n\nchunk = 2000\nfor i in range(0, len(modern), chunk):\n    j = min(i+chunk, len(modern))\n    lat_chunk = m_lat[i:j][:, None]\n    lon_chunk = m_lon[i:j][:, None]\n    # abs differences\n    ok = (np.abs(lat_chunk - r_lat[None, :]) <= threshold) & (np.abs(lon_chunk - r_lon[None, :]) <= threshold)\n    matched_mask[i:j] = ok.any(axis=1)\n\ncount_matches = int(matched_mask.sum())\nprint(count_matches)\n"}) [toolUseId=call_NYU0skgiKWyAI1KmgVCddPyP]
