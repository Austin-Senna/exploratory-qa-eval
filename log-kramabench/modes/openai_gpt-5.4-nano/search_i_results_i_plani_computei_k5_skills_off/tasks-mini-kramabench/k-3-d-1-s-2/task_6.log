        return ''.join(txt)\n    v = cell.find('main:v', NS)\n    if v is None:\n        return ''\n    text = v.text or ''\n    if t == 's':\n        try:\n            return shared_strings[int(text)]\n        except Exception:\n            return text\n    return text\n\n\nwith zipfile.ZipFile(path) as zf:\n    shared_strings = parse_shared_strings(zf)\n    sheets = parse_workbook(zf)\n    found = False\n\n    for sheet_name, sheet_path in sheets:\n        if sheet_name.upper() == 'README':\n            continue\n        root = ET.fromstring(zf.read(sheet_path))\n        rows = root.findall('.//main:sheetData/main:row', NS)\n        if not rows:\n            continue\n\n        table = []\n        for row in rows:\n            row_map = {}\n            for c in row.findall('main:c', NS):\n                ref = c.attrib.get('r', '')\n                if not ref:\n                    continue\n                idx = col_to_idx(ref)\n                row_map[idx] = cell_value(c, shared_strings)\n            table.append(row_map)\n\n        if not table:\n            continue\n\n        max_col = max((max(r.keys()) if r else -1) for r in table)\n        if max_col < 0:\n            continue\n\n        matrix = []\n        for r in table:\n            matrix.append([r.get(i, '') for i in range(max_col + 1)])\n\n        header = [str(x).strip() for x in matrix[0]]\n        peptide_col = None\n        sample_col = None\n        for i, h in enumerate(header):\n            hl = h.lower()\n            if hl == 'peptide':\n                peptide_col = i\n            if 'sample' in hl and ('peptide' in hl or 'with' in hl or 'id' in hl):\n                sample_col = i\n        if peptide_col is None:\n            for i, h in enumerate(header):\n                if h.lower() == target.lower():\n                    peptide_col = i\n                    break\n\n        for row in matrix[1:]:\n            row_texts = [str(x) for x in row]\n            hit = False\n            if pep