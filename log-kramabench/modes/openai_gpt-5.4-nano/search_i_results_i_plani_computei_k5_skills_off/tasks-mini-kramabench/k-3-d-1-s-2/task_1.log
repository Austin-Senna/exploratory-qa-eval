'),\n    ('Greece','Salonika'),\n    ('Turkey','Byzantium'),\n    ('Turkey','Constantinople'),\n    ('Turkey','Bithynia'),\n    ('Turkey','Thrace'),\n    ('Turkey','Macedonia'),\n    ('Egypt','Aghlabids'),\n    ('Egypt','Sicily'),\n    ('Tunisia','Aghlabids'),\n    ('Algeria','Ibn-Hafsun'),\n    ('Morocco','Ibn-Hafsun'),\n    ('Arab','Muslims'),\n    ('Russians','Russia'),\n    ('Kievan Rus','Russia'),\n    ('Poland','Poland'),\n    ('Saxony','Saxony'),\n]\n\ndef attrib(actor):\n    a=actor\n    # clean brackets text\n    a=a.replace('[','').replace(']','')\n    # prioritize specific known modern regions\n    if 'England' in a and 'Danish Vikings' not in a: return 'England'\n    if 'Danish Vikings' in a: return 'Denmark'\n    if 'Norwegian Vikings' in a: return 'Norway'\n    if 'Brittany' in a or 'Alsace' in a or 'Lorraine' in a or 'France' in a: return 'France'\n    if 'Germany' in a: return 'Germany'\n    if 'Austria' in a: return 'Austria'\n    if 'Italy' in a or a.startswith('Italy'): return 'Italy'\n    if 'Netherlands' in a or 'lower Lorraine' in a: return 'Netherlands'\n    if 'Spain' in a: return 'Spain'\n    if 'Magyars' in a or 'Hungary' in a: return 'Hungary'\n    if 'Moravia' in a: return 'Czechia'\n    if 'Byzantium' in a or 'Constantinople' in a or 'Salonika' in a or 'Bithynia' in a or 'Thrace' in a or 'Macedonia' in a: return 'Turkey'\n    if 'Muslims' in a or 'Aghlabids' in a or 'Ibn-Hafsun' in a: return 'Algeria'\n    if 'Franks' in a: return 'France'\n    if 'Vikings' in a: \n        if 'England' in a: return 'England'\n    if 'Russia' in a: return 'Russia'\n    if 'Bulgaria' in a: return 'Bulgaria'\n    if 'Wessex' in a: return 'England'\n    if 'Essex' in a: return 'England'\n    if 'Saxony' in a or 'Thuringia' in a: return 'Germany'\n    if 'Germans' in a: return 'Germany'\n    if 'Norwegian' in a: return 'Norway'\n    if 'Danish' in a: return 'Denmark'\n    # fallback\n    return None\n\nf['C1']=f['Actor1'].apply(attrib)\nf['C2']=f['Actor2'].ap