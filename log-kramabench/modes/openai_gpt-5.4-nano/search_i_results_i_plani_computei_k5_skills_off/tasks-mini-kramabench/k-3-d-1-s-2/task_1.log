ent_end = None\n        for _, row in grp.iterrows():\n            s, e = int(row['start']), int(row['end'])\n            if current_start is None:\n                current_start, current_end = s, e\n            elif s <= current_end:\n                current_end = max(current_end, e)\n            else:\n                merged.append((row['actor_a'], row['actor_b'], current_start, current_end))\n                current_start, current_end = s, e\n        if current_start is not None:\n            last = grp.iloc[-1]\n            merged.append((last['actor_a'], last['actor_b'], current_start, current_end))\n    return pd.DataFrame(merged, columns=['actor_a', 'actor_b', 'start', 'end'])\n\n\ndef main():\n    conflict_path = find_file('conflict_brecke.csv')\n    countries_lower = load_countries()\n    conflict_data = pd.read_csv(conflict_path)\n\n    processed = []\n    for _, row in conflict_data.iterrows():\n        conflict = str(row.get('Conflict', '')).strip()\n        start = parse_year(row.get('StartYear'))\n        end = parse_year(row.get('EndYear'))\n        if start is None or end is None:\n            continue\n        if end < start:\n            start, end = end, start\n        if (end - start) < 1:\n            continue\n        if not overlaps_window(start, end, 800, 1400):\n            continue\n\n        actor_a_text, actor_b_text = split_conflict(conflict)\n        actor_a = actor_to_country(actor_a_text, countries_lower)\n        actor_b = actor_to_country(actor_b_text, countries_lower)\n        if actor_a is None or actor_b is None:\n            continue\n        actor_a, actor_b = sorted([actor_a, actor_b])\n        processed.append({\n            'Conflict': conflict,\n            'actor_a': actor_a,\n            'actor_b': actor_b,\n            'start': start,\n            'end': end,\n        })\n\n    if not processed:\n        print(0)\n        return\n\n    df = pd.DataFrame(processed)\n\n    by_conflict = (\n        df.groupby('Conflict', as