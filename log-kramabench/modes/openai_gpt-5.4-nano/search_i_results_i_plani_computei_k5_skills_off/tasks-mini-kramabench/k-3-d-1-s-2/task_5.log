urs=pd.date_range(start, end-dt.timedelta(hours=1), freq='H')\na_grid=a_hour.reindex(hours).interpolate(method='time')\nda=a_grid.diff()  # km per hour\n# Use times from May 1 01:00 onwards\n\nda_series=da.loc[hours[1:]]\n\n# Parse OMNI2 hourly AP\n# OMNI2.dat has fixed-width numeric. We'll parse by reading columns count from first line.\n# We'll infer datetime fields by locating first 3 ints and then hour.\n\nwith open(OMNI_PATH,'r') as f:\n    first=f.readline()\n    L=len(first.rstrip('\\n'))\n\n# Many omni2 hourly files have: Year(4), DOY(3), Hour(2), then ...; we detect by splitting spaces and count.\n# We'll use regex to capture leading year doy hour and take last 3-digit/float AP field near end: typically 'Ap' is at fixed column 60-63 etc.\n# Instead, compute candidate AP column by scanning for integer values 0-400 and picking column whose distribution matches known AP (0-400). We'll do by fixed-width splitting into 80 char chunks using whitespace.\n\n# We'll read May lines and then pick AP column among rightmost numeric fields by assuming AP is one of last few integers.\n\nomni=[]\nwith open(OMNI_PATH,'r') as f:\n    for ln in f:\n        ln=ln.rstrip('\\n')\n        if not ln.strip():\n            continue\n        # parse year doy hour using positions: attempt find first 3 ints in line\n        nums=re.findall(r\"\\d+\\.?\\d*\", ln)\n        if len(nums)<10:\n            continue\n        # assume first is year, second is doy, third is hour\n        year=int(nums[0]); doy=int(nums[1]); hour=int(nums[2])\n        t=dt.datetime(year,1,1)+dt.timedelta(days=doy-1, hours=hour)\n        if t<start or t>=end:\n            continue\n        # AP field often equals nums[?] but we don't know index. Let's assume AP is near middle? We'll take last 5 numbers and choose which correlates best with drag differences at lag 0..48 by brute force later.\n        omni.append((t, ln, nums))\n\n# Build AP series candidates from possible numeric positions within nums list.\n# For each candidate index among last 10 numbers, create series and compute best r2 across lags.\n\ncand_indices=list(range(max(0,len(omni[0][2])-10), len(omni[0][2])))\n\n# create hourly index\nhour_idx=pd.date_range(start, end-dt.timedelta(hours=1), freq='H')\n\nbest_overall=None\n\n# Precompute da array\nx_da=da_series.values\n\ndef best_lag_for_ap(ap_series):\n    # ap_series indexed hourly\n    ap_grid=ap_series.reindex(hours).interpolate()\n    # shift and compute r2\n    best_r2=-1; best_lag=None\n    for lag in range(0,49):\n        ap_l=ap_grid.shift(lag).loc[hours[1:]]\n        y=ap_l.values\n        mask=~np.isnan(y) & ~np.isnan(x_da)\n        if mask.sum()<10: continue\n        r=np.corrcoef(y[mask], x_da[mask])[0,1]\n        r2=r*r\n        if r2>best_r2:\n            best_r2=r2; best_lag=lag\n    return best_r2,best_lag\n\nfor idx in cand_indices:\n    # build ap series using that numeric position\n    data={}\n    for t,ln,nums in omni:\n        try:\n            val=float(nums[idx])\n        except:\n            continue\n        data[t]=val\n    ap_series=pd.Series(data)\n    # keep within hourly\n    ap_series=ap_series.groupby(level=0).mean()\n    r2,lag=best_lag_for_ap(ap_series)\n    if best_overall is None or r2>best_overall[0]:\n        best_overall=(r2,lag,idx)\n\nprint(best_overall)\n"}) [toolUseId=call_l7EKoZhZvCY0wXgdduDTPo1a]
