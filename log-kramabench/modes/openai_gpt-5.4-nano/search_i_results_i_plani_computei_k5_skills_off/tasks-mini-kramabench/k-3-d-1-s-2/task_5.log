on_rev_per_day * 2.0 * math.pi / 86400.0\n    mu = 398600.4418  # km^3/s^2\n    return (mu / (n * n)) ** (1.0 / 3.0)\n\n# Read TLE file allowing optional name lines\nwith open(path_tle, 'r') as f:\n    raw_lines = [ln.rstrip('\\n') for ln in f if ln.strip()]\n\nline1s = []\nline2s = []\ni = 0\nwhile i < len(raw_lines):\n    if raw_lines[i].startswith('1 ') and i + 1 < len(raw_lines) and raw_lines[i + 1].startswith('2 '):\n        line1s.append(raw_lines[i])\n        line2s.append(raw_lines[i + 1])\n        i += 2\n    elif i + 2 < len(raw_lines) and raw_lines[i + 1].startswith('1 ') and raw_lines[i + 2].startswith('2 '):\n        line1s.append(raw_lines[i + 1])\n        line2s.append(raw_lines[i + 2])\n        i += 3\n    else:\n        i += 1\n\nrows = []\nfor l1, l2 in zip(line1s, line2s):\n    epoch = parse_tle_epoch(l1)\n    a_km = semi_major_from_line2(l2)\n    rows.append((epoch, a_km))\n\ntle = pd.DataFrame(rows, columns=['epoch', 'semi_major_km']).sort_values('epoch').reset_index(drop=True)\n\n# Restrict to May 1-30 2024 inclusive of May 30, excluding May 31\nstart = pd.Timestamp('2024-05-01 00:00:00', tz='UTC')\nend = pd.Timestamp('2024-05-31 00:00:00', tz='UTC')\ntle = tle[(pd.to_datetime(tle['epoch'], utc=True) >= start) & (pd.to_datetime(tle['epoch'], utc=True) < end)].copy()\n\n# Compute semi-major axis change between consecutive TLE epochs within the filtered period\n# Then round epoch timestamps to nearest hour and average if collisions occur\n# This represents hourly semi-major axis change from TLE epochs rounded to nearest hour.\ntle['delta_a_km'] = tle['semi_major_km'].diff()\ntle = tle.dropna(subset=['delta_a_km']).copy()\ntle['time_hr'] = pd.to_datetime(tle['epoch'], utc=True).dt.round('h')\nsemi_major_change = tle.groupby('time_hr', as_index=True)['delta_a_km'].mean().sort_index()\n\n# Read OMNI2 hourly AP\nomni = pd.read_fwf(path_omni, widths=widths, header=None)\nomni.columns = cols\nomni['t'] = omni.apply(\n    lambda r: datetime(int(r['year'