ue\n        year=int(float(nums[0])); doy=int(float(nums[1])); hour=int(float(nums[2]))\n        t=dt.datetime(year,1,1)+dt.timedelta(days=doy-1, hours=hour)\n        if t<start or t>=end: continue\n        omni.append((t, nums))\n\n# candidate indices among last 12 tokens\nL=len(omni[0][1])\ncands=list(range(L-12, L))\n\nhour_idx=hours\nbest=(-1,None,None)\n\ndef score_for_ap_index(idx):\n    data={}\n    for t,nums in omni:\n        try:\n            v=float(nums[idx])\n        except:\n            continue\n        if v< -1e-6 or v>1000: # filter\n            continue\n        data[t]=v\n    if not data: return None\n    ap=pd.Series(data).groupby(level=0).mean().reindex(hour_idx).interpolate()\n    best_r2=-1; best_lag=None\n    for lag in range(0,49):\n        ap_l=ap.shift(lag).loc[hours[1:]]\n        y=ap_l.values\n        mask=~np.isnan(y) & ~np.isnan(a_vals)\n        if mask.sum()<20: continue\n        r=np.corrcoef(y[mask], a_vals[mask])[0,1]\n        r2=r*r\n        if r2>best_r2:\n            best_r2=r2; best_lag=lag\n    return best_r2,best_lag\n\nfor idx in cands:\n    res=score_for_ap_index(idx)\n    if res is None: continue\n    r2,lag=res\n    if r2>best[0]:\n        best=(r2,lag,idx)\n\nprint(best[1])\n"})
