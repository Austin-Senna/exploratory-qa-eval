)[:30])\n\n# Standardize column names\n# Find tumor type and excluded flag\ncols_lower = {c: str(c).lower() for c in df_clin.columns}\n\n# Determine included/excluded column\nincluded_col = None\nfor c, cl in cols_lower.items():\n    if 'excluded' in cl:\n        included_col = c\n        break\n# if not, look for 'include'\nif included_col is None:\n    for c, cl in cols_lower.items():\n        if 'include' in cl:\n            included_col = c\n            break\n\n# Determine histology column\nhist_col = None\nfor c, cl in cols_lower.items():\n    if 'hist' in cl and ('type' in cl or 'ology' in cl):\n        hist_col = c\n        break\nfor c, cl in cols_lower.items():\n    if 'histolog' in cl:\n        hist_col = c\n        break\nif hist_col is None:\n    for c, cl in cols_lower.items():\n        if 'tumor' in cl and ('type' in cl or 'subtype' in cl):\n            hist_col = c\n            break\n\n# Sometimes there is a column named 'TUMOR_TYPE' or 'ENDOMETRIOID/SEROUS'\nif hist_col is None:\n    for c, cl in cols_lower.items():\n        if 'endometrioid' in cl or 'serous' in cl:\n            hist_col = c\n            break\n\nprint('included_col:', included_col, 'hist_col:', hist_col)\n\n# Determine sample id column to join with proteomics columns\nid_col = None\nfor c, cl in cols_lower.items():\n    if cl in ['sample', 'sample_id', 'samples', 'patient', 'patient_id', 'sampleid', 'tumor_sample', 'specimen', 'specimen_id']:\n        id_col = c\n        break\n# fallback: look for 'TCGA' or 'Sample'\nif id_col is None:\n    for c, cl in cols_lower.items():\n        if 'sample' in cl and ('id' in cl or cl.endswith('sample')):\n            id_col = c\n            break\nif id_col is None:\n    for c, cl in cols_lower.items():\n        if 'tcga' in cl:\n            id_col = c\n            break\n\nprint('id_col:', id_col)\n\n# Filter clinical to included endometrioid/serous\nclin = df_clin.copy()\nif included_col is not None:\n    # keep rows not excluded: excluded==0/False/No\n    excl = clin[included_col]\n    if excl.dtype == 'bool':\n        clin = clin[~excl]\n    else:\n        # treat strings\n        excl_str = excl.astype(str).str.lower()\n        # keep where excluded indicates not excluded\n        mask = ~excl_str.isin(['1','true','t','yes','y','excluded','exclude'])\n        # but also allow 'no'\n        mask = mask & ~excl_str.eq('excluded')\n        clin = clin[mask]\n\n# hist filter\nif hist_col is not None:\n    t = clin[hist_col].astype(str).str.lower()\n    mask_hist = t.str.contains('endometr') | t.str.contains('serous')\n    clin = clin[mask_hist]\n\n# Determine sample ids in proteomics table columns: likely columns are sample IDs\n# Identify PLK1 and CHEK2-S163 rows in protein/phospho tables\n# These sheets often have first columns like 'Protein' and then sample abundances.\n\ndef find_abundance_row(df, target):\n    # search any column for containing target\n    for c in df.columns:\n        if str(c).lower() in ['protein','proteins','gene','symbol','phosphosite','site','modification']:\n            # check values\n            if df[c].astype(str).str.contains(target, case=False, na=False).any():\n                return df[df[c].astype(str).str.contains(target, case=False, na=False)]\n    # fallback: search first column\n    c0 = df.columns[0]\n    m = df[c0].astype(str).str.contains(target, case=False, na=False)\n    if m.any():\n        return df[m]\n    # fallback: search whole df values limited\n    m = df.astype(str).apply(lambda col: col.str.contains(target, case=False, na=False)).any(axis=1)\n    return df[m]\n\nplk_rows = find_abundance_row(df_global, 'PLK1')\nchek_rows = find_abundance_row(df_phosph, 'CHEK2-S163')\nprint('plk_rows shape', plk_rows.shape, 'chek_rows shape', chek_rows.shape)\n\n# pick first matching row if multiple\nplk_row = plk_rows.iloc[0]\nchek_row = chek_rows.iloc[0]\n\n# Determine sample columns in each proteomics df by excluding metadata columns\n# Assume sample columns are those with numeric values\nmeta_cols_global = [c for c in df_global.columns if plk_row[c] is not None and str(c).lower() in ['protein','gene','symbol','uniprot','description']]\n# simpler: take columns where value is not null and column name looks like sample id (contains '-' or starts with 'C')\n\ndef get_sample_values(series, df):\n    # return dict of sample->value for columns that look like sample IDs and are numeric\n    vals = {}\n    for c in df.columns:\n        v = series[c]\n        # numeric?\n        try:\n            fv = float(v)\n        except Exception:\n            continue\n        # ignore columns that are clearly metadata by name\n        cl = str(c).lower()\n        if any(k in cl for k in ['protein','gene','symbol','uniprot','phospho','site','mod','description','id']):\n            continue\n        vals[str(c)] = fv\n    return vals\n\nplk_vals = get_sample_values(plk_row, df_global)\nchek_vals = get_sample_values(chek_row, df_phosph)\n\n# Join with included clinical sample IDs\nsample_ids = set(clin[id_col].astype(str).tolist()) if id_col is not None else set(plk_vals.keys())\n\ncommon_samples = sorted(set(plk_vals.keys()) & set(chek_vals.keys()) & sample_ids)\n\nx=[]; y=[]\nfor s in common_samples:\n    xv = plk_vals.get(s, np.nan)\n    yv = chek_vals.get(s, np.nan)\n    if pd.notna(xv) and pd.notna(yv):\n        x.append(xv); y.append(yv)\n\nprint('n paired:', len(x), 'n common:', len(common_samples))\n\nrho, p = spearmanr(x, y)\nprint('spearman rho:', rho)\nprint('rounded:', round(rho,4))\n"}) [toolUseId=call_Qm2KIH9Py4JLDg1jUJjQOBi2]
