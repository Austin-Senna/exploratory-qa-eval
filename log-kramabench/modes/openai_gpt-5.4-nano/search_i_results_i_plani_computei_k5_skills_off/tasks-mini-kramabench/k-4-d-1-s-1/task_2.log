ise ValueError(f'Sheet not found: {target_sheet_name}')\n\n        if not sheet_target.startswith('xl/'):\n            sheet_target = 'xl/' + sheet_target\n\n        sheet_root = ET.fromstring(workbook.read(sheet_target))\n        table = []\n        for row in sheet_root.findall('.//m:sheetData/m:row', ns):\n            values = {}\n            for cell in row.findall('m:c', ns):\n                value_node = cell.find('m:v', ns)\n                value = '' if value_node is None else value_node.text\n                if cell.attrib.get('t') == 's' and value != '':\n                    value = shared[int(value)]\n                values[column_index(cell.attrib['r'])] = value\n            max_index = max(values) if values else -1\n            table.append([values.get(i, '') for i in range(max_index + 1)])\n\n    headers = table[0]\n    records = []\n    for row in table[1:]:\n        padded = row + [''] * (len(headers) - len(row))\n        records.append(dict(zip(headers, padded)))\n    return records\n\n\nrecords = load_sheet_by_name(path, 'UCEC_CPTAC3_meta_table_V2.1')\n\neligible = []\nfor row in records:\n    case_excluded = str(row.get('Case_excluded', '')).strip().lower()\n    if case_excluded in {'no', 'false', '0'}:\n        age_text = str(row.get('Age', '')).strip()\n        try:\n            age_num = float(age_text)\n        except ValueError:\n            continue\n        if age_num >= 70:\n            eligible.append(row)\n\ncounts = Counter()\nfor row in eligible:\n    stage = str(row.get('FIGO_stage', '')).strip()\n    if stage and stage.upper() != 'NA':\n        counts[stage] += 1\n\nprint('FIGO_stage counts for age>=70 eligible tumor samples:')\nfor stage, count in counts.most_common():\n    print(f'{stage}\\t{count}')\n\nmost_common_stage = counts.most_common(1)[0][0] if counts else 'None'\nprint('Most common stage:', most_common_stage)", "reason": "Replaced pandas/openpyxl Excel loading with direct .xlsx XML parsing using zipfile and ElementTree so