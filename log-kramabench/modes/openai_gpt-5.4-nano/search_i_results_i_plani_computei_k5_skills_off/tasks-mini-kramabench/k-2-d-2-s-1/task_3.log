xes.\n# We'll read again with header row and keep duplicates\nraw2=pd.read_csv(path, header=row_idx, dtype=str)\nraw2.columns=[str(c).strip().strip('\"') for c in raw2.columns]\n# Determine rainbow columns exact\nrain_col=[c for c in raw2.columns if c=='1-Day Rain' or c.startswith('1-Day Rain')][0]\n# Identify Pleasure Bay locations by counting Tag/Enterococcus occurrences: columns likely: Tag,Enterococcus,Tag,Enterococcus for Pleasure Bay @ Broadway and Flagpole\n# We'll take Enterococcus columns at positions following a 'Tag' column for Pleasure Bay @ Broadway and @ Flagpole; specifically the first two Enterococcus columns before Castle Island Playground.\nent_cols=[c for c in raw2.columns if c=='Enterococcus' or c.endswith('Enterococcus')]\n# If duplicates, pandas keeps duplicates; ent_cols will include all positions.\n# We'll locate all columns with exact label 'Enterococcus'\nent_indices=[i for i,c in enumerate(raw2.columns) if c=='Enterococcus']\n# If there are more than needed, infer first two belong to Pleasure Bay @ Broadway and @ Flagpole, third to Castle Island.\n# Assume ordering: Broadway Tag,Enterococcus ; Flagpole Tag,Enterococcus ; Castle Island Tag,Enterococcus\n# Therefore first two Enterococcus columns correspond to Pleasure Bay.\npleasure_ent_indices=ent_indices[:2]\n# build long dataframe with two pleasure locations\nout=[]\nfor idx in pleasure_ent_indices:\n    temp=raw2[['Date', rain_col, raw2.columns[idx]]].copy()\n    temp.columns=['Date', 'rain', 'enterococcus']\n    temp['enterococcus']=pd.to_numeric(temp['enterococcus'], errors='coerce')\n    out.append(temp)\nlong=pd.concat(out, ignore_index=True)\n# Filter failed: >104\nfailed=long[long['enterococcus']>104].copy()\nmean_failed=failed['rain'].astype(float).mean()\nprint(round(mean_failed,2))"}) [toolUseId=call_WqRmrxkexworb25hYHkUz2BS]
