unity' in c.lower() or 'comm' in c.lower()) and 'enterococcus' not in c.lower()), None)\nif comm_col is None:\n    # fallback: municipality column if present\n    comm_col=next((c for c in water.columns if 'municip' in c.lower() or 'neighborhood' in c.lower()), None)\n\nenter_col=next((c for c in water.columns if 'enterococcus' in c.lower()), None)\nrain_col=None\nfor c in water.columns:\n    cl=c.lower()\n    if 'rain' in cl and ('3' in cl or '72' in cl):\n        rain_col=c; break\nif rain_col is None:\n    # maybe 'R3' etc\n    rain_col=next((c for c in water.columns if 'past' in c.lower() and 'rain' in c.lower()), None)\n\n# normalize and filter\nwater['_beach_norm']=water[beach_col].astype(str).str.strip().str.lower()\nwater['_comm_norm']=water[comm_col].astype(str)\nsub=water[(water['_beach_norm'].isin(beaches)) & (water['_comm_norm'].isin(communities_90))].copy()\n\nsub[rain_col]=pd.to_numeric(sub[rain_col], errors='coerce')\n\ndef parse_enter(t):\n    if pd.isna(t):\n        return np.nan\n    s=str(t).strip()\n    if s=='' or s.lower()=='nan':\n        return np.nan\n    # handle leading '<' or '>'\n    m=re.match(r'^<\\s*([0-9]*\\.?[0-9]+)', s)\n    if m:\n        return float(m.group(1))/2\n    m=re.match(r'^>\\s*([0-9]*\\.?[0-9]+)', s)\n    if m:\n        return float(m.group(1))\n    # just number\n    m=re.search(r'([0-9]*\\.?[0-9]+)', s)\n    if m:\n        return float(m.group(1))\n    return np.nan\n\nsub['enter_parsed']=sub[enter_col].apply(parse_enter)\nsub=sub.dropna(subset=[rain_col,'enter_parsed'])\n\ncorr=sub[rain_col].corr(sub['enter_parsed'])\nprint('rows',len(sub))\nprint('corr',corr)\nprint('rounded',round(float(corr),3))\n", "intent": "Compute Pearson correlation between past 3-days rainfall and Enterococcus levels for Boston Harbor beaches in communities with >90% EJ; parse '< x' as x/2 and '> x' as x; output rounded to 3 decimals."}) [toolUseId=call_grk3TaiQRoEEKtFZ61OIfFRw]
