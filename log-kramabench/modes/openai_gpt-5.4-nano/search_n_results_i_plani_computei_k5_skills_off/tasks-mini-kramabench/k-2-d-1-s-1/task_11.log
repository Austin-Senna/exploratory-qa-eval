  if isinstance(row[0],str) and row[0].strip() in ['Military Rank','Military Status','Fraud, Identity Theft, and Other Reports by Military Consumers']:\n        break\n    # branch value in col0\n    branch = str(row[branch_col]).strip().strip('\"')\n    if branch=='':\n        continue\n    # Stop if we accidentally hit something like 'Of the ... total reports'\n    if branch.lower().startswith('of the'):\n        break\n    median_raw = str(row[median_col]).strip() if median_col is not None else ''\n    rows.append((branch, median_raw))\n\nbdf = pd.DataFrame(rows, columns=['Branch','MedianFraudLossRaw'])\n\n# Clean median values like \"$584\" or \"$1,300 \"\ndef clean_money(s):\n    if s is None: return np.nan\n    s=str(s)\n    s=s.replace('$','').replace(',','').strip()\n    if s=='': return np.nan\n    # handle trailing/leading non-digits\n    m=re.search(r'[-+]?\\d+(?:\\.\\d+)?', s)\n    return float(m.group()) if m else np.nan\n\nbdf['MedianFraudLoss']=bdf['MedianFraudLossRaw'].map(clean_money)\n# Keep only numeric\nbdf=bdf.dropna(subset=['MedianFraudLoss'])\nmax_row=bdf.loc[bdf['MedianFraudLoss'].idxmax()]\nprint(bdf)\nprint('MAX', max_row['Branch'], max_row['MedianFraudLoss'])\nmax_branch=max_row['Branch']\nmax_branch"})
