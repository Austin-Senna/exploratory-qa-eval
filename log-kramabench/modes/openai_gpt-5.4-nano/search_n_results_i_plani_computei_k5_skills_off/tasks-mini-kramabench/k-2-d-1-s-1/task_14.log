ype after coercion\nnum_candidates=[]\nfor c in cols:\n    s=pd.to_numeric(df[c], errors='coerce')\n    if s.notna().mean()>0.5 and s.mean()>0:\n        num_candidates.append(c)\n\nprint('num_candidates',num_candidates)\nnum_col=num_candidates[0]\n\n# identify category column for Web Reports (Fraud & Other)\n# assume there's a column that includes both 'Web' and 'Fraud'\ncat_col=None\nfor c in cols:\n    vals=df[c].astype(str).str.lower()\n    if vals.str.contains('web').any() and vals.str.contains('fraud').any():\n        cat_col=c\n        break\nprint('cat_col',cat_col)\n\n# filter\nmask=(df[year_col].isin([2022,2023,2024]))\n# contributor/agency filter: include rows where contributor mentions FTC or 'Federal Trade Commission'\n# if cat_col includes FTC, we'll rely only on cat_col. otherwise try contributor column.\ncontrib_col=None\nfor c in cols:\n    if df[c].astype(str).str.contains('ftc', case=False, na=False).any() or df[c].astype(str).str.contains('federal trade commission', case=False, na=False).any():\n        contrib_col=c\n        break\nprint('contrib_col',contrib_col)\n\nif contrib_col:\n    mask &= df[contrib_col].astype(str).str.contains('ftc', case=False, na=False) | df[contrib_col].astype(str).str.contains('federal trade commission', case=False, na=False)\n\nif cat_col:\n    mask &= df[cat_col].astype(str).str.contains('web', case=False, na=False)\n    mask &= (df[cat_col].astype(str).str.contains('fraud', case=False, na=False) & df[cat_col].astype(str).str.contains('other', case=False, na=False)) | df[cat_col].astype(str).str.contains('fraud & other', case=False, na=False)\nelse:\n    # try separate columns\n    web_col=web_col[0] if web_col else None\n    other_col=None\n    for c in fraud_other_col:\n        if 'other' in c.lower() or 'fraud' in c.lower():\n            other_col=c\n    if web_col:\n        mask &= df[web_col].astype(str).str.contains('web', case=False, na=False)\n\n# sum\nresult=pd.to_numeric(df.loc[mask, num_col], errors='coerce').sum()\nprint('sum',result)\n"}) [toolUseId=call_kHCyBodiWiCFprLay5uteNyZ]
