rved Ap 11 Mar\\s+([0-9]{3})\")\n# observed Ap 12 Mar is in 0313 report; but instead use 0312's \"Estimated Ap 12 Mar 023\" not observed.\n# Therefore read 0313\ns3_0313 = 's3://sana-kramabench/datagov/kramabench-astronomy-easy-1/files/geomag_forecast/0313geomag_forecast.txt'\ntext_0313 = read_s3_text(s3_0313)\nobs12 = extract_after_heading(text_0313, r\"Observed Ap 12 Mar\\s+([0-9]{3})\")\n\nobserved = [int(obs10), int(obs11), int(obs12)]\nforecast = preds\nerrors = [abs(f-o) for f,o in zip(forecast, observed)]\nmae = sum(errors)/3\nprint('forecast',forecast,'observed',observed,'errors',errors,'mae',mae)\nmae"}) [toolUseId=call_q9vkyVgfkqc9GalkQ4HRrDEe]
