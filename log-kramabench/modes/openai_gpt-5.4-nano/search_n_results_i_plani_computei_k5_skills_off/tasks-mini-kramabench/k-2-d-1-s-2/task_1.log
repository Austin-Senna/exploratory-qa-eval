_target = rid_to_target[rid]\n                break\n        if sheet_target is None:\n            raise ValueError(f'Sheet not found: {target_sheet_name}')\n\n        if not sheet_target.startswith('xl/'):\n            sheet_target = 'xl/' + sheet_target\n\n        sheet_root = ET.fromstring(z.read(sheet_target))\n        rows = []\n        max_cols = 0\n        sheet_data = sheet_root.find('a:sheetData', ns_main)\n        for row in sheet_data.findall('a:row', ns_main):\n            values = {}\n            for c in row.findall('a:c', ns_main):\n                ref = c.attrib.get('r', '')\n                col_letters = ''.join(ch for ch in ref if ch.isalpha())\n                col_idx = col_to_index(col_letters)\n                cell_type = c.attrib.get('t')\n                value = ''\n                if cell_type == 'inlineStr':\n                    node = c.find('a:is/a:t', ns_main)\n                    value = node.text if node is not None and node.text is not None else ''\n                else:\n                    v = c.find('a:v', ns_main)\n                    if v is not None and v.text is not None:\n                        raw = v.text\n                        if cell_type == 's':\n                            value = shared_strings[int(raw)]\n                        else:\n                            value = raw\n                values[col_idx] = value\n                max_cols = max(max_cols, col_idx + 1)\n            rows.append(values)\n\n        matrix = []\n        for values in rows:\n            matrix.append([values.get(i, '') for i in range(max_cols)])\n\n    header = [str(x).strip() for x in matrix[0]]\n    data = matrix[1:]\n    return pd.DataFrame(data, columns=header)\n\nmeta = read_xlsx_sheet_with_zip(meta_path, 'UCEC_CPTAC3_meta_table_V2.1')\n\nmeta['idx_norm'] = meta['idx'].astype(str).str.strip()\nmeta['Case_excluded_norm'] = meta['Case_excluded'].astype(str).str.strip().str.lower()\nmeta['Histologic_type_norm'] = meta['Histologic_type'].