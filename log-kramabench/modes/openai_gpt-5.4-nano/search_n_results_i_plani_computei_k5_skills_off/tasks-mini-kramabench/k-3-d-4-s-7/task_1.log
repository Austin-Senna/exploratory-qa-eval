 year per station\nsummer = {}\nfor name, df in stations.items():\n    s = df.set_index('Year')[rain_months].sum(axis=1)\n    summer[name] = s\n\nyears = [2007,2008,2009]\n\nfresh_stations = ['Boston','Chatham','Amherst','Ashburnham']\nmarine_stations = ['Boston','Chatham']\n\nrain_fresh = np.array([np.mean([summer[st].loc[y] for st in fresh_stations]) for y in years], dtype=float)\nrain_marine = np.array([np.mean([summer[st].loc[y] for st in marine_stations]) for y in years], dtype=float)\n\n# Load beach testing datasets for 2007-2009\np2007 = '/home/ec2-user/eval_eqa/exploratory-qa-eval/.sandbox_isolated/task_1676699_1778999676258/kramabench-environment-easy-6/files/water-body-testing-2007.csv'\np2008 = '/home/ec2-user/eval_eqa/exploratory-qa-eval/.sandbox_isolated/task_1676699_1778999676258/kramabench-environment-easy-2/files/water-body-testing-2008.csv'\np2009 = '/home/ec2-user/eval_eqa/exploratory-qa-eval/.sandbox_isolated/task_1676699_1778999676258/kramabench-environment-easy-6/files/water-body-testing-2009.csv'\n\ndef load_beach(path):\n    df = pd.read_csv(path)\n    df['Year'] = pd.to_numeric(df['Year'])\n    # violation column: 'yes'/'no'\n    df['Violation'] = df['Violation'].astype(str)\n    return df\n\nbeach = pd.concat([load_beach(p2007), load_beach(p2008), load_beach(p2009)], ignore_index=True)\n\n# Determine exceedance rate per year for each beach type as proportion of rows with Violation=='yes'\n# Use all beaches of that type (marine/fresh) as 'beach-water exceedance rate'\nbeach['Beach Type Description'] = beach['Beach Type Description'].astype(str)\n\nexceed = {}\nfor btype in ['Freshwater','Marine']:\n    sub = beach[beach['Beach Type Description']==btype]\n    rate = sub.groupby('Year').apply(lambda g: (g['Violation'].str.lower()=='yes').mean())\n    # ensure years exist\n    exceed[btype] = np.array([rate.loc[y] if y in rate.index else np.nan for y in years], dtype=float)\n\n# Correlations\nfrom scipy.stats import pearsonr\n\ncorr_fresh = pear