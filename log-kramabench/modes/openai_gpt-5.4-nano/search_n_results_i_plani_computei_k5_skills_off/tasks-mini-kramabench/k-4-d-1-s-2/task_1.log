        if str(c).lower()=='year':\n            year_col=c\n            break\nprint('year_col', year_col)\n\nsample_year=-4460\nclim_df['__year']=pd.to_numeric(clim_df[year_col], errors='coerce')\nclim_df['__al']=pd.to_numeric(clim_df[al_col], errors='coerce')\nclim_df=clim_df.dropna(subset=['__year','__al'])\n\n# closest year(s)\ndelta=(clim_df['__year']-sample_year).abs()\nmin_delta=delta.min()\nclosest_years=sorted(clim_df.loc[delta==min_delta,'__year'].unique())\nprint('closest_years', closest_years, 'min_delta', float(min_delta))\n\nmax_al=clim_df.loc[clim_df['__year'].isin(closest_years),'__al'].max()\nprint('max_al', max_al)\nprint('rounded', round(float(max_al),4))\n"}) [toolUseId=call_ZIKFv3SgjpkkiKkzHDbMgP6W]
