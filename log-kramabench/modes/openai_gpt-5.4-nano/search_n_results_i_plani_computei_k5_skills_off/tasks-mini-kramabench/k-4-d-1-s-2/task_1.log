n c), None)\n    if tax_col is None:\n        tax_col = next((df.columns[i] for i,c in enumerate(cols) if 'human' in c), None)\n    # calendar year column\n    cal_col = None\n    for key in ['calendar','cal','year','yr']:\n        for i,c in enumerate(cols):\n            if key in c and ('bp' not in c):\n                cal_col = df.columns[i]\n                break\n        if cal_col is not None:\n            break\n    # also maybe 'climate_year'?\n    if cal_col is None:\n        for i,c in enumerate(cols):\n            if 'calendar year' in c:\n                cal_col=df.columns[i]\n                break\n    # location is Maltese; ensure includes Malta\n    # choose by country/location column containing 'Malta' or 'Malt'\n    loc_col=None\n    for i,c in enumerate(cols):\n        if 'country' in c or 'location' in c or 'site' in c:\n            loc_col=df.columns[i]\n            break\n    \n    # prepare subset\n    sub=df.copy()\n    # normalize\n    def contains_neolithic(x):\n        return isinstance(x,str) and 'neolith' in x.lower()\n    \n    mask_neolith=None\n    if period_col is not None:\n        mask_neolith = sub[period_col].apply(contains_neolithic)\n    else:\n        mask_neolith = np.array([False]*len(sub))\n    if tax_col is not None:\n        mask_hs = sub[tax_col].astype(str).str.lower().str.contains('homo sapiens')\n    else:\n        mask_hs = np.array([False]*len(sub))\n\n    # keep Malta rows\n    if loc_col is not None:\n        mask_malta = sub[loc_col].astype(str).str.lower().str.contains('malt')\n    else:\n        mask_malta = np.array([True]*len(sub))\n\n    subf=sub[mask_neolith & mask_hs & mask_malta].copy()\n    if len(subf)==0:\n        continue\n    # need lat and cal\n    subf['__lat']=pd.to_numeric(subf[lat_col], errors='coerce')\n    if cal_col is not None:\n        subf['__cal']=pd.to_numeric(subf[cal_col], errors='coerce')\n    else:\n        continue\n    subf=subf.dropna(subset=['__lat','__cal'])\n    if len(subf)==0:\n        continue\n    # northernmost: max lat\n    maxlat=subf['__lat'].max()\n    candidates=subf[subf['__lat']==maxlat]\n    # tie-break by later year (larger calendar year)\n    sel=candidates.sort_values('__cal', ascending=False).iloc[0]\n    year=int(round(float(sel['__cal'])))\n    key=(maxlat, float(sel['__cal']))\n    if best is None or key>best:\n        best=key\n        best_row=(name, float(sel['__lat']), float(sel['__cal']))\n\nprint('best', best_row)\n"}) [toolUseId=call_T9PciOR0s2F6FuRv4rbTBDJ6]
