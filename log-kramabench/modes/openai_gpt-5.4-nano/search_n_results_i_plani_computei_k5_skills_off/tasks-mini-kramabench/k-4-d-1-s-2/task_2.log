referred time col', preferred)\n\n# filter Malta\nif region_col is not None:\n    malta_mask=rad[region_col].astype(str).str.contains('Malta', case=False, na=False)\n    malta=rad[malta_mask]\nelse:\n    # fall back: any column containing Malta values\n    malta=rad[rad.apply(lambda r: any('malta' in str(v).lower() for v in r.values), axis=1)]\n\nprint('malta rows', len(malta))\nprint(malta[[preferred]].describe())\n\nfirst_year=float(np.nanmin(malta[preferred].values.astype(float)))\nlast_year=float(np.nanmax(malta[preferred].values.astype(float)))\nprint('first_year', first_year,'last_year', last_year)\n\n# Now climate measurements potassium\nclim_sheet=clim_xls.sheet_names[0]\nclim=pd.read_excel(clim_path, sheet_name=clim_sheet)\nprint('clim columns', clim.columns)\nprint(clim.head(3))\n\n# find time column\nclim_time_cols=[c for c in clim.columns if 'time' in str(c).lower() or 'year' in str(c).lower() or 'Study' in str(c)]\nprint('clim_time_cols', clim_time_cols)\nclim_time=clim_time_cols[0] if clim_time_cols else clim.columns[0]\n\n# potassium col\npot_cols=[c for c in clim.columns if 'pot' in str(c).lower()]\nprint('pot cols', pot_cols)\npot=pot_cols[0]\n\n# subset between first and last\nclim2=clim[[clim_time,pot]].dropna()\nclim2[clim_time]=clim2[clim_time].astype(float)\nclim2[pot]=clim2[pot].astype(float)\n\n# sort by time\nclim2=clim2.sort_values(clim_time)\n\n# build interpolation for potassium at every source year across [first,last]\n# Assume source years are all integer years? We'll use all unique years from Malta samples\nsource_years=sorted(set(malta[preferred].dropna().astype(float).values))\n# But question says average from first and last time study recorded people in Maltese area; interpolate between samples: so average across continuous range? Likely discrete climate years between first and last inclusive based on climate time grid.\n# The gold plan: interpolate for every source year across span.\n# Here use climate time points within [first,last] and interpolate potassium at those points.\nmask=(clim2[clim_time]>=min(first_year,last_year)) & (clim2[clim_time]<=max(first_year,last_year))\nspan_times=clim2.loc[mask,clim_time].values\n\nx=clim2[clim_time].values\ny=clim2[pot].values\n# linear interpolation\ninterp=np.interp(span_times, x, y)\n\navg=float(np.mean(interp))\nprint('avg',avg)\n\nprint(round(avg,4))\n"}) [toolUseId=call_KFoOdeiEdNxXssBvYZJECadV]
