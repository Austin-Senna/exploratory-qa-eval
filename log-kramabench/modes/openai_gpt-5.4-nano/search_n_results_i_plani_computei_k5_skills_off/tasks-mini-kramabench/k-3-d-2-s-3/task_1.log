te column name\ncols=duckdb.sql(\"PRAGMA table_info('wildfire')\").df()['name'].tolist()\nstate_col=[c for c in cols if c.lower()=='state' or c.lower().strip()=='state'][0]\n\n# classify party from percent_democrat > 50\nduckdb.sql('''CREATE OR REPLACE TEMP VIEW votes_party AS\n               SELECT \"usa_state_code\" AS state_code,\n                      CASE WHEN percent_democrat > 50 THEN 'Democratic' ELSE 'Republican' END AS party\n               FROM votes;''')\n\nres=duckdb.sql(f\"\"\"SELECT party, COUNT(*) AS fires\n                   FROM wildfire w\n                   JOIN votes_party v ON upper(w.{state_col})=v.state_code\n                   GROUP BY party\n                   ORDER BY fires DESC;\"\"\").df()\n\nprint(res)\n# output which party larger\nlarger=res.iloc[0]['party']\nprint('LARGER', larger)\n\""})
