on tag column values\n        # tag could be '<' or '>' or ''\n        x=val\n        ent_num = x.copy()\n        ent_num = ent_num.astype(float)\n        # if tag startswith '<' then x/2\n        ent_num = np.where(tag.str.contains('<'), x/2, ent_num)\n        ent_num = np.where(tag.str.contains('>'), x, ent_num)\n        # if tag empty, assume exact x\n        mask = rain3.notna() & pd.Series(ent_num).notna()\n        rr = rain3[mask].astype(float)\n        ee = pd.Series(ent_num)[mask].astype(float)\n        if len(rr)>1:\n            rows.append(pd.DataFrame({'rain3':rr.values,'enterococcus':ee.values}))\n\nif not rows:\n    raise SystemExit('No data matched')\nall_df = pd.concat(rows, ignore_index=True)\ncor = all_df['rain3'].corr(all_df['enterococcus'], method='pearson')\nprint(round(cor,3))\n"})
