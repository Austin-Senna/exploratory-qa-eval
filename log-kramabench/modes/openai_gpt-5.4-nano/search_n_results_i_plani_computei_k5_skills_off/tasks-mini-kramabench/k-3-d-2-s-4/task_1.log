der_idx is None:\n            continue\n        df2 = pd.read_csv(path, skiprows=header_idx)\n        # first column name might be 'Date'\n        # Extract beach name from original file first non-empty cell\n        beach_name = None\n        for i in range(0,header_idx):\n            v = df.iloc[i,0]\n            if isinstance(v,str) and v.strip():\n                beach_name = v.split(',')[0].strip().strip('\"')\n                break\n        # Extract community from first_cell after comma\n        beach_community=None\n        # try parse first non-empty in column0\n        for i in range(0,header_idx):\n            v = df.iloc[i,0]\n            if isinstance(v,str) and ',' in v:\n                beach_community = v.split(',')[1].strip().strip('\"')\n                break\n        if beach_name not in harbor_set:\n            continue\n        if beach_community not in ej_comms:\n            continue\n        # Parse date\n        df2.columns = [c.strip() for c in df2.columns]\n        # Identify 3-Day Rain column exact\n        rain3_col = None\n        for c in df2.columns:\n            if '3-Day Rain' in c:\n                rain3_col = c\n                break\n        # Enterococcus 3-day tag/value pair likely last pair\n        # columns are: Date,1-Day Rain,2-Day Rain,3-Day Rain,Tag,Enterococcus,Tag,Enterococcus,Tag,Enterococcus ...\n        # We want the Enterococcus corresponding to 3-day tag/value: that's the last Tag/Enterococcus pair.\n        # Find indices of columns named 'Tag' and 'Enterococcus'\n        cols = list(df2.columns)\n        # take tag/value for third segment: last Enterococcus column and associated Tag column before it\n        ent_cols = [i for i,c in enumerate(cols) if 'Enterococcus'==c or 'Enterococcus' in c]\n        tag_cols = [i for i,c in enumerate(cols) if c=='Tag' or 'Tag'==c]\n        # in preview, there are 3 Tag columns and 3 Enterococcus columns\n        ent3_idx = ent_cols[-1]  # last Enterococcus\n        tag3_idx = ent3_idx-1  # preceding Tag\n        rain3 = pd.to_numeric(df2[rain3_col], errors='coerce')\n        tag = df2[cols[tag3_idx]].astype(str).str.strip()\n        ent_raw = df2[cols[ent3_idx]]\n        ent_num = pd.to_numeric(ent_raw, errors='coerce')\n        # apply rules\n        est = ent_num.copy()\n        # where tag is '<x' pattern: tag column contains '<' or '>' or ''\n        est = np.where(tag=='<', ent_num/2, est)\n        est = np.where(tag=='>', ent_num, est)\n        # if empty or nan keep ent_num\n        out = pd.DataFrame({\n            'Date': pd.to_datetime(df2['Date'].astype(str).str.replace('\"',''), errors='coerce'),\n            'rain3': rain3,\n            'enterococcus': est\n        })\n        frames.append(out)\n\nall_df = pd.concat(frames, ignore_index=True)\nall_df = all_df.dropna(subset=['Date','rain3','enterococcus'])\nall_df = all_df[all_df['Date'].dt.year==2023]\n\ncorr = all_df['rain3'].corr(all_df['enterococcus'], method='pearson')\nprint(round(corr,3))\nprint(len(all_df))\n", "dataset_id": "kramabench-environment-hard-12", "file_path": "files/constitution_beach_datasheet.csv"}) [toolUseId=call_7rIdQtezdJeyh5mQvwlHg7mp]
