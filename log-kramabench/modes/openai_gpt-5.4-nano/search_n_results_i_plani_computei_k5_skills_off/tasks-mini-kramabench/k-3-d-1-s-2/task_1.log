n':'United Kingdom','Scotland':'United Kingdom','Wales':'United Kingdom',\n    'Italy':'Italy','Netherlands':'Netherlands','Spain':'Spain','Russia':'Russia','France':'France',\n    'Germany':'Germany','Magyars':'Hungary','Hungary':'Hungary','Moravia':'Czechia','Saxony':'Germany',\n    'Bavaria':'Germany','Alsace':'France','Thuringia':'Germany','Franks':'France',\n    'Danish':'Denmark','Denmark':'Denmark','Muslims':'N/A','Byzantium':'Greece','Greece':'Greece',\n    'Aghlabids':'Tunisia','Aghlabid':'Tunisia','Ibn-Hafsun':'Spain','Caliphate':'N/A'\n}\n\ndef map_actor(x):\n    x=x.strip()\n    # remove trailing/leading brackets\n    x=re.sub(r'\\[|\\]','',x)\n    for k,v in keyword_map.items():\n        if x.startswith(k) or k in x:\n            return v\n    # if actor is \"Muslims\" or \"Muslims-Byzantium\" second side will include Byzantium so ok\n    return x  # fallback to actor as country\n\n# Create pairs and intervals per original conflict label unique? question: count conflicts between two actors lasts >=1 year.\n# We'll treat each row as a conflict occurrence between two actors. Merge overlapping intervals for same attributed pair.\n\ngroups={}\nfor label,a,b,ss,ee in rows:\n    ca,cb=map_actor(a), map_actor(b)\n    key=tuple(sorted((ca,cb)))\n    groups.setdefault(key,[]).append((ss,ee,label))\n\n# merge intervals per key, count distinct merged conflicts\nmerged_count=0\nfor key,intervals in groups.items():\n    intervals_sorted=sorted(intervals,key=lambda t:t[0])\n    cur_s,cur_e=intervals_sorted[0][0],intervals_sorted[0][1]\n    merged_count_key=0\n    merged_segments=[]\n    for s,e,_ in intervals_sorted[1:]:\n        if s<=cur_e: # overlap/contiguous\n            cur_e=max(cur_e,e)\n        else:\n            merged_segments.append((cur_s,cur_e))\n            merged_count_key+=1\n            cur_s,cur_e=s,e\n    merged_segments.append((cur_s,cur_e))\n    merged_count_key+=1\n    merged_count+=merged_count_key\n\nmerged_count, len(rows), len(groups)\n"}) 