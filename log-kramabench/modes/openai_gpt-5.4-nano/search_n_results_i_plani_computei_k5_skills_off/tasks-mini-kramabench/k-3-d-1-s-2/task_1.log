or(a),map_actor(b)\n    key=tuple(sorted((ca,cb)))\n    ss=max(s,win_start); ee=min(e,win_end)\n    intervals_by_pair.setdefault(key,[]).append((ss,ee))\n\nmerged_total=0\nfor key,intervals in intervals_by_pair.items():\n    intervals=sorted(intervals)\n    cur_s,cur_e=intervals[0]\n    count=1\n    for s,e in intervals[1:]:\n        if s<=cur_e:\n            cur_e=max(cur_e,e)\n        else:\n            count+=1\n            cur_s,cur_e=s,e\n    merged_total+=count\n\nprint('merged_total',merged_total)\nprint('pairs',len(intervals_by_pair))\n"}) [toolUseId=call_HV2qgT0plzAJjW9dJRDi9Fx4]
