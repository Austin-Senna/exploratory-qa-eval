std\nrecords=[]\nfor c in geo_cols:\n    vals = total[c]\n    mean = vals.mean()\n    std = vals.std(ddof=0)\n    if std==0 or np.isnan(std):\n        continue\n    z = (vals-mean)/std\n    idx = int(z.abs().idxmax())\n    maxz = z.iloc[idx]\n    year = int(total['Year'].iloc[idx])\n    records.append((c, year, float(maxz), float(z.iloc[idx])))\n\n# find overall max abs z\nbest = max(records, key=lambda x: abs(x[2]))\ngeo, year, maxabsz, _ = best\nprint(geo)\nprint(year)\nprint(maxabsz)\n"}) [toolUseId=call_y7iaEsYvw8lVgIbR2legT8Rn]
