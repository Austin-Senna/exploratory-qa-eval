 standard: at positions 52-63.\n        # We'll robustly split and take the 8th token.\n        try:\n            tokens = line2.split()\n            # token 0 is '2'; token 7 typically mean motion\n            n_rev_per_day = float(tokens[7])\n        except Exception:\n            n_rev_per_day = float(line2[52:63].strip())\n\n    # epoch\n    epoch = None\n    for cand in ['epoch','Epoch','tle_epoch','TLE Epoch','datetime','Epoch (UTC)']:\n        if cand in row and pd.notna(row[cand]):\n            epoch = row[cand]\n            break\n    if epoch is None:\n        # parse from tle_line1 epoch field\n        line1 = None\n        for cand in ['tle_line1','line1','TLE_LINE1','TLE Line1','TLE_Line1','line_1']:\n            if cand in row and pd.notna(row[cand]):\n                line1 = str(row[cand])\n                break\n        if line1 is None:\n            raise ValueError('No epoch field or line1 found')\n        # epoch YYDDD.DDDDD in columns 18-32 (1-indexed)\n        epoch_field = line1[18:32].strip()\n        yy = int(epoch_field[0:2])\n        doy = float(epoch_field[2:])\n        year = 2000+yy if yy < 57 else 1900+yy\n        # convert day-of-year to date\n        jan1 = datetime(year,1,1,tzinfo=timezone.utc)\n        epoch = jan1 + pd.to_timedelta(doy-1, unit='D')\n\n    if not isinstance(epoch, pd.Timestamp):\n        epoch = pd.to_datetime(epoch, utc=True)\n    else:\n        epoch = epoch.tz_convert('UTC') if epoch.tzinfo else epoch.tz_localize('UTC')\n\n    return epoch.to_pydatetime(), n_rev_per_day\n\n# Kepler semi-major axis from mean motion\n# n_rad_s = n_rev_per_day * 2pi / 86400\n\ndef a_from_n(n_rev_per_day):\n    n_rad_s = n_rev_per_day * 2*np.pi / 86400.0\n    a = (mu**(1/3) / (n_rad_s**(2/3)))\n    return a  # km\n\n# Filter and compute rate by consecutive records (sorted by epoch)\n\ndef avg_rate(df, start_date, end_date):\n    records=[]\n    for _, row in df.iterrows():\n        try:\n            epoch, n = parse_tle_from_row(row)\n        except Exception:\n            continue\n        if epoch >= start_date and epoch <= end_date:\n            a = a_from_n(n)\n            records.append((epoch, a))\n    if len(records) < 2:\n        return np.nan\n    records.sort(key=lambda x: x[0])\n    rates=[]\n    for (t1,a1),(t2,a2) in zip(records[:-1], records[1:]):\n        dt_days = (t2 - t1).total_seconds()/86400.0\n        if dt_days <= 0: \n            continue\n        rates.append((a2-a1)/dt_days)\n    # average across endpoint pairs\n    return float(np.mean(rates)) if rates else np.nan\n\nquiet_rate = avg_rate(quiet,\n                        datetime(2024,5,1,tzinfo=timezone.utc),\n                        datetime(2024,5,4,23,59,59,tzinfo=timezone.utc))\n\nstorm_rate = avg_rate(storm,\n                      datetime(2024,5,10,tzinfo=timezone.utc),\n                      datetime(2024,5,13,23,59,59,tzinfo=timezone.utc))\n\nprint('quiet_avg_rate_km_day', quiet_rate)\nprint('storm_avg_rate_km_day', storm_rate)\n\n# Round maybe to 6 decimals? but request doesn't specify; we'll round to 6.\nquiet_r = None if np.isnan(quiet_rate) else round(quiet_rate,6)\nstorm_r = None if np.isnan(storm_rate) else round(storm_rate,6)\nprint('quiet_rounded', quiet_r)\nprint('storm_rounded', storm_r)\n"}) [toolUseId=call_0CdKIh2xty3n0LDXaTK94tqo]
