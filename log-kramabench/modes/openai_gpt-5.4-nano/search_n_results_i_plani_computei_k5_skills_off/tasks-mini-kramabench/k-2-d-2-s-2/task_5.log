ar specific columns\nif 'month' in cols_lower and 'year' in cols_lower:\n    month_col = cols_lower['month']\n    year_col = cols_lower['year']\n    df['year'] = df[year_col].astype(int)\n    # annual count from monthly observations: sum of fires column per year\n    # find fires column\n    fire_cands=[c for c in df.columns if 'fire' in c.lower() or 'fires' in c.lower() or 'count' in c.lower()]\n    # choose best numeric column excluding year/month/date\n    fire_col=None\n    for c in fire_cands:\n        if pd.api.types.is_numeric_dtype(df[c]):\n            fire_col=c; break\n    if fire_col is None:\n        # fallback: first numeric non-year/month\n        num_cols=[c for c in df.columns if pd.api.types.is_numeric_dtype(df[c])]\n        num_cols=[c for c in num_cols if c not in [month_col,year_col]]\n        fire_col=num_cols[0]\n    annual = df.groupby('year')[fire_col].sum().reset_index(name='noaa_fires')\nelse:\n    # parse a date column\n    date_col=None\n    for c in df.columns:\n        lc=c.lower()\n        if 'date' in lc or (('month' in lc or 'time' in lc) and 'year' not in lc):\n            date_col=c\n            break\n    if date_col is None:\n        # try any column that looks like YYYY-MM\n        for c in df.columns:\n            if df[c].astype(str).str.match(r'\\d{4}').mean()>0.5:\n                date_col=c; break\n    if date_col is None:\n        raise RuntimeError('Could not infer date column for NOAA.')\n    df[date_col]=pd.to_datetime(df[date_col], errors='coerce')\n    df=df.dropna(subset=[date_col])\n    df['year']=df[date_col].dt.year\n    # fires/count column\n    fire_cands=[c for c in df.columns if 'fire' in c.lower() or 'fires' in c.lower() or 'count' in c.lower()]\n    fire_col=None\n    for c in fire_cands:\n        if pd.api.types.is_numeric_dtype(df[c]):\n            fire_col=c; break\n    if fire_col is None:\n        num_cols=[c for c in df.columns if pd.api.types.is_numeric_dtype(df[c])]\n        num_cols=[c for c in num_cols if c!=date_col and c!='year']\n        fire_col=num_cols[0]\n    annual = df.groupby('year')[fire_col].sum().reset_index(name='noaa_fires')\n\nannual = annual[annual['year']>=2000].sort_values('year')\nprint(annual.head())\nprint('years', len(annual))\nannual.to_json('/mnt/data/noaa_annual.json', orient='records')\n"}) [toolUseId=call_FjkmEj2A4qq2xTPlDHGexutx]
