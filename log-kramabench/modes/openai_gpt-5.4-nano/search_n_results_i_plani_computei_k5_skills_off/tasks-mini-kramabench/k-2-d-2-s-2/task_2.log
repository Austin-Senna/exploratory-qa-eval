en(fr_count_col)==0:\n    # maybe combined column\n    fr_count_col = [c for c in fr_df.columns if 'reports' in c.lower() or 'total' in c.lower()][0:1]\nfr_count_col = fr_count_col[0]\n\npop_col_fr = [c for c in fr_df.columns if 'population' in c.lower()][0]\n\n# select needed\nid_sel = id_df[[state_col_id, id_count_col, pop_col_id]].copy()\nid_sel.columns = ['state','id_reports','population']\nfr_sel = fr_df[[state_col_fr, fr_count_col, pop_col_fr]].copy()\nfr_sel.columns = ['state','fraud_other_reports','population_fr']\n\n# join\njoined = id_sel.merge(fr_sel, on='state', how='inner')\n\n# use population from identity theft table\njoined['total_reports'] = joined['id_reports'] + joined['fraud_other_reports']\njoined['density_per_100k'] = joined['total_reports'] / joined['population'] * 100000\n\nmx = joined.loc[joined['density_per_100k'].idxmax()]\nprint(mx['state'])\nprint(mx['density_per_100k'])\nprint(len(joined))\n"}) [toolUseId=call_UsAKJZpITsZgJQ9UDjsLkkHj]
