 parse right.\n    # Let's re-read with first two header lines skipped until the real header row containing 'Date'\n    # Detect by searching for 'Date' in first column.\n    raw=pd.read_csv(p, header=None)\n    # find row index where any cell equals 'Date'\n    idx=None\n    for i,row in raw.iterrows():\n        if any(str(cell).strip().strip('\"')=='Date' for cell in row.values):\n            idx=i\n            break\n    raw2=pd.read_csv(p, skiprows=idx)\n    raw2.columns=[str(c).strip().strip('\"') for c in raw2.columns]\n    # rename key cols\n    col_enter=None\n    for c in raw2.columns:\n        if 'Enterococcus' in c:\n            col_enter=c\n    col_rain=None\n    for c in raw2.columns:\n        if c=='1-Day Rain' or '1-Day Rain' in c:\n            col_rain=c\n    if col_enter is None or col_rain is None:\n        raise ValueError((p,raw2.columns))\n    dff=raw2[[col_rain,col_enter]].copy()\n    dff[col_enter]=dff[col_enter].apply(to_num)\n    dff[col_rain]=dff[col_rain].apply(to_num)\n    dff=dff.dropna(subset=[col_enter,col_rain], how='any')\n    total_rows += len(dff)\n    failed = dff[col_enter] > 104\n    rain = dff[col_rain] > 0\n    failed_total += int(failed.sum())\n    failed_rain += int((failed & rain).sum())\n\npercent = failed_rain/failed_total*100 if failed_total else 0\nprint('failed_total',failed_total)\nprint('failed_rain',failed_rain)\nprint('percent',round(percent,2))\n"}) [toolUseId=call_VMtWS8683atWlRzj0Nl1cjU3]
