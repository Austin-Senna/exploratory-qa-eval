_name == 'Tenean Beach':\n        return location == 'middle' or 'tenean' in location\n    if beach_name == 'Wollaston Beach':\n        return location in ['channing street', 'milton road', 'rice road', 'sachem street'] or 'wollaston' in location\n    if beach_name == 'Malibu Beach':\n        return 'malibu' in location\n    return beach_name.replace(' Beach', '').lower() in location\n\n\ndef prepare_beach_datasheet(path):\n    df = pd.read_csv(path, skiprows=1, header=[0, 1], dtype=str)\n    cols = df.columns.to_frame(index=False)\n    cols.iloc[:, 0] = cols.iloc[:, 0].replace(r'^Unnamed.*', pd.NA, regex=True).ffill()\n    flat_cols = []\n    for a, b in cols.itertuples(index=False, name=None):\n        parts = []\n        for part in (a, b):\n            if pd.isna(part):\n                continue\n            text = str(part).strip()\n            if text and text.lower() != 'nan':\n                parts.append(text)\n        flat_cols.append('_'.join(parts) if parts else 'Unnamed')\n    df.columns = flat_cols\n\n    id_cols = [c for c in df.columns if c in ['Date', '1-Day Rain', '2-Day Rain', '3-Day Rain']]\n    value_cols = [c for c in df.columns if c not in id_cols]\n    long_df = df.melt(id_vars=id_cols, value_vars=value_cols, var_name='Variable', value_name='Value')\n    long_df['Location'] = long_df['Variable'].str.rsplit('_', n=1).str[0]\n    long_df['Measure'] = long_df['Variable'].str.rsplit('_', n=1).str[1]\n    tidy = long_df.pivot_table(index=id_cols + ['Location'], columns='Measure', values='Value', aggfunc='first').reset_index()\n    tidy.columns.name = None\n    tidy['Enterococcus_num'] = tidy.apply(lambda r: parse_value(r.get('Tag'), r.get('Enterococcus')), axis=1)\n    tidy['Year'] = pd.to_datetime(tidy['Date'], errors='coerce').dt.year\n    return tidy\n\n\ndef main():\n    txt_path = find_file('boston-harbor-beaches.txt')\n    if not txt_path:\n        raise FileNotFoundError('boston-harbor-beaches.txt not found')\n\n    with open(txt_path, enco