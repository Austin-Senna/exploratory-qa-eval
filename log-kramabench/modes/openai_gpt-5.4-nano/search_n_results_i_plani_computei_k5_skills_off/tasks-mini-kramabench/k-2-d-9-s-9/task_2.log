\ndef prepare_beach_datasheet(path):\n    df = pd.read_csv(path, skiprows=1, header=[0, 1])\n    cols = df.columns.to_frame(index=False)\n    cols.iloc[:, 0] = cols.iloc[:, 0].replace(r'^Unnamed.*', pd.NA, regex=True).ffill()\n\n    new_cols = []\n    for a, b in cols.itertuples(index=False, name=None):\n        parts = []\n        for part in (a, b):\n            if pd.isna(part):\n                continue\n            part = str(part).strip()\n            if part and part.lower() != 'nan':\n                parts.append(part)\n        new_cols.append('_'.join(parts))\n    df.columns = new_cols\n\n    id_cols = [c for c in df.columns if not (c.endswith('_Tag') or c.endswith('_Enterococcus'))]\n    value_cols = [c for c in df.columns if c not in id_cols]\n\n    long_df = df.melt(id_vars=id_cols, value_vars=value_cols, var_name='Variable', value_name='Value')\n    long_df[['Location', 'Measure']] = long_df['Variable'].str.rsplit('_', n=1, expand=True)\n    tidy = long_df.pivot_table(index=id_cols + ['Location'], columns='Measure', values='Value', aggfunc='first').reset_index()\n    tidy.columns.name = None\n    return tidy\n\n\ndef matches_location(beach_name, location):\n    loc = normalize_text(location)\n    beach = normalize_text(beach_name)\n\n    if beach_name == 'Constitution Beach':\n        return loc in {'north', 'middle', 'south'} or 'constitution' in loc\n    if beach_name == 'Pleasure Bay Beach':\n        return 'pleasure bay' in loc\n    if beach_name == 'Castle Island Beach':\n        return 'castle island' in loc\n    if beach_name == 'City Point Beach':\n        return 'city point' in loc\n    if beach_name == 'M Street Beach':\n        return 'm street' in loc\n    if beach_name == 'Carson Beach':\n        return loc in {'i street', 'mccormack bathhouse'} or 'carson' in loc\n    if beach_name == 'Malibu Beach':\n        return 'malibu' in loc\n    if beach_name == 'Tenean Beach':\n        return loc == 'middle' or 'tenean' in loc\n    if beach_name == 'Wollaston Beach':\n        return loc in {'channing street', 'milton road', 'rice road', 'sachem street'} or 'wollaston' in loc\n\n    base = beach.replace(' beach', '')\n    return base in loc or beach in loc\n\n\ndef year_from_date(series):\n    return pd.to_numeric(series.astype(str).str.extract(r'(\\d{4})')[0], errors='coerce')\n\n\nbeach_order_path = find_file(BEACH_LIST_FILE)\nwith open(beach_order_path, encoding='utf-8') as f:\n    beach_order = [line.strip() for line in f if line.strip()]\n\npassing = []\nseen = set()\n\nfor filename in DATA_FILES:\n    path = find_file(filename)\n    tidy = prepare_beach_datasheet(path)\n    years = year_from_date(tidy['Date'])\n    recent = tidy[(years >= 2020) & (years <= 2024)].copy()\n    if recent.empty:\n        continue\n\n    recent['ParsedEnterococcus'] = recent.apply(\n        lambda row: parse_enterococcus(row.get('Tag'), row.get('Enterococcus')),\n        axis=1,\n    )\n\n    for beach_name in beach_order:\n        if beach_name in seen:\n            continue\n        beach_rows = recent[recent['Location'].apply(lambda x: matches_location(beach_name, x))]\n        if beach_rows.empty:\n            continue\n        if beach_rows['ParsedEnterococcus'].map(value_is_below_104).all():\n            passing.append(beach_name)\n            seen.add(beach_name)\n\nprint(passing)", "reason": "Rewrote the code to actually process all 2020-2024 beach datasheet CSVs, preserve the master beach list order, match datasheet sub-locations to each beach, and correctly treat values with a '<' tag as below the threshold when checking that every Enterococcus sample is <104. The script prints the resulting beach list."}) [toolUseId=call_J1KloVBUKDDJNhCrBsv8GFcc]
