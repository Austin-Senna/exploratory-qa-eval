USING (beach)\n  GROUP BY p.beach\n)\nSELECT beach, avg_exceedance_rate\nFROM avg_rates\nORDER BY avg_exceedance_rate DESC\nLIMIT 10;\n'''\nres = con.execute(sql).fetchall()\nres\n"}) [toolUseId=call_gxCLAqUzqwJhRoPxAj6cwlrG]
