.columns if c.strip().startswith('Tag') or c.strip()=='Tag']\n    # handle repeated tags with suffixes\n    if len(tag_cols)==0:\n        # maybe Tag columns are numeric header like 'Tag'\n        tag_cols=[c for c in df2015.columns if 'Tag' in c]\n    # compute violation indicator if any tag>10\n    viol=np.zeros(len(df2015),dtype=bool)\n    for t in tag_cols:\n        vals=pd.to_numeric(df2015[t], errors='coerce')\n        viol |= (vals>10)\n    return viol.mean()\n\nbeach_files=['tenean_beach_datasheet.csv','carson_beach_datasheet.csv','city_point_beach_datasheet.csv','constitution_beach_datasheet.csv','m_street_beach_datasheet.csv','pleasure_bay_and_castle_island_beach_datasheet.csv','wollaston_beach_datasheet.csv','malibu_beach_datasheet.csv']\n# include those in DOWNLOAD_PATHS for completeness\npaths={}\nfor k,p in DOWNLOAD_PATHS.items():\n    for bf in beach_files:\n        if bf in k:\n            paths[bf]=p\n\nrates=[]\nfor bf,p in paths.items():\n    beach_name=bf.replace('_beach_datasheet.csv','').replace('pleasure_bay_and_castle_island_beach_datasheet','Pleasure Bay / Castle Island').replace('wollaston_beach_datasheet','Wollaston')\n    # compute\n    df=pd.read_csv(p)\n    # need to align columns: these CSVs have multi-row header; use heuristic similar as above\n    # find header row where first column is 'Date'\n    raw=pd.read_csv(p, header=None)\n    date_row=None\n    for i in range(min(60,len(raw))):\n        row=raw.iloc[i].astype(str).tolist()\n        if any(x.strip()=='Date' for x in row):\n            date_row=i\n            break\n    df=pd.read_csv(p, skiprows=date_row)\n    rate=violation_rate(df)\n    rates.append((bf,rate))\n\nrates_sorted=sorted(rates,key=lambda x:(-x[1] if pd.notna(x[1]) else -1e18))\nprint('rates_sorted',rates_sorted[:10])\nprint('top3',rates_sorted[:3])\n"}) [toolUseId=call_CLjDh72IJW24lbQP6uhKHHDQ]
