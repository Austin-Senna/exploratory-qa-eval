row = i\n                break\n        if header_row is None:\n            raise ValueError(f'Could not find header row in {path}')\n        return pd.read_csv(path, skiprows=header_row, dtype=str)\n\n    def normalize_columns(df):\n        df = df.copy()\n        df.columns = [str(c).strip() for c in df.columns]\n        return df\n\n    def violation_rate(df):\n        df = normalize_columns(df)\n        date_col = next((c for c in df.columns if c.strip() == 'Date'), df.columns[0])\n        df[date_col] = pd.to_datetime(df[date_col].astype(str).str.replace('\"', '', regex=False), errors='coerce')\n        df = df[df[date_col].dt.year == 2015].copy()\n        if df.empty:\n            return np.nan\n\n        tag_cols = [c for c in df.columns if 'tag' in c.lower()]\n        ent_cols = [c for c in df.columns if 'enterococcus' in c.lower()]\n\n        viol = pd.Series(False, index=df.index)\n        if tag_cols:\n            for c in tag_cols:\n                vals = pd.to_numeric(df[c], errors='coerce')\n                viol = viol | (vals > 10)\n        elif ent_cols:\n            for c in ent_cols:\n                vals = pd.to_numeric(df[c], errors='coerce')\n                viol = viol | (vals > 104)\n        else:\n            return np.nan\n        return float(viol.mean())\n\n    # Look for Chatham datasheets specifically.\n    candidate_paths = glob.glob(os.path.join(base, '*datasheet*.csv'))\n    chatham_keywords = ['bucks', 'pleasant', 'forest', 'chatham']\n    selected = [p for p in candidate_paths if any(k in os.path.basename(p).lower() for k in chatham_keywords)]\n\n    rates = []\n    for p in selected:\n        try:\n            df = load_datasheet(p)\n            rate = violation_rate(df)\n            beach = os.path.basename(p).replace('_datasheet.csv', '').replace('.csv', '')\n            rates.append((beach, rate))\n        except Exception:\n            pass\n\n    rates = [x for x in rates if pd.notna(x[1])]\n    rates.sort(key=lambda x: x[1], 