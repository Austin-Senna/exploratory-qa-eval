e(path).replace('_datasheet.csv', '').replace('_', ' ').title()\n    return base\n\n\ndef violation_rate_2015(df):\n    date_col = 'Date' if 'Date' in df.columns else df.columns[0]\n    dates = pd.to_datetime(df[date_col].astype(str).str.replace('\"', '', regex=False), errors='coerce')\n    dff = df[dates.dt.year == 2015].copy()\n    if dff.empty:\n        return np.nan\n\n    violation_col = None\n    for col in dff.columns:\n        if 'violation' in str(col).lower():\n            violation_col = col\n            break\n\n    if violation_col is not None:\n        viol = dff[violation_col].astype(str).str.strip().str.lower().isin(['yes', 'y', 'true', '1'])\n        return float(viol.mean())\n\n    # Fallback: use tag columns if present\n    tag_cols = [c for c in dff.columns if 'tag' in str(c).lower()]\n    if tag_cols:\n        viol = np.zeros(len(dff), dtype=bool)\n        for c in tag_cols:\n            vals = pd.to_numeric(dff[c], errors='coerce')\n            viol |= vals > 10\n        return float(viol.mean())\n\n    return np.nan\n\n\nfilenames = [\n    'carson_beach_datasheet.csv',\n    'city_point_beach_datasheet.csv',\n    'constitution_beach_datasheet.csv',\n    'm_street_beach_datasheet.csv',\n    'tenean_beach_datasheet.csv',\n]\n\nresults = []\nfor fname in filenames:\n    path = find_file(fname)\n    df = read_beach_table(path)\n    beach_name = detect_beach_name(path, df)\n    rate = violation_rate_2015(df)\n    results.append((beach_name, rate))\n\nresults = [x for x in results if pd.notna(x[1])]\nresults.sort(key=lambda x: (-x[1], x[0]))\nprint(results[:3])", "reason": "Rewrote the script to use the actually available beach datasheet CSVs in the sandbox instead of the missing aggregate water-body-testing file, robustly locate/download paths, parse datasheets by finding the embedded Date header row, compute 2015 violation rates from a Violation column (with tag-column fallback), and print the top 3 results."}) [toolUseId=call_ENmuSY0wsG3qb3YmMkTww