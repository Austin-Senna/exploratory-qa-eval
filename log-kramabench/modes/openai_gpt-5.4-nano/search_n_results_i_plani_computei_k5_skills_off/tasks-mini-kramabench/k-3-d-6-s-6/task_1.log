als[1:]\n    x_aug = np.column_stack([np.ones(len(x)), x])\n    coef, _, _, _ = np.linalg.lstsq(x_aug, y, rcond=None)\n    intercept = coef[0]\n    A = coef[1:]\n    return intercept, A\n\n\ndef forecast_var1(context_df, horizon):\n    intercept, A = fit_var1_from_context(context_df)\n    state = context_df[FEAT_COLS].iloc[-1].values.astype(float)\n    preds = []\n    for _ in range(horizon):\n        state = intercept + state @ A\n        preds.append(state.copy())\n    out = pd.DataFrame(preds, columns=[f'{c}_pred' for c in FEAT_COLS])\n    return out\n\n\ndef build_training_examples(feature_df, density_df, context_hours=16, horizon_hours=4):\n    rows_x, rows_y = [], []\n    density_times = density_df.index\n    for t in density_times:\n        start = t - pd.Timedelta(hours=context_hours)\n        hist = feature_df.loc[(feature_df.index >= start) & (feature_df.index <= t)]\n        if len(hist) != context_hours + 1:\n            continue\n        fut_times = pd.date_range(t + pd.Timedelta(hours=1), periods=horizon_hours, freq='1h')\n        if not set(fut_times).issubset(set(density_times)):\n            continue\n        fut_feat = forecast_var1(hist, horizon_hours)\n        x = fut_feat.values.reshape(-1)\n        y = density_df.loc[fut_times, 'rho'].values.reshape(-1)\n        if np.any(~np.isfinite(x)) or np.any(~np.isfinite(y)):\n            continue\n        rows_x.append(x)\n        rows_y.append(y)\n    return np.asarray(rows_x), np.asarray(rows_y)\n\n\ntrain_feat = load_feature_frame(omni_train_path, goes_train_path)\ntrain_dens = load_density_frame(rho_train_path)\neval_feat = load_feature_frame(omni_eval_path, goes_eval_path)\neval_dens = load_density_frame(rho_eval_path)\n\nX_train, Y_train = build_training_examples(train_feat, train_dens, CONTEXT_HOURS, HORIZON_HOURS)\n\nif len(X_train) == 0:\n    raise RuntimeError('No training examples could be constructed.')\n\nXb = np.column_stack([np.ones(len(X_train)), X_train])\ncoef, _, _, _ = np.linalg.lsts