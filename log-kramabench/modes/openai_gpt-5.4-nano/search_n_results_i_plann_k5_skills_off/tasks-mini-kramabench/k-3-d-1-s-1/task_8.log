 3 points, count days where at least one point value <104 and at least one point value >=104.\ncount_mixed=0\nmixed_dates=[]\nfor idx,row in data2024.iterrows():\n    vals={name: parse_count(row[col]) for name,col in points.items()}\n    meets=[v is not None and v < threshold for v in vals.values()]\n    if any(meets) and (not all(meets)):\n        count_mixed +=1\n        mixed_dates.append(row[0])\nprint('mixed days', count_mixed)\nprint('first mixed dates', mixed_dates[:10])\n"}) [toolUseId=call_pe1qRgDamVx2BE0szrKyYBXk]
