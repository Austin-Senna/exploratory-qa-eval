 dens_wu334[['Timestamp','Orbit Mean Density (kg/m^3)']].rename(columns={'Orbit Mean Density (kg/m^3)':'density'}).sort_values('Timestamp')\nd335 = dens_wu335[['Timestamp','Orbit Mean Density (kg/m^3)']].rename(columns={'Orbit Mean Density (kg/m^3)':'density'}).sort_values('Timestamp')\n\n# Downsample X to 10-minute grid? Density appears every 10 minutes.\n# We'll build features at each density timestamp by taking nearest 1-minute OMNI/GOES values and aligning.\n# Since assumption says windows valid, use exact match after rounding to 10-min.\n\ndef align_features(X):\n    X = X.copy()\n    # round timestamp to nearest 10 minutes\n    X['t10'] = X['Timestamp'].dt.floor('10T')\n    g = X.groupby('t10')[feat_cols+goes_cols].mean().reset_index().rename(columns={'t10':'Timestamp'})\n    return g.sort_values('Timestamp')\n\nX334_a = align_features(X334)\nX335_a = align_features(X335)\n\n# For training, context window 16h on inputs ends at same time density begins (overlap single timestamp)\n# We'll create VAR(1) on input end: use last observed value at time t and t+1? but 10-min steps.\n# We'll implement: fit VAR(1) of input features on sequential times with step=10min, then forecast features 4h ahead (24 steps).\n\ninput_cols = feat_cols+goes_cols\nstep = pd.Timedelta('10T')\ncontext = pd.Timedelta('16H')\nhorizon = pd.Timedelta('4H')\nN_context = int(context/step)  # 96\nN_hor = int(horizon/step)      # 24\n\n# Build sequences using density timestamps as target grid.\n# For each density start time t0 where t0 is immediately after inputs end; but we just take full overlapping period.\n# training density from 2016-10-23 to 2016-10-24: 24h -> 144 points.\n# We'll use all possible t0 such that t0+4h within density range and t0-16h within input range.\n\n\ndef forecast_rmse(train_X, train_y, test_X, test_y):\n    # Fit VAR(1) on train_X using all consecutive rows\n    A_data = train_X[input_cols].values\n    # use VAR(1): X_{t+1} = C + A*X_t\n    X_t = A_data[:-1]\n    X_tp1 = A_data[1:]\n    # add intercept\n    Phi = np.hstack([np.ones((X_t.shape[0],1)), X_t])\n    coef, *_ = np.linalg.lstsq(Phi, X_tp1, rcond=None)\n    C = coef[0]\n    A = coef[1:].T  # shape (k,k)\n\n    def multi_step(x0):\n        # x0 is vector at time t0\n        xs=[]\n        x=x0\n        for i in range(N_hor):\n            x = C + A.dot(x)\n            xs.append(x)\n        return np.array(xs)  # (N_hor,k)\n\n    # Create training samples: for each t0 (corresponding to density at t0), use input at t0 to forecast next 4h features,\n    # then fit linear regression mapping flattened forecasted features (N_hor*k) to flattened densities (N_hor)\n    # However prompt: linear regression to predict next 4 hours of density using VAR-projected input.\n    # We'll use features projected for each horizon step to predict density at same step via linear regression with lagged features.\n\n    # Prepare training design\n    times_y = train_y['Timestamp'].values\n    X_by_time = {t: row for t, row in zip(train_X['Timestamp'].values, train_X[input_cols].values)}\n\n    # t0 grid: density times where we have features at t0 and forecast stays within 10-min input span (VAR handles)\n    # We'll just use those where t0 is between train_X min+16h? already ensured by selecting train_X aligned subset.\n\n    t0_list=[]\n    Y_list=[]\n    F_list=[]\n    y_map={t: dens for t,dens in zip(train_y['Timestamp'].values, train_y['density'].values)}\n\n    for t0 in train_y['Timestamp']:\n        # need t0 in X\n        if t0 not in X_by_time: continue\n        # need density for horizon\n        ok=True\n        y_h=[]\n        for j in range(1,N_hor+1):\n            t = t0 + j*step\n            if t not in y_map: ok=False; break\n            y_h.append(y_map[t])\n        if not ok: continue\n        # get x0\n        x0 = X_by_time[t0]\n        x_fore = multi_step(x0)  # (N_hor,k)\n        F_list.append(x_fore.reshape(-1))\n        Y_list.append(y_h)\n        t0_list.append(t0)\n\n    F=np.array(F_list)\n    Y=np.array(Y_list)\n\n    # Fit linear regression per horizon step jointly using multioutput linear regression\n    # sklearn LinearRegression supports multioutput.\n    lr = LinearRegression()\n    lr.fit(F, Y)\n\n    # Evaluate on test\n    X_by_time_test = {t: row for t,row in zip(test_X['Timestamp'].values, test_X[input_cols].values)}\n    y_map_test={t: dens for t,dens in zip(test_y['Timestamp'].values, test_y['density'].values)}\n\n    preds=[]\n    trues=[]\n    for t0 in test_y['Timestamp']:\n        if t0 not in X_by_time_test: continue\n        ok=True\n        y_true_h=[]\n        for j in range(1,N_hor+1):\n            t=t0+j*step\n            if t not in y_map_test: ok=False; break\n            y_true_h.append(y_map_test[t])\n        if not ok: continue\n        x0 = X_by_time_test[t0]\n        x_fore = multi_step(x0)\n        f = x_fore.reshape(-1).reshape(1,-1)\n        y_pred_h = lr.predict(f).ravel()\n        preds.append(y_pred_h)\n        trues.append(np.array(y_true_h))\n\n    preds=np.vstack(preds)\n    trues=np.vstack(trues)\n    rmse = math.sqrt(mean_squared_error(trues.flatten(), preds.flatten()))\n    return rmse, preds.shape[0]\n\n# Select subsets according to prompt time ranges\n# Training inputs: wu334 OMNI/GOES 2016-10-22 to 2016-10-23\n# Training density: 2016-10-23 to 2016-10-24\ntrain_X = X334_a[(X334_a['Timestamp']>=pd.Timestamp('2016-10-22 00:00:00')) & (X334_a['Timestamp']<=pd.Timestamp('2016-10-23 23:50:00'))]\ntrain_y = d334[(d334['Timestamp']>=pd.Timestamp('2016-10-23 00:00:00')) & (d334['Timestamp']<=pd.Timestamp('2016-10-24 23:50:00'))]\n\n# Eval inputs: wu335 OMNI/GOES 2016-10-25 to 2016-10-26\n# Eval density: 2016-10-29\n# density file might include 2016-10-26..29; but prompt says Density: 2016-10-29. We'll filter to that day.\n\ntest_X = X335_a[(X335_a['Timestamp']>=pd.Timestamp('2016-10-25 00:00:00')) & (X335_a['Timestamp']<=pd.Timestamp('2016-10-26 23:50:00'))]\n\ntest_y = d335[(d335['Timestamp']>=