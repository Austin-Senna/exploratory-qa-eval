=10 (since datasheets have tags 10/20/31...).\n\ndef monthly_exceedance_rate(df, city_beach):\n    df=df.copy()\n    df=df.dropna(subset=['date'])\n    df['year']=df['date'].dt.year\n    df['month']=df['date'].dt.month\n    summer=df[df['month'].isin([6,7,8])]\n    # exceedance rate per month: fraction with Enterococcus>=10\n    summer['exceed']=summer['Enterococcus']>=10\n    out=summer.groupby(['year','month'])['exceed'].mean().reset_index(name='exceedance_rate')\n    return out\n\ncity_point=read_beach(path_map['kramabench-environment-hard-8/files/city_point_beach_datasheet.csv'])\nm_street=read_beach(path_map['kramabench-environment-hard-8/files/m_street_beach_datasheet.csv'])\n\n# but need Amherst, Ashburnham, Chatham fresh-water beaches -> likely in other files not downloaded.\n# For now check available precip excel? We'll need exceedance rates for those beaches; likely dataset includes water-body-testing by community.\nprint('have city_point and m_street only; need others')\n"}) [toolUseId=call_zq6yfS5UpEgp6gbyW7FzXoYb]
