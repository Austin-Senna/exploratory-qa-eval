fresh_comms))].groupby(['year','month_name'])['exceedance_rate'].mean().reset_index()\nmarine_ex=rate_m[(rate_m['Beach Type Description']=='Marine') & (rate_m['Community'].isin(marine_comms))].groupby(['year','month_name'])['exceedance_rate'].mean().reset_index()\n\n# rainfall long\n\ndef rainfall_long(comms):\n    rows=[]\n    for c in comms:\n        df=precip[c][['Year','Jun','Jul','Aug']].copy()\n        df=df.rename(columns={'Year':'year'})\n        long=df.melt(id_vars=['year'], value_vars=['Jun','Jul','Aug'], var_name='month_name', value_name='rainfall')\n        long['city']=c\n        rows.append(long)\n    return pd.concat(rows, ignore_index=True)\n\n\ndef impute_and_avg(long):\n    long=long.copy()\n    long['rainfall']=pd.to_numeric(long['rainfall'], errors='coerce')\n    meds=long.groupby('month_name')['rainfall'].transform('median')\n    long['rainfall']=long['rainfall'].fillna(meds)\n    # average across cities\n    return long.groupby(['year','month_name'])['rainfall'].mean().reset_index(name='rainfall')\n\nfresh_r=impute_and_avg(rainfall_long(fresh_comms).astype({'year':int}))\nmarine_r=impute_and_avg(rainfall_long(marine_comms).astype({'year':int}))\n\n# correlation\nfor label, ex, r in [('Freshwater',fresh_ex,fresh_r),('Marine',marine_ex,marine_r)]:\n    ex['year']=ex['year'].astype(int)\n    r['year']=r['year'].astype(int)\n    df=ex.merge(r, on=['year','month_name'], how='inner')\n    corr=df['rainfall'].corr(df['exceedance_rate'])\n    print(label,'n',len(df),'corr',corr)\n    print(df.sort_values(['year','month_name']).to_string(index=False))\n"}) [toolUseId=call_mvjN5pzsLi2YROsk8jxf6URe]
