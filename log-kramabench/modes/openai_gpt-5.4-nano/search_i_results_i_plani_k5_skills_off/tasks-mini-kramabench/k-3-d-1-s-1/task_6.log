ile: 'Reports with $ Loss'\n# Extract from raw by finding line contains 'Reports with $ Loss'\ncell = raw[raw.apply(lambda r: r.astype(str).str.contains('Reports with $ Loss', case=False, na=False).any(), axis=1)]\nprint('reports_with_loss_rows', cell.head())\n# find number in that row, second column likely\n# Let's locate row index and get all columns\nrow = cell.index[0]\nrow_vals = raw.iloc[row].tolist()\nprint('row_vals', row_vals)\n# Find value that looks like '987,520'\njoined=' '.join(row_vals)\nimport re\nm=re.search(r'([0-9]{1,3}(?:,[0-9]{3})+)', joined)\ntotal_loss_reports=int(m.group(1).replace(',',''))\nprint('total_loss_reports', total_loss_reports)\nprop = sel_total/total_loss_reports\nprint('sel_total', sel_total, 'prop', prop)\nprint(round(prop,3))\n"}) [toolUseId=call_N3Z4PlvVzCqFQnpc8p6bxsDX]
