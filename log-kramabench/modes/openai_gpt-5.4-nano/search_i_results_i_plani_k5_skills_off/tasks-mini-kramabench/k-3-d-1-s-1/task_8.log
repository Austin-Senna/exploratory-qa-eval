_point','tag','enterococcus'])\nlong['date']=pd.to_datetime(long['date_str'].str.replace('\"',''), errors='coerce')\nlong=long[long['date'].notna()]\nlong_2024=long[(long['date'].dt.year==2024)].copy()\n# Standard if fewer than 104 counts: enterococcus <104. For tags like '<' with value 10, still counts are <104 so standard True.\nlong_2024['standard']=long_2024['enterococcus']<104\n# For each date check both True and False exist among sampling points\nper_date=long_2024.groupby('date')['standard'].agg(['min','max'])\n# min False(0)?? Actually standard bool; convert\nper_date['both']= (per_date['min']!=per_date['max'])\ncount=int(per_date['both'].sum())\nprint('dates total', per_date.shape[0])\nprint('count both', count)\nprint(per_date[per_date['both']].head(10))\n"}) [toolUseId=call_v4MltMDOdYE6VWgYPxAj1o8h]
