econd=0)\n    # nearest hour rounding\n    if (epoch - epoch_round) >= timedelta(minutes=30):\n        epoch_round += timedelta(hours=1)\n    records.append((epoch,epoch_round,a))\n\ndf=pd.DataFrame(records, columns=['epoch','epoch_round','a_km'])\ndf=df[(df['epoch_round']>=datetime(2024,5,1)) & (df['epoch_round']<datetime(2024,5,31))]\n# If multiple entries round to same hour, average a\nag=df.groupby('epoch_round',as_index=False)['a_km'].mean().sort_values('epoch_round')\n# compute hourly changes: delta a between consecutive hours\nag=ag.sort_values('epoch_round')\nag['delta_a_km']=ag['a_km'].diff()\n# Keep only rows where delta exists\nag=ag.dropna(subset=['delta_a_km'])\n\n# --- Parse OMNI2 hourly AP ---\n# omni2_2024.dat is fixed-width; need specification from omni2.text but not provided; use header lines.\n# We'll implement robust fixed-width based on known OMNI2 columns:\n# Typically: columns: year(4), day(3), hour(2), minute? then values.\n# We'll look for pattern where 'AP' appears.\n\nap_rows=[]\nwith open(OMNI_PATH,'r') as f:\n    for line in f:\n        if line.startswith('DATE') or line.startswith('Year') or line.startswith('----'):\n            continue\n        if line.strip()=='' or line[0].isalpha():\n            continue\n        # First 10 chars: year(4) + day(3)?? We'll attempt parse as int year from first 4\n        try:\n            year=int(line[0:4])\n        except:\n            continue\n        if year!=2024:\n            continue\n        # DOY in cols 4:7\n        doy=int(line[4:7])\n        hour=int(line[8:10])\n        # AP at known columns: AP index is at cols 47-49? plus Kp?\n        # We'll brute extract 9th field? Use regex for last columns? \n        # Use known OMNI2 low-res format (hourly):\n        # After values, AP is at positions 50-53 maybe. We'll attempt fixed widths from classic omni2:\n        # We'll parse columns by splitting with whitespace into tokens; AP is usually 12th token.\n        toks=line.split()\n        # tokens: year doy hour min? ... ap\n        # Let's take AP as token that can be int between 0 and 400 maybe.\n        # Find first token >=0 and <= 400 near end.\n        candidates=[]\n        for t in toks:\n            try:\n                v=float(t)\n            except:\n                continue\n            if 0<=v<=400:\n                candidates.append(v)\n        # AP is usually last 1-2 tokens among candidates; choose first candidate with integer? \n        ap=None\n        for t in reversed(toks):\n            try:\n                v=float(t)\n            except:\n                continue\n            if 0<=v<=400:\n                ap=v\n                break\n        if ap is None:\n            continue\n        dt=datetime(year,1,1)+timedelta(days=doy-1,hours=hour)\n        if dt>=datetime(2024,5,1) and dt<datetime(2024,5,31):\n            ap_rows.append((dt,ap))\n\nap_df=pd.DataFrame(ap_rows, columns=['dt','AP'])\n# There should be hourly already; average duplicates\nap_df=ap_df.groupby('dt',as_index=False)['AP'].mean().sort_values('dt')\n\n# align with delta_a hours (both rounded to hour)\nap_df['dt_round']=ap_df['dt']\n# create merged time series\nmerged=ag.merge(ap_df[['dt_round','AP']], left_on='epoch_round', right_on='dt_round', how='inner')\nmerged=merged.rename(columns={'epoch_round':'dt'})\nmerged=merged.sort_values('dt')\n\n# create arrays\nx=merged['delta_a_km'].values\nap=merged['AP'].values\n# ensure equal length\nn=min(len(x),len(ap))\nx=x[:n]; ap=ap[:n]\n\nbest=None\nbest_r2=-1\n\nfor lag in range(0,49):\n    if lag==0:\n        y=ap\n        xx=x\n    else:\n        y=ap[:-lag]\n        xx=x[lag:]\n    if len(y)<10:\n        continue\n    # correlation r^2 between xx and shifted ap\n    r=pd.Series(xx).corr(pd.Series(y))\n    r2=float(r**2) if r==r else float('nan')\n    if r2>best_r2:\n        best_r2=r2; best=lag\n\nprint('n_merged',n)\nprint('best_lag',best,'best_r2',best_r2)\n"}) [toolUseId=call_peAfwLB2PCkiy9THFKa5GvJh]
