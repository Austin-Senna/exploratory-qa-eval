d get gene_name list\nmmc6 = pd.read_excel('/home/ec2-user/eval_eqa/exploratory-qa-eval/.sandbox_isolated/task_1600047_1778973932703/kramabench-biomedical-hard-8/files/1-s2.0-S0092867420301070-mmc6.xlsx', sheet_name='G-FDA approved drugs')\nfdagenes = set(mmc6['gene_name'].astype(str))\ninter = proteins.intersection(fdagenes)\nprint('CNV_HIGH endometrioid samples:', len(sample_ids))\nprint('Hyperactivated proteins:', len(proteins))\nprint('Intersecting FDA target genes:', len(inter))\nprint(sorted(inter)[:50])\n\n# Now map to protein sites: hyperactivated proteins are genes; need protein sites targeted by FDA drugs.\n# In mmc6, sheets A,B,C contain serous vs endometrioid, include IDs like GENE-S### or GENE-K### and A sheet includes proteins (no site) just ID.\n# We'll output phospho sites and acetyl sites (B and C) for genes in inter.\nsite_ids=[]\nfor sheet in ['B-SE phospho site between Serou','C-SE scetyl site between Serous']:\n    df = pd.read_excel('/home/ec2-user/eval_eqa/exploratory-qa-eval/.sandbox_isolated/task_1600047_1778973932703/kramabench-biomedical-hard-8/files/1-s2.0-S0092867420301070-mmc6.xlsx', sheet_name=sheet)\n    gene_col = 'Gene'\n    ids = df[df[gene_col].astype(str).isin(inter)]['ID'].astype(str)\n    site_ids.extend(ids.tolist())\n\nprint('Intersecting hyperactivated+FDA protein sites count:', len(set(site_ids)))\nprint(sorted(set(site_ids))[:100])\nprint('ALL_SITES', ';'.join(sorted(set(site_ids))))\n"}) [toolUseId=call_FqZ6ruM885Dp4MICDYqYAa23]
