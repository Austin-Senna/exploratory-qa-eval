ls=sorted(enter_cols, key=lambda x: data.columns.get_loc(x))\nprint('Columns:', list(data.columns))\nprint('Enter columns:', enter_cols)\n# Map enter columns to beach labels assuming North/Middle/South\nbeach_labels=['North','Middle','South']\nenter_cols_map={beach_labels[i]:enter_cols[i] for i in range(min(3,len(enter_cols)))}\nprint('Map:', enter_cols_map)\n# parse rain as numeric\nfor rc in rain_cols:\n    if rc in data.columns:\n        data[rc]=pd.to_numeric(data[rc], errors='coerce')\n# filter no rainfall preceding 3 days: 1-Day Rain==0 and 2-Day Rain==0 and 3-Day Rain==0 (also accept 0 or 0.00)\nmask = (data['1-Day Rain'].fillna(0)==0) & (data['2-Day Rain'].fillna(0)==0) & (data['3-Day Rain'].fillna(0)==0)\nfiltered=data[mask].copy()\nprint('Rows with no rain:', len(filtered))\n# failure if Enterococcus >=104 AND value not missing\ncounts={}\nfor beach,col in enter_cols_map.items():\n    vals=pd.to_numeric(filtered[col].replace(' ','', regex=True), errors='coerce')\n    counts[beach]=int((vals>=104).sum())\nprint('Failure counts:', counts)\nmax_beach=max(counts, key=counts.get)\nprint('Max beach:', max_beach, counts[max_beach])\n"}) [toolUseId=call_MkiyqgYJZH8KxcxIGHmpsVPR]
