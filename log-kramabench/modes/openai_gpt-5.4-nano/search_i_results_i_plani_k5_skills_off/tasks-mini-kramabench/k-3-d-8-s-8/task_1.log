 np.nan\n    rates.append((yr, rate, len(df_f)))\n\nrates_df=pd.DataFrame(rates, columns=['Year','exceedance_rate','n_records']).sort_values('Year')\nprint('\\nFreshwater exceedance rate per year:')\nprint(rates_df.to_string(index=False))\nex_pat = incdec_pattern(rates_df['exceedance_rate'].values)\nprint('Exceedance year-to-year pattern:', ex_pat)\n\nprint('\\nSame increase/decrease pattern?', rain_pat==ex_pat)\n"}) [toolUseId=call_N3E57lROKzF689lBJjwon5pN]
