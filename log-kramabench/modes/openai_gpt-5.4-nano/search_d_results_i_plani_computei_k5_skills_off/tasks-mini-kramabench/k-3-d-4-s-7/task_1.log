e beach type and name within month-summer.\n# We'll compute for each year and beach type (Freshwater/Marine) an exceedance rate aggregated across specified beach names.\n\nfresh_beaches = ['Boston','Chatham','Amherst','Ashburnham']\nmarine_beaches = ['Boston','Chatham']\n\nall_water = []\nfor y,p in water_files.items():\n    df = pd.read_csv(p)\n    all_water.append(df)\nwater = pd.concat(all_water, ignore_index=True)\n\n# Ensure sample date parsed\nwater['Sample Date'] = pd.to_datetime(water['Sample Date'], errors='coerce')\nwater['month'] = water['Sample Date'].dt.month\n\n# Filter June-Aug and years\nwater = water[water['Year'].isin(years) & water['month'].isin(months)]\n\n# Map beach names by 'Community' field (city) as given lists; use 'Community' column.\nwater = water.rename(columns={'Beach Type Description':'Beach Type'})\n\n# Compute exceedance as violation=='yes'\nwater['exceed'] = water['Violation'].astype(str).str.lower().eq('yes').astype(int)\n\n# For each year, beach type, and our selected beach communities: average exceedance rate across beaches (unweighted by number of samples per beach) and then average across beaches.\n\ndef compute_exceedance_rate(beach_list):\n    sub = water[water['Community'].isin(beach_list)].copy()\n    # average exceedance rate per beach-community and year and type\n    grp = sub.groupby(['Year','Beach Type','Community']).agg(exceed_rate=('exceed','mean')).reset_index()\n    # then average across communities within type/year\n    out = grp.groupby(['Year','Beach Type']).agg(exceed_rate=('exceed_rate','mean')).reset_index()\n    return out\n\nfresh_ex = compute_exceedance_rate(fresh_beaches)\nmarine_ex = compute_exceedance_rate(marine_beaches)\n\n# Get vectors aligned by beach type needed\n# Determine which Beach Type values correspond to fresh/marine based on label in data.\nprint('Fresh types present:', sorted(fresh_ex['Beach Type'].unique()))\nprint('Marine types present:', sorted(marine_ex['Beach Type'].unique()))\n\n# We'll assume values 'Freshwater' and 'Marine' exist.\n\n# ---- Rainfall totals ----\n# Load each station file: expect columns Year, Month, Precipitation or similar.\n\ndef load_station(path, station):\n    df = pd.read_csv(path)\n    cols = [c.lower() for c in df.columns]\n    # identify year column\n    year_col = None\n    for c in df.columns:\n        if c.lower()=='year' or 'year' in c.lower():\n            year_col = c; break\n    # identify month column\n    month_col = None\n    for c in df.columns:\n        if c.lower() in ['month','month_name','monthname'] or 'month' in c.lower():\n            month_col = c; break\n    # identify precip column\n    precip_col = None\n    for c in df.columns:\n        if 'precip' in c.lower() or 'rain' in c.lower() or 'in' in c.lower():\n            precip_col = c; break\n    # fallback: if two non-year columns, take last\n    if precip_col is None:\n        # choose numeric column\n        numeric_cols = [c for c in df.columns if pd.api.types.is_numeric_dtype(df[c])]\n        precip_col = numeric_cols[-1]\n    # month numbers\n    # if month is numeric already\n    mcol = df[month_col]\n    if pd.api.types.is_numeric_dtype(mcol):\n        df['month_num'] = mcol\n    else:\n        # parse month names\n        df['month_num'] = mcol.astype(str).str.extract('(\\d+)').astype(float)\n        if df['month_num'].isna().all():\n            mapping = {'june':6,'july':7,'august':8}\n            df['month_num'] = mcol.astype(str).str.strip().str.lower().map(mapping)\n    df = df.rename(columns={year_col:'Year', precip_col:'precip'})\n    df = df[['Year','month_num','precip']]\n    df['station'] = station\n    return df\n\nstation_dfs=[]\nfor st,path in precip_paths.items():\n    station_dfs.append(load_station(path, st))\nprecip = pd.concat(station_dfs, ignore_index=True)\nprecip = precip[precip['Year'].isin(years) & precip['month_num'].isin(months)]\n\n# Impute missing June/July/August within each station using median for that month across non-missing years.\nprecip['precip'] = pd.to_numeric(precip['precip'], errors='coerce')\nmed = precip.groupby(['station','month_num'])['precip'].transform(lambda s: s.median(skipna=True))\nprecip['precip_imp'] = precip['precip'].fillna(med)\n\n# Summer totals per year per station\nsummer = precip.groupby(['station','Year']).agg(summer_rain=('precip_imp','sum')).reset_index()\n\n# Average across stations in each beach type set\nfresh_station_set = ['Boston','Chatham','Amherst','Ashburnham']\nmarine_station_set = ['Boston','Chatham']\n\nfresh_rain = summer[summer['station'].isin(fresh_station_set)].groupby('Year').agg(summer_rain=('summer_rain','mean')).reset_index()\nmarine_rain = summer[summer['station'].isin(marine_station_set)].groupby('Year').agg(summer_rain=('summer_rain','mean')).reset_index()\n\n# ---- Correlation ----\n# Get exceedance rate vectors for Marine and Freshwater beach types.\n\ndef corr_for_type(ex_df, rain_df, beach_type_label):\n    vec_ex = ex_df[ex_df['Beach Type']==beach_type_label].set_index('Year').reindex(years)['exceed_rate']\n    vec_rain = rain_df.set_index('Year').reindex(years)['summer_rain']\n    # Pearson\n    r = np.corrcoef(vec_rain.values, vec_ex.values)[0,1]\n    return r, vec_rain.values, vec_ex.values\n\n# Determine labels\nfresh_label = 'Freshwater'\nmarine_label = 'Marine'\n\nr_fresh, rf, ef = corr_for_type(fresh_ex, fresh_rain, fresh_label)\n# marine exceedance from marine_ex for label Marine\nr_marine, rm, em = corr_for_type(marine_ex, marine_rain, marine_label)\n\nprint('Freshwater corr:', r_fresh)\nprint('Marine corr:', r_marine)\nprint('fresh rain', rf, 'fresh ex', ef)\nprint('marine rain', rm, 'marine ex', em)\n\nanswer = 'Freshwater' if r_fresh>r_marine else 'Marine'\nprint('ANSWER', answer)\n"}) [toolUseId=call_PXS8Bwnja7xpMTVjRjj9zcSE]
