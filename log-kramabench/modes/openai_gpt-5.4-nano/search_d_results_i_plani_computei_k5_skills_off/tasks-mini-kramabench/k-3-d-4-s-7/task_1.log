rage rainfall across specified station sets\nfresh_stations=['Boston','Chatham','Amherst','Ashburnham']\nmarine_stations=['Boston','Chatham']\n\nrain_fresh=pd.concat([rainfall[s] for s in fresh_stations],axis=1).mean(axis=1)\nrain_marine=pd.concat([rainfall[s] for s in marine_stations],axis=1).mean(axis=1)\n\n# Load water body testing exceedance data\nw2007='s3://sana-kramabench/datagov/kramabench-environment-hard-16/files/water-body-testing-2007.csv'\nw2008='s3://sana-kramabench/datagov/kramabench-environment-hard-16/files/water-body-testing-2008.csv'\nw2009='s3://sana-kramabench/datagov/kramabench-environment-hard-16/files/water-body-testing-2009.csv'\n\n\ndef read_water(uri):\n    return pd.read_csv(uri)\n\nw=pd.concat([read_water(w2007),read_water(w2008),read_water(w2009)],ignore_index=True)\n\n# Indicator violation yes/no\nw['Violation']=w['Violation'].map(lambda x: 1 if str(x).lower()=='yes' else 0)\nw['Sample Date']=pd.to_datetime(w['Sample Date'])\n\n# Map beaches: Amherst, Ashburnham appear in freshwater; Marine uses Boston/Chatham.\n# We compute exceedance rate per year as total Violation / total samples for beach type.\n\n# Determine which Beach Name corresponds to stations. Use exact Beach Name strings.\n# Filter to needed beach names and types.\n\nneed_fresh=['Boston','Chatham','Amherst','Ashburnham']\nneed_marine=['Boston','Chatham']\n\n# Some beach names in file may include address. So match startswith station name.\n\ndef match_beach(name, station):\n    return str(station).lower() in str(name).lower()\n\n# Freshwater\nfresh=w[w['Beach Name'].apply(lambda x: any(match_beach(x,s) for s in need_fresh)) & (w['Beach Type Description'].str.lower()=='freshwater')]\n# Marine\nmarine=w[w['Beach Name'].apply(lambda x: any(match_beach(x,s) for s in need_marine)) & (w['Beach Type Description'].str.lower()=='marine')]\n\n# Exceedance rate per year\nexc_fresh=fresh.groupby('Year')['Violation'].mean().reindex(years)\nexc_marine=marine.groupby('Year')['Violation'].