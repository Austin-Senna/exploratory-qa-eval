each_datasheet.csv',\n    'Malibu Beach': 'malibu_beach_datasheet.csv',\n    'Tenean Beach': 'tenean_beach_datasheet.csv',\n    'Wollaston Beach': 'wollaston_beach_datasheet.csv',\n}\n\nseen_files = []\nfor beach in beaches:\n    fname = file_map.get(beach)\n    if fname and fname not in seen_files:\n        seen_files.append(fname)\n\nall_tidy = []\nfor fname in seen_files:\n    path = os.path.join(base, fname)\n    all_tidy.append(prepare_beach_datasheet(path))\n\nall_df = pd.concat(all_tidy, ignore_index=True)\nfailed = all_df[all_df['Enterococcus'] > 104]\nwith_rain_24h = failed[failed['1-Day Rain'] > 0]\npercentage = (len(with_rain_24h) / len(failed)) * 100 if len(failed) else 0\nprint(f'{percentage:.2f}')", "reason": "Repaired the code to actually compute the requested percentage across all Boston Harbor beach datasheets by reading the beach list, loading each relevant datasheet once, reshaping the multi-location CSVs into tidy rows, filtering samples with Enterococcus > 104, then calculating the share of those failed samples with positive 1-Day Rain (within 24 hours), and printing the rounded result."}) [toolUseId=call_CPJoQpjZkQqlAQOUMx2D0R9q]
