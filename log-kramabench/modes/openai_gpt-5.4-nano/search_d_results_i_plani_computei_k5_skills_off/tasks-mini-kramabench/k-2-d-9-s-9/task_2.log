n, the beach name is in same position in row header_row-3? \n    # We'll use top title rows: read 3 rows above header_row to find beach labels.\n    top = pd.read_csv(base+fname, header=None, nrows=header_row)\n    # take last row before header_row that contains beach label strings (non-null/non-empty)\n    # We'll map using column positions based on pattern of Tag/Enterococcus repeats.\n    # Simplify: use column position to look up beach label from earlier row where that position has non-null.\n    beach_label_row = None\n    for r in range(header_row-1, max(-1, header_row-6), -1):\n        if r<0: continue\n        if top.shape[1]>0 and any((str(x).strip()!='') and ('Enterococcus' not in str(x)) and ('Date' not in str(x)) for x in top.iloc[r].values):\n            beach_label_row=r\n            break\n    if beach_label_row is None:\n        beach_label_row=header_row-1\n    # build mapping from enterococcus col index to label in beach_label_row at same index\n    row_vals = pd.read_csv(base+fname, header=None, nrows=header_row+1).iloc[beach_label_row]\n    # indices\n    for c in ent_cols:\n        idx = cols.index(c)\n        label=str(row_vals.iloc[idx])\n        label=label.strip('\" ')\n        # clean\n        if label=='':\n            # fallback using fname\n            label=_\n        # remove commas\n        label=label.replace(',','').strip()\n        order.append(label)\n    # now compute max over samples per beach column (all enterococcus columns share counts for their beach)\n    for c in ent_cols:\n        label=str(cols[cols.index(c)])\n    \n    # date filter\n    dfh[date_col]=pd.to_datetime(dfh[date_col], errors='coerce')\n    dff=dfh[(dfh[date_col]>=pd.Timestamp('2020-01-01')) & (dfh[date_col]<=pd.Timestamp('2024-12-31'))].copy()\n    for c in ent_cols:\n        # map label\n        idx = cols.index(c)\n        label=str(pd.read_csv(base+fname, header=None, nrows=header_row+1).iloc[beach_label_row].iloc[idx]).strip('\" ')\n        if label=='