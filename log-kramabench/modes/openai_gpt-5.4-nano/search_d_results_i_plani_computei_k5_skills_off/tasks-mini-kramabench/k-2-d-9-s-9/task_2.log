cate columns named exactly 'Date' and pairs like Tag/Enterococcus repeating.\n    cols=list(df.columns)\n    # normalize column names by stripping quotes\n    df.columns=[c.strip().strip('\"') for c in cols]\n    # identify date col\n    date_col=[c for c in df.columns if c.lower()=='date']\n    if not date_col:\n        # sometimes quoted\n        date_col=[c for c in df.columns if 'Date' in c]\n    dcol=date_col[0]\n    # identify beach-specific blocks by locating repeated Tag/Enterococcus columns\n    # columns include: 1-Day Rain,2-Day Rain,3-Day Rain, Tag,Enterococcus, Tag,Enterococcus, Tag,Enterococcus\n    # We'll find sequences where column name == 'Tag' and 'Enterococcus'\n    tag_idxs=[i for i,c in enumerate(df.columns) if c=='Tag']\n    ent_idxs=[i for i,c in enumerate(df.columns) if c=='Enterococcus']\n    # We assume order Tag,Enterococcus repeated and aligned.\n    pairs=[]\n    # build by scanning left to right\n    i=0\n    while i<len(df.columns)-1:\n        if df.columns[i]=='Tag' and df.columns[i+1]=='Enterococcus':\n            pairs.append((df.columns[i], df.columns[i+1]))\n            i+=2\n        else:\n            i+=1\n    # Determine beach names from first few rows: they appear in columns row0\n    # In preview, column names include 'Pleasure Bay Beach, South Boston: Bacterial Water Quality' in first col, not actual beach.\n    # Beach names are in data row where columns are not empty. We'll infer from first non-null in each Tag/Enterococcus pair for columns at top? easier: use fixed known order for these datasets.\n    # We'll hardcode mapping based on dataset file type and order.\n    if 'pleasure_bay_and_castle_island' in uri:\n        # order in preview: Pleasure Bay @ Broadway, Pleasure Bay @ Flagpole, Castle Island Playground\n        beach_names=['Pleasure Bay @ Broadway','Pleasure Bay @ Flagpole','Castle Island Playground']\n    elif 'carson_beach' in uri:\n        beach_names=['I Street (Carson Beach)','McCormack Bathhouse']\n    