exceedance_rate'})\n\n# beaches present in all four years\npresent = annual.groupby('Beach_norm')['Year'].nunique()\ncommon = present[present==4].index\nannual_common = annual[annual['Beach_norm'].isin(common)].copy()\n\n# average across years\navg = annual_common.groupby('Beach_norm', as_index=False)['annual_exceedance_rate'].mean()\nmax_val = avg['annual_exceedance_rate'].max()\ntop = avg[avg['annual_exceedance_rate']==max_val].sort_values('Beach_norm')\nprint(top.to_string(index=False))\nprint('MAX', max_val)\nprint('ANSWER', top.iloc[0]['Beach_norm'] if len(top)>0 else None)\n"}) [toolUseId=call_VqkHuqmS9SIyHcTkDrcNC0QO]
