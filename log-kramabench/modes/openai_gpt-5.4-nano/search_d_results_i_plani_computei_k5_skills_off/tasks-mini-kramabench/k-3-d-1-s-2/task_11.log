ws_elev_col = c\n            break\n\nraws_match = raws[[raws_station_col, raws_elev_col]].copy()\nraws_match[raws_station_col] = raws_match[raws_station_col].astype(str)\n\nmerged = pd.merge(\n    wildfire_stations.to_frame('station_id').drop_duplicates(),\n    raws_match.rename(columns={raws_station_col:'station_id'}),\n    on='station_id',\n    how='inner'\n)\n\nmerged[raws_elev_col] = pd.to_numeric(merged[raws_elev_col], errors='coerce')\nmerged = merged.dropna(subset=[raws_elev_col])\n\nmean_elev = merged[raws_elev_col].mean()\n# rounded to nearest foot (as per logic)\nans = int(round(mean_elev))\nprint('unique_fire_stations', wildfire_stations.nunique())\nprint('matched_stations', len(merged))\nprint('mean_elevation', mean_elev)\nprint('answer', ans)\n"}) [toolUseId=call_oXVA02UyxRiSu2Ir3dyHrlgv]
