liases = {\n        'England':'United Kingdom','Anglo-Saxons':'United Kingdom','Wessex':'United Kingdom','Danish Vikings':'Denmark',\n        'Danes':'Denmark','Vikings':'Denmark','Magyars':'Hungary','Moravia':'Czechia','France':'France',\n        'Iberians':'Spain','Muslims':'Spain','Franks':'France','Byzantium':'Greece','Russia':'Russia',\n        'England ':'United Kingdom'\n    }\n    if a in aliases: return aliases[a]\n    # try partial matches of modern country names\n    best=None\n    for mc in modern_countries:\n        if mc.lower() in a.lower():\n            # prefer exact word boundary matches\n            best=mc\n            break\n    if best is not None: return best\n    # token based mapping for a few known patterns\n    if re.search(r\"\\bFranks\\b\", a, re.I): return 'France'\n    if re.search(r\"Byzantium\", a, re.I): return 'Greece'\n    if re.search(r\"Arab|Aghlabids|Ibn-Hafsun|Muslims\", a, re.I):\n        # map to Tunisia/Spain unknown; choose Spain if 'Ibn-Hafsun' or 'Ronda' else Tunisia\n        if re.search(r\"Ronda|Balearic|Salonika\", a, re.I):\n            return 'Spain' if re.search(r\"Ronda|Balearic\", a, re.I) else 'Greece'\n        return 'Tunisia'\n    if re.search(r\"Danish|Danes\", a, re.I): return 'Denmark'\n    if re.search(r\"Magyars\", a, re.I): return 'Hungary'\n    if re.search(r\"Saxony\", a, re.I): return 'Germany'\n    if re.search(r\"Germans\", a, re.I): return 'Germany'\n    if re.search(r\"Netherlands\", a, re.I): return 'Netherlands'\n    if re.search(r\"Italy\", a, re.I): return 'Italy'\n    if re.search(r\"Spain\", a, re.I): return 'Spain'\n    if re.search(r\"Russia\", a, re.I): return 'Russia'\n    if re.search(r\"Scotland\", a, re.I): return 'United Kingdom'\n    if re.search(r\"Ireland\", a, re.I): return 'Ireland'\n    return None\n\n# filter years 800-1400 and duration>=1 year (end-start>=1)\nconf['StartYear']=pd.to_numeric(conf['StartYear'], errors='coerce')\nconf['EndYear']=pd.to_numeric(conf['EndYear'], errors='coerce')\nconf2=conf[(conf['StartYear']>=800) & (conf['EndYear']<=1400) & ((conf['EndYear']-conf['StartYear'])>=0)]\n\n# create side pairs\nrows=[]\nfor _,r in conf2.iterrows():\n    a1,a2=split_sides(r['Conflict'])\n    c1=map_actor(a1)\n    c2=map_actor(a2)\n    if c1 is None or c2 is None: continue\n    if c1==c2: continue\n    rows.append((c1,c2,int(r['StartYear']),int(r['EndYear'])))\n\npair_df=pd.DataFrame(rows, columns=['c1','c2','start','end'])\n# merge overlapping/adjacent intervals per ordered pair? conflicts between two actors, treat unordered\npair_df['pair']=pair_df.apply(lambda x: tuple(sorted([x.c1,x.c2])), axis=1)\n\nmerged_count=0\nfor pair,grp in pair_df.groupby('pair'):\n    grp=grp.sort_values('start')\n    cur_s=None;cur_e=None\n    for _,row in grp.iterrows():\n        s=row.start; e=row.end\n        if cur_s is None:\n            cur_s=s;cur_e=e\n        else:\n            # overlap if s<=cur_e+1? but lasts at least a year. define merge overlapping intervals.\n            if s<=cur_e: # overlap\n                cur_e=max(cur_e,e)\n            else:\n                merged_count+=1\n                cur_s=s;cur_e=e\n    if cur_s is not None:\n        merged_count+=1\n\nprint(int(merged_count))\n"}) [toolUseId=call_B2DfxRehyHLgDYkxrU2RLKKT]
