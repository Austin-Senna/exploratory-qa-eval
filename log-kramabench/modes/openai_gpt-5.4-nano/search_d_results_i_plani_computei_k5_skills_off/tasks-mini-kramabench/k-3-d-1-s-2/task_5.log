63]\n    return float(l2[52:63].strip())\n\n# compute semi-major axis from n: n = sqrt(mu/a^3) / (2*pi) ???\n# For two-body: mean motion rad/s = sqrt(mu/a^3). TLE n is rev/day.\n# Convert n to rad/s: n_rad_s = n_rev_day * 2*pi / 86400\n# then a = (mu / (n_rad_s**2))**(1/3)\n\ndef semi_major_axis(n_rev_day):\n    n_rad_s = n_rev_day * 2*math.pi / 86400.0\n    a = (mu / (n_rad_s**2))**(1/3)\n    return a\n\nrecords=[]\nfor i in range(len(lines)-1):\n    if lines[i].startswith('1 43180'):\n        l1=lines[i]\n        l2=lines[i+1]\n        if l2.startswith('2 43180'):\n            epoch=parse_epoch_from_line1(l1)\n            n=parse_mean_motion(l2)\n            a=semi_major_axis(n)\n            records.append((epoch,a))\n\ndf=pd.DataFrame(records, columns=['epoch','a_km'])\ndf = df.sort_values('epoch')\n\n# round epochs to nearest hour\n# nearest hour using pandas round\n\ndf['epoch_hr'] = df['epoch'].dt.tz_convert('UTC').dt.round('h')\n\n# deduplicate by hour: take mean a_km per hour\nah = df.groupby('epoch_hr', as_index=False)['a_km'].mean().sort_values('epoch_hr')\n\n# Compute delta a as change over time (semi-major axis change). We'll use first difference between successive hours.\nah['delta_a_km'] = ah['a_km'].diff()\n\n# Filter May 1-30 inclusive for delta_a (needs prior hour for diff)\nstart = datetime(2024,5,1,0,0,tzinfo=timezone.utc)\nend = datetime(2024,5,30,23,0,tzinfo=timezone.utc)\n\n# Keep hours within window\nahw = ah[(ah['epoch_hr']>=start-timedelta(hours=1)) & (ah['epoch_hr']<=end)].copy()\n\n# restrict to May 1-30 hours for delta_a by dropping NaN and outside\nahw = ahw[(ahw['epoch_hr']>=start) & (ahw['epoch_hr']<=end) & (ahw['delta_a_km'].notna())]\n\n# ---------- Parse OMNI2 AP ----------\n# Omni file appears fixed-width/space-delimited. First columns: year doy? and hour? in sample: \"2024   1  0 2596 ...\"\n# Likely columns: year month day hour minute? Actually there are 6+ numbers: year, DOY?, UT hours etc.\n# We'll read via whitespace split and