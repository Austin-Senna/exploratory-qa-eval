y at single timestamp where OMNI/GOES ends and density begins.\n# For wu335, omni/GOES ends at 2016-10-26 00:00 and density begins immediately at 2016-10-29 00:00 doesn't fit. We'll instead follow their explicit density window 2016-10-29 only.\n\n# We'll create context ending at hour 2016-10-28 20..?? Actually need 16-hour context ending at OMNI/GOES end (eval_end_omni end) and forecast next 4 hours of density starting immediately after overlap timestamp.\n# Given prompt: Density begins at 2016-10-29; thus overlap timestamp = 2016-10-26? not.\n# Instead, treat evaluation as: use last 16 hours of available features ending at 2016-10-26 23, then density target hours 2016-10-29 00..03. We'll use nearest density hours.\n\n# Fit VAR(1) on pooled training feature series (all hours)\ntrain_feats = X_train_full.dropna().astype(float)\n\n# Ensure at least VAR fit\nvar = VAR(train_feats)\nvar_res = var.fit(maxlags=1, ic=None, trend='c')\n\n# Prepare linear regression for mapping projected features to density at horizon 1..4.\n# We'll predict y(t+1..t+4) using projected features at those lead times; simplest: use flattened projected feature values length 4*5.\n\n# Build training samples using last 16 hours within X_train_full for which density targets exist.\nidx_hours = X_train_full.index\n\nsamples_X=[]\nsamples_y=[]\nfor i in range(context_len, len(idx_hours)-horizon+1):\n    t = idx_hours[i-1]  # last hour in context = t\n    # Need density at t+1..t+4; density series starts at 2016-10-23 00 within Y_train_full.\n    target_times = [t + pd.Timedelta(hours=k) for k in range(1,horizon+1)]\n    if all([tt in Y_train_full.index for tt in target_times]):\n        context_window = train_feats.loc[:t].iloc[-context_len:]\n        # Project features 4 steps forward starting from last observed state at time t\n        # VAR requires start vector at end of context: use last value and var forecast\n        projected = var_res.forecast(context_window.values, steps=horizon)  # shape (horizon, n_features)\n        samples_X.append(projected.reshape(-1))\n        samples_y.append(Y_train_full.loc[target_times].values)\n\nX_mat = np.vstack(samples_X)\ny_mat = np.vstack(samples_y)  # (n_samples, horizon)\n\nlin = LinearRegression()\nlin.fit(X_mat, y_mat)\n\n# Evaluation: take evaluation features series from X_eval_full and create one set of context ending at its last hour.\n# We'll forecast 4 hours of density starting at eval_density_start.\n# Use 16-hour context ending at last available feature time before forecast alignment.\n# We'll match first forecast time to eval_density_start.\nlast_feat_time = X_eval_full.index.max()\n# We want forecast lead 1 corresponds to eval_density_start.\n# So context end time t such that t+1h = eval_density_start => t = eval_density_start -1h.\nt_needed = eval_density_start - pd.Timedelta(hours=1)\nif t_needed not in X_eval_full.index:\n    # fallback to nearest <=\n    t_needed = X_eval_full.index[X_eval_full.index<=t_needed][-1]\n\ncontext = X_eval_full.loc[:t_needed].iloc[-context_len:]\nproj = var_res.forecast(context.values, steps=horizon)\nX_eval = proj.reshape(1,-1)\n\ny_pred = lin.predict(X_eval).reshape(-1)\n\n# Observed density for eval_density_start..start+3\nobs_times = [eval_density_start + pd.Timedelta(hours=k) for k in range(horizon)]\ny_obs = Y_eval_full.loc[obs_times].values.reshape(-1)\n\nrmse = np.sqrt(mean_squared_error(y_obs, y_pred))\nprint('RMSE', rmse)\nprint('n_points', len(y_obs))\nprint('y_obs', y_obs)\nprint('y_pred', y_pred)\n"}) [toolUseId=call_jZe29hF2XwyCsX74X7L4xvFJ]
