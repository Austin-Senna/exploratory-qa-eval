ndex i-1\nidx=X_train.index\nX_samples=[]\ny_samples=[]\nfor i in range(context_len, len(idx)-horizon+1):\n    t_end=idx[i-1]\n    target_times=[t_end+pd.Timedelta(hours=k) for k in range(1,horizon+1)]\n    if all(tt in Y_train.index for tt in target_times):\n        context_window=X_train.loc[:t_end].iloc[-context_len:]\n        proj=var1_forecast_from_last(context_window.values[-1], horizon)\n        X_samples.append(proj.reshape(-1))\n        y_samples.append(Y_train.loc[target_times].values)\n\nX_mat=np.vstack(X_samples)\ny_mat=np.vstack(y_samples)\n\nlin=LinearRegression()\nlin.fit(X_mat, y_mat)\n\n# Evaluation: forecast next-4 hours starting at 2016-10-29 00:00\nfeat_eval_start=pd.Timestamp('2016-10-25 00:00:00')\nfeat_eval_end=pd.Timestamp('2016-10-26 23:00:00')\nX_eval=features335.loc[feat_eval_start:feat_eval_end, feat_cols].dropna().astype(float)\n\n# pick context end time t_needed = eval_start -1h so lead1 hits eval_start\neval_density_start=pd.Timestamp('2016-10-29 00:00:00')\nt_needed=eval_density_start-pd.Timedelta(hours=1)\nif t_needed not in X_eval.index:\n    t_needed=X_eval.index[X_eval.index<=t_needed][-1]\ncontext=X_eval.loc[:t_needed].iloc[-context_len:]\nproj_eval=var1_forecast_from_last(context.values[-1], horizon)\nX_eval_vec=proj_eval.reshape(1,-1)\n\ny_pred=lin.predict(X_eval_vec).reshape(-1)\n\nobs_times=[eval_density_start+pd.Timedelta(hours=k) for k in range(horizon)]\nY_eval=dens335_h.loc[obs_times].astype(float)\n\ny_obs=Y_eval.values\nrmse=np.sqrt(mean_squared_error(y_obs, y_pred))\nprint(rmse)\n"})
