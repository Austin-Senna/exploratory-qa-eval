oss from col5\n        rows.append(r6)\n    else:\n        # also include if looks like branch text\n        if branch!='':\n            rows.append(r6)\n\nimport numpy as np\n\ndef parse_money(s):\n    if s is None: return np.nan\n    s=str(s).strip()\n    if s=='': return np.nan\n    # remove commas, dollar signs, spaces\n    s=s.replace('$','').replace(',','').strip()\n    # handle trailing spaces\n    s=s.replace('M','000000').replace('m','000000')\n    s=s.replace('K','000').replace('k','000')\n    # if value is like '1,300 ' already removed commas\n    # Now if it contains '-' ranges take max? question says clean median fraud loss; it's median so no range.\n    # If still contains non-numeric, extract first number\n    m=re.search(r'[-+]?[0-9]*\\.?[0-9]+', s)\n    return float(m.group()) if m else np.nan\n\n# Build mapping\nbranch_to_median={}\nfor r6 in rows:\n    branch=r6[0].strip().strip('\"')\n    median_raw=r6[5]\n    val=parse_money(median_raw)\n    branch_to_median[branch]=val\n\nbranch_to_median\nmax_branch=max(branch_to_median, key=branch_to_median.get)\nmax_val=branch_to_median[max_branch]\nmax_branch, max_val"}) [toolUseId=call_YQC7fGpYhzc1EgcRW746XchL]
