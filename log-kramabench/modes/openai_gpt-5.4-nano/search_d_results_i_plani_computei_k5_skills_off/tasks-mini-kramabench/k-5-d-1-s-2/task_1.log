 not found in sheet {ws.title}')\n\n\ndef is_number(x):\n    return isinstance(x, (int, float)) and not math.isnan(x)\n\n\ndef ranks(values):\n    ordered = sorted(enumerate(values), key=lambda t: t[1])\n    out = [0.0] * len(values)\n    i = 0\n    while i < len(ordered):\n        j = i\n        while j + 1 < len(ordered) and ordered[j + 1][1] == ordered[i][1]:\n            j += 1\n        avg_rank = (i + 1 + j + 1) / 2.0\n        for k in range(i, j + 1):\n            out[ordered[k][0]] = avg_rank\n        i = j + 1\n    return out\n\n\ndef pearson(xs, ys):\n    mx = sum(xs) / len(xs)\n    my = sum(ys) / len(ys)\n    num = sum((x - mx) * (y - my) for x, y in zip(xs, ys))\n    denx = sum((x - mx) ** 2 for x in xs)\n    deny = sum((y - my) ** 2 for y in ys)\n    return num / math.sqrt(denx * deny)\n\nws_global = wbp[global_sheet]\nws_phospho = wbp[phospho_sheet]\nplk1 = get_row_values(ws_global, 'PLK1', case_ids)\nchek2_s163 = get_row_values(ws_phospho, 'CHEK2-S163', case_ids)\npaired = [(float(a), float(b)) for a, b in zip(plk1, chek2_s163) if is_number(a) and is_number(b)]\n\nrho = pearson(ranks([a for a, _ in paired]), ranks([b for _, b in paired]))\nprint(f'{global_sheet}|{phospho_sheet}|{rho:.4f}')\n", "reason": "Rewrote the code to identify the correct sample-level sheets from the README in the proteomics workbook, load the clinical cohort for non-excluded Endometrioid/Serous tumor cases, extract PLK1 global proteomics and CHEK2-S163 phosphoproteomics abundance values, pair non-missing samples, recompute the Spearman correlation, and print the result."}) [toolUseId=call_KN6JOJtMX8aFXVl4QNNNE1RG]
