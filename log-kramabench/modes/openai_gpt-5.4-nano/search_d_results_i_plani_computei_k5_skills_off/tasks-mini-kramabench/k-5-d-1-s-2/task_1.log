 in df.columns:\n        if 'sample' in str(c).lower():\n            return c\n    for c in df.columns:\n        if 'case' in str(c).lower():\n            return c\n    return df.columns[0]\n\nid_col_global = find_id_col(global_df)\nid_col_phospho = find_id_col(phospho_df)\nid_col_clin = find_id_col(clinical_df) if clinical_df is not None else None\n\n# Filter clinical: included + endometrioid or serous\n# Find histology column and inclusion flag\nhist_col=None\nfor c in clinical_df.columns:\n    if 'hist' in str(c).lower():\n        hist_col=c;break\nif hist_col is None:\n    for c in clinical_df.columns:\n        if 'type' in str(c).lower() or 'subtype' in str(c).lower():\n            hist_col=c;break\n\nincl_col=None\nfor c in clinical_df.columns:\n    if any(k in str(c).lower() for k in ['included','exclude','exclusion','filter','analysis']):\n        incl_col=c;break\n\n# Determine included rows\nclin = clinical_df.copy()\nif incl_col is not None:\n    # if column is boolean/0-1 or text\n    if pd.api.types.is_numeric_dtype(clin[incl_col]):\n        clin_included = clin[clin[incl_col].astype(float)==1]\n    else:\n        clin_included = clin[clin[incl_col].astype(str).str.lower().isin(['included','yes','true','1'])]\nelse:\n    clin_included = clin\n\n# histology filter\nif hist_col is not None:\n    allowed = ['endometrioid','serous']\n    m = clin_included[hist_col].astype(str).str.lower()\n    clin_included = clin_included[m.str.contains('endometrioid') | m.str.contains('serous')]\n\n# Ensure unique by sample id\nclin_included = clin_included.dropna(subset=[id_col_clin])\nkeep_ids = clin_included[id_col_clin].astype(str).unique().tolist()\n\n# Extract PLK1 abundance column from global_df\nplk_col=None\nfor c in global_df.columns:\n    if str(c).strip().lower() in ['plk1','plk1 abundance'] or 'plk1' in str(c).lower():\n        plk_col=c;break\n\nchek_col=None\nfor c in phospho_df.columns:\n    if 'chek2' in str(c).lower() and 's163' in str(c).lower():\n     