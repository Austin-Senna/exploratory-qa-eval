strings):\n    ns = {'a': 'http://schemas.openxmlformats.org/spreadsheetml/2006/main'}\n    cell_type = cell.attrib.get('t')\n    if cell_type == 'inlineStr':\n        texts = [t.text or '' for t in cell.iterfind('.//a:t', ns)]\n        return ''.join(texts)\n    v = cell.find('a:v', ns)\n    if v is None:\n        return None\n    text = v.text\n    if cell_type == 's':\n        try:\n            return shared_strings[int(text)]\n        except Exception:\n            return text\n    return text\n\n\ndef load_first_sheet_rows(path):\n    with zipfile.ZipFile(path) as z:\n        shared_strings = parse_shared_strings(z)\n        sheet_path = get_sheet_path(z)\n        root = ET.fromstring(z.read(sheet_path))\n        ns = {'a': 'http://schemas.openxmlformats.org/spreadsheetml/2006/main'}\n        rows = []\n        for row in root.findall('.//a:sheetData/a:row', ns):\n            vals = {}\n            max_idx = -1\n            for c in row.findall('a:c', ns):\n                ref = c.attrib.get('r', '')\n                idx = col_to_index(ref)\n                max_idx = max(max_idx, idx)\n                vals[idx] = parse_cell_value(c, shared_strings)\n            if max_idx >= 0:\n                arr = [None] * (max_idx + 1)\n                for idx, val in vals.items():\n                    arr[idx] = val\n                rows.append(arr)\n        return rows\n\n\ndef pad(row, n):\n    if len(row) < n:\n        return row + [None] * (n - len(row))\n    return row[:n]\n\n\ndef to_float(x):\n    if x is None:\n        return None\n    if isinstance(x, (int, float)):\n        return float(x)\n    s = str(x).strip()\n    if s == '':\n        return None\n    try:\n        return float(s)\n    except Exception:\n        return None\n\n\ncarbon_path = find_file('radiocarbon_database_regional.xlsx')\nrows = load_first_sheet_rows(carbon_path)\nrows = [r for r in rows if any(v not in (None, '') for v in r)]\nheader = [str(v).strip() if v is not None else '' for v in rows