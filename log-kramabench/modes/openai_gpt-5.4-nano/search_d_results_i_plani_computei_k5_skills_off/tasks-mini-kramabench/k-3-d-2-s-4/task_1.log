abench-environment-hard-12/files/carson_beach_datasheet.csv',\n    'Malibu Beach':'s3://sana-kramabench/datagov/kramabench-environment-hard-12/files/malibu_beach_datasheet.csv',\n    'Wollaston Beach':'s3://sana-kramabench/datagov/kramabench-environment-hard-9/files/wollaston_beach_datasheet.csv',\n    'Constitution Beach':'s3://sana-kramabench/datagov/kramabench-environment-hard-13/files/constitution_beach_datasheet.csv',\n    'Castle Island Beach':'s3://sana-kramabench/datagov/kramabench-environment-hard-16/files/castle_island_beach_datasheet.csv',\n    'Pleasure Bay Beach':'s3://sana-kramabench/datagov/kramabench-environment-hard-16/files/pleasure_bay_beach_datasheet.csv',\n    'City Point Beach':'s3://sana-kramabench/datagov/kramabench-environment-hard-16/files/city_point_beach_datasheet.csv'\n}\n\n# Only keep those that exist in map\nbeaches=[b for b in beaches if b in beach_dataset_map]\n\nrows=[]\nfor b in beaches:\n    uri=beach_dataset_map[b]\n    df=pd.read_csv(uri, header=0)\n    # dataframe headers messy; identify columns containing '3-Day Rain' and 'Enterococcus'\n    cols=df.columns\n    # find 3-day rain col\n    rain_col=[c for c in cols if '3-Day Rain' in str(c)]\n    if not rain_col:\n        # maybe '3-Day Rain ' with quotes; search substring\n        rain_col=[c for c in cols if '3' in str(c) and 'Day' in str(c) and 'Rain' in str(c)]\n    rain_col=rain_col[0]\n    # Enterococcus columns: any with 'Enterococcus'\n    ent_cols=[c for c in cols if 'Enterococcus' in str(c)]\n    # also Tag cols\n    tag_cols=[c for c in cols if 'Tag'==str(c) or 'Tag' in str(c)]\n    # For multi-section datasets, use paired Tag/Enterococcus columns (three communities). We'll handle by iterating over tag_cols and corresponding enterococcus cols by position.\n    # Determine 2023 rows\n    # date col begins with 'Date'\n    date_col=[c for c in cols if 'Date' in str(c)][0]\n    df[date_col]=pd.to_datetime(df[date_col], errors='coerce')\n    df=df.loc[df[date_col].dt.year==2023].copy()\n    if df.empty:\n        continue\n    # Extract municipality from first line raw header in file\n    import io, csv\n    # read first line\n    with sopen(uri,'r') as f:\n        first=f.readline().strip()\n    m=re.search(r',\\s*([^:]+):', first)\n    muni=m.group(1).strip() if m else None\n    if muni not in Ej_munis:\n        continue\n    # Now parse each row for that municipality: choose first Enterococcus/Tag columns if only one set.\n    # If there are multiple tag/enterococcus columns, include all columns, treating each corresponds to subarea; but question asks community >90% EJ populations; municipality filter already, so take all Enterococcus columns in file (they are for subareas within same municipality) regardless.\n    for i in range(len(ent_cols)):\n        ent=ent_cols[i]\n        # find corresponding tag col same index\n        tag=tag_cols[i] if i < len(tag_cols) else None\n        if tag is None:\n            continue\n        # compute enterococcus value from tag\n        def parse_tag(x):\n            if pd.isna(x):\n                return np.nan\n            s=str(x).strip()\n            # format like '<,10'?? In file preview Tag column values like '<' and Enterococcus column like 10? Actually preview shows Tag then Enterococcus numeric.\n            # So tag column likely contains '<' or '>' or '' and enterococcus column contains number\n            return np.nan\n        # Instead use Tag column symbol in tag_cols and numeric in ent col\n        sym=df[tag].astype(str).str.strip()\n        num=pd.to_numeric(df[ent], errors='coerce')\n        val=np.where(sym=='<', num/2, np.where(sym=='>', num, num))\n        tmp=pd.DataFrame({'rain':pd.to_numeric(df[rain_col], errors='coerce'), 'ent':val})\n        tmp=tmp.dropna()\n        if len(tmp):\n            rows.append(tmp)\n\nall_df=pd.concat(rows, ignore_index=True)\n\n# Pearson correlation\ncorr=all_df['rain'].corr(all_df['ent'])\n\ncorr, len(all_df)\n", "dataset_id": "kramabench-environment-hard-7"}) [toolUseId=call_zwUxtIU7nG6my55VUQIvSZWy]
