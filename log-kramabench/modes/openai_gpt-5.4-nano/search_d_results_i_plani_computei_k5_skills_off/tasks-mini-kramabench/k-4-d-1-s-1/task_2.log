mor sample type any\nmask=pd.Series([True]*len(df))\nif exclude_col:\n    ex=df[exclude_col]\n    mask &= ~ex.astype(str).str.lower().isin(['1','true','yes','y','excluded','exclude'])\n# tumor sample condition\ntum_mask=pd.Series([False]*len(df))\nif prote_tn:\n    tum_mask |= df[prote_tn].astype(str).str.lower().eq('tumor')\nif wxs_tum_col:\n    tum_mask |= df[wxs_tum_col].notna()\nif wgs_tum_col:\n    tum_mask |= df[wgs_tum_col].notna()\nmask &= tum_mask\n# age filter\nage=pd.to_numeric(df[age_col], errors='coerce')\nmask &= age>=70\nf=df.loc[mask, figo_col]\ncounts=f.value_counts(dropna=True)\ncounts.head(10), counts.index[0], counts.iloc[0], mask.sum(), df.shape"}) [toolUseId=call_Q082UAXIgnssL6ZVxugBSNJP]
