  sheets = []\n        for sheet in wb_root.findall('m:sheets/m:sheet', NS):\n            name = sheet.attrib['name']\n            rid = sheet.attrib['{http://schemas.openxmlformats.org/officeDocument/2006/relationships}id']\n            target = rels[rid]\n            if not target.startswith('xl/'):\n                target = 'xl/' + target\n            sheets.append((name, target))\n\n    return shared, sheets\n\n\ndef load_sheet_preview(xlsx_path, target, shared, max_rows=50):\n    with ZipFile(xlsx_path) as zf:\n        root = ET.fromstring(zf.read(target))\n        rows = []\n        for row in root.findall('.//m:sheetData/m:row', NS):\n            values = {}\n            for cell in row.findall('m:c', NS):\n                values[column_index(cell.attrib['r'])] = get_cell_value(cell, shared)\n            max_idx = max(values) if values else -1\n            rows.append([values.get(i, '') for i in range(max_idx + 1)])\n            if len(rows) >= max_rows:\n                break\n    return rows\n\n\ndef score_name(text):\n    t = text.lower()\n    score = 0\n    patterns = {\n        'eligibility': ['exclude', 'eligib', 'tumor', 'sample', 'histolog', 'histologic', 'case'],\n        'age': ['age'],\n        'figo': ['figo', 'stage']\n    }\n    matched = {k: [p for p in pats if p in t] for k, pats in patterns.items()}\n    score = sum(len(v) for v in matched.values())\n    return score, matched\n\n\nshared, sheets = load_workbook_metadata(path)\nresults = []\n\nfor sheet_name, target in sheets:\n    rows = load_sheet_preview(path, target, shared, max_rows=50)\n    if not rows:\n        continue\n    header = [str(x).strip() for x in rows[0]]\n    searchable = ' '.join(header).lower()\n    score, matched = score_name(searchable)\n\n    relevant_cols = []\n    for col in header:\n        c = col.lower()\n        if any(k in c for k in ['exclude', 'eligib', 'tumor', 'sample', 'histolog', 'histologic', 'case', 'age', 'figo', 'stage']):\n            relevant_cols.ap