   kept.append(i)\n    kept = sorted(kept)\n    kept_prom = _prominences(vals, kept)\n    return kept, {'prominences': kept_prom}\n\n\npeaks, props = find_peaks_like_scipy(values, prominence=20, distance=5)\nmins, propsm = find_peaks_like_scipy([-v for v in values], prominence=20, distance=5)\n\nmax_df = pd.DataFrame({\n    'Year': [years[i] for i in peaks],\n    'Sunspot': [values[i] for i in peaks],\n    'Prom': props['prominences']\n})\nmin_df = pd.DataFrame({\n    'Year': [years[i] for i in mins],\n    'Sunspot': [values[i] for i in mins],\n    'Prom': propsm['prominences']\n})\n\nmin_years_sorted = sorted(min_df['Year'].tolist())\nintervals = [b - a for a, b in zip(min_years_sorted, min_years_sorted[1:])]\nperiod_est = sum(intervals) / len(intervals) if intervals else None\n\nresult = {\n    'maxima_years': max_df['Year'].tolist(),\n    'minima_years': min_df['Year'].tolist(),\n    'average_cycle_period_years': period_est\n}\nprint(result)", "reason": "Rewrote the script to match the intended analysis in the sandbox using the provided SILSO file path, removed the SciPy dependency by implementing peak detection with prominence and distance constraints in pure Python, filtered years 1960-2020, computed maxima/minima years, estimated average cycle period from consecutive minima spacing, and printed the result."}) [toolUseId=call_PVRkZUT5fhTR3mmGSYbVWhmx]
