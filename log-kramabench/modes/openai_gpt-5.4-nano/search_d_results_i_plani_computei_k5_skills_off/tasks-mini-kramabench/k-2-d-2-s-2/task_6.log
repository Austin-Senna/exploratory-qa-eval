s']=pd.to_numeric(nifc[fire_col2], errors='coerce')\nnifc['acres']=pd.to_numeric(nifc[acres_col2], errors='coerce')\n\nnifc_annual = nifc.groupby('year', as_index=False).agg({'fires':'sum','acres':'sum'})\n\nmerged = pd.merge(noaa_annual, nifc_annual, on='year', suffixes=('_noaa','_nifc'))\nmerged['diff_fires']=merged['fires_noaa']-merged['fires_nifc']\nmerged['diff_acres']=merged['acres_noaa']-merged['acres_nifc']\n\ncorr = merged[['diff_fires','diff_acres']].corr().iloc[0,1]\nprint(corr)\n# Also print years overlap count\nprint(len(merged))\nprint(merged[['year','diff_fires','diff_acres']].head())\n", "dataset_id": "kramabench-wildfire-hard-5"}) [toolUseId=call_5sC6A3mkZkETlJbLsFH20V1x]
