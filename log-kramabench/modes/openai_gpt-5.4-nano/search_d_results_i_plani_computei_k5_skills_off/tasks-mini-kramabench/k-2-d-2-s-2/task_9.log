ere(expected>0).sum().sum()\n\n# Degrees of freedom\ndfree = (r-1)*(k-1)\n\n# p-value: survival function of chi-square using regularized gamma Q(df/2, chi2/2)\n# p = 1 - CDF\nimport mpmath as mp\n\nnu = dfree\nx = chi2\n\nif nu>0:\n    a = nu/2\n    z = x/2\n    # Regularized lower incomplete gamma P(a,z)\n    # p-value = Q(a,z) = gammainc(a, z, inf)/gamma(a)\n    pval = mp.gammainc(a, [z, mp.inf]) / mp.gamma(a)\nelse:\n    pval = mp.nan\n\nprint('shape', ct.shape)\nprint('chi2', float(chi2))\nprint('pval', float(pval))\nprint(float(chi2), float(pval))\n", "dataset_id": "kramabench-wildfire-easy-15", "file_path": "files/noaa_wildfires.csv"}) [toolUseId=call_2QEzxGkmCTUpcWVRYjYDdgaF]
