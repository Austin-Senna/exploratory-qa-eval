ue_cols = [c for c in df.columns if c not in rain_cols + ['Date']]\n    tag_cols = [c for c in value_cols if c.endswith('_Tag') or c == 'Tag']\n    ent_cols = [c for c in value_cols if c.endswith('_Enterococcus') or c == 'Enterococcus']\n\n    if not ent_cols:\n        return 0\n\n    id_vars = [c for c in df.columns if c not in tag_cols + ent_cols]\n    use_cols = tag_cols + ent_cols\n    melted = df.melt(id_vars=id_vars, value_vars=use_cols, var_name='Variable', value_name='Value')\n    melted['Location'] = melted['Variable'].str.rsplit('_', n=1).str[0]\n    melted['Measure'] = melted['Variable'].str.rsplit('_', n=1).str[-1]\n    tidy = melted.pivot_table(index=id_vars + ['Location'], columns='Measure', values='Value', aggfunc='first').reset_index()\n    tidy.columns.name = None\n\n    for col in ['1-Day Rain', '2-Day Rain', '3-Day Rain']:\n        tidy[col] = tidy[col].map(normalize_rain)\n    tidy['Enterococcus'] = tidy['Enterococcus'].map(numeric_enterococcus)\n\n    mask = (\n        tidy['1-Day Rain'].eq(0) &\n        tidy['2-Day Rain'].eq(0) &\n        tidy['3-Day Rain'].eq(0) &\n        tidy['Enterococcus'].ge(104)\n    )\n    return int(mask.sum())\n\n\ndef main():\n    patterns = [\n        '**/*beach*_datasheet.csv',\n        '**/*_datasheet.csv',\n    ]\n    files = []\n    for pattern in patterns:\n        files.extend(glob.glob(pattern, recursive=True))\n\n    files = sorted(set(f for f in files if os.path.isfile(f)))\n\n    best_beach = None\n    best_count = -1\n    for path in files:\n        count = count_failures(path)\n        beach = beach_name_from_path(path)\n        if count > best_count:\n            best_count = count\n            best_beach = beach\n\n    print(best_beach)\n\n\nif __name__ == '__main__':\n    main()\n", "reason": "Implemented full solution: discovers beach datasheet CSVs, parses the two-row header format, reshapes per-location Enterococcus measurements, treats zero/none rainfall equivalents as no rain for all preceding 3 