read('xl/_rels/workbook.xml.rels'))\n    rel_map = {}\n    for rel in rels.findall('rel:Relationship', NS):\n        rel_map[rel.attrib['Id']] = rel.attrib['Target']\n\n    sheets = []\n    for sheet in wb.find('main:sheets', NS):\n        name = sheet.attrib.get('name', '')\n        rid = sheet.attrib.get('{%s}id' % NS['docrel'])\n        target = rel_map.get(rid, '')\n        if target and not target.startswith('xl/'):\n            target = 'xl/' + target\n        sheets.append((name, target))\n    return sheets\n\n\ndef parse_sheet_rows(zf, sheet_path, shared_strings):\n    root = ET.fromstring(zf.read(sheet_path))\n    sheet_data = root.find('main:sheetData', NS)\n    rows = []\n    if sheet_data is None:\n        return rows\n    for row in sheet_data.findall('main:row', NS):\n        vals = {}\n        for cell in row.findall('main:c', NS):\n            ref = cell.attrib.get('r', '')\n            m = re.match(r'([A-Z]+)', ref)\n            if not m:\n                continue\n            idx = col_letters_to_index(m.group(1))\n            vals[idx] = get_cell_value(cell, shared_strings)\n        rows.append(vals)\n    return rows\n\n\ndef normalize(text):\n    return re.sub(r'\\s+', ' ', str(text).strip())\n\n\ndef score_header(values):\n    texts = [normalize(v) for v in values if normalize(v)]\n    if not texts:\n        return -1\n    score = 0\n    joined = ' | '.join(t.lower() for t in texts)\n    if any('dust' in t.lower() for t in texts):\n        score += 5\n    if any('wet' in t.lower() and 'dry' in t.lower() for t in texts):\n        score += 5\n    if any(t.lower() == 'ca' or 'calcium' in t.lower() for t in texts):\n        score += 5\n    if any('odp 967' in t.lower() for t in texts):\n        score += 2\n    if len(texts) >= 3:\n        score += 1\n    score += min(len(joined), 200) / 1000.0\n    return score\n\n\nwith zipfile.ZipFile(path) as zf:\n    shared_strings = parse_shared_strings(zf)\n    sheets = workbook_info(zf)\n\n    print('Workbook:', path)\n    print('Sheets:', [name for name, _ in sheets])\n\n    found = []\n\n    for sheet_name, sheet_path in sheets:\n        rows = parse_sheet_rows(zf, sheet_path, shared_strings)\n        best = None\n        for i, row in enumerate(rows[:20]):\n            max_idx = max(row.keys()) if row else -1\n            values = [row.get(j, '') for j in range(max_idx + 1)]\n            s = score_header(values)\n            if best is None or s > best[0]:\n                best = (s, i, values)\n\n        print('\\nSheet:', sheet_name)\n        if best is None:\n            print('  No readable rows found')\n            continue\n\n        _, header_row_idx, header_values = best\n        header_values = [normalize(v) for v in header_values]\n        nonempty_headers = [v for v in header_values if v]\n        print('  Chosen header row index:', header_row_idx)\n        print('  Columns:', nonempty_headers)\n\n        dust_candidates = []\n        wetdry_candidates = []\n        calcium_candidates = []\n\n        for idx, col in enumerate(header_values):\n            low = col.lower()\n            if not col:\n                continue\n            if 'dust' in low:\n                dust_candidates.append((idx, col))\n            if 'wet' in low and 'dry' in low:\n                wetdry_candidates.append((idx, col))\n            if low == 'ca' or 'calcium' in low:\n                calcium_candidates.append((idx, col))\n\n        print('  Dust proxy candidates:', dust_candidates)\n        print('  Wet-dry index candidates:', wetdry_candidates)\n        print('  Calcium candidates:', calcium_candidates)\n\n        if dust_candidates or wetdry_candidates or calcium_candidates:\n            found.append({\n                'sheet': sheet_name,\n                'header_row': header_row_idx,\n                'dust': dust_candidates,\n                'wetdry': wetdry_candidates,\n                'calcium': calcium_candidates,\n            })\n\n    print('\\nSummary:')\n    for item in found:\n        print(item)\n", "reason": "Replaced pandas/openpyxl Excel reading with a pure-stdlib .xlsx inspector using zipfile and XML parsing, so it works despite openpyxl being unavailable. The script prints workbook sheets, inferred header rows, column names, and identifies dust proxy, wet-dry index, and calcium candidates."}) [toolUseId=call_ncDBIYsrGY4UqAEPPmIZcZy7]
