l)\n    df[c+'_meet'] = df[c+'_val'].apply(lambda v: False if (v is None or pd.isna(v)) else (v < 104))\n\nmeet_cols = [c+'_meet' for c in enter_cols]\n\n# For each date, determine if any meet and any fail\nsummary = df.groupby(date_col)[meet_cols].agg(['any','all'])\n# summary columns are multiindex; easier compute directly\n\ndef any_meet(row):\n    return row.values.astype(bool).any()\n\ndef any_fail(row):\n    # fail means at least one sampling point not meeting (i.e., meet==False)\n    return (~row.values.astype(bool)).any()\n\n# Determine meet_any and fail_any considering missing as neither; but meet flag set false when missing -> would treat missing as fail.\n# Better: use val missing to set NaN. Let's recompute with tri-state.\n\nfor c in enter_cols:\n    df[c+'_meet2'] = df[c+'_val'].apply(lambda v: pd.NA if (v is None or pd.isna(v)) else (v < 104))\n\nmeet2_cols = [c+'_meet2' for c in enter_cols]\n\nout = df.groupby(date_col).apply(lambda g: (\n    g[meet2_cols].applymap(lambda x: pd.NA if pd.isna(x) else bool(x))\n))\n\n# Do robust with boolean existence\n\ndef date_has_both(g):\n    meets = g[meet2_cols].apply(lambda col: col.dropna().astype(bool).any())\n    # meets_any: any True\n    meets_any = any(g[meet2_cols].stack().dropna().astype(bool)) if len(g[meet2_cols].stack().dropna()) else False\n    fails_any = any((~g[meet2_cols].stack().dropna().astype(bool))) if len(g[meet2_cols].stack().dropna()) else False\n    return meets_any and fails_any\n\ncount = df.groupby(date_col).apply(date_has_both).sum()\nprint(int(count))"}) [toolUseId=call_siJibOdzmVpvEmT6E6N6dewa]
