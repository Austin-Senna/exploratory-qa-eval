ty column\n# Some datasets may have Beach Name as 'Bucks Creek Beach'\n# We'll enforce Community == 'Chatham' if present\nif 'Community' in wb_bucks.columns:\n    wb_bucks = wb_bucks[wb_bucks['Community'].astype(str).str.contains('Chatham', case=False, na=False)]\n\n# parse date to month/year\nwb_bucks['Sample Date'] = pd.to_datetime(wb_bucks['Sample Date'], errors='coerce')\nwb_bucks = wb_bucks[wb_bucks['Sample Date'].notna()]\n\n# filter to year and months JJA\nwb_jja = wb_bucks[(wb_bucks['Sample Date'].dt.year == int(rainiest_year)) & (wb_bucks['Sample Date'].dt.month.isin([6,7,8]))]\n\n# exceedance indicator: Violation == 'Yes'\n# If Indicator Level is numeric exceedance threshold, but Violation already yes/no.\nwb_jja['ViolationBin'] = (wb_jja['Violation'].astype(str).str.strip().str.lower()=='yes').astype(int)\n\nexceedance_count = wb_jja['ViolationBin'].sum()\ntotal_obs = len(wb_jja)\nrate = (exceedance_count/total_obs*100) if total_obs>0 else None\nprint('RainiestYear', rainiest_year)\nprint('TotalObs', total_obs)\nprint('ExceedanceCount', int(exceedance_count))\nprint('Rate', rate)\n"}) [toolUseId=call_cWFOWJf4ClL6HEMSSxM8o6GR]
