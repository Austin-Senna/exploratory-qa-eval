o columns are Tag,Enterococcus for 3-day\ntag3_col = cols[-2]\nendo3_col = cols[-1]\n# Actually order may be ... Tag, Enterococcus, Tag, Enterococcus, Tag, Enterococcus\n# so Tag3 is cols[cols.index('Tag')? duplicates]. We'll use by position: 8,9\n\n# robust by position\nif len(cols)>=10:\n    tag3 = wj.columns[8]\n    ent3 = wj.columns[9]\nelse:\n    raise Exception('Unexpected columns')\n\n# parse tag and value\nwj[tag3]=wj[tag3].astype(str)\nwj[ent3]=pd.to_numeric(wj[ent3], errors='coerce')\n\ndef estimate(row):\n    v=row[ent3]\n    t=row[tag3]\n    if pd.isna(v):\n        return None\n    if t.startswith('<'):\n        return v/2\n    if t.startswith('>'):\n        return v\n    return v\n\nwj['enterococcus_est']=wj.apply(estimate, axis=1)\n\nwj['rain3']=wj['3-Day Rain'].astype(float)\n\n# Filter communities >90% EJ: constitution is in East Boston\nqual=True\n# need check East Boston municipality in EJ file: likely 'Boston'\n# use municipality intersection: if any qual_muns includes 'Boston' then use.\nif 'Boston' not in qual_muns:\n    # maybe EJ file uses 'East Boston' or 'Boston'\n    pass\n\n# We'll compute correlation regardless? but question asks beaches located in communities >90% EJ.\n# For Constitution Beach East Boston, community=Boston.\nif 'Boston' not in qual_muns:\n    print('Boston not in qual set; qual_muns sample:', list(sorted(qual_muns))[:10])\n    print('N qual rows:', len(wj))\n    corr=None\nelse:\n    df=wj[['rain3','enterococcus_est']].dropna()\n    corr=df['rain3'].corr(df['enterococcus_est'], method='pearson')\n    print('n',len(df))\n    print('corr',corr)\n"}) [toolUseId=call_xm1YQTuclpIlBuD59nikyck4]
