Date'] = pd.to_datetime(wb_f['Sample Date'], errors='coerce')\nwb_f = wb_f.dropna(subset=['Sample Date'])\nwb_f['month'] = wb_f['Sample Date'].dt.month\nsummer = wb_f[wb_f['month'].between(6,8)]\n\nrate = summer.groupby('Year')['Is_Exceedance'].mean().sort_index()\n# Ensure 2020-2023\nrate = rate.loc[2020:2023]\nprint('Exceedance rates:', rate.to_dict())\n\n# Precip\nprec = pd.read_csv(prec_path)\nfor m in ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec']:\n    prec[m] = pd.to_numeric(prec[m].replace({'M':np.nan}), errors='coerce')\n\nprec_years = prec[prec['Year'].between(2020,2023)].copy()\n# Impute missing by month median over available years (all years in file)\nmonth_cols = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec']\nmedians = prec[month_cols].median(skipna=True)\nprec_years_imputed = prec_years.copy()\nfor m in month_cols:\n    prec_years_imputed[m] = prec_years_imputed[m].fillna(medians[m])\n\nsummer_cols = ['Jun','Jul','Aug']\nsummer_totals = prec_years_imputed.set_index('Year')[summer_cols].sum(axis=1).loc[2020:2023]\nprint('Summer precip totals:', summer_totals.to_dict())\n\n# Compare year-to-year direction\nyears = [2020,2021,2022,2023]\nex_dir = []\npr_dir = []\nfor i in range(1,len(years)):\n    y0,y1 = years[i-1],years[i]\n    ex_dir.append(np.sign(rate[y1]-rate[y0]))\n    pr_dir.append(np.sign(summer_totals[y1]-summer_totals[y0]))\n\nex_dir = pd.Series(ex_dir, index=[f'{years[i-1]}->{years[i]}' for i in range(1,len(years))])\npr_dir = pd.Series(pr_dir, index=ex_dir.index)\nprint('Exceedance dir:', ex_dir.to_dict())\nprint('Precip dir:', pr_dir.to_dict())\n\nmatch = (ex_dir.values == pr_dir.values).all()\nprint('Patterns match?', match)\n"}) [toolUseId=call_GObBXHAwO5D8eQnt6rqTSCNC]
