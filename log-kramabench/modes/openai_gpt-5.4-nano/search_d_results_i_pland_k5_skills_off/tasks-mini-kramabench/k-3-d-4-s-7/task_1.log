each Name','Beach Type Description'], as_index=False)['DayRainExceed'].mean()\nex = ex.rename(columns={'DayRainExceed':'exceedance_rate'})\n\n# Beach type mapping\nfresh_beaches = {\n    'Boston': ['fresh','Fresh'],\n}\n# We'll filter by Beach Type Description equals 'Freshwater' vs 'Marine'\n\n# Prepare station lists by beach name contains city? We'll inspect quickly unique types\n# but proceed: filter Beach Type Description\n\n# Freshwater stations: Boston, Chatham, Amherst, Ashburnham\nfresh_cities = ['Boston','Chatham','Amherst','Ashburnham']\nmarine_cities = ['Boston','Chatham']\n\n# Determine Beach Name matches city substring from Community column\n# Use Beach Name from data includes street; Community column has city.\n# We'll recompute exceedance rates using Community.\n\nwater2 = water.copy()\nwater2['Community'] = water2['Community'].astype(str)\nex2 = water2.groupby(['Year','MonthName','Community','Beach Type Description'], as_index=False)['DayRainExceed'].mean()\nex2 = ex2.rename(columns={'DayRainExceed':'exceedance_rate'})\n\n# Keep requested cities and types\nex2['Beach Type Description'] = ex2['Beach Type Description'].astype(str)\n\n# Aggregate rainfall rows to match years 2007-2009\nyears = [2007,2008,2009]\n\n# Build dataset for freshwater and marine correlations\n\ndef build_series(cities, beach_type):\n    rows=[]\n    for city in cities:\n        df_r = rain[city]\n        df_r = df_r[df_r['Year'].isin(years)].copy()\n        ex_f = ex2[(ex2['Community']==city) & (ex2['Beach Type Description']==beach_type) & (ex2['Year'].isin(years))]\n        for _,er in ex_f.iterrows():\n            y=int(er['Year']); m=er['MonthName']\n            x = float(df_r.loc[df_r['Year']==y, m].values[0]) if m in ['Jun','Jul','Aug'] else np.nan\n            rows.append({'city':city,'Year':y,'MonthName':m,'rain':x,'exceedance_rate':er['exceedance_rate']})\n    d=pd.DataFrame(rows)\n    return d\n\nfresh_df = build_series(fresh_cities,'Freshwater')\nmarine_df = build_series(marine_cities,'Marine')\n\n# Impute missing rainfall with month-wise median across non-missing years (2007-2009) per city? requirement says across non-missing years for that month (overall). We'll do overall per month and type.\n\ndef impute(df):\n    df=df.copy()\n    med = df.groupby('MonthName')['rain'].median()\n    df['rain_imputed']=df.apply(lambda r: (med[r['MonthName']] if pd.isna(r['rain']) else r['rain']), axis=1)\n    return df\n\nfresh_df = impute(fresh_df)\nmarine_df = impute(marine_df)\n\n# Correlation Pearson between stacked months across all cities\nfor name,df in [('fresh',fresh_df),('marine',marine_df)]:\n    print(name, len(df))\n    corr = df[['rain_imputed','exceedance_rate']].corr(method='pearson').iloc[0,1]\n    print('corr',corr)\n"}) [toolUseId=call_KNpBWLzzmmAngbBVdNKZLvmp]
