ing all training hours within input window [2016-10-22 00..23:00]? but we only have until 23-00. Use full from 2016-10-22 00 to 2016-10-23 00 includes 25? Actually inclusive gives 25 points.\n\ndef prepare_hourly_inputs(omni_df, go_df):\n    df=pd.merge(omni_df[['Timestamp']+cols_omni], go_df[['Timestamp']+cols_go], on='Timestamp', how='inner').sort_values('Timestamp')\n    return df\n\n# Fit VAR(1) separately on input feature vector columns\nfeatures=['f10.7_index','Kp_index','Dst_index_nT','xrsb_flux_observed','xrsa_flux_observed']\n\nXtr_in=prepare_hourly_inputs(omni_tr_w, go_tr_w)\nXev_in=prepare_hourly_inputs(omni_ev_w, go_ev_w)\n\n# VAR(1): X_t = A X_{t-1} + c\nY=Xtr_in[features].iloc[1:].values\nXlag=Xtr_in[features].iloc[:-1].values\n# add intercept\nXlag_aug=np.hstack([Xlag, np.ones((Xlag.shape[0],1))])\ncoef=np.linalg.lstsq(Xlag_aug, Y, rcond=None)[0]\nA=coef[:-1,:].T  # Actually solve Xlag_aug @ coef = Y; coef shape (p+1,p). easier\ncoef_mat=coef\n\ndef var1_project(x_context_end_vector, steps, A, intercept):\n    # generate future vectors starting at t=end+1 for given steps\n    preds=[]\n    x=x_context_end_vector.copy()\n    for _ in range(steps):\n        x = x@A.T + intercept\n        preds.append(x.copy())\n    return np.array(preds)  # steps x p\n\np=len(features)\nA=coef_mat[:-1,:]  # (p,p)\nintercept=coef_mat[-1,:]  # (p,)\n\n# Build training samples: for each target hour t in dens_tr_train hourly, use context window of 16 hours ending at (t-horizon) -? Specifically context features use last 16 observed hours before forecast origin (t-horizon).\n# We'll set forecast origin = t_target - horizon\n# Context hours are [origin-context+1 .. origin]?? 16-hour context window; use exactly 16 past hours ending at origin-1? We'll use inclusive last 16 hours ending at origin-1, so end vector at time origin-1.\n\nhorizon=4\ncontext=16\n\ndens_tr_vals=dens_tr_train.set_index('Timestamp')['Orbit Mean Density (kg/m^3)'].sort_index()\n\n# For mapping, create projected features for each of next 4 hours using VAR from context end.\n# Then use linear regression to predict density at each horizon hour jointly (flatten).\n\nX_inputs_full=prepare_hourly_inputs(omni_tr_w, go_tr_w).set_index('Timestamp')\n\ntrain_rows=[]\ntargets=[]\n\nfor t_target in dens_tr_vals.index:\n    origin=t_target - pd.Timedelta(hours=horizon)\n    context_end=origin - pd.Timedelta(hours=1)\n    context_start=origin - pd.Timedelta(hours=context)\n    if context_start < X_inputs_full.index.min() or context_end> X_inputs_full.index.max():\n        continue\n    # Use last observed vector at context_end\n    x_end=X_inputs_full.loc[context_end, features].values.astype(float)\n    # Project forward horizon steps\n    proj=var1_project(x_end, horizon, A, intercept)  # (horizon,p)\n    # Flatten proj for regression\n    train_rows.append(proj.flatten())\n    targets.append(dens_tr_vals.loc[t_target])\n\nX_train=np.array(train_rows)\ny_train=np.array(targets)\n\nmodel=LinearRegression().fit(X_train, y_train)\n\n# Evaluation: build one sample for each of 4 forecast hours starting eval_dens_start with same procedure.\ndens_ev_vals=dens_ev_w.set_index('Timestamp')['Orbit Mean Density (kg/m^3)'].sort_index()\nX_inputs_ev_full=prepare_hourly_inputs(omni_ev_w, go_ev_w).set_index('Timestamp')\n\npreds=[]\nobs=[]\nfor t_target in dens_ev_vals.index:\n    origin=t_target - pd.Timedelta(hours=horizon)\n    context_end=origin - pd.Timedelta(hours=1)\n    context_start=origin - pd.Timedelta(hours=context)\n    x_end=X_inputs_ev_full.loc[context_end, features].values.astype(float)\n    proj=var1_project(x_end, horizon, A, intercept)\n    x_flat=proj.flatten().reshape(1,-1)\n    preds.append(model.predict(x_flat)[0])\n    obs.append(dens_ev_vals.loc[t_target])\n\nrmse=float(np.sqrt(np.mean((np.array(preds)-np.array(obs))**2)))\nrmse\n", "dataset_id": "kramabench-astronomy-hard-7"}) [toolUseId=call_hR85mjyzu607GPFaeKL4BYWQ]
