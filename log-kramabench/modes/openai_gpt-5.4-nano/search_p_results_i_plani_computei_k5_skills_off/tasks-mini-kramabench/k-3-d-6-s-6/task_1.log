 from density data at 10-minute; we resample to hourly by averaging within hour.\n# Training density window: 2016-10-23 to 2016-10-24\nh_tr_start = pd.Timestamp('2016-10-23 00:00:00')\nh_tr_end   = pd.Timestamp('2016-10-24 00:00:00')\n\n# Evaluation\nctx_start_ev = pd.Timestamp('2016-10-25 00:00:00')\nctx_end_ev   = pd.Timestamp('2016-10-26 00:00:00')\nh_ev_start   = pd.Timestamp('2016-10-29 00:00:00')\nh_ev_end     = pd.Timestamp('2016-10-30 00:00:00')\n\n# Feature selection\nomni_cols = ['f10.7_index','Kp_index','Dst_index_nT']\ngo_cols = ['xrsb_flux_observed','xrsa_flux_observed']\n\n# Resample GOES to hourly mean (it is at 1-min). OMNI is hourly already.\n\ndef build_feature_frame(omni, goes, start, end):\n    o = omni.loc[(omni['Timestamp']>=start) & (omni['Timestamp']<end)].copy()\n    # ensure hourly\n    o = o.set_index('Timestamp').sort_index()\n    # go resample\n    g = goes.loc[(goes['Timestamp']>=start) & (goes['Timestamp']<end)].copy()\n    g = g.set_index('Timestamp').sort_index()\n    g_h = g[go_cols].resample('1H').mean()\n    o_h = o[omni_cols].resample('1H').mean()\n    feat = o_h.join(g_h, how='inner')\n    return feat\n\nXctx_tr = build_feature_frame(omni_tr, go_tr, ctx_start_tr, ctx_end_tr)\nXctx_ev = build_feature_frame(omni_ev, go_ev, ctx_start_ev, ctx_end_ev)\n\n# Density resample to hourly\n\ndef build_density_hourly(dens, start, end):\n    d = dens.loc[(dens['Timestamp']>=start) & (dens['Timestamp']<end)].copy()\n    d = d.set_index('Timestamp').sort_index()\n    dh = d['density'].resample('1H').mean()\n    return dh\n\ny_tr = build_density_hourly(dens_tr, h_tr_start, h_tr_end)\ny_ev = build_density_hourly(dens_ev, h_ev_start, h_ev_end)\n\n# Training alignment: VAR projection uses last 16h ending at ctx_end_tr (exclusive), so last context hour is ctx_end_tr-1H.\n# We will model VAR(1) on the context feature series Xctx_tr: x_{t+1} = A x_t + c.\nX = Xctx_tr.values\n# Fit VAR(1) with intercept\nX_t = X[:-1]\nX_next = X[1:]\n# Add intercept\nX_design = np.hstack([np.ones((X_t.shape[0],1)), X_t])\nB, *_ = np.linalg.lstsq(X_design, X_next, rcond=None)\n# B shape (k+1, k)\n# Project forward from time ctx_end_tr (i.e., from last observed X at ctx_end_tr-1H)\n\nk = X_t.shape[1]\n\n# Helper to forecast features for next 4 hours iteratively\n\ndef forecast_var1(start_features_last, steps):\n    # start_features_last: array shape (k,)\n    preds=[]\n    x = start_features_last.copy()\n    for _ in range(steps):\n        design = np.concatenate([[1.0], x])\n        x_next = design @ B\n        preds.append(x_next)\n        x = x_next\n    return np.array(preds)\n\n# Build training samples for regression mapping projected features to density t+4h.\n# We need density targets at hourly times within y_tr, corresponding to density at time t (hourly), predicted from features at time t-4h.\n# Features known only up to ctx_end_tr-1H; but during training we can use projected features beyond that by VAR projection.\n\n# We will create regression dataset using context times where t+4 within density window.\n# Let density hours be y_tr indexed from h_tr_start to h_tr_end-1H. Those hours correspond to global time.\n# Features available for those prediction times: features projected from context end up to cover density window.\n\n# Determine hourly times for density window\ntr_times = y_tr.index\n# For each density time T, we need features at time (T-4h) generated from VAR and initial condition at end of context.\n# Since context ends exactly at first density hour (per prompt overlap single timestamp), we can set that the last context feature hour is at h_tr_start-1H, and VAR can project to produce features at times h_tr_start, h_tr_start+1, ...\n# Then for T, take projected features at (T-4h).\n\n# Get last observed feature at ctx_end_tr-1H which equals h_tr_start-1H\nlast_feat = Xctx_tr.iloc[-1].values\n# Need projected features covering from (h_tr_start-4h) to (h_tr_end-1h-? )\n# For T in tr_times, we need feature time = T-4h, which ranges from h_tr_start-4h to h_tr_end-1h-4h.\nfeat_needed_start = tr_times.min() - pd.Timedelta(hours=4)\nfeat_needed_end = tr_times.max() - pd.Timedelta(hours=4)  # inclusive\n\n# Generate projection from time ctx_end_tr (which is h_tr_start) backward 4h is not available; but prompt says only overlap at single timestamp. So we assume VAR projection starts at ctx_end_tr (h_tr_start) and we predict density for t>=h_tr_start+4h? Hmm.\n# To ensure valid, we will use density times whose required feature time is >= ctx_end_tr.\nvalid_mask = tr_times >= (ctx_end_tr + pd.Timedelta(hours=4))\nvalid_times = tr_times[valid_mask]\n\n# For each valid density time T, feature time S=T-4h is >= ctx_end_tr\nsteps = int((feat_needed_end - ctx_end_tr).total_seconds()//3600) + 1\n# Create projected features for times starting at ctx_end_tr\nproj_feats = forecast_var1(last_feat, steps)\nproj_index = pd.date_range(start=ctx_end_tr, periods=steps, freq='1H')\nproj_df = pd.DataFrame(proj_feats, index=proj_index, columns=Xctx_tr.columns)\n\n# Regression training dataset\nrows=[]\nfor T in valid_times:\n    S = T - pd.Timedelta(hours=4)\n    if S in proj_df.index:\n        rows.append((S, T))\n\nX_reg = np.array([proj_df.loc[S].values for S,T in rows])\ny_reg = np.array([y_tr.loc[T] for S,T in rows])\n\nreg = LinearRegression()\nreg.fit(X_reg, y_reg)\n\n# Evaluation forecasting similarly: need predicted density for y_ev times; feature time = T-4h where T is in y_ev.\n# VAR projection for eval context ends at ctx_end_ev which equals 2016-10-26 00:00, which is 3 days before density start 2016-10-29. VAR steps cover that gap.\nlast_feat_ev = Xctx_ev.iloc[-1].values\n\ntrange = y_ev.index\nvalid_mask_ev = trange >= (ctx_end_ev + pd.Timedelta(hours=4))\nvalid_times_ev = trange[valid_mask_ev]\n\nfeat_needed_start_ev = valid_times_ev.min() - pd.Timedelta(hours=4)\nfeat_needed_end_ev = valid_times_ev.max() - pd.Timedelta(hours=4)\nsteps_ev = int((feat_needed_end_ev - ctx_end_ev).total_seconds()//3600) + 1\nproj_feats_ev = forecast_var1(last_feat_ev, steps_ev)\nproj_index_ev = pd.date_range(start=ctx_end_ev, periods=steps_ev, freq='1H')\nproj_df_ev = pd.DataFrame(proj_feats_ev, index=proj_index_ev, columns=Xctx_ev.columns)\n\nX_pred = []\ny_true = []\nfor T in valid_times_ev:\n    S = T - pd.Timedelta(hours=4)\n    X_pred.append(proj_df_ev.loc[S].values)\n    y_true.append(y_ev.loc[T])\nX_pred = np.array(X_pred)\ny_true = np.array(y_true)\n\ny_hat = reg.predict(X_pred)\nrmse = np.sqrt(np.mean((y_hat - y_true)**2))\nprint(rmse)\n"}) [toolUseId=call_6vIUGuvIb9Mk1XLKeh6bwZgb]
