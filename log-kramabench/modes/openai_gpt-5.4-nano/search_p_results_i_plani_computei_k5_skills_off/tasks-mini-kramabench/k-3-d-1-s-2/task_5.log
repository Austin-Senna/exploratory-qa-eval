dex from omni2.text ---\nwith fs.open(base+'/omni2.text','r') as f:\n    spec=f.read()\n# token index for hourly AP in low-res file. We search for 'Ap' and 'col' pattern.\nmm=re.search(r'\\bAP\\b.*?col\\s*(\\d+)\\s*to\\s*(\\d+)', spec, re.IGNORECASE|re.DOTALL)\nif not mm:\n    # alternative: 'Ap (planetary) col'\n    mm=re.search(r'Ap.*?col\\s*(\\d+)\\s*to\\s*(\\d+)', spec, re.IGNORECASE|re.DOTALL)\nif not mm:\n    raise ValueError('AP column not found in omni2.text')\ncol_ap=int(mm.group(1))  # 1-based\n\n# --- Load OMNI2 hourly data ---\nwith fs.open(base+'/omni2_low_res/omni2_2024.dat','r') as f:\n    lines=f.read().splitlines()\n\nrows=[]\nfor ln in lines:\n    if not ln.strip():\n        continue\n    parts=ln.split()\n    year=int(parts[0])\n    doy=int(parts[1])\n    hr=int(parts[2])\n    t=pd.Timestamp(year=year, month=1, day=1)+pd.Timedelta(days=doy-1)+pd.Timedelta(hours=hr)\n    if not (start<=t<end):\n        continue\n    if col_ap-1>=len(parts):\n        continue\n    ap=float(parts[col_ap-1])\n    rows.append((t,ap))\n\nomni=pd.DataFrame(rows, columns=['t','ap']).groupby('t',as_index=False)['ap'].mean().sort_values('t')\n\nmerged=A_df.merge(omni,on='t',how='inner').sort_values('t').reset_index(drop=True)\n\ndelta=merged['delta_a_km'].to_numpy()\nap=merged['ap'].to_numpy()\n\nbest_L=0; best_r2=-1\nfor L in range(0,49):\n    if L==0:\n        x=ap; y=delta\n    else:\n        x=ap[:-L]\n        y=delta[L:]\n    if len(x)<10:\n        continue\n    r=np.corrcoef(x,y)[0,1]\n    r2=float(r*r)\n    if r2>best_r2:\n        best_r2=r2; best_L=L\n\nprint(best_L,best_r2,len(merged),col_ap)\n"}) [toolUseId=call_yv0kJVTkNaziCy2GHupd0aKl]
