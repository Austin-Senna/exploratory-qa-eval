 actor.strip()\n    # remove parenthetical\n    a = re.sub(r'\\(.*?\\)','',a).strip()\n    # direct map with keys substring\n    for k,v in actor_to_country.items():\n        if k.lower() in a.lower():\n            return v\n    # try to map to exact country in cities list\n    for c in countries:\n        if c.lower() in a.lower() or a.lower() in c.lower():\n            return c\n    return None\n\n# filter time window\n\ndf_conf = df_conf.copy()\n# ensure numeric years\nfor col in ['StartYear','EndYear']:\n    df_conf[col] = pd.to_numeric(df_conf[col], errors='coerce')\n\nf = df_conf[(df_conf['StartYear']>=800) & (df_conf['EndYear']<=1400) & (df_conf['EndYear']-df_conf['StartYear']>=1)]\n\nintervals = []\nfor _,r in f.iterrows():\n    s = r['Conflict']\n    # expected format: Actor1-Actor2 (with extra hyphens inside parentheses possible). We'll split on first '-' between actors.\n    parts = s.split('-',1)\n    if len(parts)!=2:\n        continue\n    left = parts[0].strip()\n    right = parts[1].strip()\n    # right side may include additional '-' if further; take left side of first hyphen already done, good.\n    # map\n    c1 = map_actor(left)\n    c2 = map_actor(right)\n    if c1 is None or c2 is None:\n        continue\n    a = min(c1,c2); b=max(c1,c2)\n    intervals.append((a,b,int(r['StartYear']),int(r['EndYear'])))\n\n# merge overlaps per country pair\nfrom collections import defaultdict\npairs=defaultdict(list)\nfor a,b,st,en in intervals:\n    pairs[(a,b)].append((st,en))\n\ndef merge(lst):\n    lst=sorted(lst)\n    merged=[]\n    for st,en in lst:\n        if not merged or st>merged[-1][1]:\n            merged.append([st,en])\n        else:\n            merged[-1][1]=max(merged[-1][1],en)\n    return merged\n\ncount_merged=0\nfor k,lst in pairs.items():\n    merged=merge(lst)\n    count_merged += len(merged)\n\ncount_merged"}) [toolUseId=call_gATWSeczJSqLscfgvYkWfpns]
