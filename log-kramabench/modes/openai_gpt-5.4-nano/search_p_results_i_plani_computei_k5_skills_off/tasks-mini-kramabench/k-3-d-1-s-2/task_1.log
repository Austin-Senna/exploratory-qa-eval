import pandas as pd

worldcities_path = 'kramabench-archeology-hard-12/files/worldcities.csv'
conflict_path = 'kramabench-archeology-hard-12/files/conflict_brecke.csv'

def country_matcher():
    city_df = pd.read_csv(worldcities_path)
    return sorted(set(city_df['country'].dropna().unique().tolist()))

def get_matching_country(sentence, countries):
    words = str(sentence).lower()
    for item in countries:
        if item.lower() in words:
            return item
    return None

def processed_conflicts():
    countries = country_matcher()
    conflict_data = pd.read_csv(conflict_path)
    processed = []
    for _, row in conflict_data.iterrows():
        name = str(row['Conflict'])
        if '-' in name:
            actor_a, actor_b = name.split('-', 1)
        elif 'and' in name:
            actor_a, actor_b = name.split('and', 1)
        else:
            actor_a = actor_b = name

        start = pd.to_numeric(row['StartYear'], errors='coerce')
        end = pd.to_numeric(row['EndYear'], errors='coerce')
        if pd.isna(start) or pd.isna(end):
            continue
        start = int(start)
        end = int(end)

        actor_a = get_matching_country(actor_a, countries)
        actor_b = get_matching_country(actor_b, countries)
        if actor_a is None or actor_b is None or start < 800 or end > 1400:
            continue

        actor_a, actor_b = sorted([actor_a, actor_b])
        processed.append({'actor_a': actor_a, 'actor_b': actor_b, 'start': start, 'end': end})
    return pd.DataFrame(processed)

def merged_conflicts():
    filtered = processed_conflicts()
    merged = []
    for _, df in filtered.groupby(['actor_a', 'actor_b']):
        df = df.sort_values('start')
        current = None
        for _, row in df.iterrows():
            row = row.copy()
            if current is None:
                current = row
            elif row['start'] <= current['end']:
                if row['end'] > current['end']:
                    current['end'] = row['end']
            else:
                merged.append(current)
                current = row
        if current is not None:
            merged.append(current)
    return pd.DataFrame(merged)

result = len(merged_conflicts())
print(result)
