n    s=s.strip().strip('\"')\n    if s=='' or s.lower()=='nan':\n        return np.nan\n    # remove currency and spaces\n    s=s.replace('$','').replace(',','').strip()\n    # handle trailing/leading quotes\n    s=s.strip()\n    # handle cases like 920 or 1,300 or '1,300 '\n    # if ranges like '500-700', take first\n    if '-' in s:\n        s=s.split('-')[0]\n    # if values like '71M' or '700'\n    mult=1\n    m=re.match(r'^([0-9]*\\.?[0-9]+)([KkMmBb])?$', s)\n    if m and m.group(2):\n        unit=m.group(2).upper()\n        mult={'K':1e3,'M':1e6,'B':1e9}[unit]\n        return float(m.group(1))*mult\n    try:\n        return float(s)\n    except:\n        return np.nan\n\nout['median_clean']=out['median_raw'].apply(clean_money)\n\n# drop nan\nout=out.dropna(subset=['median_clean'])\nmax_row=out.loc[out['median_clean'].idxmax()]\nmax_row['branch'], max_row['median_clean'], out[['branch','median_clean']].sort_values('median_clean', ascending=False).head(10)\n"}) [toolUseId=call_F1jDPRBHdWNPCDMYwGcGJs1S]
