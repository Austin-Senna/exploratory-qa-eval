pping_cells:\n        acetyl_sheet = mapping_cells[0][0]\n\nif acetyl_sheet is None:\n    raise RuntimeError('Could not find acetylproteomics in workbook')\n\nws = wb[acetyl_sheet]\n# Extract mapping: find row containing acetylproteomics and nearby cell specifying worksheet number/name\nfound = False\nworksheet_target = None\n\nfor row in ws.iter_rows(min_row=1, max_row=300):\n    row_vals = [cell.value for cell in row]\n    for j,cell_val in enumerate(row_vals):\n        if isinstance(cell_val,str) and 'acetylproteomics' in cell_val.lower():\n            # try to locate a worksheet reference in same row\n            for k in range(j-3, j+6):\n                if 0 <= k < len(row_vals):\n                    val = row_vals[k]\n                    if isinstance(val,(int,float)) and int(val)==val and val>0:\n                        worksheet_target = int(val)\n                        found=True\n                        break\n                    if isinstance(val,str):\n                        # look for patterns like 'Worksheet 3' or 'tab 3'\n                        import re\n                        m = re.search(r'(?:worksheet|tab|table)\\s*(\\d+)', val, flags=re.I)\n                        if m:\n                            worksheet_target = int(m.group(1))\n                            found=True\n                            break\n                        m2 = re.search(r'\\b(\\d{1,3})\\b', val)\n                        if m2:\n                            worksheet_target = int(m2.group(1))\n                            found=True\n                            break\n            if found: break\n    if found: break\n\n# If worksheet_target is a number, map to worksheet with that number order excluding readme sheets?\nif worksheet_target is None:\n    # try next: search for header like 'worksheet [computed value]' in row\n    worksheet_target = None\n\n# Determine worksheet for counting\n# Heuristic: if worksheet_target is numeric, choose wb.sheetnames where sheet name contains that number or equals 'Worksheet <n>'\nif isinstance(worksheet_target,int):\n    num = worksheet_target\n    for name in wb.sheetnames:\n        if str(num) in name:\n            # likely target\n            target_name = name\n            # avoid readme\n            if 'readme' in name.lower():\n                continue\n            worksheet_target_name = target_name\n            break\n    else:\n        # fallback: use nth non-readme sheet\n        non_readme = [n for n in wb.sheetnames if 'readme' not in n.lower()]\n        worksheet_target_name = non_readme[num-1] if 1<=num<=len(non_readme) else non_readme[0]\nelse:\n    worksheet_target_name = wb.sheetnames[0]\n\n# Now count non-empty gene rows: assume first column is 'Gene' or similar; count rows where first column not null\nws2 = wb[worksheet_target_name]\n\n# Find header row by scanning first 50 rows for 'Gene'\nheader_row = None\ngene_col = None\nfor r in range(1,51):\n    values = [ws2.cell(row=r, column=c).value for c in range(1, ws2.max_column+1)]\n    for c,val in enumerate(values, start=1):\n        if isinstance(val,str) and 'gene' in val.lower():\n            header_row = r\n            gene_col = c\n            break\n    if header_row and gene_col:\n        break\n\nif gene_col is None:\n    gene_col = 1\n    header_row = 1\n\n# count non-empty in gene_col below header_row\ncount=0\nfor r in range(header_row+1, ws2.max_row+1):\n    if ws2.cell(row=r, column=gene_col).value is not None and str(ws2.cell(row=r, column=gene_col).value).strip()!='':\n        count += 1\n\ncount, worksheet_target_name, acetyl_sheet"}) [toolUseId=call_eClWJfocFZRzveNln7ENec5v]
