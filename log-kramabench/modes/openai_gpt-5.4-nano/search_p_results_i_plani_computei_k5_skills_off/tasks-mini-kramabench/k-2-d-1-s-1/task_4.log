\n    readme_rows = sheet_rows(zf, paths['README'], strings)\n    header = [str(value).strip() for value in readme_rows[0]]\n    sheet_idx = header.index('Sheet')\n    desc_idx = header.index('Description')\n\n    target_sheet = None\n    for row in readme_rows[1:]:\n        description = row[desc_idx] if desc_idx < len(row) else ''\n        if 'acetylproteomics' in str(description).lower():\n            target_sheet = str(row[sheet_idx]).strip()\n            break\n\n    if not target_sheet:\n        raise ValueError('No README row describes acetylproteomics data')\n    if target_sheet not in paths:\n        raise ValueError(f'Sheet {target_sheet!r} is not in the workbook')\n\n    # Count non-empty rows in the mapped worksheet.\n    rows = sheet_rows(zf, paths[target_sheet], strings)\n    count = sum(1 for row in rows if any(str(value).strip() for value in row))\n\nprint(count)", "reason": "Rewrote the solution to follow the workbook’s README-based mapping, find the sheet whose description mentions acetylproteomics, then count non-empty rows in that mapped worksheet and print the result, matching the authored computation path."})
