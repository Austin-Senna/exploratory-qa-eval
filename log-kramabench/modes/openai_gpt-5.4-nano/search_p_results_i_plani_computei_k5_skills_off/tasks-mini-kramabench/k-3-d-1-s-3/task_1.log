e=None)\n    for sheet,df in xls.items():\n        if df.shape[0]==0: \n            continue\n        sample_col,hist_col,cnv_col = find_cols(df)\n        if sample_col and hist_col and cnv_col:\n            sub = df[[sample_col,hist_col,cnv_col]].dropna()\n            # filter endometrioid and cnv_high\n            end_mask = sub[hist_col].astype(str).str.contains('endometrioid', case=False, na=False)\n            cnv_mask = sub[cnv_col].astype(str).str.contains('CNV_HIGH', case=False, na=False)\n            ids = sub.loc[end_mask & cnv_mask, sample_col].astype(str)\n            for v in ids:\n                if v.strip()!='':\n                    all_ids.add(v.strip())\n\nprint('num_ids', len(all_ids))\nprint(sorted(list(all_ids))[:50])\n"})
