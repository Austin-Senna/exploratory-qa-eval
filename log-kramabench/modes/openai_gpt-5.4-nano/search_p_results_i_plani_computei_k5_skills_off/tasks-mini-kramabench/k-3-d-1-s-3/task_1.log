_meta.columns:\n    sample_col = 'Idx'\nelse:\n    # try Proteomics_Parent_Sample_IDs\n    for c in df_meta.columns:\n        if 'Proteomics_Participant_ID' in c:\n            continue\n    sample_col = df_meta.columns[0]\n\n# Filter\ndf_sel = df_meta[(df_meta[hist_col].astype(str).str.contains('Endometrioid', case=False, na=False)) & (df_meta[cnv_col].astype(str).str.upper()=='CNV_HIGH')].copy()\nsel_ids = set(df_sel[sample_col].astype(str))\n\n# Load hyperactivated proteins mapping\nhyper = pd.read_csv(hyper_path)\nhyper['sample_id'] = hyper['sample_id'].astype(str)\nhyper_sel = hyper[hyper['sample_id'].isin(sel_ids)]\nhyper_proteins = set(hyper_sel['protein'].astype(str))\n\n# Load FDA-approved drug target genes\nxl6 = pd.ExcelFile(mmc6_path)\ndf_fda = pd.read_excel(mmc6_path, sheet_name='G-FDA approved drugs')\n# gene_name is the target gene\nfda_genes = set(df_fda['gene_name'].astype(str))\n\nmatched = sorted([p for p in hyper_proteins if p in fda_genes])\nprint('n_selected_samples', len(sel_ids))\nprint('n_hyperactivated_proteins', len(hyper_proteins))\nprint('matched', matched)\nprint('matched_count', len(matched))\n"}) [toolUseId=call_oC8kvhBT4o6K6Tlsftv1Fx1a]
