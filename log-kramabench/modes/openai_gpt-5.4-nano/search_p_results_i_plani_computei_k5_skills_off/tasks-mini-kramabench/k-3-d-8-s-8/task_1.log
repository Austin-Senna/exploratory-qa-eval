v/kramabench-environment-hard-18/files/monthly_precipitations_chatham.csv\",\n\"amherst\":\"s3://sana-kramabench/datagov/kramabench-environment-hard-18/files/monthly_precipitations_amherst.csv\",\n\"ashburnham\":\"s3://sana-kramabench/datagov/kramabench-environment-hard-18/files/monthly_precipitations_ashburnham.csv\",\n}\n\nstations = []\nfor st, s3 in files_precip.items():\n    local = path_map.get(s3)\n    df = pd.read_csv(local)\n    # replace M with NaN\n    for m in ['Jun','Jul','Aug']:\n        df[m] = pd.to_numeric(df[m].replace('M', np.nan), errors='coerce')\n    # compute medians by month over all years present\n    med = {m: df[m].median(skipna=True) for m in ['Jun','Jul','Aug']}\n    d2 = df.copy()\n    for m in ['Jun','Jul','Aug']:\n        d2[m] = d2[m].fillna(med[m])\n    d2['summer'] = d2['Jun'] + d2['Jul'] + d2['Aug']\n    d2 = d2[d2['Year'].between(2020,2023)][['Year','summer']]\n    d2['station']=st\n    stations.append(d2)\n\nprecip = pd.concat(stations, ignore_index=True)\n# sum across stations per year\nrain = precip.groupby('Year')['summer'].sum().reset_index().sort_values('Year')\n\n# year-to-year pattern: +1 for increase else -1 for decrease else 0\nrain['diff'] = rain['summer'].diff()\nrain['trend'] = rain['diff'].apply(lambda x: 1 if x>0 else (-1 if x<0 else 0))\n\n# load water testing files\nwater_files = {\n2020: 's3://sana-kramabench/datagov/kramabench-environment-hard-18/files/water-body-testing-2020.csv',\n2021: 's3://sana-kramabench/datagov/kramabench-environment-hard-18/files/water-body-testing-2021.csv',\n2022: 's3://sana-kramabench/datagov/kramabench-environment-hard-18/files/water-body-testing-2022.csv',\n2023: 's3://sana-kramabench/datagov/kramabench-environment-hard-18/files/water-body-testing-2023.csv',\n}\n\nexceed = []\nfor year, s3 in water_files.items():\n    local = path_map.get(s3)\n    df = pd.read_csv(local)\n    # freshwater beaches\n    df = df[df['Beach Type Description'].str.lower().eq('freshwater')]\n    # exceedance rate: violation yes/no? assume Violation column values 'Yes'/'No'\n    df['Violation']=df['Violation'].astype(str)\n    total = len(df)\n    vio = (df['Violation'].str.lower().eq('yes')).sum()\n    rate = vio/total if total>0 else np.nan\n    exceed.append({'Year':year,'exceed_rate':rate})\n\nex = pd.DataFrame(exceed).sort_values('Year')\nex['diff'] = ex['exceed_rate'].diff()\nex['trend'] = ex['diff'].apply(lambda x: 1 if x>0 else (-1 if x<0 else 0))\n\n# Compare patterns for 2021-2023 (diff between years)\ncompare_years=[2021,2022,2023]\nrain_trend = rain[rain['Year'].isin(compare_years)].set_index('Year')['trend']\nex_trend = ex[ex['Year'].isin(compare_years)].set_index('Year')['trend']\n\nsame = all(rain_trend.loc[y]==ex_trend.loc[y] for y in compare_years)\nprint('rain',rain.to_string(index=False))\nprint('ex',ex.to_string(index=False))\nprint('same',same)\nprint('pattern_match', {y:int(rain_trend.loc[y]==ex_trend.loc[y]) for y in compare_years})\nprint('answer',same)\n"}) [toolUseId=call_WgWDo6wjSH2T8UEDGptNoGFO]
