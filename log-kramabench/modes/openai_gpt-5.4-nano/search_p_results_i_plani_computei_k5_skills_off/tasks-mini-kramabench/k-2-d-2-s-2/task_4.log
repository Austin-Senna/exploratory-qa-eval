cost = pd.read_csv(cost_path, sep='\t')
acres = pd.read_csv(acres_path, sep='\t')

def to_num(series):
    s = series.astype(str).str.replace('$', '', regex=False).str.replace(',', '', regex=False)
    s = s.replace({'N/A': np.nan, 'nan': np.nan})
    return pd.to_numeric(s, errors='coerce')

cost['Total'] = to_num(cost['Total'])
acres['Total'] = to_num(acres['Total'])

merged = cost[['Year', 'Total']].merge(acres[['Year', 'Total']], on='Year', suffixes=('_cost', '_acres'))
merged['cost_per_acre'] = merged['Total_cost'] / merged['Total_acres']
merged = merged.replace([np.inf, -np.inf], np.nan).dropna(subset=['cost_per_acre'])

max_cost_per_acre = round(merged['cost_per_acre'].max() + 1e-12, 2)
print(f"{max_cost_per_acre:.2f}")
