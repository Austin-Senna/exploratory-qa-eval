import pandas as pd
import numpy as np

cost_path = '/home/ec2-user/eval_eqa/exploratory-qa-eval/.sandbox_isolated/task_1497243_1778920872878/kramabench-wildfire-hard-4/files/nifc_suppression_costs.csv'
