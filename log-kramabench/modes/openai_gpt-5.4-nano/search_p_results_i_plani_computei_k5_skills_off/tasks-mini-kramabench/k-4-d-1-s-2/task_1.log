  return np.nan\n\n# Prefer Cal. BC 1 sigma (first range)\nsub['cal_year'] = sub['Cal. BC 1 sigma'].apply(parse_range_median)\nsub = sub.dropna(subset=['cal_year'])\n\n# tie-break by later calendar year => higher cal_year (less negative)\n# Get maximum latitude; if multiple, later year.\nmax_lat = sub['Latitude'].max()\nsub_maxlat = sub[sub['Latitude']==max_lat]\nselected = sub_maxlat.sort_values('cal_year', ascending=False).iloc[0]\nselected_year = selected['cal_year']\n\n# Convert to climate Age_ky year scale: climate uses Age_ky (thousand years BP) likely.\n# Need closest year to that year; the instruction says convert climate ages to calendar years.\n# We'll compute calendar year from Age_ky assuming BP=1950.\n\nclim = pd.read_excel(clim_path, sheet_name='Sheet1')\n# columns include Age_ky and Al\nclim['Age_ky'] = pd.to_numeric(clim['Age_ky'], errors='coerce')\nclim['Al'] = pd.to_numeric(clim['Al'], errors='coerce')\nclim = clim.dropna(subset=['Age_ky','Al'])\n\n# Convert to calendar years (BC/AD): year = 1950 - Age_ky*1000\nclim['cal_year'] = 1950 - clim['Age_ky']*1000\n\n# Find closest climate year(s) to selected_year\n# But climate rows have many ages; closest year(s) likely means exact Age_ky groups by rounded? We'll compare using cal_year.\nclim['diff'] = (clim['cal_year'] - selected_year).abs()\nmin_diff = clim['diff'].min()\nclosest = clim[clim['diff']==min_diff]\n\nmax_al = closest['Al'].max()\nmax_al_rounded = round(float(max_al),4)\nselected_year_rounded = round(float(selected_year),4)\nmin_diff_rounded = round(float(min_diff),6)\n\nprint('selected_year', selected_year_rounded)\nprint('max_al', max_al_rounded)\nprint('min_diff', min_diff_rounded)\n"})
