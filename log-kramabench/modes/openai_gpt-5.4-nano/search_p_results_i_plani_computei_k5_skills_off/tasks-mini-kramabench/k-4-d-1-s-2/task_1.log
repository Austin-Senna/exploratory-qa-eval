and loc_col is not None:\n    s = rad[loc_col].astype(str).str.lower()\n    mask_malta = s.str.contains('malta')\n\n# Filter Homo sapiens and Neolithic\n# species_col might be None; instead search for 'homo sapiens' in any object column\nmask_species = None\nfor c in rad.columns:\n    if rad[c].dtype==object:\n        s=rad[c].astype(str).str.lower()\n        if s.str.contains('homo sapiens').any():\n            mask_species=s.str.contains('homo sapiens')\n            species_field=c\n            break\n\nif mask_species is None and species_col is not None:\n    s=rad[species_col].astype(str).str.lower()\n    mask_species=s.str.contains('homo sapiens')\n\nmask_neolithic=None\nfor c in rad.columns:\n    if rad[c].dtype==object:\n        s=rad[c].astype(str).str.lower()\n        if s.str.contains('neolithic').any():\n            mask_neolithic=s.str.contains('neolithic')\n            phase_field=c\n            break\nif mask_neolithic is None and phase_col is not None:\n    s=rad[phase_col].astype(str).str.lower()\n    mask_neolithic=s.str.contains('neolithic')\n\nfilt = rad[mask_malta & mask_species & mask_neolithic].copy()\n\n# Ensure numeric latitude and year\nfilt[lat_col]=pd.to_numeric(filt[lat_col], errors='coerce')\nfilt[year_col]=pd.to_numeric(filt[year_col], errors='coerce')\n\n# Select northernmost (max latitude). Tie-breaker later year (max)\nmax_lat=filt[lat_col].max()\nsubset=filt[filt[lat_col]==max_lat]\nselected_year=subset[year_col].max()\n\n# Identify climate columns for year and aluminum and climate age fields\nclim_cols=list(clim.columns)\n\ndef cfind(patterns):\n    for c in clim_cols:\n        lc=str(c).lower()\n        if any(p in lc for p in patterns):\n            return c\n    return None\n\nclim_year_col = cfind(['year','cal','age','time'])\nal_col = cfind(['aluminum','al','alu'])\n# climate ages in radiocarbon might be multiple columns: choose those containing 'age' and 'cal'\n# But plan says convert sample's climate ages to calendar years as provided.\n# Likely radiocarbon table has 'Climate age' and 'Calendar year'. We'll instead compute closest using climateMeasurements year directly to selected_year.\n\n# Find closest climate year(s) to selected_year\nclim[clim_year_col]=pd.to_numeric(clim[clim_year_col], errors='coerce')\nclim[al_col]=pd.to_numeric(clim[al_col], errors='coerce')\n\ndiff = (clim[clim_year_col]-selected_year).abs()\nmin_diff = diff.min()\nclosest_years = clim.loc[diff==min_diff, clim_year_col].dropna().unique()\n\nclosest_rows = clim[clim_year_col].isin(closest_years)\nmax_al = closest_rows[al_col].max()\n\nans = round(float(max_al),4)\nans, selected_year, max_lat, min_diff, sorted(list(map(float,closest_years)))[:10]\n"}) [toolUseId=call_dX6DCR47bcgy9WokP7dNGB9C]
