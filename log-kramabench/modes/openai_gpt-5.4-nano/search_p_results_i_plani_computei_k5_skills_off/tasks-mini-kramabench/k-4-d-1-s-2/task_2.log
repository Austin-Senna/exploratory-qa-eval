nlineStr':\n        parts = [el.text or '' for el in cell.iterfind('.//main:is/main:t', NS)]\n        return ''.join(parts)\n    v = cell.find('main:v', NS)\n    if v is None:\n        return None\n    text = v.text\n    if t == 's':\n        try:\n            return shared_strings[int(text)]\n        except Exception:\n            return text\n    if t == 'b':\n        return text == '1'\n    return text\n\n\ndef sheet_rows(z, sheet_path, shared_strings):\n    root = ET.fromstring(z.read(sheet_path))\n    data = root.find('main:sheetData', NS)\n    rows = []\n    if data is None:\n        return rows\n    for row in data.findall('main:row', NS):\n        vals = {}\n        for c in row.findall('main:c', NS):\n            ref = c.attrib.get('r', '')\n            m = re.match(r'([A-Z]+)', ref)\n            if not m:\n                continue\n            idx = col_letters_to_index(m.group(1))\n            vals[idx] = cell_value(c, shared_strings)\n        rows.append(vals)\n    return rows\n\n\ndef rows_to_records(rows):\n    nonempty = [r for r in rows if any(v not in (None, '') for v in r.values())]\n    if not nonempty:\n        return [], []\n    header = nonempty[0]\n    max_idx = max(header.keys())\n    headers = []\n    for i in range(max_idx + 1):\n        h = header.get(i)\n        headers.append(str(h).strip() if h is not None else f'col_{i}')\n    records = []\n    for r in nonempty[1:]:\n        rec = {}\n        for i, h in enumerate(headers):\n            rec[h] = r.get(i)\n        records.append(rec)\n    return headers, records\n\n\ndef find_malta_records(headers, records):\n    region_cols = [h for h in headers if str(h).strip().lower() in ('region', 'area', 'location', 'place', 'country')]\n    if not region_cols:\n        region_cols = [h for h in headers if any(k in str(h).lower() for k in ['region', 'area', 'location', 'place', 'country', 'malt'])]\n    date_cols = [h for h in headers if str(h).strip().lower() == 'date']\n    if not date_cols:\n 