erval endpoints; include interpolation at boundaries\n\ndef interp(t):\n    return np.interp(t,x,y)\n\nt0=start; t1=end\n# build breakpoints: all x values within [t0,t1] plus endpoints\nbps=[t0]\nwithin=x[(x>=min(t0,t1)) & (x<=max(t0,t1))]\nfor v in within:\n    if v!=t0 and v!=t1:\n        bps.append(float(v))\nbps.append(t1)\n# unique sorted\nbps=sorted(set(bps))\n# compute integral over each segment where f is linear between consecutive climate points.\n# For each segment [a,b], f is linear if a and b fall within same interval of original x; but since bps are subset of x plus endpoints, it is safe.\ninteg=0.0\nfor a,b in zip(bps[:-1],bps[1:]):\n    fa=interp(a)\n    fb=interp(b)\n    integ += (fa+fb)/2*(b-a)  # trapezoid for linear segment\navg=integ/(t1-t0)\nprint('avg',avg,'rounded',round(avg,4))\nprint('using time range',t0,t1,'points in range',len(within))"}) [toolUseId=call_c6MiEJp8j8PrzZKbcvKiTUo4]
