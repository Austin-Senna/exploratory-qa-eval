):\n                        label=str(cols[j])\n                        break\n                # normalize label to beach\n                beach=''\n                if 'Flagpole' in label: beach='Pleasure Bay Beach'\n                elif 'Broadway' in label: beach='Pleasure Bay Beach'\n                elif 'Castle Island' in label or 'Playground' in label: beach='Castle Island Beach'\n                else: beach='Pleasure Bay Beach'\n                triplets.append((beach,i))\n        # count per triplet\n        per={}\n        for beach,i in triplets:\n            enter_col=None\n            for j in range(i, min(i+6, len(cols))):\n                if 'Enterococcus' in str(cols[j]):\n                    enter_col=cols[j]; break\n            rain_col=cols[i]\n            rain=df[rain_col].apply(to_float)\n            enter=df[enter_col].apply(to_float)\n            mask=(rain.fillna(0)==0) & enter.notna()\n            per[beach]=per.get(beach,0)+int(((enter>=104)&mask).sum())\n        results.update(per)\n    else:\n        # map file key to beach name\n        beach_map={'constitution':'Constitution Beach','city':'City Point Beach','mstreet':'M Street Beach','carson':'Carson Beach','malibu':'Malibu Beach','tenean':'Tenean Beach','wollaston':'Wollaston Beach'}\n        beach=beach_map[key]\n        results[beach]=count_failures(df,beach)\n\n# get max\nmax_beach=max(results, key=lambda b: results[b])\nmax_beach, results\nprint(results)\nprint(max_beach, results[max_beach])\n"}) [toolUseId=call_Kox9LapF6sBo944611LuI6Fe]
