ch/datagov/kramabench-environment-hard-12/files/wollaston_beach_datasheet.csv\",\n}\n\n# compute single-station beaches\nfor beach,path in paths.items():\n    df=pd.read_csv(path, header=[0,1,2,3], engine='python')\n    df.columns=[' '.join([str(x) for x in tup if str(x)!='nan' and str(x)!='None' and str(x)!='']).strip() for tup in df.columns.values]\n    paths[beach]=failures_in_df(df)\n\n# compute pleasure/castle separately by station label in columns\npleasure_path=\"s3://sana-kramabench/datagov/kramabench-environment-hard-12/files/pleasure_bay_and_castle_island_beach_datasheet.csv\"\ndf=pd.read_csv(pleasure_path, header=[0,1,2,3], engine='python')\ndf.columns=[' '.join([str(x) for x in tup if str(x)!='nan' and str(x)!='None' and str(x)!='']).strip() for tup in df.columns.values]\ncols=list(df.columns)\n\ntriplets=[]\nfor i,c in enumerate(cols):\n    if isinstance(c,str) and '3-Day Rain' in c:\n        # lookback for station label\n        label_candidates=[str(cols[j]) for j in range(max(0,i-8), i) if ('@' in str(cols[j]) or 'Playground' in str(cols[j]) or 'Flagpole' in str(cols[j]) or 'Broadway' in str(cols[j]) )]\n        label=label_candidates[0] if label_candidates else ''\n        if 'Flagpole' in label or 'Flagpole' in ' '.join(label_candidates):\n            beach='Pleasure Bay Beach'\n        elif 'Broadway' in label:\n            beach='Pleasure Bay Beach'\n        elif 'Castle' in label or 'Playground' in label:\n            beach='Castle Island Beach'\n        else:\n            beach='Pleasure Bay Beach'\n        enter_col=None\n        for j in range(i, min(i+6,len(cols))):\n            if 'Enterococcus' in str(cols[j]):\n                enter_col=cols[j]; break\n        triplets.append((beach,cols[i],enter_col))\n\nper={'Pleasure Bay Beach':0,'Castle Island Beach':0}\nfor beach,rain_col,enter_col in triplets:\n    rain=df[rain_col].apply(to_float)\n    enter=df[enter_col].apply(to_float)\n    mask=(rain.fillna(0)==0) & enter.notna()\n    per[beach]