7,2008,2009]\n\ndef get_rate(beach_type):\n    return [exceed_dict.get((y, beach_type), np.nan) for y in years]\n\nrain_months = ['Jun','Jul','Aug']\n\n# helper to impute median per station per month across all years with non-missing\n\ndef load_station(path_key):\n    df = pd.read_csv(DOWNLOAD_PATHS[path_key])\n    # replace M with NaN\n    for m in ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec']:\n        if m in df.columns:\n            df[m] = pd.to_numeric(df[m].replace('M', np.nan), errors='coerce')\n    df['Year']=df['Year'].astype(int)\n    return df\n\nstations = {\n 'Boston': 'boston',\n 'Chatham': 'chatham',\n 'Amherst': 'amherst',\n 'Ashburnham': 'ashburnham'\n}\n\nstation_dfs = {name: load_station(key) for name,key in stations.items()}\n\n# compute imputed summer totals for each year per station\nsummer_totals = {name:{} for name in stations}\nfor name,df in station_dfs.items():\n    imputed = df.copy()\n    for m in rain_months:\n        med = imputed.loc[imputed[m].notna(), m].median()\n        imputed[m] = imputed[m].fillna(med)\n    for y in years:\n        row = imputed.loc[imputed['Year']==y, rain_months]\n        summer_totals[name][y] = float(row.iloc[0].sum())\n\n# rainfall vectors: average totals across specified stations\nfresh_stations = ['Boston','Chatham','Amherst','Ashburnham']\nmarine_stations = ['Boston','Chatham']\n\nfresh_rain = [np.mean([summer_totals[s][y] for s in fresh_stations]) for y in years]\nmarine_rain = [np.mean([summer_totals[s][y] for s in marine_stations]) for y in years]\n\nfresh_exceed = get_rate('Freshwater')\nmarine_exceed = get_rate('Marine')\n\n# compute correlations\nr_fresh = pearsonr(fresh_rain, fresh_exceed).statistic\nr_marine = pearsonr(marine_rain, marine_exceed).statistic\nprint('Fresh rain', fresh_rain)\nprint('Fresh exceed', fresh_exceed)\nprint('Marine rain', marine_rain)\nprint('Marine exceed', marine_exceed)\nprint('r_fresh', r_fresh)\nprint('r_marine', r_marine)\nprint('winner', 'Freshwater' if r_fresh>r_marine else 'Marine')\n"}) [toolUseId=call_BrYls66j3aMBdKb6WbK7BsUa]
