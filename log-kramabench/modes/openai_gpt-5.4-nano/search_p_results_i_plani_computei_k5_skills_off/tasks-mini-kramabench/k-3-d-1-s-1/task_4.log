f multiple wd_cols, combine by averaging?\n# Use first wd_col if multiple.\nwd_col = wd_cols[0]\n\n# Clean year and wd\nwork = df[[*key_cols, year_col, wd_col]].copy() if key_cols else df[[year_col, wd_col]].copy()\nwork = work.rename(columns={year_col:'Year', wd_col:'WetDry'})\nwork['Year'] = pd.to_numeric(work['Year'], errors='coerce')\nwork['WetDry'] = pd.to_numeric(work['WetDry'], errors='coerce')\nwork = work.dropna(subset=['Year','WetDry'])\n\n# Sort and compute increases between nearest earlier and later; here adjacent years after sorting for each key group\nif key_cols:\n    work = work.sort_values(key_cols+['Year'])\n    inc = []\n    total = 0\n    for _, g in work.groupby(key_cols):\n        g = g.sort_values('Year')\n        vals = g['WetDry'].to_numpy()\n        # compare each point to previous later? nearest earlier vs later per row evaluation per instructions.\n        # Evaluate whether wet-dry increases between consecutive years.\n        dif = vals[1:] - vals[:-1]\n        valid = ~np.isnan(dif)\n        total += valid.sum()\n        inc += (dif[valid] > 0).sum()\n    increases = inc\nelse:\n    work = work.sort_values('Year')\n    vals = work['WetDry'].to_numpy()\n    dif = vals[1:] - vals[:-1]\n    valid = ~np.isnan(dif)\n    total = valid.sum()\n    increases = (dif[valid] > 0).sum()\n\npercent = float(increases) / float(total) * 100 if total else np.nan\nround(percent,2), increases, total, df.shape"}) [toolUseId=call_YqqYhs0dag6VEx39oVQirM1e]
