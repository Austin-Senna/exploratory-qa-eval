mn')\n\n# Data starts after header rows; find first row where Age_ky in col_age is numeric\nage_series = raw.iloc[:, col_age]\nwd_series = raw.iloc[:, col_wd]\n\n# Coerce to numeric and keep rows with finite wet-dry and age\nage_num = pd.to_numeric(age_series, errors='coerce')\nwd_num = pd.to_numeric(wd_series, errors='coerce')\nmask = np.isfinite(age_num) & np.isfinite(wd_num)\nclean = pd.DataFrame({'Age_ky': age_num[mask].values, 'wetdry': wd_num[mask].values})\n\n# Sort by age (younger to older?) We'll follow source: sort by Age_ky and then evaluate adjacent earlier/later.\nclean = clean.sort_values('Age_ky').reset_index(drop=True)\n\n# For each row i, define nearest earlier and nearest later wet-dry index values:\n# earlier => max age < current, later => min age > current. Since rows may have same age, we treat strict.\nages = clean['Age_ky'].values\nwet = clean['wetdry'].values\n\n# Precompute for each index i: earlier wetdry = previous row wetdry (since sorted), later wetdry = next row wetdry.\n# But if duplicates in age exist, nearest earlier/later should still be previous/next evaluated rows by position.\nprev_wet = np.roll(wet, 1)\nnext_wet = np.roll(wet, -1)\n\n# Determine which indices have both earlier and later evaluated rows\nvalid = (np.arange(len(wet))>0) & (np.arange(len(wet))<len(wet)-1)\ninc = (next_wet > prev_wet) & valid\n\nevaluated_rows = valid.sum()\nincreasing_count = inc.sum()\npercent = increasing_count / evaluated_rows * 100\npercent_rounded = round(float(percent), 2)\nprint(evaluated_rows)\nprint(increasing_count)\nprint(percent_rounded)\n"}) [toolUseId=call_tFeutUkcjNUO8niKaiHR5U8h]
