 c in ds.columns]\n\n# Rename first column if needed\n# Find date column\ndate_col=None\nfor c in ds.columns:\n    if 'Date' in c and c!='Tag':\n        date_col=c\n        break\nif date_col is None:\n    date_col=ds.columns[0]\n\n# rainfall 3-day and Enterococcus 3-day? datasheet has 1-Day Rain,2-Day Rain,3-Day Rain and Tag/Enterococcus repeated four times\n# Enterococcus columns appear as alternating Tag and Enterococcus for 1-day,2-day,3-day? We'll take last pair corresponding to 3-day rain.\n# Identify positions of '3-Day Rain'\nrain3_col='3-Day Rain'\n\n# Find Enterococcus value column for 3-day: in sample header: ... '3-Day Rain','Tag','Enterococcus','Tag','Enterococcus','Tag','Enterococcus','Tag','Enterococcus'\n# Actually columns after 3-Day Rain: Tag,Enterococcus,Tag,Enterococcus,Tag,Enterococcus,Tag,Enterococcus (for several replicates?) We'll take first Tag/Enterococcus pair after 3-Day Rain.\nidx=list(ds.columns).index(rain3_col)\npost_cols=ds.columns[idx+1:]\n# Take first two as tag1 and enter1 for 1st replicate\ntag_col=post_cols[0]; enter_col=post_cols[1]\n\n# Parse date\n# sample shows \"August 31, 2024\"; parse\n\nds[date_col]=pd.to_datetime(ds[date_col].astype(str).str.replace('\"',''), errors='coerce')\n\n# From wb_ent get sample dates for Wollaston Beach\nwb_ent_dates=wb_ent.loc[wb_ent['Beach Name'].str.strip()=='Wollaston Beach','Sample Date'].copy()\nwb_ent_dates=pd.to_datetime(wb_ent_dates, errors='coerce').dt.normalize().unique()\n\n# Filter datasheet to those dates\nsub=ds[ds[date_col].isin(pd.to_datetime(wb_ent_dates))].copy()\n\n# Censoring rules: Tag column contains '<' or '>' or ''\n# Enterococcus column is numeric.\nsub['Enterococcus_num']=pd.to_numeric(sub[enter_col], errors='coerce')\nsub['Tag']=sub[tag_col].astype(str).str.strip()\n# if Tag startswith '<' => /2 ; if startswith '>' => keep; else keep\nsub.loc[sub['Tag'].str.startswith('<'), 'Enterococcus_num']=sub.loc[sub['Tag'].str.startswith('<'), 'Enterococcus_num']/2\n# if Tag is '>' or something, keep as-is. If Tag empty, keep.\n\n# rainfall 3-day\nsub[rain3_col]=pd.to_numeric(sub[rain3_col], errors='coerce')\n\n# compute pearson\ncorr=sub[[rain3_col,'Enterococcus_num']].dropna().corr(method='pearson').iloc[0,1]\nprint('n',len(sub[[rain3_col,'Enterococcus_num']].dropna()))\nprint(round(float(corr),3))\n"}) [toolUseId=call_f2nmvfyXNGx1qTtRcTBUDaeB]
