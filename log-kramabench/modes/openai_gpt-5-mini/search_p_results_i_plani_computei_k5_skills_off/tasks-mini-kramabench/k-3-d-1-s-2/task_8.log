s ('yes') and total samples\ntotal_samples = len(bucks_summer)\nyes_count = (bucks_summer['Violation'].str.lower()=='yes').sum()\n\n# Compute exceedance percentage\nif total_samples>0:\n    exceed_pct = round(yes_count/total_samples*100,2)\nelse:\n    exceed_pct = None\n\nprint('max_year', max_year)\nprint('max_jja', max_jja)\nprint('total_samples', total_samples)\nprint('yes_count', yes_count)\nprint('exceed_pct', exceed_pct)\n\n# Also print bucks_summer rows for verification\nprint(bucks_summer[['Sample Date','Beach Name','Indicator Level','Violation']])\n", "dataset_id": "kramabench-environment-hard-17", "file_path": "files/monthly_precipitations_chatham.csv"}) [toolUseId=call_pXzJSZWPnxHpQge5wKoEmow6]
