    pd.to_numeric(
        df.loc[df['State'].astype(str).str.strip().eq('Alabama'), '# of Reports']
          .astype(str)
          .str.replace(',', '', regex=False),
        errors='coerce'
    )
    .fillna(0)
    .sum()
)

print(int(alabama_total))
