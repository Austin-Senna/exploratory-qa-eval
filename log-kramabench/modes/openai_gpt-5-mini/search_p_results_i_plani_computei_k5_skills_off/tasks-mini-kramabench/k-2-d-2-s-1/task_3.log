  if c.endswith('Tag'):\n            site = c.rsplit(' ',1)[0]\n            tag = row[c]\n            ent_col = site + ' Enterococcus'\n            if ent_col in df.columns:\n                ent = row[ent_col]\n            else:\n                ent = None\n            rows.append({'Date':date, '1-Day Rain':one_day, 'Site':site, 'Tag':tag, 'Enterococcus':ent})\n\nlong = pd.DataFrame(rows)\n# Clean Enterococcus: remove non-numeric, coerce to numeric\nlong['Enterococcus'] = pd.to_numeric(long['Enterococcus'], errors='coerce')\n# Clean 1-Day Rain numeric\nlong['1-Day Rain'] = pd.to_numeric(long['1-Day Rain'], errors='coerce')\n\n# Filter sites that contain 'Pleasure Bay'\npleasure = long[long['Site'].str.contains('Pleasure Bay', na=False)].copy()\nprint('\\nTotal pleasure rows:', len(pleasure))\nprint(pleasure.head(15).to_string())\n\n# Identify failed samples Enterococcus > 104\nfailed = pleasure[pleasure['Enterococcus'] > 104]\nprint('\\nFailed rows count:', len(failed))\nprint(failed[['Date','Site','Enterococcus','1-Day Rain']].to_string())\n\n# Compute mean of 1-Day Rain for failed samples\nmean_rain = failed['1-Day Rain'].mean()\nif pd.isna(mean_rain):\n    print('No failed samples or no rain data')\nelse:\n    print('\\nMean 1-Day Rain (unrounded):', mean_rain)\n    print('Mean rounded to 2 decimals:', round(mean_rain,2))\n    # Print value for submission\n    print('\\nRESULT:', f\"[{round(mean_rain,2)}]\")\n", "intent": "Compute mean 1-Day Rain for Pleasure Bay samples where Enterococcus > 104"}) [toolUseId=call_6zlsesbdwrlFGWHs9hUaLRH5]
