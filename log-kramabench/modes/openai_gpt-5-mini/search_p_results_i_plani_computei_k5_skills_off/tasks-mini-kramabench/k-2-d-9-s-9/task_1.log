 For each row, need to pair Tag and Enterococcus columns per site\n    # Sites are in the header row positions above ent_cols\n    # Build site names from the row above header_idx maybe\n    # Read the original file to get the two header rows above 'Date'\n    raw = pd.read_csv(p, header=None, dtype=str)\n    # assume site names are in the row header_idx-1 or header_idx-2 depending\n    site_row = None\n    if header_idx-1 >=0:\n        site_row = list(raw.iloc[header_idx-1].fillna(''))\n    else:\n        site_row = ['']*len(raw.columns)\n    # Now for each Enterococcus column, find its site by looking at site_row same col or nearest labelled\n    for ent_col in ent_cols:\n        ent_idx = data.columns.get_loc(ent_col)\n        # site name from site_row same index or left-most non-empty\n        site = site_row[ent_idx]\n        if not site or str(site).strip()==',':\n            # find nearest non-empty to the left\n            for j in range(ent_idx-1, -1, -1):\n                if str(site_row[j]).strip():\n                    site = site_row[j]\n                    break\n        # Now iterate rows\n        for i,row in data.iterrows():\n            date = row.get(date_col, '')\n            rain = row.get(rain_col, '')\n            ent = row.get(ent_col, '')\n            # clean ent: could be '<', etc. If pattern like '<,10' as in preview, need to extract number after comma\n            if isinstance(ent, str) and ',' in ent:\n                parts = ent.split(',')\n                ent_val = parts[-1]\n            else:\n                ent_val = ent\n            # strip < and spaces\n            ent_val = re.sub(r\"[^0-9.]\", \"\", str(ent_val))\n            try:\n                ent_num = float(ent_val) if ent_val!='' else None\n            except:\n                ent_num = None\n            # clean rain\n            rain_val = re.sub(r\"[^0-9.]\",\"\", str(rain))\n            try:\n                rain_num = float(rain_val) if rain_val!='' else 0.0\n            except:\n                rain_num = 0.0\n            rows.append({'file':Path(p).name, 'date':date, 'site':site, 'ent':ent_num, 'rain1':rain_num})\n\n# Build dataframe\nall_df = pd.DataFrame(rows)\n# Drop rows missing ent\nall_df = all_df[all_df['ent'].notnull()].copy()\n# Determine failed samples: ent > 104\nall_df['failed'] = all_df['ent'] > 104\nall_df['rain24'] = all_df['rain1'] > 0\n\ntotal_failed = int(all_df['failed'].sum())\nfailed_with_rain = int(all_df[all_df['failed'] & all_df['rain24']].shape[0])\npercentage = round(failed_with_rain/total_failed*100,2) if total_failed>0 else 0.0\nprint(total_failed, failed_with_rain, percentage)\n", "dataset_id": "kramabench-environment-hard-8", "file_path": "files/constitution_beach_datasheet.csv"}) [toolUseId=call_0uhnh4KUJ0bdBYWZN0MaP4j7]
