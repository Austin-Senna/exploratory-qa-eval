_beach_datasheet(path: str) -> pd.DataFrame:\n    df = pd.read_csv(path, skiprows=1, header=[0, 1])\n    cols = df.columns.to_frame(index=False)\n    cols.iloc[:, 0] = cols.iloc[:, 0].replace(r'^Unnamed.*', pd.NA, regex=True).ffill()\n\n    flat_cols = []\n    for a, b in cols.itertuples(index=False, name=None):\n        parts = []\n        for part in (a, b):\n            s = '' if pd.isna(part) else str(part).strip()\n            if s and s.lower() != 'nan':\n                parts.append(s)\n        flat_cols.append('_'.join(parts))\n    df.columns = flat_cols\n    return df\n\n\ndef get_date_col(df: pd.DataFrame) -> str:\n    for c in df.columns:\n        if c.lower() == 'date' or c.lower().endswith('_date'):\n            return c\n    raise KeyError('No date column found')\n\n\ndef normalize_location(s: str) -> str:\n    return str(s).strip().lower()\n\n\ndef matches_location(beach_name: str, location: str) -> bool:\n    location = normalize_location(location)\n    if beach_name == 'Pleasure Bay Beach':\n        return 'pleasure bay' in location\n    if beach_name == 'Castle Island Beach':\n        return 'castle island' in location\n    if beach_name == 'City Point Beach':\n        return 'city point' in location\n    if beach_name == 'M Street Beach':\n        return 'm. street' in location or 'm street' in location\n    if beach_name == 'Carson Beach':\n        return location in ['i street', 'mccormack bathhouse'] or 'carson' in location\n    if beach_name == 'Constitution Beach':\n        return location in ['north', 'middle', 'south'] or 'constitution' in location\n    if beach_name == 'Tenean Beach':\n        return location == 'middle' or 'tenean' in location\n    if beach_name == 'Wollaston Beach':\n        return location in ['channing street', 'milton road', 'rice road', 'sachem street'] or 'wollaston' in location\n    return beach_name.replace(' Beach', '').lower() in location\n\n\nqualifying = []\n\nfor beach in beach_order:\n    local_path = path_map[beach_to_file[beach]]\n    df = prepare_beach_datasheet(local_path)\n\n    date_col = get_date_col(df)\n    df['__date'] = pd.to_datetime(df[date_col], errors='coerce')\n    recent = df[(df['__date'] >= start) & (df['__date'] <= end)].copy()\n\n    enter_cols = [c for c in recent.columns if c.endswith('_Enterococcus')]\n    if not enter_cols or recent.empty:\n        continue\n\n    id_cols = [c for c in recent.columns if c not in enter_cols and not c.endswith('_Tag')]\n    long_df = recent.melt(\n        id_vars=id_cols,\n        value_vars=enter_cols,\n        var_name='Variable',\n        value_name='Enterococcus'\n    )\n    long_df['Location'] = long_df['Variable'].str.rsplit('_', n=1).str[0]\n    long_df['Enterococcus'] = pd.to_numeric(long_df['Enterococcus'], errors='coerce')\n    beach_rows = long_df[long_df['Location'].apply(lambda x: matches_location(beach, x))].copy()\n    beach_rows = beach_rows.dropna(subset=['Enterococcus'])\n\n    if not beach_rows.empty and not (beach_rows['Enterococcus'] > 104).any():\n        qualifying.append(beach)\n\nprint(qualifying)", "reason": "Rewrote the script to use the local manifest-mapped CSVs robustly, parse the two-row datasheet headers correctly, filter samples from 2020-01-01 through 2024-12-31, match each beach to its relevant monitoring locations within each datasheet, test whether all Enterococcus values are below 104, and print the final qualifying beach list."}) [toolUseId=call_0al7di6XmbUZNWZ9C7Qqlk0U]
