tasheet.csv'\n}\n\nstart = pd.Timestamp('2020-01-01')\nend = pd.Timestamp('2024-12-31')\nqualifying = []\n\nfor beach in beach_order:\n    s3 = beach_to_file[beach]\n    local = path_map[s3]\n    # read csv assuming header=2\n    try:\n        df = pd.read_csv(local, header=2)\n    except Exception:\n        df = pd.read_csv(local)\n    df.columns = [str(c).strip() for c in df.columns]\n    # find date col\n    date_col = next((c for c in df.columns if c.lower().strip().startswith('date')), None)\n    if date_col is None:\n        print(beach, 'no date col')\n        continue\n    df['__date'] = pd.to_datetime(df[date_col], errors='coerce')\n    df = df[(df['__date']>=start) & (df['__date']<=end)]\n    if df.shape[0]==0:\n        print(beach, 'no samples in range')\n        continue\n    enter_cols = [c for c in df.columns if 'enterococcus' in c.lower()]\n    vals = []\n    for c in enter_cols:\n        s = df[c].astype(str).str.replace('[^0-9.]','', regex=True)\n        num = pd.to_numeric(s, errors='coerce')\n        vals.append(num.dropna())\n    if len(vals)==0:\n        print(beach, 'no enter cols')\n        continue\n    allvals = pd.concat(vals, axis=0)\n    if allvals.shape[0]==0:\n        print(beach, 'no numeric')\n        continue\n    fails = (allvals >= 104).any()\n    print(beach, 'samples', allvals.shape[0], 'max', allvals.max(), 'fails', fails)\n    if not fails:\n        qualifying.append(beach)\n\nprint('FINAL', qualifying)\nqualifying\n", "intent": "Compute qualifying beaches using local downloaded CSVs", "dataset_id": "kramabench-environment-hard-9", "file_path": ""}) [toolUseId=call_I0CnhwZ7WOOd3NOt8kdbKRYr]
