eet1\ncl = pd.read_excel(cl_path, sheet_name='Sheet1', header=0)\nprint('CL cols:', list(cl.columns[:40]))\n\n# The preview showed repeated header rows; find the row where actual header (starts with 'Site') occurs\nwith pd.ExcelFile(cl_path) as xl:\n    # read first 15 rows raw\n    raw = pd.read_excel(cl_path, sheet_name='Sheet1', header=None, nrows=20)\nprint(raw.head(15))\n\n# Find header row index where first cell == 'Site'\nheader_row_idx = None\nfor idx, val in enumerate(raw[0].tolist()):\n    if str(val).strip()== 'Site':\n        header_row_idx = idx\n        break\nprint('header_row_idx', header_row_idx)\n\ncl = pd.read_excel(cl_path, sheet_name='Sheet1', header=header_row_idx)\nprint('Loaded climate columns:', list(cl.columns))\n\n# Look for K column (Potassium). Column header likely 'K' or 'K ' etc.\nk_col = None\nfor c in cl.columns:\n    if str(c).strip().upper()=='K' or 'POTASSIUM' in str(c).upper():\n        k_col = c\n        break\nprint('k_col:', k_col)\n\n# Age column likely 'Age_ky' or 'Age_ky' multiple; find primary Age column near K\nage_col = None\nfor c in cl.columns:\n    if 'Age' in str(c) and 'ky' in str(c):\n        age_col = c\n        break\nprint('age_col:', age_col)\n\n# Prepare dataframe of age (in ky) and K (ppm). Convert ages to years (ky to years?)\n# The radiocarbon 'date' seems to be in years (e.g., 7471). Climate 'Age_ky' is in thousands of years (ky). Need to ensure same units.\n\n# Check units: if climate ages are small decimals like 0.228251 from preview, that corresponds to ky ~ 0.228 -> 228 years? But preview showed large numbers in ppm columns and Age_ky around 0.228251 which seems likely in ky (thousands years). So convert climate Age_ky * 1000 to years.\n\ncl_age = pd.to_numeric(cl[age_col], errors='coerce')\ncl_k = pd.to_numeric(cl[k_col], errors='coerce')\n\n# Drop NaNs\ndfcl = pd.DataFrame({'age_years': cl_age*1000, 'K_ppm': cl_k}).dropna()\nprint('Climate rows with age and K:', len(dfcl))\nprint(dfcl.head())\n\n# No