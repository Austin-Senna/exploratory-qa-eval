r_totals[s][year] for s in marine_stations])\n    fresh_avg.append(fv)\n    marine_avg.append(mv)\n\nprint('fresh_avg', fresh_avg)\nprint('marine_avg', marine_avg)\n\nmarine_rates = rates['Marine']\nfresh_rates = rates['Freshwater']\nprint('marine_rates', marine_rates)\nprint('fresh_rates', fresh_rates)\n\nr_m, p_m = pearsonr(marine_avg, marine_rates)\nr_f, p_f = pearsonr(fresh_avg, fresh_rates)\nprint('marine corr, p:', r_m, p_m)\nprint('fresh corr, p:', r_f, p_f)\n\nif abs(r_f) > abs(r_m):\n    winner = 'Freshwater'\nelse:\n    winner = 'Marine'\n\nprint('winner', winner)\n\n# print winner only as final output\nwinner\n", "intent": "compute correlations and winner"})
