Year']==2023]\nw = w[w['Organism'].str.strip().str.lower().str.startswith('enter')]\nw = w[w['Beach Type Description'].str.strip().str.lower().str.startswith('marine')]\n\n# Normalize community and beach name\nw['Community_n'] = w['Community'].astype(str).str.strip().str.lower()\nw['Beach_n'] = w['Beach Name'].astype(str).str.strip().str.lower()\n\n# Filter to Boston Harbor beach list AND communities with high EJ\nw_filtered = w[(w['Beach_n'].isin(bh_set)) & (w['Community_n'].isin(high_ej_comms))]\n\nprint('Filtered rows:', len(w_filtered))\n\n# If none, we may need to match beach names partially. Let's show unique communities and beaches in filtered and available\nprint('Unique communities in data (sample 20):', w['Community_n'].unique()[:20])\nprint('Boston Harbor list (normalized):', bh_set)\nprint('Unique beach names in dataset that contain any Boston Harbor token:')\n\n# show some candidate matches\ncands = [bn for bn in w['Beach_n'].unique() if any(bh in bn or bn in bh for bh in bh_set)]\nprint('Candidate beach names matching tokens:', cands[:50])\n\n# If no rows, try partial matching: beach contains any token from Boston Harbor names or vice versa\nif len(w_filtered)==0:\n    # build token list from bh names words\n    tokens = [tok for name in bh_set for tok in name.split() if len(tok)>3]\n    tokens = list(set(tokens))\n    def match_beach(name):\n        for t in tokens:\n            if t in name:\n                return True\n        return False\n    mask_beach = w['Beach_n'].apply(lambda x: match_beach(x))\n    mask_comm = w['Community_n'].isin(high_ej_comms)\n    w_filtered = w[mask_beach & mask_comm]\n    print('After token matching filtered rows:', len(w_filtered))\n    print('Filtered beach unique:', w_filtered['Beach_n'].unique()[:50])\n\n# If still zero, print available communities that are high EJ\nif len(w_filtered)==0:\n    print('High EJ communities:', sorted(list(high_ej_comms))[:50])\n    # To debug, list rows where community in high_ej_comms\n    dbg = w[w['Community_n'].isin(high_ej_comms)]\n    print('Rows with high EJ communities in water dataset:', len(dbg))\n    print(dbg[['Community','Beach Name']].head(20))\n\n# Proceed if we have rows\nif len(w_filtered)==0:\n    # can't compute\n    print('No matching rows; exiting with NaN')\n    result = float('nan')\nelse:\n    # Clean Indicator Level column: handle < and >\n    def parse_level(x):\n        if pd.isna(x):\n            return np.nan\n        s = str(x).strip()\n        if s.startswith('<'):\n            try:\n                val = float(s.lstrip('<').strip())\n                return val/2.0\n            except:\n                return np.nan\n        if s.startswith('>'):\n            try:\n                val = float(s.lstrip('>').strip())\n                return val\n            except:\n                return np.nan\n        try:\n            return float(s)\n        except:\n            return np.nan\n\n    w_filtered['Entero'] = w_filtered['Indicator Level'].apply(parse_level)\n    # Also need 3-day rainfall column — check available columns\n    cols = w_filtered.columns.tolist()\n    rain_col = None\n    for c in cols:\n        if '3-day' in c.lower() or '3 day' in c.lower() or 'rainday' in c.lower() or 'rain' in c.lower():\n            rain_col = c\n            break\n    print('Rain column detected:', rain_col)\n    if rain_col is None:\n        # try to read the file header to know columns\n        print('Columns:', cols)\n        # No rain column — cannot compute\n        print('No rainfall column found; exiting with NaN')\n        result = float('nan')\n    else:\n        w_filtered['Rain3'] = pd.to_numeric(w_filtered[rain_col], errors='coerce')\n        df = w_filtered.dropna(subset=['Entero','Rain3'])\n        print('Rows with both measures:', len(df))\n        if len(df) < 2:\n            result = float('nan')\n        else:\n            corr, p = pearsonr(df['Rain3'], df['Entero'])\n            result = corr\n\n# print final result\nprint('Pearson corr (raw):', result)\n\n# output the rounded value if finite\nif np.isfinite(result):\n    print(f'{result:.3f}')\nelse:\n    print('NaN')\n\n", "intent": "Compute Pearson correlation per plan", "dataset_id": "kramabench-environment-hard-10", "file_path": "files/water-body-testing-2023.csv"})
