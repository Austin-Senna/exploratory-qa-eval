nterococci records in 2023\nwater = pd.read_csv(water_path)\nwater_2023 = water[water['Year'] == 2023].copy()\nwater_2023 = water_2023[\n    water_2023['Beach Type Description'].astype(str).str.strip().str.lower().eq('marine')\n    & water_2023['Organism'].astype(str).str.strip().str.lower().str.startswith('enter')\n].copy()\n\nwater_2023['Beach_clean'] = water_2023['Beach Name'].apply(clean_beach_name)\nmatched = water_2023[water_2023['Beach_clean'].isin(harbor_clean)].copy()\nmatched['Community_clean'] = matched['Community'].astype(str).str.strip().str.lower()\n\n# Unique Boston Harbor beaches and communities found in the water testing data\nbeaches_found = sorted(matched['Beach_clean'].dropna().unique())\ncommunities_found = sorted(matched['Community_clean'].dropna().unique())\n\n# Keep only communities that also have EJ percent > 90\nresults = []\nfor comm in communities_found:\n    if comm in ej90_map:\n        pretty_comm = matched.loc[matched['Community_clean'] == comm, 'Community'].astype(str).iloc[0].strip()\n        results.append((pretty_comm, float(ej90_map[comm])))\n\nif results:\n    for community, pct in sorted(results):\n        print(f\"{community}: {pct:.1f}%\")\nelse:\n    print(\"No Boston Harbor beach communities found with EJ population percent > 90%.\")\n    print(\"Boston Harbor beaches found in water-body-testing:\", ', '.join(beaches_found) if beaches_found else 'None')\n    print(\"Communities for those beaches:\", ', '.join(sorted({matched.loc[matched['Community_clean'] == c, 'Community'].astype(str).iloc[0].strip() for c in communities_found})) if communities_found else 'None')\n", "reason": "Rewrote the code to match the intent: clean Boston Harbor beach names by removing 'Beach', match them against 2023 marine Enterococci water-testing records, derive the associated communities, then report only those communities whose EJ population percent is greater than 90. The code prints the result and includes a fallback summary if no qualifying communities are found."}) [toolUseId=call_hBmJjrY6yPG5YqEjk1i69bHt]
