ame by removing suffix after '@'\ndef normalize_name(x):\n    if pd.isna(x):\n        return x\n    return x.split('@')[0].strip()\n\nfresh['Beach_norm'] = fresh['Beach Name'].apply(normalize_name)\n\n# Normalize Violation to lowercase 'yes'/'no'\nfresh['Violation_norm'] = fresh['Violation'].astype(str).str.strip().str.lower()\n\n# Compute per-year per-beach exceedance rate (fraction of samples where Violation == 'yes')\ngroup = fresh.groupby(['Beach_norm', 'Year'])['Violation_norm'].agg(\n    total_samples='count', num_violations=lambda x: (x=='yes').sum()\n).reset_index()\ngroup['exceedance_rate'] = group['num_violations'] / group['total_samples']\n\n# find beaches measured in all four years 2020-2023\nyears_needed = {2020,2021,2022,2023}\nbeach_years = group.groupby('Beach_norm')['Year'].apply(lambda yrs: set(yrs)).reset_index()\nbeach_years['has_all'] = beach_years['Year'].apply(lambda s: years_needed.issubset(s))\ncommon_beaches = beach_years[beach_years['has_all']]['Beach_norm'].tolist()\n\n# Filter group for common_beaches and pivot to have one rate per year\ncommon_group = group[group['Beach_norm'].isin(common_beaches)].copy()\n# compute average of four annual rates per beach\navg_rates = common_group.groupby('Beach_norm')['exceedance_rate'].mean().reset_index()\n# find max\nmax_row = avg_rates.loc[avg_rates['exceedance_rate'].idxmax()]\n\nprint(max_row['Beach_norm'])\nprint(float(max_row['exceedance_rate']))\n\n# For debugging, print top 5\ntop5 = avg_rates.sort_values('exceedance_rate', ascending=False).head(5)\nprint(top5.to_csv(index=False))\n", "intent": "Compute freshwater beaches present in all years 2020-2023, normalize beach names, compute annual exceedance rates, average across years, and select the beach with highest average."}) [toolUseId=call_8taUScjvoanCaIspExclQqR9]
