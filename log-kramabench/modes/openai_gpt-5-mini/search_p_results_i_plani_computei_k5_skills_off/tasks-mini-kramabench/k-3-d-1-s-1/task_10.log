import pandas as pd

# Local sandbox path for the dataset
path = 'other-benchmarks/Kramabench/data/wildfire/input/noaa_wildfires_monthly_stats.csv'

# Skip the two non-data header rows so the third row becomes the header
# (matches the dataset preview and benchmark plan)
df = pd.read_csv(path, skiprows=2)

# Clean and parse YYYYMM date values
df['Date'] = df['Date'].astype(str).str.strip()
df['month'] = pd.to_datetime(df['Date'], format='%Y%m')

# Clean numeric column in case it is read as text
df['Acres Burned'] = pd.to_numeric(df['Acres Burned'], errors='coerce')

# Filter from 2000-01-01 onward and sort chronologically
df = df[df['month'] >= pd.Timestamp('2000-01-01')].sort_values('month').reset_index(drop=True)

# Verify months are consecutive by reindexing to a complete monthly range
df = df.set_index('month')
full_months = pd.date_range(df.index.min(), df.index.max(), freq='MS')
df = df.reindex(full_months)

# Compute 3-month rolling sums only where all 3 months are present
rolling_sum = df['Acres Burned'].rolling(window=3, min_periods=3).sum()
max_sum = int(rolling_sum.max())

# Print the required result
print(max_sum)
