turn None\n    s = str(val).strip()\n    # remove commas\n    s = s.replace(',','')\n    # if empty\n    if s == '':\n        return None\n    # sometimes there are non-numeric like 'TNTC' - try to extract digits\n    m = re.search(r\"(\\d+\\.?\\d*)\", s)\n    if m:\n        try:\n            return float(m.group(1))\n        except:\n            return None\n    return None\n\nfor loc in ['North','Middle','South']:\n    df_2024[f'{loc}_Value'] = df_2024.apply(lambda r: parse_value(r[f'{loc}_Tag'], r[f'{loc}_Enterococcus']), axis=1)\n    # Determine meet: True if value < 104; if value is None -> NA\n    df_2024[f'{loc}_Meets'] = df_2024[f'{loc}_Value'].apply(lambda x: True if (x is not None and x < 104) else (False if (x is not None and x >= 104) else None))\n\n# For each date, check if at least one True and at least one False across three locations\nresults = []\nfor idx, row in df_2024.iterrows():\n    meets = [row[f'{loc}_Meets'] for loc in ['North','Middle','South']]\n    # count True/False ignoring None\n    true_count = sum(1 for v in meets if v is True)\n    false_count = sum(1 for v in meets if v is False)\n    has_true = true_count >= 1\n    has_false = false_count >= 1\n    results.append({'Date': row['Date_parsed'].date(), 'has_true': has_true, 'has_false': has_false, 'true_count': true_count, 'false_count': false_count})\n\nres_df = pd.DataFrame(results)\n# group by Date in case duplicates (shouldn't be), but ensure unique\nres_grp = res_df.groupby('Date').agg({'has_true':'max','has_false':'max','true_count':'sum','false_count':'sum'}).reset_index()\nres_grp['mixed'] = res_grp['has_true'] & res_grp['has_false']\n\ncount_mixed = res_grp['mixed'].sum()\nprint('count_mixed:', int(count_mixed))\n\n# Print some example rows where mixed is True\nprint(res_grp[res_grp['mixed']].head(20))\n\n# final output\nprint(int(count_mixed))\n", "dataset_id": "kramabench-environment-hard-13", "file_path": "files/constitution_beach_datasheet.csv"}) [toolUseId=call_py2DQITONKdpMeb4p3Mo3w9S]
