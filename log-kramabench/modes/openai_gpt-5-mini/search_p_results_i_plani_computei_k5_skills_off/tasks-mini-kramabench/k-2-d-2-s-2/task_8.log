 state['Generally Unsafe Days'] / state['Days with AQI']\n\n# clean wild state names: match whitespace\nwild['State'] = wild['State'].str.strip()\nstate['State'] = state['State'].str.strip()\n\n# merge\nmerged = pd.merge(state, wild[['State','Total Acres Burned']], on='State', how='inner')\n\n# drop NA\nmerged = merged.dropna(subset=['Proportion Generally Unsafe','Total Acres Burned'])\n\n# compute Pearson correlation\ncorr, p = pearsonr(merged['Proportion Generally Unsafe'], merged['Total Acres Burned'])\nprint('n states:', len(merged))\nprint('corr raw:', corr)\nprint('corr rounded:', round(corr,2))\n\n# print merged sample\nprint(merged.head())\n\n# final output\nprint(round(corr,2))\n", "intent": "Compute Pearson correlation between state proportion of generally unsafe AQI days and total acres burned using the two CSVs downloaded."}) [toolUseId=call_TG2hp2bOaxczh8RnyqaiOn7k]
