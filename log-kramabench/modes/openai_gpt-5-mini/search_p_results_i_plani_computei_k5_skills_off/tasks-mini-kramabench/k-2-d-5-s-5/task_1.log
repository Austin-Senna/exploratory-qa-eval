nt(round(meet_percent))\n\nprint(rounded)\n# Also print debugging info\nprint({'per_year': results, 'rates': rates, 'avg_violation_rate': avg_violation_rate, 'meet_percent': meet_percent})", "intent": "Compute Wollaston Beach violation rates across 2019-2023 and return rounded percent meeting swimming standards."}) [toolUseId=call_WlKxGayb46JQcNUExMhgFZKl]
