len(frame):\n        out['Cal_1_sigma_ranges'] = frame.apply(lambda r: combine_ranges(r, cal_1_cols), axis=1)\n        out['Cal_2_sigma_ranges'] = frame.apply(lambda r: combine_ranges(r, cal_2_cols), axis=1)\n        out['all_cal_years'] = out['Cal_1_sigma_ranges'].fillna('') + ' ' + out['Cal_2_sigma_ranges'].fillna('')\n        out['earliest_cal_bc'] = out['all_cal_years'].apply(lambda s: max(extract_years(s)) if extract_years(s) else pd.NA)\n        out['latest_cal_bc'] = out['all_cal_years'].apply(lambda s: min(extract_years(s)) if extract_years(s) else pd.NA)\n        out = out.drop(columns=['all_cal_years'])\n    print(title)\n    print('count:', len(frame))\n    if len(out):\n        print(out.to_string(index=False))\n    else:\n        print('No matching records found.')\n    print()\n\nprint('Malta records count:', len(malta))\nsummarize(malta, 'Malta records with calibrated ranges')\nsummarize(humans, 'All Homo sapiens / Homo records with calibrated ranges')\nsummarize(malta_humans, 'Malta Homo sapiens / Homo records with calibrated ranges')", "reason": "Rewrote the script to directly satisfy the intent: identify Malta-region records, find Homo/Homo sapiens entries, and explicitly extract calendar-calibrated 1-sigma and 2-sigma ranges for those matches. The fix also handles duplicate Excel column names like repeated 'Cal. BC 1 sigma'/'Cal. BC 2 sigma' by preserving both copies with unique suffixes, then combines them into usable calibrated-range fields and prints the results."}) [toolUseId=call_zUmDvuWzW0CMatIBo7MO6kpt]
