nimport numpy as np\nzscores = pd.DataFrame({'Year': total['Year']})\nmax_abs = -1\nmax_area = None\nmax_year = None\nmax_z = None\nfor a in areas:\n    vals = total[a]\n    mean = vals.mean()\n    std = vals.std(ddof=0)\n    if pd.isna(std) or std==0:\n        z = (vals-mean)\n    else:\n        z = (vals-mean)/std\n    zscores[a] = z\n    # find max absolute z\n    idx = z.abs().idxmax()\n    if z.abs().iloc[idx] > max_abs:\n        max_abs = float(z.abs().iloc[idx])\n        max_area = a\n        max_year = int(total['Year'].iloc[idx])\n        max_z = float(z.iloc[idx])\n\nprint(max_area + ',' + str(max_year))\nprint('max_abs_zscore:', max_abs)\nprint('zscore:', max_z)\n", "intent": "Compute combined acres per area-year from human and lightning CSVs, compute z-scores per area across years, and identify the single area and year with the largest absolute z-score.", "dataset_id": "kramabench-wildfire-hard-7", "file_path": "files/nifc_human_caused_acres.csv"}) [toolUseId=call_9h5NkbhoK1POe1CJWMPaHLqS]
