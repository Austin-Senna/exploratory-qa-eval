nited Kingdom','Ireland':'Ireland'}\n\nfrom collections import Counter\nctr=Counter()\nfor actors in sel['actors']:\n    mapped=set()\n    for a in actors:\n        for key in mapping:\n            if key.lower() in a.lower():\n                mapped.add(mapping[key])\n    if not mapped:\n        # fallback: take first token as country\n        tok=actors[0]\n        mapped.add(tok)\n    for m in mapped:\n        ctr[m]+=1\n\nprint('counts', ctr.most_common(20))\n# print final total conflicts\nprint('total_conflicts', len(sel))\n# print per-country dict\nprint(dict(ctr))\n# Print only what we need\nprint('\\nFINAL_COUNTS')\nfor k,v in ctr.most_common():\n    print(k,v)\nprint('TOTAL', len(sel))\n", "intent": "Filter and aggregate conflicts from CSV mapping to modern countries"}) [toolUseId=call_dzBYwwFCKdGW7u7oaXjPOtgm]
