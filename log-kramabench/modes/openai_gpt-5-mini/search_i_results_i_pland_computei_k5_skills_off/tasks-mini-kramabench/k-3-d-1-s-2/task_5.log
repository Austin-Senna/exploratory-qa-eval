y integer values and typical Ap range 0-127.\n# Evaluate which candidate has many integer values\nbest_col = None\nbest_int_fraction = -1\nfor c,stats in cands.items():\n    vals = []\n    for r in rows:\n        try:\n            vals.append(float(r[c]))\n        except:\n            vals.append(np.nan)\n    vals = np.array(vals)\n    frac_int = np.mean(np.isclose(vals, np.round(vals), atol=1e-8))\n    if frac_int>best_int_fraction:\n        best_int_fraction = frac_int\n        best_col = c\n\nprint('chosen ap column', best_col, 'int_frac', best_int_fraction)\n\nap_col = best_col\n# build time series: OMNI2 has standard order year, month, day, hour at start? Try to parse: we'll detect which columns make valid datetime by trying combos\n\n# find possible date columns among first 6 columns: test combos (year, month, day, hour) from indices 0..6\nfrom itertools import product, combinations\nn=len(rows)\nrows_arr = rows\nfound_dt = None\nfor y in range(0,4):\n    for m in range(1,5):\n        for d in range(2,7):\n            for hr in range(3,8):\n                try:\n                    sample_dt = datetime(int(rows_arr[0][y]), int(rows_arr[0][m]), int(rows_arr[0][d]), int(rows_arr[0][hr]))\n                    # also try second row to ensure progression by 1 hour or so\n                    sample2 = datetime(int(rows_arr[1][y]), int(rows_arr[1][m]), int(rows_arr[1][d]), int(rows_arr[1][hr]))\n                    diff = (sample2 - sample_dt).total_seconds()/3600.0\n                    if abs(diff - 1.0) < 1.1: # about hourly\n                        found_dt = (y,m,d,hr)\n                        break\n                except Exception:\n                    continue\n            if found_dt:\n                break\n        if found_dt:\n            break\n    if found_dt:\n        break\n\nprint('found_dt', found_dt)\n\nif not found_dt:\n    # alternative: file likely has Year, Month, dummy, DOY, H1,H2? Inspect first row slice\n    print('could not autodetect datetime columns')\nelse:\n    y,m,d,hr = found_dt\n    omni_times = []\n    omni_ap = []\n    for r in rows:\n        try:\n            yy = int(r[y]); mm = int(r[m]); dd = int(r[d]); h = int(r[hr])\n            omni_times.append(datetime(yy,mm,dd,h))\n            omni_ap.append(float(r[ap_col]))\n        except Exception:\n            omni_times.append(None); omni_ap.append(np.nan)\n    omni_df = pd.DataFrame({'time':omni_times, 'ap':omni_ap})\n    omni_df = omni_df.dropna(subset=['time']).reset_index(drop=True)\n    # filter to May 1-30\n    omni_df = omni_df[(omni_df['time']>=start) & (omni_df['time']<=end)]\n    # round times to nearest hour (they are hourly already)\n    omni_df['hour'] = omni_df['time']\n    omni_df = omni_df[['hour','ap']]\n\n    # align with df_hour\n    merged = pd.merge(df_hour, omni_df, on='hour', how='inner')\n    merged = merged.sort_values('hour').reset_index(drop=True)\n    print('merged rows', len(merged))\n\n    # compute r2 for lags 0..48 where ap at time t-lag correlated with delta_a at time t\n    results = []\n    for lag in range(0,49):\n        # create AP_lagged such that for each row at time t, use ap at t-lag\n        merged['ap_lag'] = merged['ap'].shift(lag)\n        sub = merged.dropna(subset=['ap_lag','delta_a'])\n        if len(sub)<3:\n            results.append((lag, np.nan))\n            continue\n        r = np.corrcoef(sub['delta_a'], sub['ap_lag'])[0,1]\n        results.append((lag, r**2))\n    # print results and best lag\n    best = max(results, key=lambda x: (x[1] if not np.isnan(x[1]) else -1))\n    print('best', best)\n    for r in results:\n        print(r)\n\n    # output best lag\n    print(best[0])\n", "dataset_id": "kramabench-astronomy-hard-9", "file_path": "files/omni2_low_res/omni2_2024.dat"}) [toolUseId=call_jjAfCIAYzmOfZcancfVKK9qJ]
