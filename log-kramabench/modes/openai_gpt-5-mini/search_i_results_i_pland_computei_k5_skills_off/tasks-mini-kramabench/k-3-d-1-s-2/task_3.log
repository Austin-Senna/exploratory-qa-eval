an['lat'], errors='coerce')\n\n# world lat/lng columns are 'lat','lng'\nworld_large['lat'] = pd.to_numeric(world_large['lat'], errors='coerce')\nworld_large['lng'] = pd.to_numeric(world_large['lng'], errors='coerce')\n\n# For each modern city, find roman cities within 0.1 degrees distance (max of abs differences?)\n# Use Euclidean distance on degrees\n\ndef find_matches_for_modern():\n    matches = []\n    # Convert roman to list for iteration\n    roman_valid = roman.dropna(subset=['lat','lon','rank_parsed']).copy()\n    world_valid = world_large.dropna(subset=['lat','lng','population']).copy()\n    for idx, w in world_valid.iterrows():\n        # compute distance\n        dlat = np.abs(roman_valid['lat'] - w['lat'])\n        dlon = np.abs(roman_valid['lon'] - w['lng'])\n        dist = np.sqrt(dlat**2 + dlon**2)\n        close = roman_valid[dist < 0.1]\n        if close.empty:\n            continue\n        # if multiple ancient cities, take the last sample in the data (i.e. last row order)\n        last = close.iloc[[-1]]\n        rank = last['rank_parsed'].values[0]\n        matches.append({'modern_idx': idx, 'modern_city': w['city_ascii'], 'modern_pop': w['population'], 'ancient_pk': last.iloc[0,0], 'ancient_name': last['Ancient Toponym'].values[0], 'rank': rank, 'dist_min': float(dist.min())})\n    return pd.DataFrame(matches)\n\nmatches_df = find_matches_for_modern()\nprint('matches count:', matches_df.shape[0])\n\n# Compute correlation between ancient rank and modern population\nmatches_df = matches_df.dropna(subset=['rank','modern_pop'])\nif matches_df.shape[0] < 2:\n    corr = np.nan\nelse:\n    corr = matches_df['rank'].corr(matches_df['modern_pop'])\n\nprint('corr raw:', corr)\n\n# print first rows of matches\nprint(matches_df.head(20))\n\n# print correlation to 6 decimals\nif np.isnan(corr):\n    print('final_corr: NaN')\nelse:\n    print('final_corr:', format(corr, '.6f'))\n\n# Output final values for the agent to read\nprint('OUTPUT_CORR', format(corr,