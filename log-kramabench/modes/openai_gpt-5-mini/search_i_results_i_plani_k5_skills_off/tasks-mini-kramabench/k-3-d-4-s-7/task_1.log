}\n    for y in [2007,2008,2009]:\n        row = df[df['Year']==y]\n        vals=[]\n        if not row.empty:\n            for m in ['Jun','Jul','Aug']:\n                v = row.iloc[0][m]\n                vals.append(med[m] if pd.isna(v) else float(v))\n        else:\n            vals = [med[m] for m in ['Jun','Jul','Aug']]\n        imputed[st][y]=sum(vals)\n\nmarine_stations = ['Boston','Chatham']\nfresh_stations = ['Boston','Chatham','Amherst','Ashburnham']\nmarine_totals = [np.mean([imputed[s][y] for s in marine_stations]) for y in [2007,2008,2009]]\nfresh_totals = [np.mean([imputed[s][y] for s in fresh_stations]) for y in [2007,2008,2009]]\n\n# compute Pearson\nr_marine = pearsonr(marine_totals, rates['Marine'])[0]\nr_fresh = pearsonr(fresh_totals, rates['Freshwater'])[0]\n\nprint('marine_totals', marine_totals)\nprint('fresh_totals', fresh_totals)\nprint('marine_rates', rates['Marine'])\nprint('fresh_rates', rates['Freshwater'])\nprint('r_marine, r_fresh', r_marine, r_fresh)\n\nif abs(r_fresh) > abs(r_marine):\n    print('Freshwater higher')\nelse:\n    print('Marine higher')\n"}) [toolUseId=call_wCt5S6SKQNDM14Vuhp5JUbDK]
