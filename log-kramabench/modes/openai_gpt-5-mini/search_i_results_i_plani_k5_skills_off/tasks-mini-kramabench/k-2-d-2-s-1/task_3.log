ip()\n    data[c] = pd.to_numeric(data[c], errors='coerce')\n\n# Clean 1-Day Rain numeric\ndata['1-Day Rain'] = data['1-Day Rain'].astype(str).str.replace(',','').str.strip()\ndata['1-Day Rain'] = pd.to_numeric(data['1-Day Rain'], errors='coerce')\n\n# Determine failed Pleasure Bay samples: either Broadway or Flagpole Enterococcus > 104\npb_failed_mask = (data['Enterococcus_PB_Broadway'] > 104) | (data['Enterococcus_PB_Flagpole'] > 104)\nfailed = data[pb_failed_mask].copy()\nprint('\\nNumber of failed Pleasure Bay samples:', len(failed))\nprint(failed[['Date','1-Day Rain','Enterococcus_PB_Broadway','Enterococcus_PB_Flagpole']].to_string(index=False))\n\n# Compute mean 1-Day Rain for failed Pleasure Bay samples\nmean_rain = failed['1-Day Rain'].mean()\nprint('\\nMean 1-Day Rain (raw):', mean_rain)\nprint('\\nRounded to 2 decimals:')\nprint(round(mean_rain,2))\n\n# Print final value only (for parsing)\nprint('\\nFINAL_ANSWER:', f\"{round(mean_rain,2):.2f}\")\n"}) [toolUseId=call_9FFy1EcjLcTIvCA2X4QUiAVZ]
