= raws[(np.abs(raws['Latitude']-lat)<=0.5) & (np.abs(raws['Longitude']-lon)<=0.5)]\n    for sid in nearby['Station ID'].dropna().unique():\n        matched_station_ids.add(sid)\n\nmatched_station_ids = sorted(matched_station_ids)\nprint('matched station count', len(matched_station_ids))\n\n# compute mean elevation for matched\nmatched_raws = raws[raws['Station ID'].isin(matched_station_ids) & raws['Elevation'].notna()]\nmean_elev = matched_raws['Elevation'].mean()\nprint('mean elevation (raws matched):', mean_elev)\n# round result\nif pd.notna(mean_elev):\n    print(round(mean_elev))\nelse:\n    print('NA')\n\n# Also, if no matches found, consider alternative: station IDs may be in NOAA file under columns like 'Station ID' or 'MesoWest Station ID'.\npossible_cols = [c for c in noaa.columns if 'station' in c.lower() or 'id' in c.lower()]\nprint('possible cols in noaa with station/id keywords:', possible_cols)\n\n# check raws Station ID uniqueness\nprint('unique raws Station ID count', raws['Station ID'].nunique())\nprint('sample matched raws rows:', matched_raws.head(5).to_csv(index=False))\n\n# print first 10 RAWS station IDs for manual check\nprint('first 10 raws Station IDs:', list(raws['Station ID'].dropna().unique()[:10]))\n"}) [toolUseId=call_RvJvZsPQGYWCcuNgh5FFTbAJ]
