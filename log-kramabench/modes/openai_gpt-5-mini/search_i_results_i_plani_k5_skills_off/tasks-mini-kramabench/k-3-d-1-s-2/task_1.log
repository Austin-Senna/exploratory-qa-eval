2026-05-17 16:39:06 | DEBUG | strands_evaluation.instrumentation.agent_plugins | Model response #9 [role=assistant block=1 tool_use] execute_code({"code": "import pandas as pd\nimport re\nfrom collections import defaultdict\n\nconf = pd.read_csv(DOWNLOAD_PATHS['s3://sana-kramabench/datagov/kramabench-archeology-hard-12/files/conflict_brecke.csv'])\nworld = pd.read_csv(DOWNLOAD_PATHS['s3://sana-kramabench/datagov/kramabench-archeology-hard-12/files/worldcities.csv'])\n\n# prepare country list and admin names and city names\ncountries = set(world['country'].dropna().unique())\nadmin_names = set(world['admin_name'].dropna().unique())\ncity_names = set(world['city'].dropna().unique()) | set(world['city_ascii'].dropna().unique())\n\n# lowercase maps for quick search\ncountries_l = [c.lower() for c in countries]\nadmin_l = [a.lower() for a in admin_names]\ncity_l = [c.lower() for c in city_names]\n\n# historical mapping for some common actor names\nhist_map = {\n    'magyars':'Hungary',\n    'byzantium':'Turkey',\n    'byzantine':'Turkey',\n    'russia':'Russia',\n    'rus':'Russia',\n    'franks':'France',\n    'frank':'France',\n    'muslims':'Various',\n    'muslim':'Various',\n    'vikings':'Scandinavia',\n    'english':'United Kingdom',\n    'england':'United Kingdom',\n    'scots':'United Kingdom',\n    'spain':'Spain',\n    'italy':'Italy',\n    'germans':'Germany',\n    'germany':'Germany',\n    'netherlands':'Netherlands',\n    'hungary':'Hungary',\n    'egypt':'Egypt',\n    'magyars':'Hungary'\n}\n\n# helper to map a token to country\n\ndef map_actor_to_country(actor):\n    if pd.isna(actor):\n        return None\n    s = actor.lower()\n    s_clean = re.sub(r\"[^a-z0-9 ,]\",\" \", s)\n    # direct country substring\n    for c in countries:\n        if c.lower() in s:\n            return c\n    # historical map\n    for k,v in hist_map.items():\n        if k in s:\n            return v\n    # admin name match\n    for a in admin_names:\n        if a and a.lower() in s:\n            # find a corresponding country from a sample city\n            row = world[world['admin_name']==a].iloc[0]\n            return row['country']\n    # city name exact token match\n    tokens = s_clean.split()\n    for t in tokens:\n        if t in city_l:\n            # find a city row\n            row = world[world['city_ascii'].str.lower()==t]\n            if len(row):\n                return row.iloc[0]['country']\n            row = world[world['city'].str.lower()==t]\n            if len(row):\n                return row.iloc[0]['country']\n    return None\n\n# parse conflicts\npairs_intervals = defaultdict(list)\n\nfor idx,row in conf.iterrows():\n    try:\n        start = int(row['StartYear'])\n        end = int(row['EndYear'])\n    except Exception:\n        continue\n    # only keep fully within 800-1400\n    if start < 800 or end > 1400:\n        continue\n    # duration at least 1 year\n    if (end - start) < 1:\n        continue\n    cstr = str(row['Conflict'])\n    # split into two actors\n    if '-' in cstr:\n        a1,a2 = cstr.split('-',1)\n    elif ' vs ' in cstr.lower():\n        parts = re.split(' vs | v\\.| v ', cstr, flags=re.IGNORECASE)\n        if len(parts)>=2:\n            a1,a2 = parts[0],parts[1]\n        else:\n            a1,a2 = cstr, ''\n    else:\n        # try to extract actor and location in parentheses\n        m = re.match(r\"^(.*?)\\s*\\((.*?)\\)\", cstr)\n        if m:\n            a1 = m.group(1)\n            a2 = m.group(2)\n        else:\n            # can't split, skip\n            continue\n    a1 = a1.strip()\n    a2 = a2.strip()\n    ctry1 = map_actor_to_country(a1)\n    ctry2 = map_actor_to_country(a2)\n    # if one is None but other side contains a known country token, try to extract\n    if not ctry1:\n        # look for country in full string left of hyphen\n        for c in countries:\n            if c.lower() in a1.lower():\n                ctry1 = c\n                break\n    if not ctry2:\n        for c in countries:\n            if c.lower() in a2.lower():\n                ctry2 = c\n                break\n    # normalize unknowns\n    if not ctry1:\n        ctry1 = 'Unknown'\n    if not ctry2:\n        ctry2 = 'Unknown'\n    # sort pair to create undirected pair\n    pair = tuple(sorted([ctry1, ctry2]))\n    pairs_intervals[pair].append((start,end))\n\n# merge intervals per pair\n\ndef merge_intervals(intervals):\n    if not intervals:\n        return []\n    intervals_sorted = sorted(intervals)\n    merged = []\n    cur_s,cur_e = intervals_sorted[0]\n    for s,e in intervals_sorted[1:]:\n        if s <= cur_e: # overlap\n            cur_e = max(cur_e,e)\n        else:\n            merged.append((cur_s,cur_e))\n            cur_s,cur_e = s,e\n    merged.append((cur_s,cur_e))\n    return merged\n\nmerged_counts = {}\nfor pair, intervals in pairs_intervals.items():\n    merged = merge_intervals(intervals)\n    merged_counts[pair] = len(merged)\n\n# total conflicts is sum of merged_counts excluding Unknown-Unknown pairs maybe include Unknown\ntotal = sum(merged_counts.values())\n\n# print summary: top 20 pairs\npairs_sorted = sorted(merged_counts.items(), key=lambda x: -x[1])\nprint('Total conflicts (merged) between 800 and 1400 with >=1 year duration:', total)\nprint('\\nTop 20 country pairs by conflict count:')\nfor i,(pair,cnt) in enumerate(pairs_sorted[:20]):\n    print(i+1, pair, cnt)\n\n# also count how many pairs involve Unknown\nunknown_pairs = {p:c for p,c in merged_counts.items() if 'Unknown' in p}\nprint('\\nPairs with Unknown mapping:', len(unknown_pairs))\n\n# print total unique pairs\nprint('Unique country pairs:', len(merged_counts))\n\n# For final output, print total\nprint('\\nFINAL_TOTAL:', total)\n"}) [toolUseId=call_t9rpjVAI6iDXG98PgpA54AqK]
