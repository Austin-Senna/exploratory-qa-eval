tagov/kramabench-biomedical-hard-8/files/1-s2.0-S0092867420301070-mmc6.xlsx']\nfda = pd.read_excel(mmc6_path, sheet_name='G-FDA approved drugs')\nprint('\\nfda rows, cols:', fda.shape)\nprint(fda.head())\n\n# standardize gene name column\nfda_genes = set(fda['gene_name'].astype(str).str.upper())\nprint('\\nNumber of unique FDA gene targets:', len(fda_genes))\n\n# Now determine Endometrioid samples with CNV_HIGH. Try to find CNV_class info by searching for 'CNV' in cell values\n# Search across dataframe for the string 'CNV_HIGH' and report the column and sample idx\nmatches = []\nfor col in meta.columns:\n    mask = meta[col].astype(str).str.contains('CNV_HIGH', na=False)\n    if mask.any():\n        rows = meta.loc[mask, 'idx'].tolist()\n        matches.append((col, rows))\n\nprint('\\nMatched CNV_HIGH occurrences:', matches)\n\n# If none, look for columns with values like 'CNV_HIGH' or 'CNV_LOW' by searching unique values in columns that might be CNA-related\n# We'll print value counts for columns that have small number unique values (<=10) to inspect\nfor c in meta.columns:\n    try:\n        u = meta[c].dropna().unique()\n        if len(u)<=10:\n            print('\\nColumn', c, 'unique values sample:', u[:10])\n    except Exception as e:\n        pass\n\n# Based on peek, histologic type is in 'Histologic_type'. Use that and search for columns mentioning 'CNV' in other ways (e.g., 'Copy_number'?)\nprint('\\nUnique histologic types:', meta['Histologic_type'].unique())\n\n# Look for any column that contains 'class' and show its uniques\nclass_cols = [c for c in meta.columns if 'class' in c.lower() or 'classification' in c.lower() or 'subtype' in c.lower()]\nprint('\\nClass-like columns:', class_cols)\nfor c in class_cols:\n    print(c, meta[c].dropna().unique()[:20])\n\n# If CNV class is not explicit, check whether CNV class is encoded in another file in mmc6 sheets (maybe 'A-SE' etc). But hyperactivated.csv has sample IDs matching meta idx.\n\n# Filter meta for En