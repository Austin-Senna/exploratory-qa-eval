    'unhealthy': 'sum',\n    'very_unhealthy': 'sum',\n    'hazardous': 'sum'\n}).reset_index()\n\n# Fill missing columns if any\nfor c in ['unhealthy_sensitive', 'unhealthy', 'very_unhealthy', 'hazardous']:\n    if c not in state_aqi.columns:\n        state_aqi[c] = 0\n\n# Compute unsafe days = unhealthy_sensitive + unhealthy + very_unhealthy + hazardous\nstate_aqi['unsafe_days'] = state_aqi[['unhealthy_sensitive','unhealthy','very_unhealthy','hazardous']].sum(axis=1)\nstate_aqi['prop_unsafe'] = state_aqi['unsafe_days'] / state_aqi['days_with_aqi']\n\nprint(\"State AQI aggregated sample:\\n\", state_aqi.head().to_string(index=False))\n\n# Read wildfire data\nwf = pd.read_csv(wildfire_path)\nprint(\"Wildfire sample:\\n\", wf.head().to_string(index=False))\n\n# Prepare wildfire dataframe: ensure State names align\n# Strip whitespace in both\nstate_aqi['State_clean'] = state_aqi['State'].str.strip()\nwf['State_clean'] = wf['State'].str.strip()\n\n# Merge on cleaned state names\nmerged = pd.merge(state_aqi, wf[['State_clean','Total Acres Burned']], on='State_clean', how='inner')\n\nprint(f\"Merged rows: {len(merged)}\")\nprint(merged[['State_clean','prop_unsafe','Total Acres Burned']].head().to_string(index=False))\n\n# Compute Pearson correlation\ncorr = merged['prop_unsafe'].corr(merged['Total Acres Burned'])\nprint(\"Pearson correlation:\", corr)\n\n# Print rounded to 2 decimals\nprint(\"Rounded:\", round(corr,2))\n\n# Output merged length and correlation for final submission\nprint(len(merged), corr)\n"}) [toolUseId=call_yShERaoOMKHTSl0JkgayK3qY]
