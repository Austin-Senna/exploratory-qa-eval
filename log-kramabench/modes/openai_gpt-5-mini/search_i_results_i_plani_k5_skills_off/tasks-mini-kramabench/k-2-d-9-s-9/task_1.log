 rain_col = rain_cols[0]\n    else:\n        rain_col = None\n    # find enterococcus columns\n    ent_cols = [c for c in data.columns if 'enterococcus' in c.lower()]\n    if not ent_cols:\n        # sometimes column named just 'Enterococcus' or 'Enterococcus ' after combine\n        ent_cols = [c for c in data.columns if 'enterococcus' in c.lower()]\n    # iterate rows\n    for idx,row in data.iterrows():\n        # parse rain\n        rain_val = None\n        if rain_col:\n            rv = str(row[rain_col]) if pd.notna(row[rain_col]) else ''\n            rv = rv.strip()\n            # extract number\n            m = re.search(r\"([-+]?[0-9]*\\.?[0-9]+)\", rv)\n            if m:\n                try:\n                    rain_val = float(m.group(1))\n                except:\n                    rain_val = None\n        for ec in ent_cols:\n            v = str(row[ec]) if pd.notna(row[ec]) else ''\n            v = v.strip()\n            if v=='' or v.lower() in ['nan','none']:\n                continue\n            # remove leading '<' or non-numeric\n            m = re.search(r\"([-+]?[0-9]*\\.?[0-9]+)\", v)\n            if not m:\n                continue\n            try:\n                val = float(m.group(1))\n            except:\n                continue\n            if val>104:\n                total_failed += 1\n                if rain_val is not None and rain_val>0:\n                    failed_with_rain += 1\n\nprint('total_failed', total_failed)\nprint('failed_with_rain', failed_with_rain)\nif total_failed>0:\n    pct = failed_with_rain/total_failed*100\n    print(f\"pct: {pct:.2f}\")\nelse:\n    print('pct: NaN')\n"}) [toolUseId=call_sRCPrK2nYBIPdAqUkg9bmWf3]
