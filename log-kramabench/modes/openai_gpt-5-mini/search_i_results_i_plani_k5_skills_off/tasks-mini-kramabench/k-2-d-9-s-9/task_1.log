der\n        if header_idx>0:\n            prev = rows[header_idx-1]\n            combined = [((prev[i] or '') + ' ' + (header[i] or '')).strip() for i in range(max(len(prev), len(header)))]\n            ent_idx = [i for i,h in enumerate(combined) if h and 'enterococcus' in h.lower()]\n            if rain_idx is None:\n                for i,h in enumerate(combined):\n                    if h and re.search(r'1\\s*-?day\\s*rain', h, re.IGNORECASE):\n                        rain_idx = i\n                        break\n            header_norm = combined\n    # iterate data rows\n    for row in rows[header_idx+1:]:\n        # skip empty rows\n        if not any(cell and cell.strip() for cell in row):\n            continue\n        # get rain value\n        rain_val = 0.0\n        if rain_idx is not None and rain_idx < len(row):\n            rv = (row[rain_idx] or '').strip()\n            m = re.search(r'([-+]?[0-9]*\\.?[0-9]+)', rv)\n            if m:\n                try:\n                    rain_val = float(m.group(1))\n                except:\n                    rain_val = 0.0\n        # for each enterococcus column index, extract numeric\n        for i in ent_idx:\n            if i >= len(row):\n                continue\n            cell = (row[i] or '').strip()\n            if cell=='' or cell.lower()=='nan':\n                continue\n            m = re.search(r'([-+]?[0-9]*\\.?[0-9]+)', cell)\n            if not m:\n                # sometimes tag is in this column and number in next column? try next\n                if i+1 < len(row):\n                    m = re.search(r'([-+]?[0-9]*\\.?[0-9]+)', (row[i+1] or ''))\n                if not m:\n                    continue\n            try:\n                val = float(m.group(1))\n            except:\n                continue\n            if val>104:\n                total_failed += 1\n                if rain_val>0:\n                    failed_with_rain += 1\n\nprint('total_failed', total_failed)\nprint('failed_with_rain', failed_with_rain)\nif total_failed>0:\n    print('pct', failed_with_rain/total_failed*100)\nelse:\n    print('pct NaN')\n"}) [toolUseId=call_3hGW3d55SVJlABkFg3ZxZccH]
