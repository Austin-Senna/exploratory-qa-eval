(unique_communities))\n# find best match by case-insensitive contains\nmatches=[c for c in unique_communities if c.lower().startswith(minc['community'].lower()) or minc['community'].lower() in c.lower()]\nprint('matches for',minc['community'],matches[:20])\nif not matches:\n    # try exact capitalize\n    matches=[c for c in unique_communities if c.lower()==minc['community'].lower()]\n    print('exact matches',matches)\nif not matches:\n    # fallback: use minc['community'] as-is\n    matches=[minc['community']]\nselected_community=matches[0]\nprint('selected community:',selected_community)\n# filter wdf\ncw=wdf[wdf['Community'].astype(str).str.lower()==selected_community.lower()].copy()\nprint('samples for community:',len(cw))\n# compute violation rates by Beach Name\ncw['Violation_flag']=cw['Violation'].astype(str).str.lower().map({'yes':1,'y':1,'no':0,'n':0}).fillna(0)\ngroup=cw.groupby('Beach Name').agg(samples=('Violation', 'count'), violations=('Violation_flag','sum')).reset_index()\ngroup['violation_rate']=group['violations']/group['samples']\n# sort descending by violation_rate then by samples?\ngroup_sorted=group.sort_values(['violation_rate','samples'],ascending=[False,False])\nprint('top beaches:')\nprint(group_sorted.head(10).to_string(index=False))\n# get top 3 names\ntop3=list(group_sorted['Beach Name'].head(3))\nprint('TOP3:',top3)\n"})
