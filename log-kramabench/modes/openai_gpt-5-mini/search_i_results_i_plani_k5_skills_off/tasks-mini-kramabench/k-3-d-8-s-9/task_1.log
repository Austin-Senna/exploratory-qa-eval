n cols\n    rain_cols = [c for c in cols if c and '1-Day' in c or c and '1-Day Rain' in c]\n    # better to match exact\n    def col_exists(name):\n        return name in df.columns\n    # common names\n    possible_rain = ['1-Day Rain','1-Day Rain','1-Day Rain ']\n    # find columns by partial match\n    rain1 = [c for c in cols if '1-Day' in str(c)][0] if any('1-Day' in str(c) for c in cols) else None\n    rain2 = [c for c in cols if '2-Day' in str(c)][0] if any('2-Day' in str(c) for c in cols) else None\n    rain3 = [c for c in cols if '3-Day' in str(c)][0] if any('3-Day' in str(c) for c in cols) else None\n    # find enterococcus columns (any column with Enterococcus in name or 'Enterococcus' exactly)\n    ent_cols = [c for c in cols if 'Enterococcus' in str(c)]\n    # If there is a 'Tag' column pattern, they alternate Tag, Enterococcus. We'll take Enterococcus columns only.\n    if len(ent_cols)==0:\n        # sometimes header row offset, check next rows\n        ent_cols = [c for c in cols if 'Tag' in str(c) or 'Enteroc' in str(c)]\n    # keep enter columns only\n    # filter rows where rain1==0 and rain2==0 and rain3==0\n    if not rain1 or not rain2 or not rain3:\n        # try different header row\n        df = pd.read_csv(path, header=1)\n        df.columns = [c.strip() if isinstance(c,str) else c for c in df.columns]\n        cols = df.columns.tolist()\n        rain1 = [c for c in cols if '1-Day' in str(c)][0] if any('1-Day' in str(c) for c in cols) else None\n        rain2 = [c for c in cols if '2-Day' in str(c)][0] if any('2-Day' in str(c) for c in cols) else None\n        rain3 = [c for c in cols if '3-Day' in str(c)][0] if any('3-Day' in str(c) for c in cols) else None\n        ent_cols = [c for c in cols if 'Enterococcus' in str(c)]\n    # final check\n    if not rain1 or not rain2 or not rain3 or len(ent_cols)==0:\n        print('Failed to find cols for', beach)\n        continue\n    # select rows where rains are all 0\n    subset = df[(df[rain1]==