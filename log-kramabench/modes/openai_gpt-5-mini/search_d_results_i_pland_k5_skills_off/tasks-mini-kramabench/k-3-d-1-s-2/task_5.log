print('TLE hourly rows:', len(hourly_df))\n\n# parse OMNI2 by splitting tokens and using year, doy, hour\nomni_rows = [ln.strip() for ln in open(omni_path).read().splitlines() if ln.strip()]\ncols = [row.split() for row in omni_rows]\nprint('sample tokens per row:', len(cols[0]))\n# tokens: [year, doy, hour, f107x10, ... ap at index 8]\nap_index = 8\n# build df\nomni_df = pd.DataFrame(cols)\nomni_df = omni_df.rename(columns=lambda x: 'c'+str(x))\nomni_df['year'] = omni_df['c0'].astype(int)\nomni_df['doy'] = omni_df['c1'].astype(int)\nomni_df['hour'] = omni_df['c2'].astype(int)\nomni_df['ap'] = omni_df['c'+str(ap_index)].astype(float)\n# build datetime from year + doy + hour\nomni_df['time'] = omni_df.apply(lambda r: datetime(r['year'],1,1) + timedelta(days=int(r['doy'])-1, hours=int(r['hour'])), axis=1)\nomni_df = omni_df.set_index('time').sort_index()\n\n# filter May 1-30\nomni_may = omni_df[(omni_df['year']==2024) & (omni_df.index>=start) & (omni_df.index<=end)].copy()\nprint('OMNI May rows (hours):', len(omni_may))\n\n# AP series\nap_series = omni_may['ap']\nprint(ap_series.head())\n\n# compute Pearson r^2 for lags 0..48 where AP is shifted forward by lag hours relative to delta_a\nfrom math import isnan\nresults = []\nfor lag in range(0,49):\n    # shift AP forward by lag: AP at time t maps to delta at time t+lag, so we shift index by +lag\n    shifted_ap = ap_series.copy()\n    shifted_ap.index = shifted_ap.index + pd.to_timedelta(lag, unit='h')\n    merged = hourly_df.set_index('time').join(shifted_ap.rename('ap'), how='inner')\n    merged = merged.dropna(subset=['delta_a','ap'])\n    if len(merged) < 3:\n        r2 = np.nan\n    else:\n        r = np.corrcoef(merged['delta_a'].values, merged['ap'].values)[0,1]\n        r2 = r**2\n    results.append((lag, r2, len(merged)))\n\nresdf = pd.DataFrame(results, columns=['lag','r2','n'])\nbest = resdf.loc[resdf['r2'].idxmax()]\nprint('best:', best.to_dict())\nprint(resdf.sort_values('r2', ascending=False).head(10))\n