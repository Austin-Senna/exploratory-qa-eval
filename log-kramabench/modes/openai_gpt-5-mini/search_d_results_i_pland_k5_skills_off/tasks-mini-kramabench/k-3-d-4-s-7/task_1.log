ce rate = violations / tests\nwb_summer['ViolationFlag'] = wb_summer['Violation'].str.lower().map({'yes':1,'no':0})\n# Group by Community, Beach Type, Year, Month\ngrp = wb_summer.groupby(['Community','Beach Type Description','Year','Month']).agg(tests=('ViolationFlag','count'), exceedances=('ViolationFlag','sum')).reset_index()\ngrp['exceedance_rate'] = grp['exceedances'] / grp['tests']\nprint('Grouped sample rows:', grp.head().to_dict(orient='records')[:5])\n\n# Now for each category, we need monthly rainfall for communities mapping: Boston, Chatham, Amherst, Ashburnham\n# Precip files keyed by Year with months as columns Jun, Jul, Aug\nprec_files = {\n    'Boston': prec_boston,\n    'Chatham': prec_chatham,\n    'Amherst': prec_amherst,\n    'Ashburnham': prec_ash\n}\n\n# Build rainfall long table for years 2007-2009 and months 6-8\nrain_rows = []\nfor comm, df in prec_files.items():\n    for _, row in df[df['Year'].isin([2007,2008,2009])].iterrows():\n        year = int(row['Year'])\n        for m, col in zip([6,7,8], ['Jun','Jul','Aug']):\n            val = row[col]\n            rain_rows.append({'Community': comm, 'Year': year, 'Month': m, 'Rain': val})\nrain = pd.DataFrame(rain_rows)\n# Replace 'M' with NaN and convert to float\nrain['Rain'] = pd.to_numeric(rain['Rain'].replace('M', np.nan))\nprint('Rain sample:', rain)\n\n# Impute missing rainfall values with median for that month across non-missing years (for that community?)\n# The instruction: \"impute missing rainfall values with the median for that month across non-missing years.\" Likely across non-missing years for that station.\n# For each Community and Month compute median across non-missing years and fill missing\nrain['Rain_imputed'] = rain.groupby(['Community','Month'])['Rain'].transform(lambda x: x.fillna(x.dropna().median()))\nprint('Rain after impute:', rain)\n\n# Now need to assemble for freshwater and marine categories: monthly summer rainfall and beach-water exceedance rate\n# For Freshwater, use Communities: Boston, Chatham, Amherst, Ashburnham but only Beach Type == 'Freshwater'\n# For Marine, use Communities: Boston and Chatham and Beach Type == 'Marine'\n\nfresh_comms = ['Boston','Chatham','Amherst','Ashburnham']\nmarine_comms = ['Boston','Chatham']\n\n# Aggregate exceedance rate across beaches within community? The question: \"between fresh water beaches and marine beaches, which had the higher Pearson correlation between monthly summer rainfall and beach-water exceedance rate? Use June, July, and August rainfall; use Boston, Chatham, Amherst, and Ashburnham for fresh water beaches; use Boston and Chatham for marine beaches\"\n# Interpret as: For each month-year-community, take exceedance_rate aggregated across beaches of that type (freshwater or marine) in that community. Then correlate rainfall (for that community-month-year) with exceedance rate across all community-month-year rows pooled across communities in that category and across years 2007-2009.\n\n# Compute community-month-year exceedance rate per Beach Type\ncomm_rates = grp.groupby(['Community','Beach Type Description','Year','Month']).apply(lambda df: pd.Series({'exceedance_rate': (df['exceedances'].sum()/df['tests'].sum()) if df['tests'].sum()>0 else np.nan})).reset_index()\n\n# Filter freshwater and marine\nfresh_rates = comm_rates[comm_rates['Community'].isin(fresh_comms) & comm_rates['Beach Type Description'].str.contains('Fresh', case=False, na=False)].copy()\nmarine_rates = comm_rates[comm_rates['Community'].isin(marine_comms) & comm_rates['Beach Type Description'].str.contains('Marine', case=False, na=False)].copy()\n\nprint('Fresh rates sample', fresh_rates.head().to_dict(orient='records')[:5])\nprint('Marine rates sample', marine_rates.head().to_dict(orient='records')[:5])\n\n# Merge rainfall\nfresh = pd.merge(fresh_rates, rain[['Community','Year','Month','Rain_imputed']], on=['Community','Year','Month'], how='left')\nmarine = pd.merge(marine_rates, rain[['Community','Year','Month','Rain_imputed']], on=['Community','Year','Month'], how='left')\n\n# Drop rows with missing exceedance_rate or Rain_imputed\nfresh = fresh.dropna(subset=['exceedance_rate','Rain_imputed'])\nmarine = marine.dropna(subset=['exceedance_rate','Rain_imputed'])\n\n# For each category, compute Pearson correlation between Rain_imputed and exceedance_rate across all rows\nf_r, f_p = pearsonr(fresh['Rain_imputed'], fresh['exceedance_rate'])\nm_r, m_p = pearsonr(marine['Rain_imputed'], marine['exceedance_rate'])\n\nprint('Fresh Pearson r,p:', f_r, f_p)\nprint('Marine Pearson r,p:', m_r, m_p)\n\n# Print which is higher\nif abs(f_r) > abs(m_r):\n    print('Higher: Freshwater')\nelse:\n    print('Higher: Marine')\n\n# Also print counts\nprint('Fresh rows:', len(fresh), 'Marine rows:', len(marine))\n\n# Final print of r values for answer\nprint(f_r)\nprint(m_r)\n\n\n"}) [toolUseId=call_FmxE1MPBeVgEQASkPUSJGjjx]
