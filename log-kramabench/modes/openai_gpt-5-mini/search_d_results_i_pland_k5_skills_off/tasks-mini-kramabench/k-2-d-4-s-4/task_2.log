3]:\n        sub = df[df['Beach Name']==beach]\n        total = len(sub)\n        viol = sub['Violation'].sum()\n        rate = viol/total if total>0 else np.nan\n        rates.append((total,viol,rate))\n    avg_rate = np.nanmean([r[2] for r in rates])\n    rows.append({'Beach Name':beach,'rates':rates,'avg_rate':avg_rate})\n\nres = sorted(rows, key=lambda x: x['avg_rate'], reverse=True)\n# print top 10\nfor r in res[:10]:\n    print(r['Beach Name'], r['avg_rate'], r['rates'])\n\nprint('Top beach:', res[0]['Beach Name'], res[0]['avg_rate'])\nprint(len(res))\n\n# print exact numeric rate as fraction\nprint('Top details:')\nprint(res[0])\n\n# Also print counts/violations for top 5\nfor r in res[:5]:\n    print(r['Beach Name'])\n    for year,df in zip([2020,2021,2022,2023],[f2020,f2021,f2022,f2023]):\n        s = df[df['Beach Name']==r['Beach Name']]\n        print(year, len(s), int(s['Violation'].sum()))\n    print('avg_rate', r['avg_rate'])\n\nprint('DONE')\n"}) [toolUseId=call_yUS0kluYPPrTznedkThNbTK7]
