Xdesign, Y, rcond=None)\n    A = coef[:-1].T\n    c = coef[-1]\n    last_state = X_ctx.iloc[-1].values\n    steps = int(4*60/10)\n    proj = []\n    cur = last_state.copy()\n    for i in range(steps):\n        nxt = A.dot(cur) + c\n        proj.append(nxt)\n        cur = nxt\n    proj_index = pd.date_range(start=end_time + pd.Timedelta(minutes=10), periods=steps, freq='10min')\n    X_proj = pd.DataFrame(proj, index=proj_index, columns=X_ctx.columns)\n    density_obs = dens.reindex(X_proj.index)\n    dens_col = dens.columns[0]\n    density_obs = density_obs[dens_col]\n    return X_proj, density_obs\n\n# Train on wu334 (already computed earlier but retrain here)\nX_proj_train, y_train = process_case(omni334, goes334, dens334)\nmask = ~y_train.isna()\nX_train = X_proj_train[mask]\ny_train = y_train[mask]\n\nlr = LinearRegression()\nlr.fit(X_train.values, y_train.values)\n\n# Eval wu335\nX_proj_eval, y_eval = process_case(omni335, goes335, swarma335)\nmask = ~y_eval.isna()\nX_eval = X_proj_eval[mask]\ny_eval = y_eval[mask]\n\nfrom sklearn.metrics import mean_squared_error\n\ny_pred = lr.predict(X_eval.values)\nrmse = np.sqrt(mean_squared_error(y_eval.values, y_pred))\nprint('RMSE', rmse)\nprint('count', len(y_eval))\nprint('y_eval[:10]', y_eval.values[:10])\nprint('y_pred[:10]', y_pred[:10])\n", "max_output_chars": 7532}) [toolUseId=call_INF8Gk3FI9AziJj4TBFUQXio]
