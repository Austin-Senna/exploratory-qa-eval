rominence and then enforce distance\n    peaks = [p for p in peaks if p[2]>=prominence]\n    # enforce min distance: greedy select highest peaks\n    peaks_sorted = sorted(peaks, key=lambda x: x[1], reverse=True)\n    selected = []\n    for p in peaks_sorted:\n        if all(abs(p[0]-s[0])>distance for s in selected):\n            selected.append(p)\n    # return sorted by index (chronological)\n    selected = sorted(selected, key=lambda x: x[0])\n    return selected\n\npeaks = find_peaks_prom_dist(y, prominence=20, distance=5)\n# minima: invert y\nminima = find_peaks_prom_dist(-y, prominence=20, distance=5)\n\nprint('\\nDetected maxima (index, sunspot, prominence):')\nprint(peaks)\nprint('\\nDetected minima (index, sunspot, prominence):')\nprint(minima)\n\n# map indices to years and values\nmaxima = [(years[i], val, prom) for (i,val,prom) in peaks]\nminima = [(years[i], val, prom) for (i,val,prom) in minima]\n\n# compute mean period between successive maxima\nif len(maxima)>=2:\n    max_years = [m[0] for m in maxima]\n    periods = np.diff(max_years)\n    mean_period = periods.mean()\nelse:\n    mean_period = None\n\nprint('\\nMaxima years and values:')\nprint(maxima)\nprint('\\nMinima years and values:')\nprint(minima)\nprint('\\nMean period between successive maxima:', mean_period)\n\n# top five maxima and minima by sunspot value within detected sets\ntop5_max = sorted(maxima, key=lambda x: x[1], reverse=True)[:5]\ntop5_min = sorted(minima, key=lambda x: x[1])[:5]\nprint('\\nTop5 maxima (year, value):', top5_max)\nprint('Top5 minima (year, value):', top5_min)\n\n# final print formatted for submission\nresult = {\n    'mean_period': float(mean_period),\n    'top5_maxima_years': [int(x[0]) for x in top5_max],\n    'top5_minima_years': [int(x[0]) for x in top5_min]\n}\nprint('\\nRESULT_JSON:', result)\n"}) [toolUseId=call_ADdNty1QZITkVMpiki6fPeRp]
