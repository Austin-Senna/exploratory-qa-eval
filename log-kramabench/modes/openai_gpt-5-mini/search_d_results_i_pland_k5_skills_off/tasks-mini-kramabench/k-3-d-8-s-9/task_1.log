h key\n    if 'Constitution' in beach_name:\n        key = 'Constitution Beach'\n    elif 'Pleasure Bay' in beach_name or 'Castle' in beach_name:\n        # this file contains multiple sites: Pleasure Bay @ Broadway, @ Flagpole, Castle Island Playground\n        key = 'Pleasure Bay / Castle Island'\n    elif 'City Point' in beach_name:\n        key = 'City Point Beach'\n    elif 'M Street' in beach_name or 'M. Street' in beach_name:\n        key = 'M Street Beach'\n    elif 'Carson' in beach_name:\n        key = 'Carson Beach'\n    elif 'Malibu' in beach_name:\n        key = 'Malibu Beach'\n    elif 'Tenean' in beach_name:\n        key = 'Tenean Beach'\n    elif 'Wollaston' in beach_name:\n        key = 'Wollaston Beach'\n    else:\n        key = beach_name\n\n    # find indices\n    try:\n        i_rain1 = header.index('1-Day Rain')\n    except ValueError:\n        i_rain1 = None\n    try:\n        i_rain2 = header.index('2-Day Rain')\n    except ValueError:\n        i_rain2 = None\n    try:\n        i_rain3 = header.index('3-Day Rain')\n    except ValueError:\n        i_rain3 = None\n    ent_indices = [i for i,c in enumerate(header) if 'Enterococcus' in c or c=='Enterococcus']\n    # iterate data rows\n    for row in reader[header_row+1:]:\n        if not row or len(row)==0:\n            continue\n        if all(cell=='' for cell in row):\n            continue\n        # check date presence\n        date_cell = row[0] if len(row)>0 else ''\n        if date_cell=='' or date_cell is None:\n            continue\n        inspected += 1\n        # get rain vals\n        def get_r(idx):\n            if idx is None or idx>=len(row):\n                return 0.0\n            try:\n                v = row[idx].strip()\n                if v=='':\n                    return 0.0\n                return float(v)\n            except:\n                return 0.0\n        r1 = get_r(i_rain1)\n        r2 = get_r(i_rain2)\n        r3 = get_r(i_rain3)\n        # for files with multiple sub-sites, we'll count per file key (grouped)\n        # iterate enterococcus values\n        any_enter = False\n        for idx in ent_indices:\n            if idx>=len(row):\n                continue\n            val = row[idx].strip()\n            if val=='' or val.lower()=='nan':\n                continue\n            # remove <, >, quotes\n            val_clean = val.lstrip('<').lstrip('>').strip().strip('\"')\n            try:\n                num = float(val_clean)\n            except:\n                continue\n            any_enter = True\n            if r1==0 and r2==0 and r3==0:\n                no_rain_count += 1\n                if num >= 104:\n                    counts[key] += 1\n                    failed_total += 1\n        # if no enterococcus columns, skip\n\n# print results\nprint('counts per beach:')\nfor k,v in sorted(counts.items(), key=lambda x:-x[1]):\n    print(k, v)\nprint('\\ninspected rows total:', inspected)\nprint('no_rain samples considered:', no_rain_count)\nprint('failed_total:', failed_total)\n"}) [toolUseId=call_H2ISy1GNe5xa4zaDbqGiegZP]
