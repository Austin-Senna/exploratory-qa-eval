nmerged = pd.merge(annual_noaa, nifc[['Year','Fires']], on='Year', how='inner')\nmerged = merged.sort_values('Year')\n# Compute per-year difference\nmerged['diff'] = merged['Number of Fires'] - merged['Fires']\n# Compute average difference\navg_diff = merged['diff'].mean()\nprint('years_counted', len(merged))\nprint(merged[['Year','Number of Fires','Fires','diff']].to_string(index=False))\nprint('avg_diff', avg_diff)\nprint(round(avg_diff))\n", "dataset_id": "kramabench-wildfire-hard-5", "file_path": "files/noaa_wildfires_monthly_stats.csv"}) [toolUseId=call_MHGTMSXs8Lbae30TgeqDIF9y]
