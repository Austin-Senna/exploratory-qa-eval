# compute medians\nmedians = {m: float(precip[m].median(skipna=True)) for m in ['Jun','Jul','Aug']}\nprint('medians', medians)\n# impute\nfor m in ['Jun','Jul','Aug']:\n    precip[m] = precip[m].fillna(medians[m])\n\n# compute summer total rainfall per year\nprecip['summer_total'] = precip['Jun'] + precip['Jul'] + precip['Aug']\n\n# find year with most summer rainfall\nmax_row = precip.loc[precip['summer_total'].idxmax()]\nmax_year = int(max_row['Year'])\nmax_total = float(max_row['summer_total'])\nprint('max_year', max_year, 'total', max_total)\n\n# Now find exceedance rate for that year from summer_group\nif max_year in summer_group.index:\n    rate = summer_group.loc[max_year,'exceed_rate']\nelse:\n    # if no samples that year, rate is 0? but likely there are samples\n    rate = 0.0\n\nprint('rate', rate)\n\n# print final rounded to 2 decimals\nprint(f\"{rate:.2f}\")\n\n# final output value\nrate\n", "dataset_id": "kramabench-environment-hard-17", "file_path": "files/water-body-testing-2006.csv"}) [toolUseId=call_EvsEUTHc974D4h768QRmw4uN]
