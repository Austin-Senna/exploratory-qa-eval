ce')\nrc_malt_neol = rc_malt[rc_malt['Culture'].str.contains('Neolithic', case=False, na=False)].copy()\nprint('Malta Neolithic count:', len(rc_malt_neol))\nprint(rc_malt_neol[['Region','Site','Latitude','date','Cal. BC 1 sigma']].head(20))\n\n# If still empty, instead find rows where Site/Region contains 'Gozo' or 'Malta' in Notes\nif len(rc_malt_neol)==0:\n    print('No Malta explicit Neolithic rows; try finding rows with latitude within Malta bounds among all Neolithic')\n    rc_neolithic = rc[rc['Culture'].str.contains('Neolithic', case=False, na=False)].copy()\n    rc_neolithic['Latitude'] = pd.to_numeric(rc_neolithic['Latitude'], errors='coerce')\n    rc_malt_neol = rc_neolithic[(rc_neolithic['Latitude']>35.7) & (rc_neolithic['Latitude']<36.2)].copy()\n    print('Found by lat:', len(rc_malt_neol))\n    print(rc_malt_neol[['Region','Site','Latitude','date','Cal. BC 1 sigma']])\n\n# Now find the most northern sample: max Latitude; break ties by later year -> later year means larger 'date'?\n# 'date' column likely is BP? The preview shows date like 7020 etc. We assume 'date' is radiocarbon years BP; but user asked 'year of most northern Neolithic sample' -> likely the 'date' column.\nif len(rc_malt_neol)==0:\n    raise SystemExit('No Malta Neolithic rows found')\n\nmax_lat = rc_malt_neol['Latitude'].max()\nmost_north = rc_malt_neol[rc_malt_neol['Latitude']==max_lat].copy()\nprint('Most north candidates count:', len(most_north))\n# break ties by later year: use 'date' numeric (higher -> later?)\nmost_north['date_num'] = pd.to_numeric(most_north['date'], errors='coerce')\n# Later year: larger date -> choose max\nselected = most_north.loc[most_north['date_num'].idxmax()]\nprint('Selected row:', selected[['Region','Site','Latitude','date','date_num','Cal. BC 1 sigma']])\nselected_date = float(selected['date_num'])\nprint('selected_date', selected_date)\n\n# Now load climateMeasurements and find Al values for closest year(s)\ncl_path = DOWNLOAD_PATHS['s3://sana-kramab