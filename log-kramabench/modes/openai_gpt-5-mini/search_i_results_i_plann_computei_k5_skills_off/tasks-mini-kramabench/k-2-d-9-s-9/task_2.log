olumn names\n    cols = list(df.columns)\n    # find date column\n    date_col = None\n    for c in cols:\n        if 'date' in str(c).lower():\n            date_col = c\n            break\n    if date_col is None:\n        continue\n    df[date_col] = pd.to_datetime(df[date_col], errors='coerce')\n    df = df[(df[date_col] >= date_lo) & (df[date_col] <= date_hi)]\n    if df.empty:\n        results[p] = {'all_meet': False, 'reason': 'no_samples'}\n        continue\n    # find all columns with 'Enterococcus' in name\n    ec_cols = [c for c in cols if 'enterococcus' in str(c).lower()]\n    # sometimes header alternates Tag, Enterococcus pairs; ensure we capture\n    if not ec_cols:\n        # try to find columns whose header contains 'enter' substring\n        ec_cols = [c for c in cols if 'enter' in str(c).lower()]\n    if not ec_cols:\n        results[p] = {'all_meet': False, 'reason': 'no_enterococcus_column'}\n        continue\n    # For each row and each ec_col, check meets_standard_value; if any explicit False -> fail\n    any_fail = False\n    any_sample = False\n    for _, row in df.iterrows():\n        for c in ec_cols:\n            cell = row[c]\n            m = meets_standard_value(cell)\n            if m is None:\n                continue\n            any_sample = True\n            if m is False:\n                any_fail = True\n                break\n        if any_fail:\n            break\n    all_meet = (not any_fail) and any_sample\n    results[p] = {'all_meet': all_meet, 'any_sample': any_sample, 'any_fail': any_fail, 'ec_cols': ec_cols}\n\n# Map file paths to beach names\nmapping = {}\nfor p,info in results.items():\n    name = Path(p).name.replace('_datasheet.csv','').replace('_',' ').title()\n    mapping[name] = info\n\nprint(mapping)\n", "dataset_id": "kramabench-environment-hard-9", "file_path": "files/malibu_beach_datasheet.csv"}) [toolUseId=call_D3aa1oNO3snJNGAzXMmUKqkO]
