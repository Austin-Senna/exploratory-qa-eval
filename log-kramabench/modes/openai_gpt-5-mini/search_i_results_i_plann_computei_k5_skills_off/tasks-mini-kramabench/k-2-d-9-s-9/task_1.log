] = 0\n        rain_col = 'rain_tmp'\n    # for each Enterococcus column, count\n    for c in ent_cols:\n        # coerce to numeric\n        df[c+'_num'] = pd.to_numeric(df[c], errors='coerce')\n        # failed condition\n        failed_mask = df[c+'_num'] > 104\n        total_failed += int(failed_mask.sum())\n        # rain within 24h condition\n        rain_mask = df[rain_col] > 0\n        failed_with_rain += int((failed_mask & rain_mask).sum())\n\n# Avoid division by zero\nif total_failed == 0:\n    pct = 0.0\nelse:\n    pct = 100.0 * failed_with_rain / total_failed\n\nprint(f\"total_failed={total_failed}, failed_with_rain={failed_with_rain}\")\nprint(f\"pct={pct:.2f}\")\n\n# output final percentage\nprint(f\"{pct:.2f}\")\n", "dataset_id": "kramabench-environment-hard-8", "file_path": "files/constitution_beach_datasheet.csv"}) [toolUseId=call_oQgv8ZSt7d8Ego2QJXgdCbcI]
