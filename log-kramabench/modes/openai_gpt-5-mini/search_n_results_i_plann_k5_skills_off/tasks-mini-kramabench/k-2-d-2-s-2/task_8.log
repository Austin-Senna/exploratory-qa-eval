rged['prop_unhealthy_or_worse'].corr(merged['Total Acres Burned'])\nprint(round(corr,2))\nprint('n_states', len(merged))\nprint(merged[['State','prop_unhealthy_or_worse','Total Acres Burned']].head())\n"}) [toolUseId=call_pJInRyr5jQn614hhuCeFholT]
