_mm(mm_rev_per_day):\n    n = mm_rev_per_day * 2*pi / 86400.0\n    return (mu / (n**2))**(1.0/3.0)\n\nfor name, df in [('quiet', quiet), ('storm', storm)]:\n    df = df.sort_values('epoch_dt')\n    df['a_km'] = df['mm'].apply(semi_major_axis_from_mm)\n    # compute daily rates: take linear fit slope over time in days\n    times = (df['epoch_dt'] - df['epoch_dt'].min()).dt.total_seconds() / 86400.0\n    # linear fit a = a0 + rate * t\n    coef = np.polyfit(times, df['a_km'], 1)\n    rate = coef[0]  # km per day\n    print(name, 'rate km/day (fit):', rate)\n    # store\n    if name=='quiet': quiet_rate = rate\n    else: storm_rate = rate\n\n# print final pair\nprint('\\nFinal rates:', quiet_rate, storm_rate)\n"}) [toolUseId=call_NDGfMJ4ZbN5Zly0YWs7M4BnT]
