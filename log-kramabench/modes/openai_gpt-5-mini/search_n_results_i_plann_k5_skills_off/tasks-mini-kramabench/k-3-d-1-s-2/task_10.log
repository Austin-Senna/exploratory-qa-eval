own rows using more structured read: skip leading non-tabular lines\nmil2 = pd.read_csv(mil_path, skiprows=9)\nprint('\\nMil2 head:')\nprint(mil2.head(10).to_string(index=False))\n\nall2 = pd.read_csv(all_path, skiprows=3)\nprint('\\nAll2 head:')\nprint(all2.head(15).to_string(index=False))\n\n# normalize percentages\n# find imposter in all2\nimp_all = all2[all2.iloc[:,1]=='Imposter Scams']\nprint('\\nimp_all rows:\\n', imp_all.to_string(index=False))\n\n# find in mil2\nimp_mil = mil2[mil2.iloc[:,1]=='Imposter Scams']\nprint('\\nimp_mil rows:\\n', imp_mil.to_string(index=False))\n\n# compute percentages\n# all dataset percentage is column 3 (index 3) in all2\nimp_all_pct = None\nif not imp_all.empty:\n    val = imp_all.iloc[0,3]\n    imp_all_pct = str(val).strip()\n    print('\\nimp_all_pct raw:', imp_all_pct)\n\n# military: mil2 has # of Reports in column 2 and the category in column 1; need to compute as percent of military reports\n# find total military reports: earlier in file there's '# of Fraud Reports,\"99,443\"' and 'Report Type,# of Reports' etc.\n# but the Top 10 Fraud Categories in mil2 likely are subset; need percent of all military reports for same demographic: in 'Report Categories' overall percentage was percent of total Sentinel reports (6,471,708)\n# the military file includes top 10 fraud categories with counts; but we need 'as a percentage of all reports for the same demographic' meaning percent of military reports overall. The military file likely doesn't include that percent column for overall categories; but it shows '# of Fraud Reports,\"99,443\"' at top and imposter count 44,587 -> compute 44,587 / 99,443\n# extract numbers\n\n# extract the fraud reports count from mil (search for '# of Fraud Reports')\nfraud_reports = None\nfor i,row in mil.iterrows():\n    if row.astype(str).str.contains('# of Fraud Reports').any():\n        # next column contains number\n        # row like ['# of Fraud Reports','99,443',...]\n        fraud_reports = row.tolist()[1]\n        break\nprint('\\nfraud_reports raw:', fraud_reports)\n\n# get imposter count from mil2\nimp_mil_count = None\nif not imp_mil.empty:\n    imp_str = imp_mil.iloc[0,2]\n    imp_mil_count = imp_str\n    print('imp_mil_count raw:', imp_mil_count)\n\n# clean numeric\nimport re\n\ndef clean_num(x):\n    if pd.isna(x):\n        return None\n    s = str(x)\n    s = re.sub(r\"[^0-9]\",\"\",s)\n    return int(s) if s else None\n\nfr = clean_num(fraud_reports)\ni_mc = clean_num(imp_mil_count)\nprint('fr', fr, 'i_mc', i_mc)\n\nmil_pct = i_mc / fr * 100 if fr and i_mc else None\nprint('\\nmil pct of fraud reports:', mil_pct)\n\n# all_pct: imp_allPct raw is like '13.07%'\nall_pct = None\nif imp_all_pct:\n    all_pct = float(re.sub(r\"[^0-9\\.]+\",\"\",imp_all_pct))\nprint('all_pct:', all_pct)\n\nprint('\\nCompare military pct vs all pct:', mil_pct, all_pct)\nprint('mil_pct > all_pct?', mil_pct>all_pct if mil_pct and all_pct else 'unknown')\n\nprint('\\nFinal values to report: military percentage of imposter scams among military fraud reports (percent):', round(mil_pct,2), 'General population percentage of all reports:', all_pct)\n\nprint('\\nPrint only the two numbers:')\nprint(round(mil_pct,2))\nprint(all_pct)\n"}) [toolUseId=call_PQfCe8IcD4W9Qgh7Vfezetym]
