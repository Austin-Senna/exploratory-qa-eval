lues by scanning a line and locating that token, then offset to get ap.\n\nomni_path = DOWNLOAD_PATHS['s3://sana-kramabench/datagov/kramabench-astronomy-hard-9/files/omni2_low_res/omni2_2024.dat']\n# find a sample line for May and locate the f10.7-like token (value ~100-200)\nwith open(omni_path,'r') as f:\n    for line in f:\n        if line.startswith('2024') and ' 5 ' in line[:8]:\n            parts = line.split()\n            # print parts with index\n            for i,p in enumerate(parts):\n                pass\n            sample_parts = parts\n            break\n\nfor i,p in enumerate(sample_parts):\n    print(i,p)\n\n# locate token with decimal and value between 60 and 300 as candidate f10.7\nf107_idx = None\nfor i,p in enumerate(sample_parts):\n    try:\n        val = float(p)\n    except:\n        continue\n    if 60 <= val <= 300 and ('.' in p):\n        f107_idx = i\n        break\nprint('f10.7 token index guess:', f107_idx, 'value:', sample_parts[f107_idx])\n\n# Based on mapping, ap_index should be the token two positions before f10.7 (CSV had ap_index_nT then f10.7_index)\n# Let's assume ap_idx = f107_idx-1 (or -2). We'll try both later. Build dataframe extracting ap candidate at those indices.\nrows = []\nwith open(omni_path,'r') as f:\n    for line in f:\n        if not line.startswith('2024'): continue\n        parts = line.split()\n        if len(parts)<=f107_idx: continue\n        year=int(parts[0]); month=int(parts[1]); day=int(parts[2]); hour=int(parts[3])\n        f107 = float(parts[f107_idx])\n        ap_cand1 = float(parts[f107_idx-1])\n        ap_cand2 = float(parts[f107_idx-2])\n        rows.append({'dt':pd.Timestamp(year,month,day,hour), 'ap_cand1':ap_cand1, 'ap_cand2':ap_cand2, 'f107':f107})\nomni_df = pd.DataFrame(rows).set_index('dt')\nprint('omni rows for May:', len(omni_df))\nprint(omni_df.head())\n\n# Inspect ranges\nprint('ap_cand1 unique sample:', omni_df['ap_cand1'].unique()[:20])\nprint('ap_cand2 unique sample:', omni_df['ap_cand2'].unique()[:20])\n\n# Determine which candidate looks like ap index by typical AP ranges. AP index often 0-400, sometimes small integers. From CSV earlier ap_index_nT had values like 127.7? Wait that was f10.7. ap in CSV was like -27 etc? Hmm. Let's print head of both.\n\n# Now compute semi-major axis change between consecutive TLE hours to get delta a (km) representing drag (negative change). We'll align by epoch_rounded.\n\na_df = tle_df[['epoch','epoch_rounded','a_km']].drop_duplicates('epoch_rounded').set_index('epoch_rounded').sort_index()\n# compute hourly differences\na_df['delta_a'] = a_df['a_km'].diff()\nprint('a_df sample:')\nprint(a_df.head(10))\n\n# Merge with omni by matching datetimes\nmerged = a_df.merge(omni_df, left_index=True, right_index=True, how='inner')\nprint('Merged rows:', len(merged))\nprint(merged.head())\n\n# Compute correlations for lags 0..48 hours: shift AP forward by lag (i.e. AP at t-lag influences delta_a at t)\nfrom sklearn.metrics import r2_score\nbest_r2 = -1\nbest_lag = None\nfor lag in range(0,49):\n    shifted = merged.copy()\n    shifted['ap_shift'] = shifted['ap_cand1'].shift(lag)\n    df_valid = shifted.dropna(subset=['delta_a','ap_shift'])\n    if len(df_valid)<10:\n        continue\n    # compute r^2 of linear regression\n    # simple linear fit\n    X = df_valid['ap_shift'].values.reshape(-1,1)\n    y = df_valid['delta_a'].values\n    # intercept fit\n    coef = np.linalg.lstsq(np.hstack([np.ones_like(X),X]), y, rcond=None)[0]\n    ypred = coef[0] + coef[1]*X.flatten()\n    r2 = r2_score(y, ypred)\n    if r2>best_r2:\n        best_r2=r2; best_lag=lag\n\nprint('Best lag candidate using ap_cand1:', best_lag, best_r2)\n\n# try with ap_cand2\nbest_r2_2=-1; best_lag_2=None\nfor lag in range(0,49):\n    shifted = merged.copy()\n    shifted['ap_shift'] = shifted['ap_cand2'].shift(lag)\n    df_valid = shifted.dropna(subset=['delta_a','ap_shift'])\n    if len(df_valid)<10: continue\n    X = df_valid['ap_shift'].values.reshape(-1,1)\n    y = df_valid['delta_a'].values\n    coef = np.linalg.lstsq(np.hstack([np.ones_like(X),X]), y, rcond=None)[0]\n    ypred = coef[0] + coef[1]*X.flatten()\n    r2 = r2_score(y, ypred)\n    if r2>best_r2_2:\n        best_r2_2=r2; best_lag_2=lag\nprint('Best lag candidate using ap_cand2:', best_lag_2, best_r2_2)\n\nprint('Done')\n"}) [toolUseId=call_fdrM71hdU7Ukx7LT4Y2EJdKI]
