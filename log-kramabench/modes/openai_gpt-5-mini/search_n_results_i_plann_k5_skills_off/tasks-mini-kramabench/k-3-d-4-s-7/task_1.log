.month\n\n# Indicator: Violation 'yes' counts as exceedance\nwb['ViolationFlag'] = wb['Violation'].astype(str).str.lower().map({'yes':1,'no':0})\nwb['Beach Type'] = wb['Beach Type Description']\n\n# We'll compute monthly summer (Jun-Jul-Aug) exceedance rate per community and beach type per year\nsummer = wb[wb['Month'].isin([6,7,8]) & wb['Year'].isin([2007,2008,2009])]\n\ngroup = summer.groupby(['Year','Month','Community','Beach Type'])['ViolationFlag'].agg(['sum','count']).reset_index()\n# compute rate\ngroup['rate'] = group['sum']/group['count']\nprint('group rows sample:', group.head().to_csv(index=False))\n\n# Now we need monthly rainfall for selected towns\nprecips = {}\nfor name in ['boston','chatham','amherst','ashburnham']:\n    precips[name] = pd.read_csv(paths[name])\n    precips[name]['Year'] = precips[name]['Year'].astype(int)\n\n# Keep only 2007-2009 and months 6,7,8\nmonths = {6:'Jun',7:'Jul',8:'Aug'}\n# compute rainfall series for each town: create rows Year, Month, Precip\nrain_rows = []\nfor town, df in precips.items():\n    for yr in [2007,2008,2009]:\n        row = df[df['Year']==yr]\n        if row.empty:\n            # missing year\n            for mnum,mname in months.items():\n                rain_rows.append({'Town':town,'Year':yr,'Month':mnum,'Precip':np.nan})\n        else:\n            for mnum,mname in months.items():\n                val = row.iloc[0][mname]\n                if isinstance(val,str) and val.strip().upper()=='M':\n                    val = np.nan\n                rain_rows.append({'Town':town,'Year':yr,'Month':mnum,'Precip':float(val) if pd.notnull(val) else np.nan})\nrain = pd.DataFrame(rain_rows)\nprint('rain sample:\\n', rain)\n\n# impute missing rainfall values with median for that month across non-missing years (per town or across towns?). The prompt: \"impute missing rainfall values with the median for that month across non-missing years.\" That implies median across years for that station/town.\n# So per Town and Month, compute median across available years (in full dataset? includes other years present in files) across non-missing years.\n\n# compute medians using full file data (all years) for that town-month\nfull_medians = {}\nfor town, df in precips.items():\n    med = {}\n    for mnum,mname in months.items():\n        col = mname\n        vals = pd.to_numeric(df[col], errors='coerce')\n        if vals.dropna().empty:\n            med[mnum]=np.nan\n        else:\n            med[mnum]=vals.dropna().median()\n    full_medians[town]=med\nprint('medians:', full_medians)\n\n# apply imputation\ndef impute(row):\n    if pd.isna(row['Precip']):\n        return full_medians[row['Town']][row['Month']]\n    return row['Precip']\n\nrain['Precip_imp'] = rain.apply(impute, axis=1)\nprint('after impute\\n', rain)\n\n# Now aggregate rainfall for 'fresh water beaches' - using towns Boston, Chatham, Amherst, Ashburnham\n# For each Year, compute total summer rainfall across June-July-August summed across the four towns (sum of monthly totals across towns?) The prompt: \"Use June, July, and August rainfall; use Boston, Chatham, Amherst, and Ashburnham for fresh water beaches; use Boston and Chatham for marine beaches; and impute missing rainfall values with the median for that month across non-missing years.\"\n# Likely they want monthly summer rainfall series aligned with exceedance rate per month. But exceedance rate computed per Month-Year; we need correlation between monthly summer rainfall and beach-water exceedance rate. So we should for each month-year (June/July/August of 2007-2009) compute rainfall value aggregated across the towns in each group and the exceedance rate aggregated across beaches in that group.\n\n# rainfall per Year-Month for group: sum of Precip_imp across town members\n\nrain_group = rain.copy()\nrain_group['GroupFresh'] = rain_group['Town'].isin(['boston','chatham','amherst','ashburnham'])\nrain_group['GroupMarine'] = rain_group['Town'].isin(['boston','chatham'])\