ount']\nmarine_group = marine_sel.groupby(['Year','Month'])['ViolationFlag'].agg(['sum','count']).reset_index()\nmarine_group['rate'] = marine_group['sum']/marine_group['count']\n\nprint('fresh_group\\n', fresh_group)\nprint('marine_group\\n', marine_group)\n\n# merge rainfall with rates\nfg = pd.merge(fresh_group, rg_fresh, on=['Year','Month'], how='inner')\nmg = pd.merge(marine_group, rg_marine, on=['Year','Month'], how='inner')\n\nprint('fg merged\\n', fg)\nprint('mg merged\\n', mg)\n\n# compute Pearson correlation between Rain_* and rate for months Jun-Jul-Aug across 2007-2009\nfrom scipy.stats import pearsonr\n\n# ensure enough points\nif len(fg)>=2:\n    r_fresh = pearsonr(fg['Rain_Fresh'], fg['rate'])[0]\nelse:\n    r_fresh = float('nan')\nif len(mg)>=2:\n    r_marine = pearsonr(mg['Rain_Marine'], mg['rate'])[0]\nelse:\n    r_marine = float('nan')\n\nprint('r_fresh', r_fresh, 'r_marine', r_marine)\nprint('fg rows', len(fg), 'mg rows', len(mg))\n\n# print final tables for inspection\nprint('FG rows:\\n', fg[['Year','Month','rate','Rain_Fresh']].to_csv(index=False))\nprint('MG rows:\\n', mg[['Year','Month','rate','Rain_Marine']].to_csv(index=False))\n\nprint('Done')\n"}) [toolUseId=call_pQWnmfbI5xgkPO5JtWiYAgQz]
