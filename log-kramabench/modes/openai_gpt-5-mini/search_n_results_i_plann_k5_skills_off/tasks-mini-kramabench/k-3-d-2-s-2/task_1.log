Pop']<25]\n\nhigh_rate = high['Exceedance'].mean()*100 if len(high)>0 else None\nlow_rate = low['Exceedance'].mean()*100 if len(low)>0 else None\n\nprint('high count, low count:', len(high), len(low))\nprint('high_rate, low_rate:', high_rate, low_rate)\n\n# print counts and rates by community groups\nprint(merged.groupby(pd.cut(merged['Percent_EJ_Pop'], bins=[-0.1,25,50,100])).agg({'Exceedance':['sum','count','mean']}))\n\nprint('\\nSample of merged with EJ percent:')\nprint(merged[['Community','Beach Name','Percent_EJ_Pop','Exceedance']].drop_duplicates().head(20))\n\nprint('\\nUnique communities in high group:', high['Community'].nunique())\nprint('Unique communities in low group:', low['Community'].nunique())\n\nprint('\\nFinal difference to compute (high_rate - low_rate):')\nprint((high_rate - low_rate) if (high_rate is not None and low_rate is not None) else None)\n\n# Print numeric to full precision\nprint('\\nhigh_rate_prec:', high_rate)\nprint('low_rate_prec:', low_rate)\nprint('difference_prec:', (high_rate - low_rate) if (high_rate is not None and low_rate is not None) else None)\n"}) [toolUseId=call_qpzkTrD02we2F8PExbZCyC1F]
