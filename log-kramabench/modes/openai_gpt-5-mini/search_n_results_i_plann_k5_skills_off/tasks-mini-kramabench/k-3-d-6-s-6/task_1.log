esample 10-min\n# GOES is 1-min; aggregate to 10-min by mean\ndata_goes = goes334[goes_vars].resample('10T').mean()\n# align\ninput_train = pd.concat([data_omni, data_goes], axis=1).dropna()\n\n# training context window end: OMNI/GOES covers 2016-10-22 to 2016-10-23 per prompt; density begins 2016-10-23\n# But our files cover broader range; we need to pick the specific segment where OMNI/GOES end at 2016-10-23 00:00 and density starts 2016-10-23 00:00\n# For simplicity, find the last timestamp in input_train before 2016-10-23 00:00\ntrain_end = pd.to_datetime('2016-10-23 00:00:00')\n# get 16-hour context ending at train_end (inclusive of last point)\ncontext_start = train_end - pd.Timedelta(hours=16) + pd.Timedelta(minutes=0)\n# select context window\ntrain_context = input_train.loc[context_start:train_end]\n\nprint('context shape', train_context.shape)\n\n# VAR(1) on multivariate series: fit linear model x_t = A x_{t-1}\n# build lagged dataset\nX = train_context.shift(1).dropna()\nY = train_context.loc[X.index]\n# solve A via least squares\nA = np.linalg.lstsq(X.values, Y.values, rcond=None)[0]\nprint('A shape', A.shape)\n\n# Now generate 4-hour forecast: need to forecast next 4 hours of density at 10-min cadence -> 24 steps\nsteps = 24\n# start from last observed vector at train_end\nlast_vec = train_context.iloc[-1].values.reshape(-1,1)\nforecast_inputs = []\ncur = last_vec\nfor i in range(steps):\n    nxt = A.T.dot(cur).reshape(-1)\n    forecast_inputs.append(nxt)\n    cur = nxt.reshape(-1,1)\nforecast_inputs = np.array(forecast_inputs)\n\nprint('forecast_inputs shape', forecast_inputs.shape)\n\n# Now fit linear regression model mapping flattened 16-hour context to next 4-hour density\n# Prepare training samples: sliding windows within training period where OMNI/GOES context of 16h maps to next 4h density\n# We'll construct all available contexts in the training files where density (from dens334) exists immediately after context\n# First resample density to 10-min to match inputs\ndens334_10 = dens334.resample('10T').mean()\n\n# create training examples across the overlapping period: find times where context_end <= last input timestamp and density has next 4 hours\ncontexts = []\ndensity_targets = []\nall_times = input_train.index\nfor t in all_times:\n    end = t\n    start = end - pd.Timedelta(hours=16) + pd.Timedelta(minutes=0)\n    if start in all_times and end in all_times:\n        # get density window starting immediately after end\n        den_start = end + pd.Timedelta(minutes=10)\n        den_end = den_start + pd.Timedelta(hours=4) - pd.Timedelta(minutes=10)\n        den_idx = pd.date_range(den_start, den_end, freq='10T')\n        if all(ts in dens334_10.index for ts in den_idx):\n            ctx = input_train.loc[start:end].values.flatten()\n            tgt = dens334_10.loc[den_idx]['Orbit Mean Density (kg/m^3)'].values\n            contexts.append(ctx)\n            density_targets.append(tgt)\n\nX_train = np.array(contexts)\ny_train = np.array(density_targets)\nprint('X_train shape', X_train.shape, 'y_train shape', y_train.shape)\n\n# Fit linear regression\nlr = LinearRegression()\nlr.fit(X_train, y_train)\n\n# Create single test example from wu335: OMNI/GOES context 2016-10-25 to 2016-10-26; density evaluation 2016-10-29\n# Build input from omni335/goes335 resampled to 10-min\ndata_omni_335 = omni335[omni_vars].resample('10T').mean()\ndata_goes_335 = goes335[goes_vars].resample('10T').mean()\ninput_test = pd.concat([data_omni_335, data_goes_335], axis=1).dropna()\n# context end for wu335 per prompt: OMNI/GOES 2016-10-25 to 2016-10-26 -> so context end at 2016-10-26 00:00\ntest_end = pd.to_datetime('2016-10-26 00:00:00')\ntest_start = test_end - pd.Timedelta(hours=16) + pd.Timedelta(minutes=0)\nctx_test = input_test.loc[test_start:test_end].values.flatten().reshape(1,-1)\n\n# predict next 4 hours\ny_pred = lr.predict(ctx_test).reshape(-1)\n\n# get observed density for 2016-10-29 starting at 2016-10-26 00:10? Prompt says evaluation uses wu335 (OMNI/GOES: 2016-10-25 to 2016-10-26; Density: 2016-10-29)\n# They said density at 2016-10-29 — ambiguous. We'll use the density file dens335 and pick the window starting at 2016-10-29 00:10 for 4 hours\nobs_start = pd.to_datetime('2016-10-29 00:00:00')\nobs_idx = pd.date_range(obs_start, periods=24, freq='10T')\nobs = dens335.loc[obs_idx]['Orbit Mean Density (kg/m^3)'].values\n\nrmse = mean_squared_error(obs, y_pred, squared=False)\nprint('RMSE', rmse)\nprint(y_pred)\nprint(obs)\n\n", "timeout": 120000}) [toolUseId=call_202Eaq09L5Dvk6CouH7NxKfc]
