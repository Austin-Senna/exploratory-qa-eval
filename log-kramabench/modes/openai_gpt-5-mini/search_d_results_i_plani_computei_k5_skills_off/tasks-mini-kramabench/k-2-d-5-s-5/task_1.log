2023 (including missing):', len(sel))\n\n# Drop rows where value is NaN and not lt (completely missing)\nsel2 = sel[~(sel['value'].isna() & ~sel['lt'])].copy()\nprint('rows after dropping missing:', len(sel2))\n\n# Define violation: value > 61 -> True. If lt True and value <=61 or NaN -> not violation\nsel2['violation'] = False\nsel2.loc[sel2['value']>61,'violation'] = True\nsel2.loc[sel2['value'].isna() & sel2['lt'], 'violation'] = False\n\n# Count per year\nper_year = sel2.groupby('year').agg(total=('value','count'), violations=('violation','sum')).reindex(range(2019,2024)).fillna(0)\nper_year['violation_rate'] = per_year['violations']/per_year['total'].replace({0:np.nan})\nper_year['violation_rate'] = per_year['violation_rate'].fillna(0)\n\navg_violation_rate = per_year['violation_rate'].mean()\nmet_rate = (1-avg_violation_rate)*100\n\nprint(per_year)\nprint('avg_violation_rate', avg_violation_rate)\nprint('met_rate_percent', met_rate)\nprint('rounded', round(met_rate))\n\n# final output\nprint(round(met_rate))\n", "intent": "Compute final percentage", "dataset_id": "kramabench-environment-hard-8", "file_path": "files/wollaston_beach_datasheet.csv"}) [toolUseId=call_5NXnpm0dZXvKkiI8bGOktoss]
