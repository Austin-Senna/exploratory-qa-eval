\nrc['lon'] = pd.to_numeric(rc['Longitude (X)'], errors='coerce')\nrc['lat'] = pd.to_numeric(rc['Latitude (Y)'], errors='coerce')\nrc = rc.dropna(subset=['lon','lat'])\n\n# modern cities: population > 1,000,000\nwc['population'] = pd.to_numeric(wc['\"population\"'].astype(str).str.replace('\"',''), errors='coerce') if '\"population\"' in wc.columns else pd.to_numeric(wc['population'], errors='coerce')\n# handle city lat/lng column names\nif '\"lat\"' in wc.columns:\n    wc['lat'] = pd.to_numeric(wc['\"lat\"'].astype(str).str.replace('\"',''), errors='coerce')\n    wc['lon'] = pd.to_numeric(wc['\"lng\"'].astype(str).str.replace('\"',''), errors='coerce')\n    wc['city'] = wc['\"city\"'].astype(str).str.replace('\"','')\nelse:\n    wc['lat'] = pd.to_numeric(wc['lat'], errors='coerce')\n    wc['lon'] = pd.to_numeric(wc['lng'] if 'lng' in wc.columns else wc['lon'], errors='coerce')\n    wc['city'] = wc['city']\n\nwc = wc.dropna(subset=['lat','lon','population'])\nwc_big = wc[wc['population']>1_000_000].copy()\n\n# For each modern city, find roman rows within 0.1 degrees and take last matched roman row in file order\npairs = []\n# ensure roman original order preserved\nrc = rc.reset_index()\nfor idx, m in wc_big.iterrows():\n    lat_m = m['lat']\n    lon_m = m['lon']\n    # match within abs diff <= 0.1\n    matches = rc[(rc['lat'].sub(lat_m).abs()<=0.1) & (rc['lon'].sub(lon_m).abs()<=0.1)]\n    if len(matches)>0:\n        # take last matched roman row in file order -> highest original index\n        last = matches.iloc[-1]\n        pairs.append((m['population'], last['rank_num']))\n\npairs[:10], len(pairs)\n\n# compute Pearson correlation\nif len(pairs)>1:\n    pops = np.array([p for p,r in pairs])\n    ranks = np.array([r for p,r in pairs])\n    corr, pval = pearsonr(ranks, pops)\nelse:\n    corr = np.nan\n\nprint('corr', corr, 'n', len(pairs))\n\n# print correlation rounded to 6 decimals and n\nprint(round(corr,6), len(pairs))\n\n# Also output correlation numeric full\