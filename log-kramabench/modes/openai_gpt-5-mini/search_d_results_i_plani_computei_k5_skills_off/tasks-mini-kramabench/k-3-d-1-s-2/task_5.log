nprint('Aligned rows count:', len(aligned))\n\n# For lags 0..48, shift AP forward by lag (i.e. AP at t-lag influences delta at t?) The instruction: shift AP by each candidate lag and choose lag with maximum r-squared. We'll try shifting AP forward so that we compute r2 between delta(t) and AP(t-lag), equivalently shift AP downwards by lag hours.\n\nfrom sklearn.linear_model import LinearRegression\n\ndef compute_r2(lag):\n    # shift AP earlier by lag: use AP shifted forward to align previous AP with current delta\n    y = aligned['delta_a_km'].values.reshape(-1,1)\n    X = aligned['AP'].shift(lag).dropna()\n    common_idx = aligned['AP'].shift(lag).dropna().index.intersection(aligned.index)\n    if len(common_idx) < 10:\n        return np.nan\n    Xv = aligned.loc[common_idx, 'AP'].values.reshape(-1,1)\n    yv = aligned.loc[common_idx, 'delta_a_km'].values.reshape(-1,1)\n    # simple linear regression\n    model = LinearRegression().fit(Xv, yv)\n    r2 = model.score(Xv, yv)\n    return r2\n\nr2s = {}\nfor lag in range(0,49):\n    r2s[lag] = compute_r2(lag)\n\nbest_lag = max(r2s, key=lambda k: (r2s[k] if not np.isnan(r2s[k]) else -1))\nprint('Best lag:', best_lag, 'r2:', r2s[best_lag])\nprint(r2s)\n", "intent": "Parse TLEs for SATCAT 43180, compute hourly semi-major axis changes for May 1-30 2024, parse OMNI2 hourly AP from omni2_2024.dat, align, shift AP by 0-48h, compute r^2 for each, return best lag", "dataset_id": "kramabench-astronomy-hard-9", "file_path": "files/TLE/43180.tle"})
