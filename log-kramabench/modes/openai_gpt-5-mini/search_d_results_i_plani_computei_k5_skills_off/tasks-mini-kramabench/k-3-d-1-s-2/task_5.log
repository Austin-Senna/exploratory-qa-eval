        n = parse_mean_motion(l2)  # revs per day\n        # orbital period T = 86400/n seconds\n        T = 86400.0 / n\n        a = (mu * (T/(2*np.pi))**2)**(1/3)\n        epochs.append(dt)\n        semi_major.append(a)\n    except Exception as e:\n        # skip problematic\n        pass\n\n# Build DataFrame\ntle_df = pd.DataFrame({'epoch':epochs, 'a_km':semi_major}).sort_values('epoch').reset_index(drop=True)\nprint('TLE records parsed:', len(tle_df))\nprint(tle_df.head().to_string())\n\n# Round epochs to nearest hour\ntle_df['epoch_hr'] = tle_df['epoch'].dt.round('H')\n\n# Compute hourly delta-a: For each hour, take first and last a within that hour? Instruction: compute May 2024 semi-major-axis changes rounded to hourly timestamps.\n# We'll compute delta a per hour as difference between median a at hour and median a at next hour? Better: group by epoch_hr and take mean a, then compute diff between successive hours.\n\n# Filter for May 1--30, 2024\nstart = datetime(2024,5,1)\nend = datetime(2024,5,30,23,59,59)\nmask = (tle_df['epoch']>=start) & (tle_df['epoch']<=end)\nprint('TLE in May count:', mask.sum())\nif mask.sum()==0:\n    # maybe TLE file contains 24122 (May 1 is day 122) yes\n    pass\n\nmay_df = tle_df[mask].copy()\n# group by hour\nhour_mean = may_df.groupby('epoch_hr')['a_km'].mean().sort_index()\nhourly = hour_mean.to_frame().rename(columns={'a_km':'a_mean'})\nhourly['delta_a'] = hourly['a_mean'].diff()  # a(t) - a(t-1)\n# keep hours from May 1 00:00 to May 30 23:00\nall_hours = pd.date_range(start=start, end=datetime(2024,5,30,23), freq='H')\nhourly = hourly.reindex(all_hours)\nprint('Hourly a rows:', len(hourly))\n\n# Read omni2 data: fixed width columns; from omni2.text spec, AP index appears as column? We need to identify which column is AP.\n# Let's inspect header of omni2.text to find AP column index. We'll open file and search for AP description.\nomni_text = Path('kramabench-astronomy-hard-9/files/omni2_low_res/omni2.text').read_text()\nprint('\\nOMNI2 spec sample lines:\\n', '\\n'.join(omni_text.splitlines()[:200]))\n\n# From common OMNI2 low-res format, AP (planetary A index) often is column 'ap' or 'AP' maybe an integer 0-400. Looking at data sample first line, the values after date include 2596 51 52  60  36   5.3   5.1  -7.3 322.9   4.0  -3.0  -0.6  -2.8  -1.4   0.1   1.5   0.3   0.4   1.5   31114.   7.4 ...'\n# We need to find which field is AP. The omni2.text documentation likely describes columns; let's grep for 'ap' or 'AP index' in omni2.text\n\nprint('\\nSearching for \"ap\" in omni2.text...')\n\nprint('\\n'.join([ln for ln in omni_text.splitlines() if 'AP' in ln or 'ap' in ln or 'A P' in ln][:50]))\n\n# We'll parse omni2_2024.dat by fixed columns known for OMNI2 low-res: Format commonly: year month day hour ... ap ...\n# Let's inspect a few lines tokenized by whitespace to see which token corresponds to ap-like integer (0-400)\nomni_lines = Path(DOWNLOAD_PATHS['omni']).read_text().splitlines()\nsample = [ln for ln in omni_lines if ln.strip()][:20]\nfor ln in sample[:10]:\n    toks = ln.split()\n    print(toks)\n\n# OBSERVE tokens: e.g. ['2024', '1', '0', '2596', '51', '52', '60', '36', '5.3', '5.1', '-7.3', '322.9', '4.0', '-3.0', ...]\n# Which token is ap? ap (3-hourly planetary index) often ranges small like 0-400 but typical values are low (<100). In sample tokens, near token index 7 is '36' then floats.\n# There is also a token around later '31114.' which is large maybe seconds? Need documentation mapping. But omni2.text includes 'ap' maybe uppercase.\n\n# Let's search omni2.text for 'AP index' explicitly\nif 'AP' in omni_text:\n    print('AP mentions present')\n\n# Manual mapping approach: Known OMNI2 low-res fields from documentation: per hour columns include 'ap' 3-hourly index? Another known index is 'ap' or 'ap1..ap8'\n# Alternatively, we can find which column is integer between 0 and 400 across many rows; pick the column with int values in that range.\n\n# Tokenize all lines and build stats per token position for first 2000 lines\nmax_lines = min(5000, len(omni_lines))\ncols = {}\nfor ln in omni_lines[:max_lines]:\n    toks = ln.split()\n    for i,tk in enumerate(toks):\n        try:\n            val = float(tk)\n        except:\n            val = None\n        cols.setdefault(i, []).append(val)\n\n# compute ranges\ncol_stats = {}\nfor i,vals in cols.items():\n    nums = [v for v in vals if v is not None]\n    if not nums:\n        continue\n    col_stats[i] = (min(nums), max(nums), len(nums))\n\n# print candidate columns that are small integers 0-400\ncands = {i:col_stats[i] for i in col_stats if col_stats[i][0]>=0 and col_stats[i][1]<=400}\nprint('Candidate int columns (0-400):', cands)\n\n# Print sample tokens at those indices for first lines\nfor i in sorted(cands):\n    print('\\nColumn', i, 'samples:', [ln.split()[i] if len(ln.split())>i else None for ln in sample[:10]])\n\n# From inspection, column index 7 seems small ints like 36,33,33... That might be AP. Let's assume column 7 is AP.\nap_idx = 7\n# Build dataframe of omni with datetime and ap\nomni_dates = []\nap_vals = []\nfor ln in omni_lines:\n    toks = ln.split()\n    if len(toks) <= ap_idx:\n        continue\n    try:\n        year = int(toks[0])\n        month = int(toks[1])\n        day = int(toks[2])\n        hour = int(toks[3])\n        ap = float(toks[ap_idx])\n        dt = datetime(year,month,day,hour)\n        omni_dates.append(dt)\n        ap_vals.append(ap)\n    except Exception as e:\n        continue\nomni_df = pd.DataFrame({'dt':omni_dates, 'AP':ap_vals}).set_index('dt').sort_index()\nprint('\\nOMNI rows parsed:', len(omni_df))\nprint(omni_df.loc['2024-05-01':'2024-05-30'].head())\n\n# Extract AP for May 1-30 hours\nap_may = omni_df.loc[datetime(2024,5,1):datetime(2024,5,30,23)].reindex(all_hours)\n\n# Now align with hourly delta_a from TLE hourly\naligned = pd.DataFrame({'delta_a_km':hourly['delta_a'].values, 'AP':ap_may['AP'].values}, index=all_hours)\n\n# Drop rows with NaN\naligned = aligned.dropna()\nprint('Aligned rows count:', len(aligned))\n\n# For lags 0..48, shift AP forward by lag (i.e. AP at t-lag influences delta at t?) The instruction: shift AP by each candidate lag and choose lag with maximum r-squared. We'll try shifting AP forward so that we compute r2 between delta(t) and AP(t-lag), equivalently shift AP downwards by lag hours.\n\nfrom sklearn.linear_model import LinearRegression\n\ndef compute_r2(lag):\n    # shift AP earlier by lag: use AP shifted forward to align previous AP with current delta\n    y = aligned['delta_a_km'].values.reshape(-1,1)\n    X = aligned['AP'].shift(lag).dropna()\n    common_idx = aligned['AP'].shift(lag).dropna().index.intersection(aligned.index)\n    if len(common_idx) < 10:\n        return np.nan\n    Xv = aligned.loc[common_idx, 'AP'].values.reshape(-1,1)\n    yv = aligned.loc[common_idx, 'delta_a_km'].values.reshape(-1,1)\n    # simple linear regression\n    model = LinearRegression().fit(Xv, yv)\n    r2 = model.score(Xv, yv)\n    return r2\n\nr2s = {}\nfor lag in range(0,49):\n    r2s[lag] = compute_r2(lag)\n\nbest_lag = max(r2s, key=lambda k: (r2s[k] if not np.isnan(r2s[k]) else -1))\nprint('Best lag:', best_lag, 'r2:', r2s[best_lag])\nprint(r2s)\n", "intent": "Parse TLEs for SATCAT 43180, compute hourly semi-major axis changes for May 1-30 2024, parse OMNI2 hourly AP from omni2_2024.dat, align, shift AP by 0-48h, compute r^2 for each, return best lag", "dataset_id": "kramabench-astronomy-hard-9", "file_path": "files/TLE/43180.tle"}) [toolUseId=call_AwHZyLHeUF0lpmfVJeu9nvEN]
