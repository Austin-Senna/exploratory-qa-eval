er()==city.lower()]\n            return rows['country'].mode().iloc[0]\n    # try splitting on - or vs or parentheses\n    parts = re.split('[-()]| and | vs | v\\.| vs\\.|/|,', text)\n    for p in parts:\n        p = p.strip()\n        for c in countries:\n            if p.lower()==c.lower():\n                return c\n    return None\n\n# parse actor pairs from Conflict column which sometimes is like 'A-B' or 'A-B (place)'\n\ndef parse_actors(conflict_text):\n    if pd.isna(conflict_text):\n        return []\n    # replace parentheses with commas\n    text = re.sub(r\"\\(.*?\\)\", \"\", conflict_text)\n    # split on hyphen indicating actors\n    if '-' in text:\n        left,right = text.split('-',1)\n        return [left.strip(), right.strip()]\n    # otherwise if 'vs' or 'and'\n    if ' vs ' in text.lower():\n        return [p.strip() for p in re.split('(?i) vs | v\\.| vs\\.| and | / ', text)][:2]\n    # fallback: take first token\n    pieces = re.split(',|;', text)\n    return [pieces[0].strip(), pieces[1].strip()] if len(pieces)>=2 else [pieces[0].strip()]\n\nconf['actors'] = conf['Conflict'].apply(parse_actors)\nconf['actor1'] = conf['actors'].apply(lambda x: x[0] if len(x)>0 else None)\nconf['actor2'] = conf['actors'].apply(lambda x: x[1] if len(x)>1 else None)\nconf['StartYear'] = pd.to_numeric(conf['StartYear'], errors='coerce')\nconf['EndYear'] = pd.to_numeric(conf['EndYear'], errors='coerce')\n\n# Some records have StartYear==EndYear; duration 0 -> filter out as need at least 1 year\nconf['duration'] = conf['EndYear'] - conf['StartYear']\n\n# filter overlapping 800-1400: event interval intersects [800,1400]\ndef overlaps(s,e, a=800, b=1400):\n    if pd.isna(s) or pd.isna(e):\n        return False\n    return not (e < a or s > b)\n\nconf['in_period'] = conf.apply(lambda r: overlaps(r['StartYear'], r['EndYear']), axis=1)\nconf_period = conf[conf['in_period'] & (conf['duration']>=1)].copy()\nprint('period rows >=1yr', len(conf_period))\n\n# attribute actors