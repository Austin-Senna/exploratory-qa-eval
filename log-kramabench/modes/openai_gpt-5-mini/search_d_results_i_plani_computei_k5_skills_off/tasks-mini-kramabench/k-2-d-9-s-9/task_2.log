.columns if 'Tag' in col or 'Enterococcus' in col]\n    id_cols = [col for col in df.columns if col not in value_cols]\n\n    long_df = df.melt(id_vars=id_cols, value_vars=value_cols, var_name='Variable', value_name='Value')\n    long_df['Location'] = long_df['Variable'].str.split('_').str[0]\n    long_df['Measure'] = long_df['Variable'].str.split('_').str[1]\n\n    tidy = long_df.pivot(index=id_cols + ['Location'], columns='Measure', values='Value').reset_index()\n    tidy.columns.name = None\n\n    for col in tidy.columns:\n        if col not in id_cols + ['Location', 'Tag']:\n            tidy[col] = pd.to_numeric(tidy[col], errors='coerce')\n    return tidy\n\n\ndef matches_location(beach_name, location):\n    location = str(location).lower()\n    if beach_name == 'Pleasure Bay Beach':\n        return 'pleasure bay' in location\n    if beach_name == 'Castle Island Beach':\n        return 'castle island' in location\n    if beach_name == 'City Point Beach':\n        return 'city point' in location\n    if beach_name == 'M Street Beach':\n        return 'm. street' in location or 'm street' in location\n    if beach_name == 'Carson Beach':\n        return location in ['i street', 'mccormack bathhouse'] or 'carson' in location\n    if beach_name == 'Constitution Beach':\n        return location in ['north', 'middle', 'south'] or 'constitution' in location\n    return beach_name.replace(' Beach', '').lower() in location\n\n\nresults = []\n\nfor key, path in files.items():\n    df = prepare_beach_datasheet(path)\n    years = pd.to_numeric(df['Date'].astype(str).str.extract(r'(\\d{4})')[0], errors='coerce')\n    recent = df[(years >= 2020) & (years <= 2024)].copy()\n\n    if key == 'Pleasure Bay / Castle Island':\n        beach_names = ['Castle Island Beach', 'Pleasure Bay Beach']\n    else:\n        beach_names = [key]\n\n    for beach_name in beach_names:\n        beach_rows = recent[recent['Location'].apply(lambda x: matches_location(beach_name, x))]\n        if len