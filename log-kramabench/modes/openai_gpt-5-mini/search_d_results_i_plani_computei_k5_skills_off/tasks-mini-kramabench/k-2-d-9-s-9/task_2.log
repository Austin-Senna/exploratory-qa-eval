t' in location\n    if beach_name == 'Carson Beach':\n        return location in ['i street', 'mccormack bathhouse'] or 'carson' in location\n    if beach_name == 'Constitution Beach':\n        return location in ['north', 'middle', 'south'] or 'constitution' in location\n    if beach_name == 'Tenean Beach':\n        return location == 'middle' or 'tenean' in location\n    if beach_name == 'Wollaston Beach':\n        return location in ['channing street', 'milton road', 'rice road', 'sachem street'] or 'wollaston' in location\n    return beach_name.replace(' Beach', '').lower() in location\n\n\nfiles = [\n    ('Malibu Beach', path_map['s3://sana-kramabench/datagov/kramabench-environment-hard-10/files/malibu_beach_datasheet.csv']),\n    ('Tenean Beach', path_map['s3://sana-kramabench/datagov/kramabench-environment-hard-10/files/tenean_beach_datasheet.csv']),\n    ('Wollaston Beach', path_map['s3://sana-kramabench/datagov/kramabench-environment-hard-10/files/wollaston_beach_datasheet.csv']),\n]\n\nresult = []\nfor beach_name, path in files:\n    df = prepare_beach_datasheet(path)\n    years = pd.to_numeric(df['Date'].astype(str).str.extract(r'(\\d{4})$')[0], errors='coerce')\n    recent = df[(years >= 2020) & (years <= 2024)].copy()\n    mask = recent['Location'].apply(lambda value: matches_location(beach_name, value))\n    beach_rows = recent[mask]\n    if len(beach_rows) and int((beach_rows['Enterococcus'] > 104).sum()) == 0:\n        result.append(beach_name)\n\nprint(result)", "reason": "Rewrote the code to follow the authored per-beach computation pattern from the plan records, using the downloaded manifest files for Malibu, Tenean, and Wollaston only, preserving beach-list order and printing the qualifying beaches list."}) [toolUseId=call_XdPnOMCbLcWR061Qef0PKIW1]
