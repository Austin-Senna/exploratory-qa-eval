ols if 'PLK1' in str(c) or str(c).startswith('PLK1|')]\nchek_alt = [c for c in cols if 'CHEK2' in str(c) and 'S163' in str(c)]\nprint('plk_alt', plk_alt[:20])\n\n# If still nothing, inspect tail columns for proteomics values (these might be many numeric columns after metadata)\nprint('last 50 cols', cols[-50:])\n\n# Identify numeric columns by trying to convert a column to numeric\nnumeric_cols = []\nfor c in cols:\n    try:\n        pd.to_numeric(meta[c].dropna().iloc[:10])\n        numeric_cols.append(c)\n    except Exception:\n        pass\nprint('numeric cols count', len(numeric_cols))\n\n# Let's search for any column that contains 'PLK1' or 'CHEK2' irrespective of case\nplk_any = [c for c in cols if 'plk1' in str(c).lower()]\nchek_any = [c for c in cols if 'chek2' in str(c).lower()]\nprint('plk_any', plk_any[:50])\nprint('chek_any sample', chek_any[:50])\n\n# If we have candidates, pick first ones\nif plk_any and chek_any:\n    plk_col = plk_any[0]\n    # find CHEK2-S163 specifically\n    chek_col = None\n    for c in chek_any:\n        if '163' in str(c):\n            chek_col = c\n            break\n    if chek_col is None:\n        chek_col = chek_any[0]\n    print('using', plk_col, chek_col)\n    # Filter clinical: 'Case_excluded' == 'No' and 'Histologic_type' in ['Endometrioid','Serous']\n    filt = meta[(meta['Case_excluded']=='No') & (meta['Histologic_type'].isin(['Endometrioid','Serous']))]\n    print('filtered shape', filt.shape)\n    x = pd.to_numeric(filt[plk_col], errors='coerce')\n    y = pd.to_numeric(filt[chek_col], errors='coerce')\n    df = pd.concat([x,y], axis=1).dropna()\n    df.columns = ['plk','chek']\n    print('paired n', df.shape[0])\n    corr, p = spearmanr(df['plk'], df['chek'])\n    print('spearman', round(corr,4))\nelse:\n    print('No direct PLK1/CHEK2 columns found; need manual inspection of column names')\n\n# As a final resort, save column names to inspect\nprint('done')\n"})
