chek2_s163_cols = [c for c in cols if 'CHEK2-S163' in str(c) or 'CHEK2_S163' in str(c) or 'CHEK2 S163' in str(c) or 'S163' in str(c) and 'CHEK2' in str(c)]\nprint('after heuristic', plk_cols[:50], chek2_s163_cols[:50])\n\n# If direct column names not found, inspect column name samples to find pattern\nprint('first 200 cols:', cols[:200])\n\n# manual pattern inspection: find columns that start with 'protein_' or 'phospho_'\ncandidates_plk = [c for c in cols if str(c).startswith('PLK1') or 'PLK1' in str(c)]\ncandidates_chek2 = [c for c in cols if 'CHEK2' in str(c) and ('S163' in str(c) or '163' in str(c))]\nprint('candidates_plk', candidates_plk[:50])\nprint('candidates_chek2', candidates_chek2[:50])\n\n# If still not found, look into column names further by printing those containing '-' (phosphosites often contain '-')\nhyphen_cols = [c for c in cols if '-' in str(c)]\nprint('hyphen cols sample', hyphen_cols[:200])\n\n# Let's find columns that match pattern of 'CHEK2-S163' exactly in any column string\nexact_chek2 = [c for c in cols if 'CHEK2-S163' in str(c)]\nprint('exact_chek2', exact_chek2)\n\n# If proteomics and phospho data are in separate sheets, check for other sheets names\n# But Excel had only one sheet; columns likely include both global and phospho values.\n# Strategy: identify columns where header contains gene names (split by '|') e.g. 'CHEK2-S163' appears in header text\n# Search for 'S163' anywhere in column names\ns163_cols = [c for c in cols if 'S163' in str(c) or 's163' in str(c)]\nprint('s163_cols', s163_cols)\n\n# If we find one PLK1 and one CHEK2-S163 column, compute correlation. Otherwise, search in columns beyond 200\n# Expand search to full list as strings\nplk_cols_full = [c for c in cols if 'PLK1' in str(c)]\nchek_s163_full = [c for c in cols if 'CHEK2' in str(c) and 'S163' in str(c)]\nprint('plk_cols_full count', len(plk_cols_full), 'chek_s163_full count', len(chek_s163_full))\n\n# Fallback: search for columns containing 'PLK1|' pattern common in proteomics\nplk_alt = [c for c in cols if 'PLK1' in str(c) or str(c).startswith('PLK1|')]\nchek_alt = [c for c in cols if 'CHEK2' in str(c) and 'S163' in str(c)]\nprint('plk_alt', plk_alt[:20])\n\n# If still nothing, inspect tail columns for proteomics values (these might be many numeric columns after metadata)\nprint('last 50 cols', cols[-50:])\n\n# Identify numeric columns by trying to convert a column to numeric\nnumeric_cols = []\nfor c in cols:\n    try:\n        pd.to_numeric(meta[c].dropna().iloc[:10])\n        numeric_cols.append(c)\n    except Exception:\n        pass\nprint('numeric cols count', len(numeric_cols))\n\n# Let's search for any column that contains 'PLK1' or 'CHEK2' irrespective of case\nplk_any = [c for c in cols if 'plk1' in str(c).lower()]\nchek_any = [c for c in cols if 'chek2' in str(c).lower()]\nprint('plk_any', plk_any[:50])\nprint('chek_any sample', chek_any[:50])\n\n# If we have candidates, pick first ones\nif plk_any and chek_any:\n    plk_col = plk_any[0]\n    # find CHEK2-S163 specifically\n    chek_col = None\n    for c in chek_any:\n        if '163' in str(c):\n            chek_col = c\n            break\n    if chek_col is None:\n        chek_col = chek_any[0]\n    print('using', plk_col, chek_col)\n    # Filter clinical: 'Case_excluded' == 'No' and 'Histologic_type' in ['Endometrioid','Serous']\n    filt = meta[(meta['Case_excluded']=='No') & (meta['Histologic_type'].isin(['Endometrioid','Serous']))]\n    print('filtered shape', filt.shape)\n    x = pd.to_numeric(filt[plk_col], errors='coerce')\n    y = pd.to_numeric(filt[chek_col], errors='coerce')\n    df = pd.concat([x,y], axis=1).dropna()\n    df.columns = ['plk','chek']\n    print('paired n', df.shape[0])\n    corr, p = spearmanr(df['plk'], df['chek'])\n    print('spearman', round(corr,4))\nelse:\n    print('No direct PLK1/CHEK2 columns found; need manual inspection of column names')\n\n# As a final resort, save column names to inspect\nprint('done')\n"}) [toolUseId=