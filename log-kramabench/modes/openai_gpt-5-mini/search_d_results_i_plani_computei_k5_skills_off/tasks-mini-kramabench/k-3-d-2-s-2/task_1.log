 samples in 2023\nmarine_2023 = merged[(merged['Year']==2023) & (merged['Beach Type Description'].str.lower().str.contains('marine'))]\n\n# Determine exceedance flag: 'Violation' column equals 'Yes'\nmarine_2023['Exceedance'] = marine_2023['Violation'].astype(str).str.lower().str.strip()=='yes'\n\n# Classify municipalities\nmarine_2023['EJ_percent'] = pd.to_numeric(marine_2023[ej_col], errors='coerce')\nhigh_ej = marine_2023[marine_2023['EJ_percent']>50]\nlow_ej = marine_2023[marine_2023['EJ_percent']<25]\n\n# Compute exceedance rates: number of exceedances / total samples\nhigh_rate = high_ej['Exceedance'].mean() if len(high_ej)>0 else 0.0\nlow_rate = low_ej['Exceedance'].mean() if len(low_ej)>0 else 0.0\n\n# Difference\ndiff = high_rate - low_rate\n\n# Print results\nprint('high_count', len(high_ej), 'low_count', len(low_ej))\nprint('high_rate', high_rate)\nprint('low_rate', low_rate)\nprint('diff', diff)\n\n# final rounded difference\nprint(round(diff,2))\n", "intent": "Compute exceedance rates and difference as specified using pandas, reading downloaded CSVs"})
