    if len(df_a) < 2:\n        return None\n    t0 = df_a['epoch'].iloc[0]\n    t1 = df_a['epoch'].iloc[-1]\n    a0 = df_a['a_km'].iloc[0]\n    a1 = df_a['a_km'].iloc[-1]\n    days = (t1 - t0).total_seconds() / 86400.0\n    rate = (a1 - a0) / days\n    return rate, a0, a1, days, t0, t1\n\nquiet_rate = endpoint_rate(quiet_a)\nstorm_rate = endpoint_rate(storm_a)\n\nprint('quiet_rate detail:', quiet_rate)\nprint('storm_rate detail:', storm_rate)\n\n# Print only the rates in requested order\nquiet_rate_km_day = quiet_rate[0]\nstorm_rate_km_day = storm_rate[0]\nprint('RESULT:', quiet_rate_km_day, storm_rate_km_day)\n\n# Round to reasonable precision (e.g., 6 decimal places)\nprint(round(quiet_rate_km_day, 6), round(storm_rate_km_day, 6))\n\n# Output final values for submit\nquiet_val = float(quiet_rate_km_day)\nstorm_val = float(storm_rate_km_day)\nprint([quiet_val, storm_val])\n", "intent": "Calculate semi-major axis from mean motion and compute endpoint average decay rate (km/day) for quiet and storm CSV files for NORAD 58214."}) [toolUseId=call_i7L9emKkwmwaQR5sDWDswRCZ]
