 else use complement via math: use scipy.special.gammaincc\n\ntry:\n    from scipy import special\n    p_value = special.chdtrc(dfree, chi2) if hasattr(special, 'chdtrc') else special.gammaincc(dfree/2, chi2/2)\nexcept Exception:\n    try:\n        import mpmath as mp\nn        # mpmath quad? but mpmath not available perhaps\n    except Exception:\n        # fallback: use incomplete gamma via math and approximation using regularized upper incomplete gamma via continued fraction from Numerical Recipes\n        # Implement regularized upper incomplete gamma Q(a,x) using math and math.lgamma\n        import math\n        def gammainc_upper_Q(a, x):\n            # Use continued fraction (Lentz's algorithm) for regularized upper incomplete gamma Q(a,x)\n            # From Numerical Recipes 3rd ed. Implementation adapted.\n            if x < 0 or a <= 0:\n                return float('nan')\n            EPS = 1e-14\n            FPMIN = 1e-300\n            # Calculate ln(gamma(a))\n            gln = math.lgamma(a)\n            # Series representation for x < a+1\n            if x < a + 1.0:\n                # use series representation to compute lower incomplete gamma P(a,x)\n                ap = a\n                sum_ = 1.0 / a\n                del_ = sum_\n                while True:\n                    ap += 1\n                    del_ *= x / ap\n                    sum_ += del_\n                    if abs(del_) < abs(sum_) * EPS:\n                        break\n                P = sum_ * math.exp(-x + a*math.log(x) - gln)\n                return 1.0 - P\n            # Continued fraction representation for x >= a+1\n            b = x + 1.0 - a\n            c = 1.0 / FPMIN\n            d = 1.0 / b\n            h = d\n            i = 1\n            while True:\n                an = -i * (i - a)\n                b += 2.0\n                d = an * d + b\n                if abs(d) < FPMIN:\n                    d = FPMIN\n                c = b + an / c\n                if abs(c) < FPMIN:\n                    c = FPMIN\n                d = 1.0 / d\n                delta = d * c\n                h *= delta\n                if abs(delta - 1.0) < EPS:\n                    break\n                i += 1\n                if i > 1000:\n                    break\n            Q = math.exp(-x + a*math.log(x) - gln) * h\n            return Q\n        p_value = gammainc_upper_Q(dfree/2, chi2/2)\n\nprint('chi2, df, p-value')\nprint(chi2, dfree, p_value)\n\n# Print final numbers required\nprint('\\nFINAL')\nprint(chi2, p_value)\n", "dataset_id": "kramabench-wildfire-easy-15", "file_path": "files/noaa_wildfires.csv"}) [toolUseId=call_DMpKKxH50WAve0msjauZgRo1]
