2026-05-17 18:26:25 | DEBUG | strands_evaluation.instrumentation.agent_plugins | Model response #8 [role=assistant block=1 tool_use] execute_ideal({"code": "# intent: Load the downloaded OMNI2, GOES, and Swarm Alpha density CSVs for wu334 (train) and wu335 (eval). Build hourly aggregated features (f10.7_index, Kp_index, Dst_index_nT, xrsb_flux_observed, xrsa_flux_observed), construct 16-hour context windows at hourly cadence, fit VAR(1) on the 16-hour histories of these five features using the training window end data, project them forward 4 hours for each training sample, train linear regression to predict next 4 hourly density values from projected features, evaluate on wu335 and compute RMSE over 4-hour forecast horizon.\n\nimport pandas as pd\nimport numpy as np\nfrom statsmodels.tsa.api import VAR\nfrom sklearn.linear_model import LinearRegression\nfrom sklearn.metrics import mean_squared_error\nimport math\nimport os\n\n# Load paths from DOWNLOAD_MANIFEST_PATH\nimport json\nwith open(os.environ['DOWNLOAD_MANIFEST_PATH']) as f:\n    manifest = json.load(f)\npath_map = manifest['path_map']\n\nomni334 = pd.read_csv(path_map[next(k for k in path_map if k.endswith('omni2-wu334-20160824_to_20161023.csv'))], parse_dates=['Timestamp'])\ngoes334 = pd.read_csv(path_map[next(k for k in path_map if k.endswith('goes-wu334-20160824_to_20161023.csv'))], parse_dates=['Timestamp'])\ndens334 = pd.read_csv(path_map[next(k for k in path_map if 'swarma-wu334' in k)], parse_dates=['Timestamp'])\n\nomni335 = pd.read_csv(path_map[next(k for k in path_map if k.endswith('omni2-wu335-20160827_to_20161026.csv'))], parse_dates=['Timestamp'])\ngoes335 = pd.read_csv(path_map[next(k for k in path_map if k.endswith('goes-wu335-20160827_to_20161026.csv'))], parse_dates=['Timestamp'])\ndens335 = pd.read_csv(path_map[next(k for k in path_map if 'swarma-wu335' in k)], parse_dates=['Timestamp'])\n\n# Select columns of interest\nomni_cols = ['Timestamp','f10.7_index','Kp_index','Dst_index_nT']\ngoes_cols = ['Timestamp','xrsb_flux_observed','xrsa_flux_observed']\n\nomni334 = omni334[omni_cols].set_index('Timestamp')\ngoes334 = goes334[goes_cols].set_index('Timestamp')\ndens334 = dens334.set_index('Timestamp')\n\nomni335 = omni335[omni_cols].set_index('Timestamp')\ngoes335 = goes335[goes_cols].set_index('Timestamp')\ndens335 = dens335.set_index('Timestamp')\n\n# Resample to hourly means (as instruction uses hourly frames)\nomni334_h = omni334.resample('1H').mean()\ngoesh334_h = goes334.resample('1H').mean()\ntrain_feat = pd.concat([omni334_h, goesh334_h], axis=1).ffill().bfill()\n\nomni335_h = omni335.resample('1H').mean()\ngoesh335_h = goes335.resample('1H').mean()\neval_feat = pd.concat([omni335_h, goesh335_h], axis=1).ffill().bfill()\n\n# Density: resample to hourly by taking mean of 6*10min samples\ndens334_h = dens334.resample('1H').mean()\ndens335_h = dens335.resample('1H').mean()\n\n# Build samples: each sample uses 16 hours of context ending at time t (inclusive), and predicts density at t+1..t+4 hours.\n# We'll create samples where the omni/goes context lies in the training OMNI/GOES window and the density targets lie in the density file.\n\nFEATURES = ['f10.7_index','Kp_index','Dst_index_nT','xrsb_flux_observed','xrsa_flux_observed']\n\n# For training (wu334): OMNI/GOES cover up to 2016-10-23 inclusive; density begins 2016-10-23 00:00\n# We'll align by using times where the 16-hour context ends at latest time where next 4 hourly densities exist in dens334_h.\n\n# Determine valid end times for training: end time t such that we have 16 hours of features up to t, and dens targets at t+1..t+4\n\ndef build_samples(feat_df, dens_df):\n    feat_df = feat_df.sort_index()\n    dens_df = dens_df.sort_index()\n    samples = []\n    targets = []\n    times = []\n    # possible end times are indices in feat_df\n    for t in feat_df.index:\n        t_end = t\n        t_start = t_end - pd.Timedelta(hours=15)  # 16 hours inclusive\n        if t_start < feat_df.index[0]:\n            continue\n        # check density target availability\n        target_times = [t_end + pd.Timedelta(hours=h) for h in range(1,5)]\n        if all(tt in dens_df.index for tt in target_times):\n            hist = feat_df.loc[t_start:t_end]\n            if hist.shape[0]==16:\n                samples.append(hist[FEATURES].values)\n                targets.append(dens_df.loc[target_times]['Orbit Mean Density (kg/m^3)'].values)\n                times.append(t_end)\n    return np.array(samples), np.array(targets), times\n\ntrain_samples, train_targets, train_times = build_samples(train_feat, dens334_h)\nprint('train_samples', train_samples.shape, 'train_targets', train_targets.shape)\n\n# Fit VAR(1) on the training_features time series aggregated: instruction says VAR trained on the 16-hour context at the end of the OMNI/GOES input window; interpret as fit VAR(1) to the sequence of feature vectors from training feature DF.\n# We'll fit VAR(1) on the concatenated hourly training feature series.\n\nvar_model = VAR(train_feat[FEATURES])\nvar_res = var_model.fit(1)\n\n# For each training sample, project features forward 4 hours starting from the last observed vector (t_end), using VAR(1) iteration\n\ndef project_var(last_vec, var_res, steps=4):\n    # var_res.params : intercept + lag1 coefficients\n    coefs = var_res.params  # DataFrame with intercept and lag coefficients per endogenous\n    # Extract coefficient matrices\n    intercept = coefs.loc['const'].values if 'const' in coefs.index else np.zeros(len(FEATURES))\n    # lag1 cols are like L1.f10.7_index ...\n    lag1_cols = [c for c in coefs.index if c.startswith('L1.')]\n    A = coefs.loc[lag1_cols].values.T\n    # state update: x_t = intercept + A @ x_{t-1}\n    x = last_vec.copy()\n    preds = []\n    for i in range(steps):\n        x = intercept + A.dot(x)\n        preds.append(x.copy())\n    return np.array(preds)\n\n# Build projected features for training samples (and flatten)\ntrain_proj = []\nfor i, t in enumerate(train_times):\n    last_vec = train_samples[i][-1]\n    preds = project_var(last_vec, var_res, steps=4)\n    train_proj.append(preds.flatten())\ntrain_proj = np.array(train_proj)\n\n# Train linear regression: input is projected features (5 features * 4 steps = 20), target is 4 density values\nlr = LinearRegression()\nlr.fit(train_proj, train_targets)\n\n# Now evaluation on wu335: build samples from eval_feat and dens335_h\neval_samples, eval_targets, eval_times = build_samples(eval_feat, dens335_h)\nprint('eval_samples', eval_samples.shape, 'eval_targets', eval_targets.shape)\n\n# Project eval samples using var_res (trained on training feat series)\neval_proj = []\nfor i in range(len(eval_samples)):\n    last_vec = eval_samples[i][-1]\n    preds = project_var(last_vec, var_res, steps=4)\n    eval_proj.append(preds.flatten())\neval_proj = np.array(eval_proj)\n\n# Predict and compute RMSE across all evaluation samples and forecast horizon\npreds = lr.predict(eval_proj)\nrmse = math.sqrt(mean_squared_error(eval_targets.flatten(), preds.flatten()))\nprint('RMSE', rmse)\n\n# Print final RMSE\nprint(rmse)\n", "dataset_id": "kramabench-astronomy-hard-7", "file_path": "files/STORM-AI/warmup/v2/OMNI2/omni2-wu334-20160824_to_20161023.csv"}) [toolUseId=call_jpLC7YPPQGBQcHUYOpeTocLK]
