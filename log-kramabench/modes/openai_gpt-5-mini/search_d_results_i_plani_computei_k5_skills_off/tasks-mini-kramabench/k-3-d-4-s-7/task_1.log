c(df[col], errors='coerce')\n\n# For each station, compute median for each month across non-missing years\nstations = {'Boston':boston,'Chatham':chatham,'Amherst':amherst,'Ashburnham':ash}\nmedians = {}\nfor name,df in stations.items():\n    med = {}\n    for m in ['Jun','Jul','Aug']:\n        med[m] = df[m].median(skipna=True)\n    medians[name]=med\n\n# For years 2007-2009 compute summer total Jun+Jul+Aug with median imputation for missing months per station\nrain = {name:[] for name in stations}\nyears = [2007,2008,2009]\nfor name,df in stations.items():\n    df2 = df.set_index('Year')\n    for y in years:\n        if y in df2.index:\n            row = df2.loc[y]\n            vals = []\n            for m in ['Jun','Jul','Aug']:\n                v = row[m]\n                if pd.isna(v):\n                    v = medians[name][m]\n                vals.append(v)\n            rain[name].append(sum(vals))\n        else:\n            # if year missing, impute all months by medians\n            rain[name].append(sum(medians[name].values()))\n\n# Average rainfall totals over sets: freshwater stations = Boston, Chatham, Amherst, Ashburnham\nfresh_names = ['Boston','Chatham','Amherst','Ashburnham']\nmarine_names = ['Boston','Chatham']\nfresh_avg = [np.mean([rain[n][i] for n in fresh_names]) for i in range(3)]\nmarine_avg = [np.mean([rain[n][i] for n in marine_names]) for i in range(3)]\n\n# Load water-body testing files and compute exceedance rates per year for freshwater vs marine\nw2007 = pd.read_csv(lp('kramabench-environment-easy-2/files/water-body-testing-2007.csv'), parse_dates=['Sample Date'])\nw2008 = pd.read_csv(lp('kramabench-environment-easy-2/files/water-body-testing-2008.csv'), parse_dates=['Sample Date'])\nw2009 = pd.read_csv(lp('kramabench-environment-easy-2/files/water-body-testing-2009.csv'), parse_dates=['Sample Date'])\n\nw_all = pd.concat([w2007,w2008,w2009], ignore_index=True)\n# Exceedance rate: fraction of samples within June-August (inclusive) that 