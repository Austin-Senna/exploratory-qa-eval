 months\nw_all['Month'] = w_all['Sample Date'].dt.month\nw_jja = w_all[w_all['Month'].isin([6,7,8])].copy()\n\n# Group by Year and Beach Type Description\ngroup = w_jja.groupby(['Year','Beach Type Description'])['Violation'].agg(['count', lambda x: (x=='yes').sum()])\ngroup = group.rename(columns={'count':'n_samples','<lambda_0>':'n_violations'}).reset_index()\n\n# compute exceedance rate\ngroup['exceedance_rate'] = group['n_violations'] / group['n_samples']\n\n# inspect available labels\nlabels = group['Beach Type Description'].unique().tolist()\n\n# Determine freshwater label\nflabel = None\nfor lab in labels:\n    if 'Fresh' in str(lab):\n        flabel = lab\n        break\n# marine label\nmlabel = None\nfor lab in labels:\n    if 'Marine' in str(lab) or 'marine' in str(lab):\n        mlabel = lab\n        break\n\n# Build vectors\nfresh_rates = []\nmarine_rates = []\nfor y in years:\n    fr = group[(group['Year']==y) & (group['Beach Type Description']==flabel)]['exceedance_rate']\n    mr = group[(group['Year']==y) & (group['Beach Type Description']==mlabel)]['exceedance_rate']\n    fresh_rates.append(float(fr.values[0]) if len(fr)>0 else np.nan)\n    marine_rates.append(float(mr.values[0]) if len(mr)>0 else np.nan)\n\n# compute correlations\nimport math\nfrates = np.array(fresh_rates, dtype=float)\nmrates = np.array(marine_rates, dtype=float)\nf_rain = np.array(fresh_avg, dtype=float)\nm_rain = np.array(marine_avg, dtype=float)\n\ncorr_f, p_f = pearsonr(f_rain, frates)\ncorr_m, p_m = pearsonr(m_rain, mrates)\n\noutput = {\n    'corr_fresh': float(corr_f),\n    'corr_marine': float(corr_m),\n    'fresh_rates': fresh_rates,\n    'marine_rates': marine_rates,\n    'fresh_rain': fresh_avg,\n    'marine_rain': marine_avg\n}\nprint(json.dumps(output))\n", "intent": "compute correlations between summer rainfall and beach exceedance rates for 2007-2009 using provided stations, with median imputation for missing months", "dataset_id": "kramabench-environment-easy-2", "f