f['EPOCH_dt'].dt.date <= pd.to_datetime(end_date).date())\n    sub = df.loc[mask].sort_values('EPOCH_dt')\n    if len(sub) < 2:\n        return np.nan, None\n    first = sub.iloc[0]\n    last = sub.iloc[-1]\n    delta_days = (last['EPOCH_dt'] - first['EPOCH_dt']).total_seconds() / 86400.0\n    rate = (last['sma_km'] - first['sma_km']) / delta_days\n    return rate, {'first_time': first['EPOCH_dt'], 'last_time': last['EPOCH_dt'], 'first_sma': first['sma_km'], 'last_sma': last['sma_km'], 'delta_days': delta_days}\n\nquiet_rate, quiet_info = avg_rate_for_period(q, '2024-05-01', '2024-05-04')\nstorm_rate, storm_info = avg_rate_for_period(s, '2024-05-10', '2024-05-13')\n\nprint('\\nquiet_rate_km_per_day, info:')\nprint(quiet_rate)\nprint(quiet_info)\nprint('\\nstorm_rate_km_per_day, info:')\nprint(storm_rate)\nprint(storm_info)\n\n# print rounded to reasonable precision\nprint('\\nrounded_rates:')\nprint(round(quiet_rate,6), round(storm_rate,6))\n", "dataset_id": "kramabench-astronomy-easy-6", "file_path": "files/space-track/58214_quiet.csv"}) [toolUseId=call_xkuRMPW77cahx2K3jLPbtkug]
