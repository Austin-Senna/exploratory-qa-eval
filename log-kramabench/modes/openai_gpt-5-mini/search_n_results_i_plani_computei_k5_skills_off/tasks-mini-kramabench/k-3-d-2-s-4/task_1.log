   if comm_col is not None:\n        prec['Community_norm'] = prec[comm_col].astype(str).str.strip()\n\n    wb_filt['Date_norm'] = wb_filt['Sample Date'].dt.normalize()\n\n    if beach_col is not None and comm_col is not None:\n        merged = wb_filt.merge(\n            prec[['Date_norm', 'Beach_clean', 'Community_norm', 'Rain_3day']].dropna(subset=['Date_norm']),\n            on=['Date_norm', 'Beach_clean', 'Community_norm'],\n            how='inner'\n        )\n    elif beach_col is not None:\n        merged = wb_filt.merge(\n            prec[['Date_norm', 'Beach_clean', 'Rain_3day']].dropna(subset=['Date_norm']),\n            on=['Date_norm', 'Beach_clean'],\n            how='inner'\n        )\n    else:\n        merged = wb_filt.merge(\n            prec[['Date_norm', 'Community_norm', 'Rain_3day']].dropna(subset=['Date_norm']),\n            on=['Date_norm', 'Community_norm'],\n            how='inner'\n        )\nelse:\n    # Fallback: the precipitation file may already provide one row per community with 3-day rain,\n    # or may be malformed. If so, report clearly rather than crashing.\n    merged = pd.DataFrame(columns=['Rain_3day', 'Enterococcus'])\n\n# Compute Pearson correlation\ncorr_df = merged[['Rain_3day', 'Enterococcus']].dropna() if 'Rain_3day' in merged.columns else pd.DataFrame()\n\nif len(corr_df) >= 2:\n    r, p = pearsonr(corr_df['Rain_3day'], corr_df['Enterococcus'])\n    print(r)\nelse:\n    print('NOT_ENOUGH_DATA')\n    print('matched_rows', len(corr_df))\n    print('candidate_beaches', '|'.join(sorted(wb_filt['Beach_clean'].dropna().astype(str).unique())))\n    print('precip_columns', list(prec.columns))", "reason": "Rewrote the code to correctly identify Boston Harbor beaches in >90% EJ communities, normalize beach names using the benchmark plan, parse Enterococcus values, robustly inspect the precipitation file for date/rain/beach/community columns, merge on normalized keys, and print the Pearson correlation result when enough matched data