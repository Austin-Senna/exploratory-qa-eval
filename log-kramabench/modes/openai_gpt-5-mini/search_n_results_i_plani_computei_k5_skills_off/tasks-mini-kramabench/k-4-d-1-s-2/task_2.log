ader row index 2 (0-based)\ncm = pd.read_excel(cm_path, sheet_name=0, header=2)\n# Rename columns trimming whitespace\ncm.columns = cm.columns.astype(str).str.strip()\n# The Potassium column likely labelled 'K'\nif 'K' not in cm.columns:\n    print('columns:', cm.columns.tolist())\n\ncm = cm[['Age_ky','K']].copy()\ncm = cm.rename(columns={'Age_ky':'Age_ky_1'})\n# However there are multiple Age_ky columns; find the numeric Age_ky that matches K\n# We need the Age_ky value for each row corresponding to K column; the header layout had 'Age_ky' at col 8 then many columns, and later Age_ky repeated. We'll find numeric columns that correlate.\n\n# Find numeric columns\nnumeric = cm[['Age_ky','K']]\n\n# Convert 'Age_ky' to numeric\nnumeric['Age_ky'] = pd.to_numeric(numeric['Age_ky'], errors='coerce')\nnumeric['K'] = pd.to_numeric(numeric['K'], errors='coerce')\n# Drop rows with NaN Age or K\nnumeric = numeric.dropna(subset=['Age_ky','K'])\n\n# Age_ky is in kyr (thousands of years). Convert to years (BP?) The radiocarbon 'date' seems in BP (years). The climate Age_ky likely in ky (thousand years). We'll convert Age_ky*1000 to years.\nnumeric['Year'] = numeric['Age_ky']*1000\n\n# Interpolate K for first_year and last_year\nfrom numpy import interp\nyears = numeric['Year'].values\nkvals = numeric['K'].values\n# Ensure years monotonic increasing or decreasing - interp requires increasing x\n# Sort by Year\norder = years.argsort()\nyears_sorted = years[order]\nk_sorted = kvals[order]\n\n# Interpolate\nk_first = float(interp(first_year, years_sorted, k_sorted))\nk_last = float(interp(last_year, years_sorted, k_sorted))\navg = round((k_first + k_last)/2,4)\nprint('k_first', k_first)\nprint('k_last', k_last)\nprint('avg', avg)\n\navg\n", "dataset_id": "kramabench-archeology-hard-5", "file_path": "files/climateMeasurements.xlsx"}) [toolUseId=call_WFNrsg4cAFDddMY6lrn16Y2Z]
