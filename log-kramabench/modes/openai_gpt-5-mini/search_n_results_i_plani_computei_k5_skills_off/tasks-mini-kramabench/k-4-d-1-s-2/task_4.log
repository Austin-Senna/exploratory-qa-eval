\nmerged = b2012.merge(b2013, left_index=True, right_index=True, how='inner')\n\n# Exclude beaches with zero samples in 2012 (shouldn't occur since grouped by count) but just in case\nmerged = merged[merged['samples_2012']>0]\n\n# Count beaches where rate_2013 > rate_2012\ncount_higher = (merged['rate_2013'] > merged['rate_2012']).sum()\n\nprint('matched_beaches', len(merged))\nprint('count_higher', count_higher)\n\n# For transparency print a few rows where rate increased\ninc = merged[merged['rate_2013'] > merged['rate_2012']].sort_values(['rate_2013','rate_2012'], ascending=False)\nprint(inc.head(20))\n\ncount_higher\n", "intent": "Compute per-beach exceedance rates and count beaches where 2013 rate > 2012 rate excluding zero 2012 samples", "dataset_id": "kramabench-environment-hard-16", "file_path": "files/water-body-testing-2012.csv"}) [toolUseId=call_Sq4rkTbbgXPAchz30d0fpk7G]
