l = c\n            break\n    if date_col is None:\n        date_col = cols[0]\n    # parse dates\n    df[date_col] = pd.to_datetime(df[date_col], errors='coerce')\n    # filter years 2020-2024 inclusive\n    df = df[(df[date_col].dt.year>=2020) & (df[date_col].dt.year<=2024)]\n    # extract numeric values from enterococcus columns; some cells like '<,10' or '<,10' or '<,10' may have commas and symbols\n    values = []\n    for c in ent_cols:\n        # remove '<' and non-digit, but preserve numbers like 10, 1010 (typo?)\n        for val in df[c].dropna().astype(str):\n            # split on non-digit to find numeric substrings\n            nums = re.findall(r\"\\d+\", val)\n            if nums:\n                # choose the last numeric token? we'll parse all tokens\n                for n in nums:\n                    values.append(int(n))\n    return df, values, ent_cols, date_col\n\n# iterate over beaches, map to datasheet files by filename containing beach name parts\nresults = {}\nfor beach in beaches:\n    # find matching datasheet file\n    key = None\n    for fname, path in local_files.items():\n        if beach.lower().split()[0] in fname.lower():\n            # crude match\n            key = path\n            break\n    if key is None:\n        # try contains\n        for fname,path in local_files.items():\n            if beach.lower() in fname.lower():\n                key = path\n                break\n    if key is None:\n        results[beach] = {'file': None, 'all_counts': [], 'failed': True}\n        continue\n    df, values, ent_cols, date_col = extract_enterococcus_counts(key)\n    # determine if any sample >=104\n    failed = any(v>=104 for v in values)\n    results[beach] = {'file': key, 'n_samples': len(values), 'max': max(values) if values else None, 'failed': failed, 'ent_cols': ent_cols}\n\n# print results\nfor b in beaches:\n    print(b, results[b])\n\n# compile list of beaches with zero failures\nqualifying = [b for b in beaches if results[b].get('failed')==False]\nprint('\\nQUALIFYING:', qualifying)\n\n# final print for execute_ideal\nprint(qualifying)\n", "intent": "Find Boston Harbor beaches with no Enterococcus samples >= 104 between 2020-01-01 and 2024-12-31 using downloaded datasheets", "dataset_id": "kramabench-environment-hard-9", "file_path": ""}) [toolUseId=call_iylVRpXIpnNwEQ5h71w2XZ2i]
