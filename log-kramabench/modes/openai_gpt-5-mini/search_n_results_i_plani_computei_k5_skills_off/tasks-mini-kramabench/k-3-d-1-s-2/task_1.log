mes from worldcities\ncountries = sorted(world['country'].dropna().unique())\n\n# function to map actor token to best country by substring match\ndef map_to_country(actor):\n    actor = str(actor).lower()\n    best = None\n    for c in countries:\n        if c.lower() in actor:\n            return c\n    # try matching known historic names to modern countries (simple heuristics)\n    mapping = {\n        'byzantium':'Turkey',\n        'russia':'Russia',\n        'mongol':'Mongolia',\n        'muslim':'Turkey',\n        'frank':'France',\n        'france':'France',\n        'england':'United Kingdom',\n        'scotland':'United Kingdom',\n        'germany':'Germany',\n        'germans':'Germany',\n        'spain':'Spain',\n        'italy':'Italy',\n        'magyar':'Hungary',\n        'hungary':'Hungary',\n        'bavaria':'Germany',\n        'norway':'Norway',\n        'sweden':'Sweden',\n        'denmark':'Denmark',\n        'poland':'Poland',\n        'prussia':'Germany',\n        'netherlands':'Netherlands',\n        'holland':'Netherlands',\n        'ireland':'Ireland',\n        'scandinavia':'Norway',\n        'iberia':'Spain',\n        'north africa':'Morocco',\n        'egypt':'Egypt',\n        'abyssinia':'Ethiopia',\n        'china':'China',\n        'japan':'Japan',\n        'india':'India',\n        'mali':'Mali',\n        'timurid':'Uzbekistan',\n        'zantakis':'Greece'\n    }\n    for k,v in mapping.items():\n        if k in actor:\n            return v\n    # else unknown\n    return 'Unknown'\n\nconf['countryA'] = conf['sideA'].apply(map_to_country)\nconf['countryB'] = conf['sideB'].apply(map_to_country)\n\n# canonical pair (sorted)\nconf['pair'] = conf.apply(lambda r: ' vs '.join(sorted([r['countryA'], r['countryB']])), axis=1)\n\n# count conflicts per pair\npair_counts = conf['pair'].value_counts().reset_index()\npair_counts.columns = ['pair','count']\n\n# print total count\nprint(len(conf))\n# print top pairs\nprint(pair_counts.head(50).to_st