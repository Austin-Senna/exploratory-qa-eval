(str).str.strip()\nraws['Station ID_str'] = raws['Station ID'].astype(str).str.strip()\n\n# Map: create set of stations referenced in NOAA\nnoaa_ids = noaa['station_verified_in_psa'].dropna().astype(str).str.strip()\nunique_noaa_ids = sorted(set(noaa_ids))\nprint('unique_noaa_ids count:', len(unique_noaa_ids))\nprint('unique_noaa_ids sample:', unique_noaa_ids[:20])\n\n# Join: find RAWs rows where either WX ID or Station ID matches any noaa id\nmatched_raws = raws[raws['WX ID_str'].isin(unique_noaa_ids) | raws['Station ID_str'].isin(unique_noaa_ids)]\nprint('matched raws count:', len(matched_raws))\n\n# If none matched, also try matching by numeric substring\nif len(matched_raws)==0:\n    # try numeric substring matching\n    def find_matches(id_):\n        matches = raws[raws['WX ID_str'].str.contains(id_) | raws['Station ID_str'].str.contains(id_)]\n        return matches\n    sample = unique_noaa_ids[:50]\n    total_matches = pd.DataFrame()\n    for i in sample:\n        m = find_matches(i)\n        if not m.empty:\n            total_matches = pd.concat([total_matches, m])\n    matched_raws = total_matches.drop_duplicates()\n    print('after substring match count:', len(matched_raws))\n\n# Use Elevation column from RAWs. Compute mean elevation for matched stations\n# Elevation column name is 'Elevation'\nif 'Elevation' in raws.columns:\n    # matched based on WX ID or Station ID above; if matched_raws empty, attempt to match by numeric equality\n    if matched_raws.empty:\n        # try numeric equality by converting to int\n        try:\n            noaa_ints = pd.to_numeric(noaa['station_verified_in_psa'], errors='coerce').dropna().astype(int).astype(str)\n            matched_raws = raws[raws['WX ID_str'].isin(noaa_ints) | raws['Station ID_str'].isin(noaa_ints)]\n        except Exception as e:\n            pass\n    # compute mean elevation\n    elevations = matched_raws['Elevation'].astype(float)\n    mean_elev = elevations.mean()\n    print('mean elevation raw