)))\n            except:\n                pass\n    col_candidates[col] = (min(vals) if vals else None, max(vals) if vals else None)\n\nprint('col candidate ranges', col_candidates)\n# From printing earlier, columns appear: [0]=year, [1]=month, [2]=day, [3]=hour\n# filter rows with plausible month/day/hour\nparsed = []\nfor r in rows:\n    try:\n        year=int(r[0]); month=int(r[1]); day=int(r[2]); hour=int(r[3])\n    except:\n        continue\n    if year==2024 and 1<=month<=12 and 1<=day<=31 and 0<=hour<=23:\n        parsed.append(r)\nprint('parsed rows after date filter', len(parsed))\n\n# Build omni DataFrame\nomni_records = []\nfor r in parsed:\n    year=int(r[0]); month=int(r[1]); day=int(r[2]); hour=int(r[3])\n    dt = datetime(year,month,day,hour)\n    nums = []\n    for tok in r[4:60]:\n        try:\n            nums.append(float(tok))\n        except:\n            nums.append(np.nan)\n    omni_records.append((dt,nums))\n\nomni_df = pd.DataFrame({ 'dt':[rr[0] for rr in omni_records], **{f'c{i}':[rr[1][i] if len(rr[1])>i else np.nan for rr in omni_records] for i in range(0,40)} })\nomni_df = omni_df.set_index('dt').sort_index()\nprint('omni_df shape', omni_df.shape)\nomni_df = omni_df[(omni_df.index>=datetime(2024,5,1)) & (omni_df.index<=datetime(2024,5,30,23))]\nprint('omni_df may rows', len(omni_df))\n\n# test candidate columns 0..15\nfrom sklearn.linear_model import LinearRegression\nbest = {'lag':None,'col':None,'r2':-np.inf}\nresults=[]\nfor col in range(0,16):\n    series = omni_df[f'c{col}']\n    if series.isnull().all():\n        continue\n    for lag in range(0,49):\n        s = series.shift(lag)\n        df_align = pd.DataFrame({'delta_a':delta_a, 'ap':s})\n        df_align = df_align[(df_align.index>=datetime(2024,5,1)) & (df_align.index<=datetime(2024,5,30,23))]\n        df_align = df_align.dropna()\n        if len(df_align)<10:\n            continue\n        X = df_align['ap'].values.reshape(-1,1)\n        y = df_align['delta_a'].values\n        lr = LinearRegression().fit(X,y)\n        r2 = lr.score(X,y)\n        results.append((col,lag,r2,len(df_align)))\n        if r2>best['r2']:\n            best={'col':col,'lag':lag,'r2':r2,'n':len(df_align)}\n\nprint('best candidate col/lag r2',best)\n# print top 10\nresults_sorted = sorted(results,key=lambda x: x[2],reverse=True)\nfor r in results_sorted[:10]:\n    print(r)\n\nbest\n", "intent": "Parse TLEs for SATCAT 43180, compute hourly semi-major axis and hourly delta-a for May 1-30 2024; parse OMNI2 hourly AP values for same window; test lags 0-48h and compute r^2 between delta-a and AP shifted; print best lag and r^2 for all."})
