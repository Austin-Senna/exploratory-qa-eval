mark',\n    'norway': 'Norway',\n    'sweden': 'Sweden',\n    'prussia': 'Poland',\n    'mongols': 'Mongolia',\n    'khazars': 'Russia',\n    'aquitaine': 'France',\n    'provencia': 'France',\n    'ottoman': 'Turkey',\n    'ottomans': 'Turkey',\n    'andalus': 'Spain',\n    'galicia': 'Spain',\n    'bulgaria': 'Bulgaria',\n    'serbia': 'Serbia',\n    'croatia': 'Croatia',\n    'bosnia': 'Bosnia and Herzegovina',\n    'moravia': 'Czech Republic',\n    'bohemia': 'Czech Republic',\n    'leon': 'Spain',\n    'navarre': 'Spain',\n    'portugal': 'Portugal',\n    'celts': 'United Kingdom'\n}\n\n# helper to map actor string to modern country\n\ndef map_actor(actor):\n    a = str(actor).lower()\n    # strip parentheses content\n    a = re.sub(r\"\\(.*?\\)\", \"\", a)\n    # split on common separators\n    parts = re.split(r\"[-/,]\", a)\n    # try to find a known country substring\n    for p in parts:\n        p = p.strip()\n        # check manual mappings\n        for key, val in manual_map.items():\n            if key in p:\n                return val\n        # check world country names\n        for idx, country in enumerate(lc_countries):\n            if country in p or p in country:\n                return countries[idx]\n    # fallback: check tokens\n    tokens = re.split(r\"\\s+\", a)\n    for t in tokens:\n        for key, val in manual_map.items():\n            if key == t:\n                return val\n    return 'Unknown'\n\n# parse conflict into two actors\n\ndef split_conflict(conflict_str):\n    s = str(conflict_str)\n    # remove extra parentheses around single actor descriptors\n    # first try common separators\n    if '-' in s:\n        parts = s.split('-', 1)\n    elif ' vs ' in s.lower():\n        parts = re.split(r\"\\s+vs\\s+\", s, flags=re.IGNORECASE)\n    elif ' vs. ' in s.lower():\n        parts = re.split(r\"\\s+vs\\.\\s+\", s, flags=re.IGNORECASE)\n    elif 'against' in s.lower():\n        parts = re.split(r\"against\", s, flags=re.IGNORECASE)\n    else:\n        # try parentheses like 'England (Rebellion in York)'\n        m = re.match(r\"([^\\(]+)\\((.*)\\)\", s)\n        if m:\n            # it's internal conflict, treat as actor vs internal\n            return m.group(1).strip(), m.group(1).strip()\n        return s, 'Unknown'\n    a1 = parts[0].strip()\n    a2 = parts[1].strip()\n    return a1, a2\n\n# iterate and map\npairs = defaultdict(int)\ncountry_counts = defaultdict(int)\n\nfor idx, row in conf.iterrows():\n    c = row['Conflict']\n    a1, a2 = split_conflict(c)\n    m1 = map_actor(a1)\n    m2 = map_actor(a2)\n    # sort pair for undirected\n    pair = tuple(sorted([m1, m2]))\n    pairs[pair] += 1\n    country_counts[m1] += 1\n    country_counts[m2] += 1\n\n# print totals\nprint('total_conflicts:', sum(pairs.values()))\n# print top pairs\nsorted_pairs = sorted(pairs.items(), key=lambda x: x[1], reverse=True)\nprint('top_pairs:', sorted_pairs[:30])\n# print country counts\nsorted_countries = sorted(country_counts.items(), key=lambda x: x[1], reverse=True)\nprint('country_counts:', sorted_countries[:30])\n\n# expose results\nresults = {\n    'total_conflicts': sum(pairs.values()),\n    'pairs': pairs,\n    'country_counts': country_counts\n}\nprint('DONE')\n", "intent": "Filter conflicts 800-1400 with duration >=1 year, parse actors, map to modern countries using heuristic mapping and worldcities, and count/aggregate conflict pairs."}) [toolUseId=call_bX0kcnMS91xl30n7VBeDjOde]
