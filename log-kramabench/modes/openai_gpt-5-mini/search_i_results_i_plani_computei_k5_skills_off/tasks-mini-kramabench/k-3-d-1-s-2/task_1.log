urkey', 'andalus': 'Spain', 'galicia': 'Spain', 'bulgaria': 'Bulgaria',\n    'serbia': 'Serbia', 'croatia': 'Croatia', 'bosnia': 'Bosnia and Herzegovina', 'moravia': 'Czech Republic',\n    'bohemia': 'Czech Republic', 'leon': 'Spain', 'navarre': 'Spain', 'portugal': 'Portugal', 'celts': 'United Kingdom'\n}\n\n\ndef map_actor(actor):\n    a = str(actor).lower()\n    a = re.sub(r\"\\(.*?\\)\", \"\", a)\n    # replace common punctuation\n    a = a.replace('_',' ')\n    # direct manual map\n    for key,val in manual_map.items():\n        if key in a:\n            return val\n    # try to match any country name\n    for idx,country in enumerate(lc_countries):\n        if country in a:\n            return countries[idx]\n    # try tokens\n    tokens = re.split(r\"[\\s,()]+\", a)\n    for t in tokens:\n        for key,val in manual_map.items():\n            if key == t:\n                return val\n    return 'Unknown'\n\n\ndef split_conflict(s):\n    s = str(s)\n    # if pattern 'X-Y' and both look like actors\n    if '-' in s and not s.strip().startswith('('):\n        parts = s.split('-',1)\n        return parts[0].strip(), parts[1].strip()\n    # vs variations\n    m = re.split(r\"\\s+vs\\.?\\s+\", s, flags=re.IGNORECASE)\n    if len(m)==2:\n        return m[0].strip(), m[1].strip()\n    # 'against'\n    m = re.split(r\"against\", s, flags=re.IGNORECASE)\n    if len(m)==2:\n        return m[0].strip(), m[1].strip()\n    # parentheses internal conflicts\n    m = re.match(r\"([^\\(]+)\\((.*)\\)\", s)\n    if m:\n        actor = m.group(1).strip()\n        return actor, actor\n    return s, 'Unknown'\n\n# collect intervals per country pair\nintervals_by_pair = defaultdict(list)\ncountry_pair_event_counts = defaultdict(int)\ncountry_event_counts = defaultdict(int)\n\nfor idx,row in conf.iterrows():\n    a1,a2 = split_conflict(row['Conflict'])\n    c1 = map_actor(a1)\n    c2 = map_actor(a2)\n    pair = tuple(sorted([c1,c2]))\n    intervals_by_pair[pair].append((int(row['StartYear']), int(row['EndYear'])))\n\n# function to merge intervals\n\ndef merge_intervals(intervals):\n    if not intervals:\n        return []\n    ints = sorted(intervals, key=lambda x: x[0])\n    merged = []\n    cur_start, cur_end = ints[0]\n    for s,e in ints[1:]:\n        if s <= cur_end:  # overlapping or contiguous\n            cur_end = max(cur_end, e)\n        else:\n            merged.append((cur_start, cur_end))\n            cur_start, cur_end = s,e\n    merged.append((cur_start, cur_end))\n    return merged\n\n# merge and count\nfor pair, intervals in intervals_by_pair.items():\n    merged = merge_intervals(intervals)\n    country_pair_event_counts[pair] = len(merged)\n    # add counts to individual countries (each merged interval counts for both countries)\n    for c in pair:\n        country_event_counts[c] += len(merged)\n\ntotal_merged_conflicts = sum(country_pair_event_counts.values())\n\n# prepare outputs\nsorted_pairs = sorted(country_pair_event_counts.items(), key=lambda x: x[1], reverse=True)\nsorted_countries = sorted(country_event_counts.items(), key=lambda x: x[1], reverse=True)\n\nprint('total_merged_conflicts:', total_merged_conflicts)\nprint('top_pairs:', sorted_pairs[:20])\nprint('top_countries:', sorted_countries[:20])\n\n# print Unknown details\nunknown_pairs = {p:c for p,c in country_pair_event_counts.items() if 'Unknown' in p}\nprint('unknown_pairs_count:', len(unknown_pairs))\n\n# expose as dict\nresults = {\n    'total_merged_conflicts': total_merged_conflicts,\n    'pairs': country_pair_event_counts,\n    'countries': country_event_counts\n}\nprint('DONE')\n", "intent": "Compute merged conflict events per country pair for StartYear 800-1400 with duration>=1 year, then output total merged conflicts and top pairs/countries."}) [toolUseId=call_ihzG257VN8Qo3lUGx7ru8dPV]
