if 'WX ID' in raws.columns and 'WX ID' not in candidate_id_cols:\n    candidate_id_cols.append('WX ID')\n# make a mapping from id column values to elevation per column\nmatched_station_elevs = {}\nfor col in candidate_id_cols:\n    for idx, row in raws[[col,'Elevation_num']].dropna(subset=[col]).iterrows():\n        key = str(row[col]).strip()\n        if key=='':\n            continue\n        # if key maps to elevation\n        if pd.notna(row['Elevation_num']):\n            matched_station_elevs.setdefault(key, row['Elevation_num'])\n# Now for each unique noaa id try to find matching keys\nfound_elevs = {}\nfor nid in unique_noaa_ids:\n    if nid in matched_station_elevs:\n        found_elevs[nid] = matched_station_elevs[nid]\n    else:\n        # try numeric compare (as ints)\n        try:\n            ni = str(int(float(nid)))\n        except:\n            ni = None\n        if ni and ni in matched_station_elevs:\n            found_elevs[nid] = matched_station_elevs[ni]\n        else:\n            # try substring match in keys\n            for k,v in matched_station_elevs.items():\n                if nid in k or k in nid:\n                    found_elevs[nid] = v\n                    break\n# compute mean of unique matched elevations\nmatched_vals = sorted(set(found_elevs.values()))\nif len(matched_vals)==0:\n    # fallback to mean of all raws Elevation\n    mean_elev = raws['Elevation_num'].dropna().astype(float).mean()\nelse:\n    mean_elev = float(sum(matched_vals)/len(matched_vals))\n# print result\nprint(mean_elev)\n", "intent": "compute mean elevation of matched unique RAWS stations"}) [toolUseId=call_wX9iDYff7f2Db4JoZ7dAqH5t]
