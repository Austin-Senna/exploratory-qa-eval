cols[0]]\nelse:\n    # find exact 'Elevation'\n    if 'Elevation' in raws.columns:\n        raws['Elevation'] = raws['Elevation']\n    else:\n        raise Exception('No elevation column found')\n\n# Remove non-numeric chars and convert\nraws['Elevation_num'] = raws['Elevation'].astype(str).str.replace('[^0-9.-]','',regex=True)\nraws['Elevation_num'] = pd.to_numeric(raws['Elevation_num'], errors='coerce')\n\n# Determine join key: in raws there is 'Station ID' and 'Station Name' and 'WX ID'\nprint('Unique station id sample from noaa:', noaa['station_verified_in_psa'].dropna().unique()[:20])\n\n# Inspect raws 'Station ID' values\nfor col in ['Station ID','WX ID','Station Name','StationID','Station_Id']:\n    if col in raws.columns:\n        print(col, raws[col].head(10).tolist() )\n\n# Look for matching by substring: noaa ids might be numeric or other formatting\nnoaa_ids = noaa['station_verified_in_psa'].dropna().unique()\n# Some NOAA station ids might be numeric strings; strip and handle\nnoaa_ids_clean = [str(x).strip() for x in noaa_ids if str(x).strip()!='' and str(x).strip().lower()!='nan']\nprint('count unique station ids in noaa:', len(noaa_ids_clean))\n\n# Try join by matching raws 'Station ID' and 'Station ID' possibly in column 'Station ID' or 'Station ID' with BOM\nraws_id_col = None\nfor c in raws.columns:\n    if c.lower().replace(' ','').replace('_','') in ('stationid','stationid','stationid'):\n        raws_id_col = c\n# fallback to 'Station ID'\nif raws_id_col is None and 'Station ID' in raws.columns:\n    raws_id_col = 'Station ID'\n\nprint('using raws id col:', raws_id_col)\n\n# If raws_id_col exists, match directly\nmatched_elevs = []\nif raws_id_col:\n    # build a map from raws id to elevation\n    id_to_elev = {str(v).strip():e for v,e in zip(raws[raws_id_col].fillna('').astype(str).str.strip(), raws['Elevation_num'])}\n    # try direct lookup and also try matching by contains\n    for sid in noaa_ids_clean:\n        elev = id_to_elev.get(sid)\n