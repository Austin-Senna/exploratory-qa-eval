          rain_num = extract_number(rain_str)\n            rows.append({\n                'beach_file': uri.split('/')[-1],\n                'enterococcus': ent_num,\n                'one_day_rain': rain_num\n            })\n\n# build dataframe\nall_df = pd.DataFrame(rows)\n# drop rows with no enterococcus numeric\nall_df = all_df[all_df['enterococcus'].notna()]\n# exclude negative sentinel values like -9\nall_df = all_df[all_df['enterococcus']>=0]\n# failures: enterococcus > 104\nfail_df = all_df[all_df['enterococcus']>104]\ntotal_fail = len(fail_df)\nfail_with_rain = len(fail_df[fail_df['one_day_rain'].notna() & (fail_df['one_day_rain']>0)])\n# compute percentage\npct = (fail_with_rain / total_fail * 100) if total_fail>0 else 0.0\n# print values\nprint(total_fail)\nprint(fail_with_rain)\nprint(f\"{pct:.2f}\")\n\n", "intent": "Compute percent of Enterococcus>104 failed samples across listed Boston Harbor beach datasheets that had 1-Day Rain>0"})
