(tag).strip() if pd.notnull(tag) else ''\n    if val == '' or val.lower() == 'nan':\n        return None\n    try:\n        num = float(val)\n    except:\n        # if val contains non-numeric, try extracting digits\n        import re\n        m = re.search(r\"(\\d+)\", val)\n        if m:\n            num = float(m.group(1))\n        else:\n            return None\n    censored = ('<' in tag)\n    meets = None\n    if num is not None:\n        meets = (num < 104) or (censored and num < 104)\n    return {'num': num, 'censored': censored, 'meets': meets}\n\n# Apply to each of the three locations\nfor loc in ['North','Middle','South']:\n    df[loc+'_Parsed'] = df.apply(lambda r: parse_value(r[loc+'_Tag'], r[loc+'_Enterococcus']), axis=1)\n    df[loc+'_Num'] = df[loc+'_Parsed'].apply(lambda x: x['num'] if x is not None else None)\n    df[loc+'_Censored'] = df[loc+'_Parsed'].apply(lambda x: x['censored'] if x is not None else False)\n    df[loc+'_Meets'] = df[loc+'_Parsed'].apply(lambda x: x['meets'] if x is not None else None)\n\n# Filter year 2024\ndf2024 = df[df['Date'].dt.year == 2024].copy()\nprint('Total 2024 rows:', len(df2024))\n\n# For each date, determine if at least one sample meets and at least one does not\n\ndef row_has_meets_and_not(row):\n    meets_list = []\n    not_list = []\n    for loc in ['North','Middle','South']:\n        m = row[loc+'_Meets']\n        if m is True:\n            meets_list.append(loc)\n        elif m is False:\n            not_list.append(loc)\n        # None means missing; ignore\n    return (len(meets_list) > 0) and (len(not_list) > 0)\n\n# Apply per row\ndf2024['MeetsAndNot'] = df2024.apply(row_has_meets_and_not, axis=1)\ncount = df2024['MeetsAndNot'].sum()\nprint('Count:', int(count))\n\n# Print rows where true for inspection\nprint(df2024[df2024['MeetsAndNot']][['Date','North_Num','North_Censored','North_Meets','Middle_Num','Middle_Censored','Middle_Meets','South_Num','South_Censored','South_Meets']].to_csv(index=False))\n\n# final output\nprint(int(count))", "intent": "Compute count of 2024 dates where at least one sample meets (<104) and at least one does not (>=104)"}) [toolUseId=call_5tuSnam8CyvVBEDn9PqJNQs0]
