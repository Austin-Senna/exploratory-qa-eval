]), axis=1)\n    df[loc+'_Num'] = df[loc+'_Parsed'].apply(lambda x: x['num'] if x is not None else None)\n    df[loc+'_Censored'] = df[loc+'_Parsed'].apply(lambda x: x['censored'] if x is not None else False)\n    df[loc+'_Meets'] = df[loc+'_Parsed'].apply(lambda x: x['meets'] if x is not None else None)\n\n# Filter to 2024\ndf2024 = df[df['Date'].dt.year == 2024].copy()\n\n# Determine per date if at least one meets and at least one does not\n\ndef meets_and_not(row):\n    meets = False\n    not_meets = False\n    for loc in ['North','Middle','South']:\n        m = row[loc+'_Meets']\n        if m is True:\n            meets = True\n        elif m is False:\n            not_meets = True\n    return meets and not_meets\n\ndf2024['MeetsAndNot'] = df2024.apply(meets_and_not, axis=1)\ncount = int(df2024['MeetsAndNot'].sum())\nprint(count)\n\n# For verification, print rows where true\nrows = df2024[df2024['MeetsAndNot']]\nif len(rows) > 0:\n    print(rows[['Date','North_Num','North_Censored','North_Meets','Middle_Num','Middle_Censored','Middle_Meets','South_Num','South_Censored','South_Meets']].to_string(index=False))\n\ncount", "intent": "Same as above, using local downloaded file"})
