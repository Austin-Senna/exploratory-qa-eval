g10 of variants per Mb might be ~0-2)\nnumeric = df.select_dtypes(include=['number']).columns.tolist()\nprint('numeric columns count:', len(numeric))\nprint('numeric sample columns:', numeric[:50])\n\n# Print numeric columns with small ranges for serous\nfor c in numeric:\n    vals = serous[c].dropna()\n    if len(vals)==0:\n        continue\n    mn, mx = vals.min(), vals.max()\n    if mn>-10 and mx<10: # plausible log10 range\n        print('\\nNumeric plausible log column:', c, 'min', mn, 'max', mx)\n        print(vals.head(10))\n\n# If we find a column named 'Log10_mutation_burden' or similar, use it; otherwise try 'Mutation_burden_log10'\npreferred = None\nfor name in df.columns:\n    if name.lower().replace(' ','').replace('_','') in ('log10mutationburden','mutationburdenlog10','log_mutation_burden','mutation_burden_log10','log10_tmb'):\n        preferred = name\n        break\nprint('preferred candidate:', preferred)\n\n# Attempt common column names\ncommon_names = ['mutation_burden_log10','mutation_burden','log10_mutation_burden','log10_TMB','log10_mutations_per_mb','mutations_per_mb_log10','tmb_log10','tmb_log']\nfound = None\nfor cname in common_names:\n    for col in df.columns:\n        if cname.lower() in col.lower().replace(' ',''):\n            found = col\n            break\n    if found:\n        break\nprint('found by common names:', found)\n\n# If found, compute median converting from log10 to linear variants per Mb\nif found is not None:\n    serous_vals = pd.to_numeric(serous[found], errors='coerce').dropna()\n    linear = (10**serous_vals)\n    median = linear.median()\n    print('median_linear', round(median,4))\nelse:\n    # Search for a column that when exponentiated gives reasonable values e.g. 0.1-100\n    for c in df.columns:\n        try:\n            vals = pd.to_numeric(serous[c], errors='coerce').dropna()\n            if len(vals)==0:\n                continue\n            linear = 10**vals\n            med = linear.median()\n            if 0.01 < med < 1000:\n                print('Using candidate', c, 'median linear', round(med,4))\n                found = c\n                print('sample vals', vals.head())\n                break\n        except Exception as e:\n            pass\n    if found is None:\n        print('No suitable mutation-burden log column found')\n\n# If found earlier, print final median in required format\nif found is not None:\n    serous_vals = pd.to_numeric(serous[found], errors='coerce').dropna()\n    linear = (10**serous_vals)\n    median = linear.median()\n    print('\\nFINAL_MEDIAN', round(median,4))\nelse:\n    print('\\nFINAL_MEDIAN not found')\n"}) [toolUseId=call_u2nsmhwdKWqSLSQ8UnB7cMv8]
